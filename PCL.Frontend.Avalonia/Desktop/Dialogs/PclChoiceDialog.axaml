<Window
    x:Class="PCL.Frontend.Avalonia.Desktop.Dialogs.PclChoiceDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls"
    Background="Transparent"
    CanResize="False"
    ShowInTaskbar="False"
    SystemDecorations="None"
    TransparencyLevelHint="Transparent"
    WindowStartupLocation="CenterOwner"
    Title="选择">
  <Window.Styles>
    <Style Selector="ListBox#ChoiceListBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="ListBox#ChoiceListBox ListBoxItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="#00000000" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,4" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="ListBox#ChoiceListBox ListBoxItem:pointerover">
      <Setter Property="Background" Value="#E2EEFE" />
      <Setter Property="BorderBrush" Value="#D5E6FD" />
    </Style>
    <Style Selector="ListBox#ChoiceListBox ListBoxItem:selected">
      <Setter Property="Background" Value="#EAF2FE" />
      <Setter Property="BorderBrush" Value="#96C0F9" />
    </Style>
    </Window.Styles>

  <Grid Background="Transparent">
    <Border
        x:Name="OverlayBorder"
        Classes="pcl-dialog-overlay"
        Background="#5A000000" />

    <Border
        x:Name="MessagePanel"
        Classes="pcl-dialog-panel"
        MinWidth="400"
        MaxWidth="620"
        Margin="25"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Background="{DynamicResource ColorBrushMsgBox}"
        BoxShadow="0 2 20 0 #CC3C3C3C"
        CornerRadius="7">
      <Grid Margin="22,22,22,23" RowDefinitions="Auto,2,13,Auto,*,Auto">
        <TextBlock
            x:Name="TitleTextBlock"
            Margin="7,-1,70,9"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            FontSize="23"
            Foreground="{DynamicResource ColorBrush2}"
            TextTrimming="None" />

        <Rectangle
            Grid.Row="1"
            Height="2"
            Fill="{Binding Foreground, ElementName=TitleTextBlock}" />

        <ScrollViewer
            x:Name="MessageHost"
            Grid.Row="3"
            Margin="0,0,0,7"
            Padding="7,0,15,0"
            MaxHeight="120"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
          <TextBlock
              x:Name="MessageTextBlock"
              Padding="1"
              FontSize="15"
              FontWeight="Normal"
              Foreground="{DynamicResource ColorBrush1}"
              LineHeight="18"
              TextTrimming="None"
              TextWrapping="Wrap" />
        </ScrollViewer>

        <ScrollViewer
            Grid.Row="4"
            Margin="0,0,0,17"
            Padding="7,0,15,0"
            MaxHeight="280"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
          <ListBox
              x:Name="ChoiceListBox"
              Background="Transparent"
              BorderThickness="0">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border
                    Padding="10,8"
                    Background="Transparent"
                    BorderBrush="#00000000"
                    BorderThickness="1"
                    CornerRadius="4">
                  <StackPanel Spacing="4">
                    <TextBlock
                        Foreground="{DynamicResource ColorBrush1}"
                        FontSize="14"
                        Text="{Binding Title}" />
                    <TextBlock
                        Foreground="#697A8C"
                        FontSize="12.5"
                        Text="{Binding Summary}"
                        TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </ScrollViewer>

        <StackPanel
            Grid.Row="5"
            Margin="150,0,8,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
          <controls:PclButton
              Width="96"
              Margin="12,0,0,0"
              Text="取消"
              ContentPadding="8,5"
              TextMargin="0,-1,0,0"
              Command="{Binding CancelCommand}" />
          <controls:PclButton
              Width="108"
              Margin="12,0,0,0"
              Text="{Binding ConfirmText}"
              ContentPadding="8,5"
              TextMargin="0,-1,0,0"
              ColorType="Highlight"
              Command="{Binding ConfirmCommand}" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
