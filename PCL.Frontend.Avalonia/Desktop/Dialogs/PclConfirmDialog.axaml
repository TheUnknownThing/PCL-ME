<Window
    x:Class="PCL.Frontend.Avalonia.Desktop.Dialogs.PclConfirmDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls"
    Background="Transparent"
    CanResize="False"
    ShowInTaskbar="False"
    SystemDecorations="None"
    TransparencyLevelHint="Transparent"
    WindowStartupLocation="CenterOwner"
    Title="确认">
  <Grid Background="Transparent">
    <Border
        x:Name="OverlayBorder"
        Classes="pcl-dialog-overlay"
        Background="#5A000000" />

    <Border
        x:Name="MessagePanel"
        Classes="pcl-dialog-panel"
        MinWidth="400"
        MaxWidth="560"
        Margin="25"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Background="{DynamicResource ColorBrushMsgBox}"
        BoxShadow="0 2 20 0 #CC3C3C3C"
        CornerRadius="7">
      <Grid Margin="22,22,22,23" RowDefinitions="Auto,2,13,*,Auto">
        <TextBlock
            x:Name="TitleTextBlock"
            Margin="7,-1,70,9"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            FontSize="23"
            Foreground="{DynamicResource ColorBrush2}"
            TextTrimming="None" />

        <Rectangle
            Grid.Row="1"
            Height="2"
            Fill="{Binding Foreground, ElementName=TitleTextBlock}" />

        <ScrollViewer
            Grid.Row="3"
            Margin="0,0,0,17"
            Padding="7,0,15,0"
            MaxHeight="280"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
          <TextBlock
              x:Name="MessageTextBlock"
              Padding="1"
              FontSize="15"
              FontWeight="Normal"
              Foreground="{DynamicResource ColorBrush1}"
              LineHeight="18"
              TextTrimming="None"
              TextWrapping="Wrap" />
        </ScrollViewer>

        <StackPanel
            Grid.Row="4"
            Margin="150,0,8,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
          <controls:PclButton
              Width="96"
              Margin="12,0,0,0"
              Text="取消"
              ContentPadding="8,5"
              TextMargin="0,-1,0,0"
              Command="{Binding CancelCommand}" />
          <controls:PclButton
              Width="108"
              Margin="12,0,0,0"
              Text="{Binding ConfirmText}"
              ContentPadding="8,5"
              TextMargin="0,-1,0,0"
              ColorType="{Binding ConfirmColorType}"
              Command="{Binding ConfirmCommand}" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
