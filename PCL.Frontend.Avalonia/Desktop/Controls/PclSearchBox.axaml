<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.Controls.PclSearchBox"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animation="clr-namespace:PCL.Frontend.Avalonia.Desktop.Animation"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls"
    x:Name="Root"
    Height="40">
  <UserControl.Styles>
    <Style Selector="TextBox.search-input">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBox.search-input:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBox.search-input:focus">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBox.search-input /template/ Border">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
  </UserControl.Styles>

  <Border
      x:Name="SearchRowBorder"
      Height="40"
      Background="{DynamicResource ColorBrushHalfWhite}"
      BorderBrush="{DynamicResource ColorBrush6}"
      BorderThickness="1"
      CornerRadius="5">
    <Grid>
      <TextBox
          x:Name="SearchTextBox"
          Classes="search-input"
          FocusAdorner="{x:Null}"
          Background="Transparent"
          BorderBrush="Transparent"
          BorderThickness="0"
          FontSize="13.5"
          Padding="34,0,40,0"
          Text="{Binding Text, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
          VerticalContentAlignment="Center"
          Watermark="{Binding Watermark, ElementName=Root}" />

      <Path
          Width="14"
          Height="14"
          Margin="14,0,0,0"
          HorizontalAlignment="Left"
          VerticalAlignment="Center"
          Fill="{DynamicResource ColorBrushEntrySecondaryIdle}"
          Stretch="Uniform"
          Data="M15.5,14H14.71L14.43,13.73A6.471,6.471 0 0,0 16,9.5A6.5,6.5 0 1,0 9.5,16A6.471,6.471 0 0,0 13.73,14.43L14,14.71V15.5L19,20.49L20.49,19L15.5,14M9.5,14A4.5,4.5 0 1,1 14,9.5A4.5,4.5 0 0,1 9.5,14Z" />

      <controls:PclIconButton
          x:Name="ClearButton"
          Margin="0,0,10,0"
          HorizontalAlignment="Right"
          VerticalAlignment="Center"
          HoverBackgroundBrush="{DynamicResource ColorBrush8}"
          IconBrush="{DynamicResource ColorBrushEntrySecondaryIdle}"
          IconData="F1 M2,0 L0,2 8,10 0,18 2,20 10,12 18,20 20,18 12,10 20,2 18,0 10,8 2,0Z"
          IconScale="0.75"
          IdleBackgroundBrush="{DynamicResource ColorBrushTransparent}"
          Opacity="0">
        <controls:PclIconButton.Transitions>
          <Transitions>
            <DoubleTransition Property="Opacity" Duration="{Binding QuickState, Source={x:Static animation:MotionDurations.Source}}" />
          </Transitions>
        </controls:PclIconButton.Transitions>
      </controls:PclIconButton>

      <controls:PclButton
          x:Name="SearchButton"
          Width="60"
          Height="32"
          Margin="0,4,4,4"
          Command="{Binding SearchCommand, ElementName=Root}"
          HorizontalAlignment="Right"
          IsVisible="{Binding ShowSearchButton, ElementName=Root}"
          Text="{Binding SearchButtonText, ElementName=Root}" />
    </Grid>
  </Border>
</UserControl>
