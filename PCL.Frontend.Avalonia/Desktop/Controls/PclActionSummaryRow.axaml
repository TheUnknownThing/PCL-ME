<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.Controls.PclActionSummaryRow"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls">
  <Border
      Margin="0,0,0,2"
      Background="{DynamicResource ColorBrushSemiTransparent}"
      CornerRadius="4">
    <Grid MinHeight="42" ColumnDefinitions="14,*,Auto,12">
      <StackPanel
          Grid.Column="1"
          Margin="0,6,14,6"
          VerticalAlignment="Center"
          Spacing="2">
        <TextBlock
            Foreground="{DynamicResource ColorBrush1}"
            FontSize="13.5"
            Text="{Binding Title, ElementName=Root}"
            TextTrimming="CharacterEllipsis" />
        <TextBlock
            Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
            FontSize="12"
            Text="{Binding Info, ElementName=Root}"
            TextTrimming="CharacterEllipsis"
            TextWrapping="Wrap" />
        <TextBlock
            Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
            FontSize="11.5"
            IsVisible="{Binding ShowMeta, ElementName=Root}"
            Text="{Binding Meta, ElementName=Root}"
            TextTrimming="CharacterEllipsis" />
      </StackPanel>

      <controls:PclButton
          Grid.Column="2"
          Width="92"
          Height="30"
          Margin="0,0,0,0"
          VerticalAlignment="Center"
          Command="{Binding Command, ElementName=Root}"
          Text="{Binding ActionText, ElementName=Root}" />
    </Grid>
  </Border>
</UserControl>
