<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.Controls.PclSidebarButton"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animation="clr-namespace:PCL.Frontend.Avalonia.Desktop.Animation"
    x:Name="Root">
  <Border
      x:Name="PanBack"
      MinHeight="52"
      Padding="0"
      Background="{DynamicResource ColorBrushSemiTransparent}"
      BorderBrush="{DynamicResource ColorBrushSemiTransparent}"
      BorderThickness="1"
      CornerRadius="5"
      RenderTransformOrigin="0.5,0.5"
      RenderTransform="scale(1)">
    <Border.Transitions>
      <Transitions>
        <BrushTransition Property="Background" Duration="{Binding InteractiveState, Source={x:Static animation:MotionDurations.Source}}" />
        <BrushTransition Property="BorderBrush" Duration="{Binding InteractiveState, Source={x:Static animation:MotionDurations.Source}}" />
        <TransformOperationsTransition Property="RenderTransform" Duration="{Binding InteractiveState, Source={x:Static animation:MotionDurations.Source}}" />
        <DoubleTransition Property="Opacity" Duration="{Binding InteractiveState, Source={x:Static animation:MotionDurations.Source}}" />
      </Transitions>
    </Border.Transitions>
    <Button
        x:Name="ButtonHost"
        Classes="nochrome"
        Padding="0"
        Background="Transparent"
        BorderBrush="Transparent"
        BorderThickness="0"
        Command="{Binding Command, ElementName=Root}">
      <Grid ColumnDefinitions="4,*,Auto">
        <Border
            x:Name="SelectionBar"
            Margin="0,10,0,10"
            Background="{DynamicResource ColorBrush3}"
            CornerRadius="0,2,2,0"
            IsVisible="False" />
        <StackPanel Grid.Column="1" Margin="14,9,10,9" Spacing="2">
          <TextBlock
              x:Name="TitleBlock"
              FontSize="14"
              FontWeight="Medium"
              Foreground="{DynamicResource ColorBrushGray1}" />
          <TextBlock
              x:Name="SummaryBlock"
              FontSize="11.5"
              Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
              TextWrapping="Wrap"
              MaxLines="2" />
        </StackPanel>
        <TextBlock
            x:Name="ChevronBlock"
            Grid.Column="2"
            Margin="0,0,14,0"
            VerticalAlignment="Center"
            Foreground="{DynamicResource ColorBrushEntryChevronIdle}"
            FontSize="18"
            Text="›" />
      </Grid>
    </Button>
  </Border>
</UserControl>
