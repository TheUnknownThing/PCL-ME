<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.Controls.PclMemorySummary"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel Spacing="4">
    <TextBlock
        Margin="2,0,0,4"
        Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
        FontSize="11"
        Text="{Binding UsageHeaderText, ElementName=Root}" />
    <Grid Height="6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="{Binding UsedBarWidth, ElementName=Root}" />
        <ColumnDefinition Width="{Binding AllocatedBarWidth, ElementName=Root}" />
        <ColumnDefinition Width="{Binding FreeBarWidth, ElementName=Root}" />
      </Grid.ColumnDefinitions>
      <Border Grid.Column="0" Background="{DynamicResource ColorBrushSemanticSuccessForeground}" CornerRadius="3,0,0,3" />
      <Border Grid.Column="1" Background="{DynamicResource ColorBrushSemanticInfoForeground}" />
      <Border Grid.Column="2" Background="{DynamicResource ColorBrushSemanticNeutralBorder}" CornerRadius="0,3,3,0" />
    </Grid>
    <Grid Margin="2,4,0,0" ColumnDefinitions="Auto,*">
      <TextBlock
          VerticalAlignment="Center"
          FontSize="16">
        <Run Foreground="{DynamicResource ColorBrushSemanticSuccessForeground}" Text="{Binding UsedRamLabel, ElementName=Root}" />
        <Run Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}" Text=" / " />
        <Run Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}" Text="{Binding TotalRamLabel, ElementName=Root}" />
      </TextBlock>
      <TextBlock
          Grid.Column="1"
          Margin="18,0,0,0"
          VerticalAlignment="Center"
          FontSize="16">
        <Run Foreground="{DynamicResource ColorBrushSemanticInfoForeground}" Text="{Binding AllocationPrefixText, ElementName=Root}" />
        <Run Foreground="{DynamicResource ColorBrushSemanticInfoForeground}" Text=" " />
        <Run Foreground="{DynamicResource ColorBrushSemanticInfoForeground}" Text="{Binding AllocatedRamLabel, ElementName=Root}" />
      </TextBlock>
    </Grid>
  </StackPanel>
</UserControl>
