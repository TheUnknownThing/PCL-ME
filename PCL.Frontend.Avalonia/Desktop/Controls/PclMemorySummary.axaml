<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.Controls.PclMemorySummary"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel Spacing="4">
    <TextBlock
        Margin="2,0,0,4"
        Foreground="#7D8897"
        FontSize="11"
        Text="已使用内存 / 已安装内存" />
    <Grid Height="6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="{Binding UsedBarWidth, ElementName=Root}" />
        <ColumnDefinition Width="{Binding AllocatedBarWidth, ElementName=Root}" />
        <ColumnDefinition Width="{Binding FreeBarWidth, ElementName=Root}" />
      </Grid.ColumnDefinitions>
      <Border Grid.Column="0" Background="#58C86F" CornerRadius="3,0,0,3" />
      <Border Grid.Column="1" Background="#86B6FF" />
      <Border Grid.Column="2" Background="#D5DCE5" CornerRadius="0,3,3,0" />
    </Grid>
    <Grid Margin="2,4,0,0" ColumnDefinitions="Auto,*">
      <TextBlock
          VerticalAlignment="Center"
          FontSize="16">
        <Run Foreground="#2F8F45" Text="{Binding UsedRamLabel, ElementName=Root}" />
        <Run Foreground="#4B5968" Text="{Binding TotalRamLabel, ElementName=Root}" />
      </TextBlock>
      <TextBlock
          Grid.Column="1"
          Margin="18,0,0,0"
          VerticalAlignment="Center"
          FontSize="16">
        <Run Foreground="#4C78C2" Text="游戏分配 " />
        <Run Foreground="#4C78C2" Text="{Binding AllocatedRamLabel, ElementName=Root}" />
      </TextBlock>
    </Grid>
  </StackPanel>
</UserControl>
