<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.Controls.PclTabButton"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animation="clr-namespace:PCL.Frontend.Avalonia.Desktop.Animation"
    x:Name="Root">
  <Border
      x:Name="PanBack"
      MinHeight="27"
      MaxHeight="27"
      Height="27"
      Padding="0"
      CornerRadius="13.5"
      RenderTransformOrigin="0.5,0.5"
      RenderTransform="scale(1)"
      Background="{DynamicResource ColorBrushSemiTransparent}">
    <Border.Transitions>
      <Transitions>
        <BrushTransition Property="Background" Duration="{Binding InteractiveState, Source={x:Static animation:MotionDurations.Source}}" />
        <TransformOperationsTransition Property="RenderTransform" Duration="{Binding InteractiveState, Source={x:Static animation:MotionDurations.Source}}" />
        <DoubleTransition Property="Opacity" Duration="{Binding InteractiveState, Source={x:Static animation:MotionDurations.Source}}" />
      </Transitions>
    </Border.Transitions>
    <Button
        x:Name="ButtonHost"
        Classes="nochrome"
        Background="Transparent"
        BorderBrush="Transparent"
        BorderThickness="0"
        Command="{Binding Command, ElementName=Root}"
        Padding="0">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <Path
            x:Name="ShapeLogo"
            Width="14"
            Height="14"
            Margin="15,0,0,0"
            VerticalAlignment="Center"
            Fill="White"
            Stretch="Uniform" />
        <TextBlock
            x:Name="LabText"
            Margin="8,0,12,0"
            VerticalAlignment="Center"
            FontSize="14"
            Foreground="White" />
      </StackPanel>
    </Button>
  </Border>
</UserControl>
