<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.Controls.PclListItem"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animation="clr-namespace:PCL.Frontend.Avalonia.Desktop.Animation"
    x:Name="Root"
    Height="42"
    MinHeight="34">
  <Grid
      x:Name="LayoutRoot"
      Background="{DynamicResource ColorBrushSemiTransparent}"
      RenderTransformOrigin="0.5,0.5"
      RenderTransform="scale(1)">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="4" />
      <ColumnDefinition Width="14" />
      <ColumnDefinition Width="18" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="12" />
    </Grid.ColumnDefinitions>
    <Grid.Transitions>
      <Transitions>
        <TransformOperationsTransition Property="RenderTransform" Duration="{x:Static animation:MotionDurations.InteractiveState}" />
        <DoubleTransition Property="Opacity" Duration="{x:Static animation:MotionDurations.InteractiveState}" />
      </Transitions>
    </Grid.Transitions>

    <Border
        x:Name="RectBack"
        Grid.ColumnSpan="7"
        Margin="0"
        Background="{DynamicResource ColorBrushEntrySelectedBackground}"
        BorderThickness="0"
        CornerRadius="4"
        Opacity="0" />

    <Border
        x:Name="SelectionBar"
        Grid.RowSpan="3"
        Margin="0,7,0,7"
        Background="{DynamicResource ColorBrush3}"
        CornerRadius="0,3,3,0"
        IsVisible="False" />

    <Path
        x:Name="LogoPath"
        Grid.Column="2"
        Width="16"
        Height="16"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Fill="{DynamicResource ColorBrushGray2}"
        Stretch="Uniform"
        IsVisible="False" />

    <Image
        x:Name="LogoImage"
        Grid.Column="2"
        Width="32"
        Height="32"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Stretch="Uniform"
        IsVisible="False" />

    <Button
        x:Name="MainButton"
        Classes="nochrome"
        Grid.Column="3"
        Grid.ColumnSpan="2"
        FocusAdorner="{x:Null}"
        Focusable="False"
        IsHitTestVisible="False"
        Padding="0"
        Background="Transparent"
        BorderBrush="Transparent"
        BorderThickness="0"
        HorizontalContentAlignment="Stretch">
      <StackPanel
          Margin="4,0,0,0"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Center"
          Spacing="1">
        <TextBlock
            x:Name="TitleBlock"
            HorizontalAlignment="Left"
            FontSize="14"
            Foreground="{DynamicResource ColorBrushGray1}"
            TextAlignment="Left"
            TextTrimming="CharacterEllipsis" />
        <TextBlock
            x:Name="InfoBlock"
            HorizontalAlignment="Left"
            FontSize="12"
            Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
            IsVisible="False"
            TextAlignment="Left"
            TextTrimming="CharacterEllipsis"
            TextWrapping="NoWrap" />
      </StackPanel>
    </Button>

    <Button
        x:Name="AccessoryButton"
        Classes="nochrome"
        Grid.Column="5"
        Width="25"
        Height="25"
        Margin="0,0,3,0"
        HorizontalAlignment="Right"
        VerticalAlignment="Center"
        FocusAdorner="{x:Null}"
        Background="Transparent"
        BorderBrush="Transparent"
        BorderThickness="0"
        Command="{Binding AccessoryCommand, ElementName=Root}"
        IsVisible="False"
        ToolTip.Tip="{Binding AccessoryToolTip, ElementName=Root}">
      <Path
          x:Name="AccessoryPath"
          Width="12"
          Height="12"
          Fill="{DynamicResource ColorBrush5}"
          Stretch="Uniform" />
    </Button>
  </Grid>
</UserControl>
