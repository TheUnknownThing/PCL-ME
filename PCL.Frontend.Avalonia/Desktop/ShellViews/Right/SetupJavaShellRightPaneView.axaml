<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.ShellViews.Right.SetupJavaShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls"
    x:Name="Root"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,25,25,10" Spacing="15">
      <controls:PclCard ContentMargin="12">
        <controls:PclCard.CardContent>
          <StackPanel Orientation="Horizontal">
            <controls:PclButton
                Width="110"
                Height="35"
                Command="{Binding AddJavaRuntimeCommand}"
                ColorType="Highlight"
                Text="{Binding SetupText.Java.AddButton}" />
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard ContentMargin="15">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <Border
                Padding="14,12"
                Background="{DynamicResource ColorBrush8}"
                BorderBrush="{DynamicResource ColorBrush6}"
                BorderThickness="1"
                CornerRadius="5">
              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                <RadioButton
                    Margin="0,3,12,0"
                    VerticalAlignment="Top"
                    IsChecked="{Binding IsAutoJavaSelected}"
                    Command="{Binding SelectAutoJavaCommand}" />
                <TextBlock
                    Grid.Column="1"
                    Foreground="{DynamicResource ColorBrush1}"
                    FontSize="14"
                    Text="{Binding SetupText.Java.AutoSelectLabel}" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="0,3,0,0"
                    Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                    FontSize="12"
                    Text="{Binding SetupText.Java.AutoSelectDescription}"
                    TextWrapping="Wrap" />
              </Grid>
            </Border>

            <ItemsControl ItemsSource="{Binding JavaRuntimeEntries}" IsVisible="{Binding HasJavaRuntimeEntries}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border
                      Margin="0,0,0,10"
                      Padding="14,12"
                      Background="{DynamicResource ColorBrushBackground}"
                      BorderBrush="{DynamicResource ColorBrush6}"
                      BorderThickness="1"
                      CornerRadius="5">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" RowDefinitions="Auto,Auto,Auto">
                      <RadioButton
                          Grid.RowSpan="3"
                          Margin="0,3,12,0"
                          VerticalAlignment="Top"
                          IsEnabled="{Binding IsEnabled}"
                          IsChecked="{Binding IsSelected}"
                          Command="{Binding SelectCommand}" />
                      <TextBlock
                          Grid.Column="1"
                          Foreground="{Binding TitleForeground}"
                          FontSize="14"
                          Opacity="{Binding TitleOpacity}"
                          Text="{Binding Title}" />
                      <StackPanel
                          Grid.Column="2"
                          Grid.RowSpan="3"
                          Orientation="Horizontal"
                          VerticalAlignment="Top"
                          Spacing="10">
                        <controls:PclOutlineButton
                            Width="72"
                            Command="{Binding OpenCommand}"
                            Text="{Binding DataContext.SetupText.Java.OpenButton, ElementName=Root}" />
                        <controls:PclOutlineButton
                            Width="92"
                            Command="{Binding InfoCommand}"
                            Text="{Binding DataContext.SetupText.Java.DetailsButton, ElementName=Root}" />
                        <controls:PclOutlineButton
                            Width="72"
                            Command="{Binding ToggleEnabledCommand}"
                            Text="{Binding ToggleButtonText}" />
                      </StackPanel>
                      <TextBlock
                          Grid.Row="1"
                          Grid.Column="1"
                          Margin="0,3,0,0"
                          Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                          FontSize="12"
                          Text="{Binding Info}"
                          TextWrapping="Wrap" />
                      <ItemsControl Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" ItemsSource="{Binding Tags}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border
                                Margin="0,0,8,0"
                                Padding="8,3"
                                Background="{DynamicResource ColorBrush8}"
                                BorderBrush="{DynamicResource ColorBrush6}"
                                BorderThickness="1"
                                CornerRadius="10">
                              <TextBlock
                                  Foreground="{DynamicResource ColorBrushEntrySecondarySelected}"
                                  FontSize="11"
                                  Text="{Binding .}" />
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>
    </StackPanel>
  </ScrollViewer>
</UserControl>
