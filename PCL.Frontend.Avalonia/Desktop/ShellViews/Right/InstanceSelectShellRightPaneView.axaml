<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.ShellViews.Right.InstanceSelectShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls"
    xmlns:motion="clr-namespace:PCL.Frontend.Avalonia.Desktop.Animation"
    xmlns:sections="clr-namespace:PCL.Frontend.Avalonia.Desktop.ShellViews.Right.Sections"
    DataContext="{Binding Shell}">
  <UserControl.Styles>
  </UserControl.Styles>

  <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="25,15,25,10" Spacing="0">
        <StackPanel Margin="0,0,0,12" IsVisible="{Binding HasInstanceSelectionSearchBox}">
          <controls:PclSearchBox
              Text="{Binding InstanceSelectionSearchQuery, Mode=TwoWay}"
              ToolTip.Tip="{Binding InstanceSelectionSearchToolTip}"
              Watermark="{Binding InstanceSelectionSearchWatermark}" />
        </StackPanel>

        <ItemsControl ItemsSource="{Binding InstanceSelectionGroups}" IsVisible="{Binding HasInstanceSelectionEntries}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <controls:PclCard
                  Margin="4,4,4,18"
                  Header="{Binding HeaderText}"
                  HeaderCommand="{Binding ToggleExpandCommand}"
                  ShowChevron="True"
                  IsChevronExpanded="{Binding IsExpanded}"
                  motion:Motion.AnimateOnVisible="True"
                  motion:Motion.InitialOpacity="0"
                  motion:Motion.OffsetX="0"
                  motion:Motion.OffsetY="14"
                  motion:Motion.OvershootTranslation="True"
                  ContentMargin="20,40,18,2">
                <controls:PclCard.CardContent>
                  <ItemsControl ItemsSource="{Binding Entries}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Spacing="0" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <sections:InstanceSelectEntryCardView />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </controls:PclCard.CardContent>
              </controls:PclCard>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border
            Width="580"
            MaxWidth="640"
            Padding="26,18,26,18"
            Margin="0,28,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource ColorBrush8}"
            BorderBrush="{DynamicResource ColorBrush6}"
            BorderThickness="1"
            CornerRadius="7"
            IsVisible="{Binding HasNoInstanceSelectionEntries}">
          <StackPanel Spacing="12">
            <TextBlock
                HorizontalAlignment="Center"
                Foreground="{DynamicResource ColorBrush3}"
                FontSize="19"
                Text="{Binding InstanceSelectionEmptyTitle}" />
            <Border Height="2" Background="{DynamicResource ColorBrush4}" />
            <TextBlock
                Margin="2,10,2,0"
                Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                FontSize="12.5"
                Text="{Binding InstanceSelectionEmptyDescription}"
                TextAlignment="Left"
                TextWrapping="Wrap" />
            <StackPanel
                Margin="0,4,0,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="10">
              <controls:PclButton
                  Width="126"
                  Height="35"
                  ColorType="Highlight"
                  Command="{Binding OpenInstanceSelectionDownloadCommand}"
                  IsVisible="{Binding ShowInstanceSelectionEmptyDownloadAction}"
                  Text="{Binding InstanceSelectionEmptyDownloadButtonText}" />
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
