<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.ShellViews.Right.SetupLauncherMiscShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,10,25,10" Spacing="15">
      <controls:PclCard Header="{Binding SetupText.LauncherMisc.SystemCardHeader}" ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="28,9,Auto,5,Auto,5,20,8,35">
            <TextBlock
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="{Binding SetupText.LauncherMisc.LauncherAnnouncementsLabel}" />
            <ComboBox
                Grid.Column="1"
                Height="28"
                ItemsSource="{Binding SystemActivityOptions}"
                SelectedIndex="{Binding SelectedSystemActivityIndex}" />

            <TextBlock
                Grid.Row="2"
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="{Binding SetupText.LauncherMisc.MaxAnimationFpsLabel}" />
            <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,58">
              <Slider
                  VerticalAlignment="Center"
                  Minimum="0"
                  Maximum="59"
                  Value="{Binding AnimationFpsLimit}" />
              <TextBlock
                  Grid.Column="1"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                  FontSize="12"
                  Text="{Binding AnimationFpsLabel}" />
            </Grid>

            <TextBlock
                Grid.Row="4"
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="{Binding SetupText.LauncherMisc.RealTimeLogLinesLabel}" />
            <Grid Grid.Row="4" Grid.Column="1" ColumnDefinitions="*,58">
              <Slider
                  VerticalAlignment="Center"
                  Minimum="0"
                  Maximum="29"
                  Value="{Binding MaxRealTimeLogValue}" />
              <TextBlock
                  Grid.Column="1"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                  FontSize="12"
                  Text="{Binding MaxRealTimeLogLabel}" />
            </Grid>

            <StackPanel
                Grid.Row="6"
                Grid.ColumnSpan="2"
                IsVisible="{Binding IsHardwareAccelerationToggleVisible}"
                Orientation="Horizontal"
                Spacing="12">
              <CheckBox
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource ColorBrush1}"
                  Content="{Binding SetupText.LauncherMisc.DisableHardwareAccelerationLabel}"
                  IsChecked="{Binding DisableHardwareAcceleration}" />
              <TextBlock
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                  FontSize="12"
                  Text="{Binding SetupText.LauncherMisc.DisableHardwareAccelerationHint}"
                  TextWrapping="Wrap" />
            </StackPanel>

            <Grid Grid.Row="8" Grid.ColumnSpan="2" ColumnDefinitions="Auto,Auto,Auto">
              <controls:PclButton
                  Grid.Column="0"
                  Margin="0,0,20,0"
                  MinWidth="140"
                  Command="{Binding ExportSettingsCommand}"
                  Text="{Binding SetupText.LauncherMisc.ExportSettingsButton}" />
              <controls:PclButton
                  Grid.Column="1"
                  Margin="0,0,20,0"
                  MinWidth="140"
                  Command="{Binding ImportSettingsCommand}"
                  Text="{Binding SetupText.LauncherMisc.ImportSettingsButton}" />
              <controls:PclButton
                  Grid.Column="2"
                  MinWidth="140"
                  Command="{Binding OpenSettingsFolderCommand}"
                  Text="{Binding SetupText.LauncherMisc.OpenSettingsFolderButton}" />
            </Grid>
          </Grid>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="{Binding SetupText.LauncherMisc.NetworkCardHeader}" ContentMargin="25,38,25,15">
        <controls:PclCard.CardContent>
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="28,4,28,4,28,4,Auto,6,Auto">
            <TextBlock
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="{Binding SetupText.LauncherMisc.SecureDnsModeLabel}" />
            <ComboBox
                Grid.Column="1"
                ItemsSource="{Binding SecureDnsModeOptions}"
                SelectedIndex="{Binding SelectedSecureDnsModeIndex}" />

            <TextBlock
                Grid.Row="2"
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="{Binding SetupText.LauncherMisc.SecureDnsProviderLabel}" />
            <ComboBox
                Grid.Row="2"
                Grid.Column="1"
                IsEnabled="{Binding IsSecureDnsProviderSelectionEnabled}"
                ItemsSource="{Binding SecureDnsProviderOptions}"
                SelectedIndex="{Binding SelectedSecureDnsProviderIndex}" />

            <TextBlock
                Grid.Row="4"
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="{Binding SetupText.LauncherMisc.HttpProxyLabel}" />
            <Grid Grid.Row="4" Grid.Column="1" ColumnDefinitions="*,*,*,0.2*">
              <RadioButton
                  Grid.Column="0"
                  GroupName="HttpProxyType"
                  Content="{Binding SetupText.LauncherMisc.NoProxyLabel}"
                  IsChecked="{Binding IsNoHttpProxySelected}" />
              <RadioButton
                  Grid.Column="1"
                  GroupName="HttpProxyType"
                  Content="{Binding SetupText.LauncherMisc.SystemProxyLabel}"
                  IsChecked="{Binding IsSystemHttpProxySelected}" />
              <RadioButton
                  Grid.Column="2"
                  GroupName="HttpProxyType"
                  Content="{Binding SetupText.LauncherMisc.CustomProxyLabel}"
                  IsChecked="{Binding IsCustomHttpProxySelected}" />
            </Grid>

            <StackPanel Grid.Row="6" Grid.Column="1" Spacing="9">
              <StackPanel IsVisible="{Binding IsCustomHttpProxyEnabled}" Spacing="9">
                <Border
                    Padding="12,10"
                    Background="{DynamicResource ColorBrushSemanticWarningBackground}"
                    BorderBrush="{DynamicResource ColorBrushSemanticWarningBorder}"
                    BorderThickness="1"
                    CornerRadius="4">
                  <TextBlock
                      Foreground="{DynamicResource ColorBrushSemanticWarningForeground}"
                      FontSize="12.5"
                      Text="{Binding SetupText.LauncherMisc.CustomProxyWarning}"
                      TextWrapping="Wrap" />
                </Border>

                <TextBox
                    Height="28"
                    Padding="8,4"
                    Text="{Binding HttpProxyAddress}"
                    Watermark="{Binding SetupText.LauncherMisc.HttpProxyAddressWatermark}" />

                <Grid ColumnDefinitions="Auto,*,Auto,*">
                  <TextBlock
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"
                      Foreground="{DynamicResource ColorBrush1}"
                      FontSize="13"
                      Text="{Binding SetupText.LauncherMisc.HttpProxyUsernameLabel}" />
                  <TextBox
                      Grid.Column="1"
                      Height="28"
                      Margin="0,0,8,0"
                      Padding="8,4"
                      Text="{Binding HttpProxyUsername}"
                      Watermark="{Binding SetupText.LauncherMisc.HttpProxyValueWatermark}" />
                  <TextBlock
                      Grid.Column="2"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"
                      Foreground="{DynamicResource ColorBrush1}"
                      FontSize="13"
                      Text="{Binding SetupText.LauncherMisc.HttpProxyPasswordLabel}" />
                  <TextBox
                      Grid.Column="3"
                      Height="28"
                      Padding="8,4"
                      Text="{Binding HttpProxyPassword}"
                      Watermark="{Binding SetupText.LauncherMisc.HttpProxyValueWatermark}" />
                </Grid>
              </StackPanel>
            </StackPanel>

            <StackPanel
                Grid.Row="8"
                Grid.Column="1"
                Spacing="6">
              <StackPanel
                  HorizontalAlignment="Center"
                  Orientation="Horizontal"
                  Spacing="8">
                <controls:PclButton
                    MinWidth="120"
                    Command="{Binding TestProxyConnectionCommand}"
                    Text="{Binding SetupText.LauncherMisc.TestProxyButton}" />
                <controls:PclButton
                    MinWidth="120"
                    IsVisible="{Binding IsCustomHttpProxyEnabled}"
                    Command="{Binding ApplyProxySettingsCommand}"
                    Text="{Binding SetupText.LauncherMisc.ApplyProxyButton}" />
              </StackPanel>

              <Border
                  IsVisible="{Binding IsProxyTestSuccessVisible}"
                  Padding="12,10"
                  HorizontalAlignment="Center"
                  MaxWidth="520"
                  Background="{DynamicResource ColorBrushSemanticSuccessBackground}"
                  BorderBrush="{DynamicResource ColorBrushSemanticSuccessBorder}"
                  BorderThickness="1"
                  CornerRadius="4">
                <TextBlock
                    Foreground="{DynamicResource ColorBrushSemanticSuccessForeground}"
                    FontSize="12.5"
                    Text="{Binding ProxyTestFeedbackText}"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
              </Border>

              <Border
                  IsVisible="{Binding IsProxyTestFailureVisible}"
                  Padding="12,10"
                  HorizontalAlignment="Center"
                  MaxWidth="520"
                  Background="{DynamicResource ColorBrushSemanticErrorBackground}"
                  BorderBrush="{DynamicResource ColorBrushSemanticErrorBorder}"
                  BorderThickness="1"
                  CornerRadius="4">
                <TextBlock
                    Foreground="{DynamicResource ColorBrushSemanticErrorForeground}"
                    FontSize="12.5"
                    Text="{Binding ProxyTestFeedbackText}"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
              </Border>

            </StackPanel>
          </Grid>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard
          Header="{Binding SetupText.LauncherMisc.DebugCardHeader}"
          ShowChevron="True"
          IsChevronExpanded="False"
          ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="Auto,*">
              <TextBlock
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource ColorBrush1}"
                  FontSize="13.5"
                  Margin="0,0,25,0"
                  Text="{Binding SetupText.LauncherMisc.DebugAnimationSpeedLabel}" />
              <Grid Grid.Column="1" ColumnDefinitions="*,52">
                <Slider
                    VerticalAlignment="Center"
                    Minimum="0"
                    Maximum="30"
                    Value="{Binding DebugAnimationSpeed}" />
                <TextBlock
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                    FontSize="12"
                    Text="{Binding DebugAnimationSpeedLabel}" />
              </Grid>
            </Grid>

            <Grid ColumnDefinitions="*">
              <CheckBox
                  Grid.Column="0"
                  Foreground="{DynamicResource ColorBrush1}"
                  Content="{Binding SetupText.LauncherMisc.DebugModeLabel}"
                  IsChecked="{Binding DebugModeEnabled}" />
            </Grid>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>
    </StackPanel>
  </ScrollViewer>
</UserControl>
