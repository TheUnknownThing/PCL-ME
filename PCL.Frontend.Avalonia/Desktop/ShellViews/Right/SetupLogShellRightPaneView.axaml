<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.ShellViews.Right.SetupLogShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,25,25,25" Spacing="10">
      <controls:PclCard Header="{Binding SetupText.Log.ActionsCardHeader}" ContentMargin="25,40,20,20">
        <controls:PclCard.CardContent>
          <WrapPanel>
            <controls:PclButton
                Width="100"
                Height="35"
                Margin="0,0,15,0"
                Command="{Binding ExportLogCommand}"
                ColorType="Highlight"
                Text="{Binding SetupText.Log.ExportLogButton}" />
            <controls:PclButton
                Width="120"
                Height="35"
                Margin="0,0,15,0"
                Command="{Binding ExportAllLogsCommand}"
                Text="{Binding SetupText.Log.ExportAllLogsButton}" />
            <controls:PclButton
                Width="120"
                Height="35"
                Margin="0,0,15,0"
                Command="{Binding OpenLogDirectoryCommand}"
                Text="{Binding SetupText.Log.OpenDirectoryButton}" />
            <controls:PclButton
                Width="120"
                Height="35"
                Command="{Binding CleanLogsCommand}"
                ColorType="Red"
                Text="{Binding SetupText.Log.CleanHistoryButton}" />
          </WrapPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="{Binding SetupText.Log.AllLogsCardHeader}" ContentMargin="20,36,18,18">
        <controls:PclCard.CardContent>
          <ItemsControl ItemsSource="{Binding LogEntries}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <controls:PclListItem
                    Margin="0,0,0,8"
                    Command="{Binding Command}"
                    Info="{Binding Info}"
                    Title="{Binding Title}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </controls:PclCard.CardContent>
      </controls:PclCard>
    </StackPanel>
  </ScrollViewer>
</UserControl>
