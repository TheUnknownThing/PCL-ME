<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.ShellViews.Right.DownloadResourceShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls"
    DataContext="{Binding Shell}">
  <UserControl.Resources>
    <DataTemplate x:Key="DownloadResourceFilterOptionTemplate">
      <TextBlock Text="{Binding Label}" />
    </DataTemplate>
  </UserControl.Resources>
  <UserControl.Styles>
    <Style Selector="Button.download-resource-entry:pointerover > Border.download-resource-entry-background">
      <Setter Property="Background" Value="{DynamicResource ColorBrushEntryHoverBackground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ColorBrush6}" />
    </Style>

    <Style Selector="Button.download-resource-entry:pressed > Border.download-resource-entry-background">
      <Setter Property="Background" Value="{DynamicResource ColorBrushEntrySelectedHoverBackground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ColorBrush6}" />
    </Style>

    <Style Selector="Button.download-resource-nav-button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="6,0" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="Button.download-resource-nav-button:pointerover">
      <Setter Property="Background" Value="{DynamicResource ColorBrush7}" />
    </Style>

    <Style Selector="Button.download-resource-nav-button:pressed">
      <Setter Property="Background" Value="{DynamicResource ColorBrush6}" />
    </Style>

    <Style Selector="Button.download-resource-nav-button:disabled">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.download-resource-nav-button Path.chevron-enabled">
      <Setter Property="Stroke" Value="{DynamicResource ColorBrush3}" />
    </Style>

    <Style Selector="Button.download-resource-nav-button:pointerover Path.chevron-enabled">
      <Setter Property="Stroke" Value="{DynamicResource ColorBrush4}" />
    </Style>

    <Style Selector="Button.download-resource-page-button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="MinWidth" Value="32" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>

    <Style Selector="Button.download-resource-page-button > Border.page-chip">
      <Setter Property="Width" Value="32" />
      <Setter Property="Height" Value="32" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="Button.download-resource-page-button > Border.page-chip > TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource ColorBrush3}" />
    </Style>

    <Style Selector="Button.download-resource-page-button:pointerover > Border.page-chip">
      <Setter Property="Background" Value="{DynamicResource ColorBrush7}" />
    </Style>

    <Style Selector="Button.download-resource-page-button:pressed > Border.page-chip">
      <Setter Property="Background" Value="{DynamicResource ColorBrush6}" />
    </Style>

    <Style Selector="Button.download-resource-page-button.active > Border.page-chip">
      <Setter Property="Background" Value="{DynamicResource ColorBrush3}" />
    </Style>

    <Style Selector="Button.download-resource-page-button.active > Border.page-chip > TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource ColorBrushWhite}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

  </UserControl.Styles>
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,10,25,25" Spacing="15">
      <controls:PclCard
          Header="{Binding DownloadResourceCurrentInstanceCardTitle}"
          IsVisible="{Binding ShowDownloadResourceCurrentInstanceCard}"
          ContentMargin="20,18,20,18">
        <controls:PclCard.CardContent>
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Spacing="5">
              <TextBlock
                  Foreground="{DynamicResource ColorBrush1}"
                  FontSize="13"
                  Text="{Binding DownloadResourceCurrentInstanceTitle}" />
              <TextBlock
                  Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                  FontSize="11.5"
                  Text="{Binding DownloadResourceCurrentInstanceSummary}"
                  TextWrapping="Wrap" />
            </StackPanel>
            <controls:PclButton
                Grid.Column="1"
                Width="96"
                Height="35"
                Command="{Binding SelectDownloadResourceInstanceCommand}"
                Text="{Binding DownloadResourceCurrentInstanceActionText}" />
          </Grid>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclSearchBox
          x:Name="SearchRow"
          SearchCommand="{Binding SearchDownloadResourceCommand}"
          SearchButtonText="{Binding CommonSearchButtonText}"
          ShowSearchButton="True"
          Text="{Binding DownloadResourceSearchQuery, Mode=TwoWay}"
          Watermark="{Binding DownloadResourceSearchWatermark}" />

      <controls:PclCard x:Name="FilterCard" ContentMargin="7,7,7,7">
        <controls:PclCard.CardContent>
          <Grid ColumnDefinitions="Auto,*,Auto,1.3*,Auto,*,Auto" RowDefinitions="28,8,28">
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                Margin="5,0,7,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13"
                Text="{Binding DownloadResourceFilterSourceText}" />
            <ComboBox
                Grid.Row="0"
                Grid.Column="1"
                x:Name="DownloadResourceSourceComboBox"
                ItemsSource="{Binding DownloadResourceSourceOptions}"
                ItemTemplate="{StaticResource DownloadResourceFilterOptionTemplate}"
                SelectedItem="{Binding SelectedDownloadResourceSourceOption}"
                SelectionBoxItemTemplate="{StaticResource DownloadResourceFilterOptionTemplate}" />

            <TextBlock
                Grid.Row="0"
                Grid.Column="2"
                Margin="12,0,7,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13"
                Text="{Binding DownloadResourceFilterTagText}" />
            <ComboBox
                Grid.Row="0"
                Grid.Column="3"
                x:Name="DownloadResourceTagComboBox"
                ItemsSource="{Binding DownloadResourceTagOptions}"
                ItemTemplate="{StaticResource DownloadResourceFilterOptionTemplate}"
                SelectedItem="{Binding SelectedDownloadResourceTagOption}"
                SelectionBoxItemTemplate="{StaticResource DownloadResourceFilterOptionTemplate}" />

            <TextBlock
                Grid.Row="0"
                Grid.Column="4"
                Margin="12,0,7,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13"
                Text="{Binding DownloadResourceFilterSortText}" />
            <ComboBox
                Grid.Row="0"
                Grid.Column="5"
                x:Name="DownloadResourceSortComboBox"
                ItemsSource="{Binding DownloadResourceSortOptions}"
                ItemTemplate="{StaticResource DownloadResourceFilterOptionTemplate}"
                SelectedItem="{Binding SelectedDownloadResourceSortOption}"
                SelectionBoxItemTemplate="{StaticResource DownloadResourceFilterOptionTemplate}" />

            <StackPanel
                Grid.Row="0"
                Grid.Column="6"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="4">
              <controls:PclIconButton
                  Command="{Binding ResetDownloadResourceFiltersCommand}"
                  HoverBackgroundBrush="{DynamicResource ColorBrushBg1}"
                  IconBrush="{DynamicResource ColorBrushEntrySecondaryIdle}"
                  IconData="F1 M 3 2 A 1 1 0 0 0 2 3 V 8 A 1.0001 1.0001 0 0 0 3 9 H 8 A 1 1 0 0 0 9 8 A 1 1 0 0 0 8 7 H 4 V 3 A 1 1 0 0 0 3 2 Z m 8.99609 0 C 9.22233 2.01043 6.55872 3.09358 4.56445 5.02148 a 1.0001 1.0001 0 0 0 -0.011719 0.011719 L 2.29297 7.29297 a 1 1 0 0 0 0 1.41406 a 1 1 0 0 0 1.41406 0 L 5.95508 6.45898 C 7.57782 4.89024 9.74308 4.0095 12 4 c 3.60637 0 6.23273 2.14173 7.39062 4.9375 c 1.1579 2.79577 0.815357 6.16902 -1.73438 8.71875 c -2.54973 2.54973 -5.92298 2.89227 -8.71875 1.73438 C 6.14173 18.2327 4 15.6064 4 12 A 1 1 0 0 0 3 11 A 1 1 0 0 0 2 12 c 0 4.41234 2.70513 7.80169 6.17383 9.23828 c 3.4687 1.43659 7.77682 0.951691 10.8965 -2.16797 c 3.11966 -3.11966 3.60456 -7.42779 2.16797 -10.8965 C 19.8017 4.70513 16.4123 2 12 2 a 1.0001 1.0001 0 0 0 -0.0039 0 z" />
            </StackPanel>

            <TextBlock
                Grid.Row="2"
                Grid.Column="0"
                Margin="5,0,7,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13"
                Text="{Binding DownloadResourceFilterVersionText}" />
            <ComboBox
                Grid.Row="2"
                Grid.Column="1"
                x:Name="DownloadResourceVersionComboBox"
                ItemsSource="{Binding DownloadResourceVersionOptions}"
                ItemTemplate="{StaticResource DownloadResourceFilterOptionTemplate}"
                SelectedItem="{Binding SelectedDownloadResourceVersionOption}"
                SelectionBoxItemTemplate="{StaticResource DownloadResourceFilterOptionTemplate}" />

            <TextBlock
                Grid.Row="2"
                Grid.Column="2"
                Margin="12,0,7,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13"
                IsVisible="{Binding ShowDownloadResourceLoaderFilter}"
                Text="{Binding DownloadResourceFilterLoaderText}" />
            <ComboBox
                Grid.Row="2"
                Grid.Column="3"
                x:Name="DownloadResourceLoaderComboBox"
                IsVisible="{Binding ShowDownloadResourceLoaderFilter}"
                ItemsSource="{Binding DownloadResourceLoaderOptions}"
                ItemTemplate="{StaticResource DownloadResourceFilterOptionTemplate}"
                SelectedItem="{Binding SelectedDownloadResourceLoaderOption}"
                SelectionBoxItemTemplate="{StaticResource DownloadResourceFilterOptionTemplate}" />
          </Grid>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <Border
          x:Name="HintBanner"
          Padding="12,10"
          Background="{DynamicResource ColorBrushSemanticWarningBackground}"
          BorderBrush="{DynamicResource ColorBrushSemanticWarningBorder}"
          BorderThickness="1"
          CornerRadius="4"
          IsVisible="False">
        <TextBlock
            Foreground="{DynamicResource ColorBrushSemanticWarningForeground}"
            FontSize="12.5"
            Text="{Binding DownloadResourceHintText}"
            TextWrapping="Wrap" />
      </Border>

      <StackPanel x:Name="ContentHost" IsVisible="False" Spacing="15">
        <controls:PclCard ContentMargin="12,12,12,12">
          <controls:PclCard.CardContent>
            <StackPanel Spacing="0">
              <ItemsControl ItemsSource="{Binding DownloadResourceEntries}" IsVisible="{Binding HasDownloadResourceEntries}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button
                        Classes="nochrome download-resource-entry"
                        Margin="0,0,0,2"
                        Padding="0"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Command="{Binding Command}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch">
                      <Border
                          Classes="download-resource-entry-background"
                          Height="64"
                          Background="{DynamicResource ColorBrushSemiTransparent}"
                          BorderBrush="Transparent"
                          BorderThickness="1"
                          CornerRadius="4">
                        <Grid ColumnDefinitions="7,50,8,Auto,*,30" RowDefinitions="*,20,18,16,*">
                          <Border
                              Grid.Column="1"
                              Grid.Row="1"
                              Grid.RowSpan="3"
                              Width="50"
                              Height="50"
                              ClipToBounds="True"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              CornerRadius="6">
                            <Image
                                Width="50"
                                Height="50"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsVisible="{Binding HasIcon}"
                                Source="{Binding Icon}"
                                Stretch="UniformToFill" />
                          </Border>

                          <TextBlock
                              Grid.Column="3"
                              Grid.ColumnSpan="2"
                              Grid.Row="1"
                              VerticalAlignment="Center"
                              Foreground="{DynamicResource ColorBrush1}"
                              FontSize="14"
                              Text="{Binding Title}"
                              TextTrimming="CharacterEllipsis" />

                          <StackPanel
                              Grid.Column="3"
                              Grid.Row="2"
                              Margin="-1,0,1,0"
                              Orientation="Horizontal"
                              VerticalAlignment="Center"
                              IsVisible="{Binding HasVisibleTags}">
                            <ItemsControl ItemsSource="{Binding VisibleTags}">
                              <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                  <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                              </ItemsControl.ItemsPanel>
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <Border
                                      Margin="0,0,3,0"
                                      Padding="3,1"
                                      Background="{DynamicResource ColorBrushSemanticNeutralBackground}"
                                      CornerRadius="3">
                                    <TextBlock
                                        Foreground="{DynamicResource ColorBrushSemanticNeutralForeground}"
                                        FontSize="11"
                                        Text="{Binding}" />
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>

                          <TextBlock
                              Grid.Column="4"
                              Grid.Row="2"
                              Margin="0,0,3,0.5"
                              VerticalAlignment="Center"
                              Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                              FontSize="12"
                              IsVisible="{Binding HasInfo}"
                              Text="{Binding Info}"
                              TextTrimming="CharacterEllipsis" />

                          <Grid
                              Grid.Column="3"
                              Grid.ColumnSpan="2"
                              Grid.Row="3"
                              VerticalAlignment="Center"
                              ColumnDefinitions="Auto,Auto,0.25*,Auto,Auto,0.25*,Auto,Auto,0.25*,Auto,Auto,0.25*">
                            <Path
                                Grid.Column="0"
                                Height="11"
                                Fill="{DynamicResource ColorBrushEntrySecondaryIdle}"
                                Stretch="Uniform"
                                Data="M940.4 463.7L773.3 174.2c-17.3-30-49.2-48.4-83.8-48.4H340.2c-34.6 0-66.5 18.5-83.8 48.4L89.2 463.7c-17.3 30-17.3 66.9 0 96.8L256.4 850c17.3 30 49.2 48.4 83.8 48.4h349.2c34.6 0 66.5-18.5 83.8-48.4l167.2-289.5c17.3-29.9 17.3-66.8 0-96.8z m-94.6 96.8L725.9 768.1c-17.3 30-49.2 48.4-83.8 48.4H387.5c-34.6 0-66.5-18.5-83.8-48.4L183.9 560.5c-17.3-30-17.3-66.9 0-96.8l119.8-207.5c17.3-30 49.2-48.4 83.8-48.4h254.6c34.6 0 66.5 18.5 83.8 48.4l119.8 207.5c17.3 30 17.3 66.9 0.1 96.8z M522.3 321.2c-2.5-0.1-5-0.2-7.5-0.2-119.9 0-214 110.3-186.3 235 15.8 70.9 71.5 126.6 142.4 142.4 17.5 3.9 34.7 5.4 51.4 4.7 102.1-3.9 183.6-87.9 183.6-191 0.1-103-81.5-187-183.6-190.9z m68.6 269.1c-18.5 18-43 28.9-68.6 30.7l-6 0.3c-30.2 0.4-58.6-11.4-79.7-33-19.5-20.1-30.7-47-30.9-75-0.3-29.6 11.1-57.4 32-78.3 20.6-20.6 48-32 77.2-32 2.5 0 5 0.1 7.5 0.3 26.7 1.8 51.5 13.2 70.5 32.5 19.6 20 30.8 46.9 31.2 74.9 0.2 30.2-11.5 58.6-33.2 79.6z" />
                            <TextBlock
                                Grid.Column="1"
                                Margin="4,0,2,0"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                                FontSize="12"
                                Text="{Binding VersionLabel}"
                                TextTrimming="CharacterEllipsis" />

                            <Path
                                Grid.Column="3"
                                Height="10.5"
                                Fill="{DynamicResource ColorBrushEntrySecondaryIdle}"
                                Stretch="Uniform"
                                Data="M955 610h-59c-15 0-29 13-29 29v196c0 15-13 29-29 29h-649c-15 0-29-13-29-29v-196c0-15-13-29-29-29h-59c-15 0-29 13-29 29V905c0 43 35 78 78 78h787c43 0 78-35 78-78V640c0-15-13-29-29-29zM492 740c11 11 29 11 41 0l265-265c11-11 11-29 0-41l-41-41c-11-11-29-11-41 0l-110 110c-11 11-33 3-33-13V68C571 53 555 39 541 39h-59c-15 0-29 13-29 29v417c0 17-21 25-33 13l-110-110c-11-11-29-11-41 0L226 433c-11 11-11 29 0 41L492 740z" />
                            <TextBlock
                                Grid.Column="4"
                                Margin="5,0,2,0"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                                FontSize="12"
                                Text="{Binding DownloadCountLabel}"
                                TextTrimming="CharacterEllipsis" />

                            <Path
                                Grid.Column="6"
                                Height="11.5"
                                Margin="0,0,1,0"
                                Fill="{DynamicResource ColorBrushEntrySecondaryIdle}"
                                Stretch="Uniform"
                                Data="M810 403l-39 39c-10 10-28 10-39 0l-162-162v412c0 15-12 28-28 28h-56c-15 0-28-12-28-28v-412l-162 162c-10 10-28 10-39 0l-39-39c-10-10-10-28 0-39l278-278c10-10 28-10 39 0l278 278c10 10 10 28 0 39zM568 946h-112v-112h112v112z" />
                            <TextBlock
                                Grid.Column="7"
                                Margin="5,0,2,0"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                                FontSize="12"
                                Text="{Binding UpdatedLabel}"
                                TextTrimming="CharacterEllipsis" />

                            <Path
                                Grid.Column="9"
                                Height="11.5"
                                Fill="{DynamicResource ColorBrushEntrySecondaryIdle}"
                                Stretch="Uniform"
                                Data="M511 143c-203 0-369 165-369 369 0 203 165 369 369 369s369-165 369-369c0-203-165-369-369-369z m0 673c-29 0-68-59-89-159l178 0c-20 100-59 159-89 159z m-98-224c-2-24-3-51-3-79 0-29 1-57 4-83l197 0c2 25 4 53 4 83 0 28-1 54-3 79l-198-0z m98-383c29 0 67 58 88 156l-177-0c20-98 59-155 88-155z m164 221l128 0c7 26 11 54 11 82 0 27-3 54-10 80l-129-0c2-26 3-52 3-79 0-28-1-56-4-83z m101-64l-110-0c-7-37-16-72-28-102-4-11-9-22-15-33 66 25 121 74 155 135z m-376-135c-5 10-10 21-15 33-12 30-21 64-28 102l-110-0c34-60 89-109 154-134z m-181 199l128 0c-2 27-3 54-3 83 0 27 1 53 3 79l-127-0v6c-8-27-12-55-12-85-0-29 3-57 11-83z m24 227l112 0c7 38 16 74 29 105 4 11 9 22 15 33-67-26-122-76-156-139zM621 795c5-10 10-21 15-33 12-30 22-66 29-105l111 0c-34 62-89 111-156 137z" />
                            <TextBlock
                                Grid.Column="10"
                                Margin="5,0,2,0"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                                FontSize="12"
                                Text="{Binding Source}"
                                TextTrimming="CharacterEllipsis" />
                          </Grid>

                          <Path
                              Grid.Column="5"
                              Grid.Row="0"
                              Grid.RowSpan="5"
                              Width="10"
                              Height="10"
                              VerticalAlignment="Center"
                              Fill="{DynamicResource ColorBrushEntrySecondaryIdle}"
                              Stretch="Uniform"
                              Data="M6.4,0L4.98,1.4L8.58,5L4.98,8.6L6.4,10L11.4,5L6.4,0Z" />
                        </Grid>
                      </Border>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <StackPanel IsVisible="{Binding HasNoDownloadResourceEntries}" Spacing="6">
                <TextBlock
                    Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                    FontSize="13"
                    Text="{Binding DownloadResourceEmptyStateText}"
                    TextWrapping="Wrap" />
                <TextBlock
                    IsVisible="{Binding ShowDownloadResourceEmptyStateHint}"
                    Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                    FontSize="12"
                    Text="{Binding DownloadResourceEmptyStateHintText}"
                    TextWrapping="Wrap" />
              </StackPanel>
            </StackPanel>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <controls:PclCard
            ContentMargin="8,8,8,8"
            HorizontalAlignment="Center"
            IsVisible="{Binding ShowDownloadResourcePagination}">
          <controls:PclCard.CardContent>
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="12" VerticalAlignment="Center">
                <Button
                    Grid.Column="0"
                    Classes="nochrome download-resource-nav-button"
                    Command="{Binding FirstDownloadResourcePageCommand}"
                    IsEnabled="{Binding CanGoToPreviousDownloadResourcePage}"
                    Margin="0,0,4,0">
                  <Grid Width="14" Height="14">
                    <Path
                        Classes="chevron-enabled"
                        Width="14"
                        Height="14"
                        VerticalAlignment="Center"
                        IsVisible="{Binding CanGoToPreviousDownloadResourcePage}"
                        StrokeThickness="2"
                        StrokeLineCap="Round"
                        Stretch="Uniform"
                        Data="M12,1 L7,7 L12,13 M7,1 L2,7 L7,13" />
                    <Path
                        Width="14"
                        Height="14"
                        VerticalAlignment="Center"
                        Stroke="{DynamicResource ColorBrushGray4}"
                        IsVisible="{Binding CanNotGoToPreviousDownloadResourcePage}"
                        StrokeThickness="2"
                        StrokeLineCap="Round"
                        Stretch="Uniform"
                        Data="M12,1 L7,7 L12,13 M7,1 L2,7 L7,13" />
                  </Grid>
                </Button>

                <Button
                    Grid.Column="1"
                    Classes="nochrome download-resource-nav-button"
                    Command="{Binding PreviousDownloadResourcePageCommand}"
                    IsEnabled="{Binding CanGoToPreviousDownloadResourcePage}"
                    Margin="4,0,0,0">
                  <Grid Width="9" Height="14">
                    <Path
                        Classes="chevron-enabled"
                        Width="9"
                        Height="14"
                        VerticalAlignment="Center"
                        IsVisible="{Binding CanGoToPreviousDownloadResourcePage}"
                        StrokeThickness="2"
                        StrokeLineCap="Round"
                        Stretch="Uniform"
                        Data="M7,1 L2,7 L7,13" />
                    <Path
                        Width="9"
                        Height="14"
                        VerticalAlignment="Center"
                        Stroke="{DynamicResource ColorBrushGray4}"
                        IsVisible="{Binding CanNotGoToPreviousDownloadResourcePage}"
                        StrokeThickness="2"
                        StrokeLineCap="Round"
                        Stretch="Uniform"
                        Data="M7,1 L2,7 L7,13" />
                  </Grid>
                </Button>

                <TextBlock
                    Grid.Column="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource ColorBrush3}"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="{Binding DownloadResourcePageLabel}" />

                <Button
                    Grid.Column="3"
                    Classes="nochrome download-resource-nav-button"
                    Command="{Binding NextDownloadResourcePageCommand}"
                    IsEnabled="{Binding CanGoToNextDownloadResourcePage}"
                    Margin="4,0,0,0">
                  <Grid Width="9" Height="14">
                    <Path
                        Classes="chevron-enabled"
                        Width="9"
                        Height="14"
                        VerticalAlignment="Center"
                        IsVisible="{Binding CanGoToNextDownloadResourcePage}"
                        StrokeThickness="2"
                        StrokeLineCap="Round"
                        Stretch="Uniform"
                        Data="M2,1 L7,7 L2,13" />
                    <Path
                        Width="9"
                        Height="14"
                        VerticalAlignment="Center"
                        Stroke="{DynamicResource ColorBrushGray4}"
                        IsVisible="{Binding CanNotGoToNextDownloadResourcePage}"
                        StrokeThickness="2"
                        StrokeLineCap="Round"
                        Stretch="Uniform"
                        Data="M2,1 L7,7 L2,13" />
                  </Grid>
                </Button>
            </Grid>
          </controls:PclCard.CardContent>
        </controls:PclCard>
      </StackPanel>

      <controls:PclCard
          x:Name="LoadingCard"
          Margin="40,50"
          ContentMargin="20,20,20,17"
          HorizontalAlignment="Center"
          IsVisible="False"
          VerticalAlignment="Center">
        <controls:PclCard.CardContent>
          <controls:PclLoading
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Text="{Binding DownloadResourceLoadingText}" />
        </controls:PclCard.CardContent>
      </controls:PclCard>
    </StackPanel>
  </ScrollViewer>
</UserControl>
