<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.ShellViews.Right.DownloadFavoritesShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animation="clr-namespace:PCL.Frontend.Avalonia.Desktop.Animation"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls"
    xmlns:sections="clr-namespace:PCL.Frontend.Avalonia.Desktop.ShellViews.Right.Sections"
    DataContext="{Binding Shell}">
  <Grid ClipToBounds="False">
    <ScrollViewer x:Name="ContentScrollViewer" VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="25,25,25,10" Spacing="15">
        <StackPanel Spacing="15">
          <controls:PclSearchBox
              Text="{Binding DownloadFavoriteSearchQuery, Mode=TwoWay}"
              Watermark="搜索收藏夹内容" />

          <controls:PclCard ContentMargin="15,8,0,15">
            <controls:PclCard.CardContent>
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                  <ComboBox
                      Width="180"
                      HorizontalAlignment="Left"
                      ItemsSource="{Binding DownloadFavoriteTargetOptions}"
                      SelectedIndex="{Binding SelectedDownloadFavoriteTargetIndex}" />
                  <controls:PclIconButton
                      x:Name="ManageTargetButton"
                      Grid.Column="1"
                      Margin="8,0,15,0"
                      HorizontalAlignment="Right"
                      Command="{Binding ManageDownloadFavoriteTargetCommand}"
                      ToolTip.Tip="管理"
                      VerticalAlignment="Center" />
                </Grid>

                <WrapPanel>
                  <controls:PclButton
                      MinWidth="110"
                      Margin="0,0,15,0"
                      Command="{Binding SelectAllDownloadFavoritesCommand}"
                      IsEnabled="{Binding CanSelectAllDownloadFavorites}"
                      Text="全选" />
                </WrapPanel>
              </StackPanel>
            </controls:PclCard.CardContent>
          </controls:PclCard>
        </StackPanel>

        <Border
            Padding="12,10"
            Background="#FFF8DD"
            BorderBrush="#F2D777"
            BorderThickness="1"
            CornerRadius="4"
            IsVisible="{Binding ShowDownloadFavoriteWarning}">
          <TextBlock
              Foreground="#6E5800"
              FontSize="12.5"
              Text="{Binding DownloadFavoriteWarningText}"
              TextWrapping="Wrap" />
        </Border>

        <ItemsControl ItemsSource="{Binding DownloadFavoriteSections}" IsVisible="{Binding HasDownloadFavoriteSections}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <controls:PclCard Margin="0,0,0,15" Header="{Binding Title}" ContentMargin="20,18,18,18">
                <controls:PclCard.CardContent>
                  <ItemsControl ItemsSource="{Binding Items}" Padding="0">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <sections:ResourceEntryCardView />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </controls:PclCard.CardContent>
              </controls:PclCard>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <controls:PclCard Header="还没有收藏内容" IsVisible="{Binding HasNoDownloadFavoriteSections}" ContentMargin="20,34,20,20">
          <controls:PclCard.CardContent>
            <StackPanel Spacing="9">
              <TextBlock
                  Foreground="#4B5968"
                  FontSize="13"
                  Text="在资源详细信息界面中可以点击收藏按钮进行收藏。"
                  TextWrapping="Wrap" />
            </StackPanel>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <Border
            x:Name="SelectionActionSpacer"
            Height="0"
            Background="Transparent"
            IsHitTestVisible="False">
          <Border.Transitions>
            <Transitions>
              <DoubleTransition Property="Height" Duration="{Binding SurfaceState, Source={x:Static animation:MotionDurations.Source}}" />
            </Transitions>
          </Border.Transitions>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <controls:PclCard
        x:Name="SelectionActionCard"
        MinWidth="420"
        MaxWidth="780"
        Margin="25,25,25,0"
        ContentMargin="0"
        HorizontalAlignment="Center"
        IsHitTestVisible="False"
        IsVisible="False"
        Opacity="0"
        RenderTransform="translate(0px,10px) scale(0.985)"
        RenderTransformOrigin="0.5,1"
        VerticalAlignment="Bottom">
      <controls:PclCard.Transitions>
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="{Binding QuickState, Source={x:Static animation:MotionDurations.Source}}" />
          <TransformOperationsTransition Property="RenderTransform" Duration="{Binding QuickState, Source={x:Static animation:MotionDurations.Source}}" />
        </Transitions>
      </controls:PclCard.Transitions>
      <controls:PclCard.CardContent>
        <Grid RowDefinitions="Auto,Auto">
          <TextBlock
              Margin="9,9,9,0"
              HorizontalAlignment="Center"
              Foreground="{DynamicResource ColorBrush2}"
              FontSize="13"
              FontWeight="SemiBold"
              Text="{Binding DownloadFavoriteSelectionText}" />
          <WrapPanel
              Grid.Row="1"
              Margin="5,14,5,5"
              HorizontalAlignment="Center">
            <controls:PclIconTextButton
                x:Name="SelectionInstallButton"
                Command="{Binding BatchInstallSelectedDownloadFavoritesCommand}"
                IsEnabled="{Binding CanBatchInstallSelectedDownloadFavorites}"
                Text="批量安装" />
            <controls:PclIconTextButton
                x:Name="SelectionShareButton"
                Command="{Binding ShareSelectedDownloadFavoritesCommand}"
                IsEnabled="{Binding CanShareSelectedDownloadFavorites}"
                Text="分享所选" />
            <controls:PclIconTextButton
                x:Name="SelectionFavoriteButton"
                Command="{Binding FavoriteSelectedDownloadFavoritesToTargetCommand}"
                IsEnabled="{Binding CanFavoriteSelectedDownloadFavoritesToTarget}"
                Text="收藏到" />
            <controls:PclIconTextButton
                x:Name="SelectionRemoveButton"
                Command="{Binding RemoveSelectedDownloadFavoritesCommand}"
                IsEnabled="{Binding CanRemoveSelectedDownloadFavorites}"
                Text="移出收藏夹" />
            <controls:PclIconTextButton
                x:Name="SelectionCancelButton"
                Command="{Binding ClearDownloadFavoriteSelectionCommand}"
                Text="取消选择" />
          </WrapPanel>
        </Grid>
      </controls:PclCard.CardContent>
    </controls:PclCard>
  </Grid>
</UserControl>
