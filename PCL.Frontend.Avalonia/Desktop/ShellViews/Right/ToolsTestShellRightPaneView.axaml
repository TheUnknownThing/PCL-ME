<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.ShellViews.Right.ToolsTestShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,10,25,10" Spacing="15">
      <controls:PclCard Header="百宝箱" ContentMargin="25,40,21,5">
        <controls:PclCard.CardContent>
          <ItemsControl ItemsSource="{Binding ToolboxActions}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel ItemHeight="50" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <controls:PclButton
                    Height="35"
                    Margin="0,0,15,15"
                    MinWidth="{Binding MinWidth}"
                    Command="{Binding Command}"
                    ColorType="{Binding ColorType}"
                    Text="{Binding Title}"
                    ToolTip.Tip="{Binding ToolTip}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="下载自定义文件" ContentMargin="25,40,25,20">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <TextBlock
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13"
                Text="使用 PCL 的高速多线程下载引擎下载任意文件。请注意，部分网站（例如百度网盘）可能会报错 (403) 已禁止，无法正常下载。"
                TextWrapping="Wrap" />
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="28,10,28,10,28,10,28">
              <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush1}" FontSize="13.5" Margin="0,0,25,0" Text="下载地址" />
              <TextBox Grid.Column="1" Height="28" Padding="8,4" Text="{Binding ToolDownloadUrl}" />

              <TextBlock Grid.Row="2" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush1}" FontSize="13.5" Margin="0,0,25,0" Text="User-Agent" />
              <TextBox Grid.Row="2" Grid.Column="1" Height="28" Padding="8,4" Text="{Binding ToolDownloadUserAgent}" />

              <TextBlock Grid.Row="4" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush1}" FontSize="13.5" Margin="0,0,25,0" Text="保存到" />
              <Grid Grid.Row="4" Grid.Column="1" ColumnDefinitions="*,Auto">
                <TextBox Height="28" Padding="8,4" Text="{Binding ToolDownloadFolder}" />
                <controls:PclButton
                    Grid.Column="1"
                    Height="35"
                    Width="70"
                    Margin="10,0,0,0"
                    Command="{Binding SelectDownloadFolderCommand}"
                    Text="选择" />
              </Grid>

              <TextBlock Grid.Row="6" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush1}" FontSize="13.5" Margin="0,0,25,0" Text="文件名" />
              <TextBox Grid.Row="6" Grid.Column="1" Height="28" Padding="8,4" Text="{Binding ToolDownloadName}" />
            </Grid>

            <Grid ColumnDefinitions="*,*" Margin="0,5,0,0">
              <controls:PclButton
                  Grid.Column="0"
                  Height="35"
                  Width="140"
                  HorizontalAlignment="Right"
                  Margin="0,0,15,0"
                  Command="{Binding StartCustomDownloadCommand}"
                  ColorType="Highlight"
                  Text="开始下载" />
              <controls:PclButton
                  Grid.Column="1"
                  Height="35"
                  Width="140"
                  HorizontalAlignment="Left"
                  Command="{Binding OpenCustomDownloadFolderCommand}"
                  Text="打开文件夹" />
            </Grid>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="下载正版玩家的皮肤" ContentMargin="25,40,25,15">
        <controls:PclCard.CardContent>
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="28,14,35">
            <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush1}" FontSize="13.5" Margin="0,0,25,0" Text="正版玩家名" />
            <TextBox Grid.Column="1" Height="28" Padding="8,4" Text="{Binding OfficialSkinPlayerName}" />
            <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="Auto,*">
              <controls:PclButton
                  Height="35"
                  Width="140"
                  Command="{Binding SaveOfficialSkinCommand}"
                  Text="保存皮肤" />
            </Grid>
          </Grid>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="瞅眼服务器" ContentMargin="15,40,15,15">
        <controls:PclCard.CardContent>
          <controls:MinecraftServerQuery />
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="自定义成就图片生成器（仅支持英文）" ShowChevron="True" IsChevronExpanded="False" ContentMargin="25,30,25,15">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="28,10,28,10,28,10,28">
              <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush1}" FontSize="13.5" Margin="0,0,25,0" Text="物品名（ID）" />
              <TextBox Grid.Column="1" Height="28" Padding="8,4" Text="{Binding AchievementBlockId}" />
              <TextBlock Grid.Row="2" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush1}" FontSize="13.5" Margin="0,0,25,0" Text="成就名" />
              <TextBox Grid.Row="2" Grid.Column="1" Height="28" Padding="8,4" Text="{Binding AchievementTitle}" />
              <TextBlock Grid.Row="4" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush1}" FontSize="13.5" Margin="0,0,25,0" Text="第一行" />
              <TextBox Grid.Row="4" Grid.Column="1" Height="28" Padding="8,4" Text="{Binding AchievementFirstLine}" />
              <TextBlock Grid.Row="6" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush1}" FontSize="13.5" Margin="0,0,25,0" Text="第二行" />
              <TextBox Grid.Row="6" Grid.Column="1" Height="28" Padding="8,4" Text="{Binding AchievementSecondLine}" />
            </Grid>

            <Grid ColumnDefinitions="*,*">
              <controls:PclButton
                  Grid.Column="0"
                  Height="35"
                  Width="140"
                  HorizontalAlignment="Right"
                  Margin="0,0,15,0"
                  Command="{Binding PreviewAchievementCommand}"
                  ColorType="Highlight"
                  Text="预览成就图像" />
              <controls:PclButton
                  Grid.Column="1"
                  Height="35"
                  Width="140"
                  HorizontalAlignment="Left"
                  Command="{Binding SaveAchievementCommand}"
                  Text="保存图片" />
            </Grid>

            <Border
                Width="320"
                Height="64"
                Padding="12,8"
                Background="{DynamicResource ColorBrushAchievementPreviewCardBackground}"
                BorderBrush="{DynamicResource ColorBrushAchievementPreviewCardBorder}"
                BorderThickness="1"
                CornerRadius="5"
                HorizontalAlignment="Center"
                IsVisible="{Binding ShowAchievementPreview}">
              <Grid ColumnDefinitions="40,12,*">
                <Border
                    Width="32"
                    Height="32"
                    Margin="0,2,0,0"
                    Background="{DynamicResource ColorBrushAchievementPreviewBadgeBackground}"
                    BorderBrush="{DynamicResource ColorBrushAchievementPreviewBadgeBorder}"
                    BorderThickness="1"
                    CornerRadius="4">
                  <TextBlock
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Foreground="{DynamicResource ColorBrushAchievementPreviewBadgeForeground}"
                      FontSize="10"
                      Text="{Binding AchievementBlockId}" />
                </Border>
                <StackPanel Grid.Column="2" Spacing="2">
                  <TextBlock Foreground="{DynamicResource ColorBrushAchievementPreviewTitle}" FontSize="13" Text="{Binding AchievementTitle}" />
                  <TextBlock Foreground="{DynamicResource ColorBrushAchievementPreviewFirstLine}" FontSize="12.5" Text="{Binding AchievementFirstLine}" />
                  <TextBlock Foreground="{DynamicResource ColorBrushAchievementPreviewSecondLine}" FontSize="12" Text="{Binding AchievementSecondLine}" />
                </StackPanel>
              </Grid>
            </Border>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="皮肤头像生成器" ShowChevron="True" IsChevronExpanded="False" ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="Auto,*">
              <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush1}" FontSize="13.5" Margin="0,0,20,0" Text="头像大小" />
              <ComboBox
                  Grid.Column="1"
                  Width="120"
                  ItemsSource="{Binding HeadSizeOptions}"
                  SelectedIndex="{Binding SelectedHeadSizeIndex}" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto,Auto,*">
              <controls:PclButton
                  Grid.Column="1"
                  Height="35"
                  Width="140"
                  Margin="0,0,10,0"
                  Command="{Binding SelectHeadSkinCommand}"
                  Text="选择皮肤" />
              <controls:PclButton
                  Grid.Column="2"
                  Height="35"
                  Width="140"
                  Command="{Binding SaveHeadCommand}"
                  Text="保存头像" />
            </Grid>

            <Border
                Width="{Binding HeadPreviewSize}"
                Height="{Binding HeadPreviewSize}"
                Padding="14,12"
                Background="{DynamicResource ColorBrush8}"
                BorderBrush="{DynamicResource ColorBrush6}"
                BorderThickness="1"
                CornerRadius="5"
                HorizontalAlignment="Center"
                IsVisible="{Binding HasSelectedHeadSkin}">
              <StackPanel HorizontalAlignment="Center" Spacing="10">
                <Border
                    Width="{Binding HeadPreviewSize}"
                    Height="{Binding HeadPreviewSize}"
                    Background="{DynamicResource ColorBrush8}"
                    BorderBrush="{DynamicResource ColorBrush6}"
                    BorderThickness="1"
                    CornerRadius="8">
                  <Grid>
                    <Border
                        Width="{Binding HeadPreviewSize}"
                        Height="{Binding HeadPreviewSize}"
                        Background="{DynamicResource ColorBrush4}"
                        CornerRadius="8" />
                    <Border
                        Width="{Binding HeadPreviewSize}"
                        Height="{Binding HeadPreviewSize}"
                        Background="{DynamicResource ColorBrush5}"
                        CornerRadius="8"
                        Margin="0,0,0,6" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource ColorBrush2}"
                        FontSize="12"
                        Text="头像预览" />
                  </Grid>
                </Border>
              </StackPanel>
            </Border>
            <TextBlock
                HorizontalAlignment="Center"
                Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                FontSize="12.5"
                Text="{Binding SelectedHeadSkinPath}" />
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>
    </StackPanel>
  </ScrollViewer>
</UserControl>
