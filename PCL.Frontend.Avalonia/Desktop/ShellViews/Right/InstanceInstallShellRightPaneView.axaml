<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.ShellViews.Right.InstanceInstallShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls"
    xmlns:sections="clr-namespace:PCL.Frontend.Avalonia.Desktop.ShellViews.Right.Sections"
    DataContext="{Binding Shell}">
  <UserControl.Styles>
    <Style Selector="Button.install-choice-row">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Button.install-choice-row:pointerover">
      <Setter Property="Background" Value="#14000000" />
    </Style>
  </UserControl.Styles>
  <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="25,10,25,75" Spacing="0">
        <sections:InstanceInstallHintsSection />
        <sections:InstanceInstallSelectionSummarySection />
        <sections:InstanceInstallMinecraftSection />
        <sections:InstanceInstallOptionsSection />
      </StackPanel>
    </ScrollViewer>

    <controls:PclIconTextButton
        HorizontalAlignment="Center"
        VerticalAlignment="Bottom"
        Margin="0,0,0,18"
        Command="{Binding ApplyInstanceInstallCommand}"
        IsEnabled="{Binding CanApplyInstanceInstall}"
        ColorType="Highlight"
        IconData="{Binding InstanceInstallApplyButtonIconData}"
        IconScale="{Binding InstanceInstallApplyButtonIconScale}"
        Text="{Binding InstanceInstallApplyButtonText}" />
  </Grid>
</UserControl>
