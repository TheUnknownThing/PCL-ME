<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.ShellViews.Right.SetupUiShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,10,25,10" Spacing="15">
      <controls:PclCard Header="基础" ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="10">
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,10,28">
              <TextBlock
                  VerticalAlignment="Center"
                  Foreground="#343D4A"
                  FontSize="13.5"
                  Margin="0,0,20,0"
                  Text="不透明度" />
              <Grid Grid.Column="1" ColumnDefinitions="*,60">
                <Slider
                    VerticalAlignment="Center"
                    Minimum="0"
                    Maximum="600"
                    Value="{Binding LauncherOpacity}" />
                <TextBlock
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Foreground="#677789"
                    FontSize="12"
                    Text="{Binding LauncherOpacityLabel}" />
              </Grid>

              <TextBlock
                  Grid.Row="2"
                  VerticalAlignment="Center"
                  Foreground="#343D4A"
                  FontSize="13.5"
                  Margin="0,0,20,0"
                  Text="主题" />
              <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="Auto,*,92,*,92,*">
                <ComboBox
                    Grid.Column="0"
                    ItemsSource="{Binding DarkModeOptions}"
                    SelectedIndex="{Binding SelectedDarkModeIndex}" />
                <TextBlock
                    Grid.Column="2"
                    Margin="20,0,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="#343D4A"
                    FontSize="12.5"
                    Text="浅色配色" />
                <ComboBox
                    Grid.Column="3"
                    ItemsSource="{Binding ThemeColorOptions}"
                    SelectedIndex="{Binding SelectedLightColorIndex}" />
                <TextBlock
                    Grid.Column="4"
                    Margin="20,0,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="#343D4A"
                    FontSize="12.5"
                    Text="深色配色" />
                <ComboBox
                    Grid.Column="5"
                    ItemsSource="{Binding ThemeColorOptions}"
                    SelectedIndex="{Binding SelectedDarkColorIndex}" />
              </Grid>
            </Grid>

            <Border
                Padding="18,16"
                Background="#FFF8DD"
                BorderBrush="#F2D777"
                BorderThickness="1"
                CornerRadius="5">
              <StackPanel Spacing="9">
                <TextBlock
                    Foreground="#6E5800"
                    FontSize="13"
                    Text="蓝色，蓝色，还是蓝色！想要逃离蓝色困境？请使用官方快照版！"
                    TextWrapping="Wrap" />
                <controls:PclButton
                    Width="140"
                    Height="35"
                    HorizontalAlignment="Center"
                    Command="{Binding OpenSnapshotBuildCommand}"
                    ColorType="Highlight"
                    Text="获取官方快照版" />
              </StackPanel>
            </Border>

            <CheckBox
                Foreground="#343D4A"
                Content="打开启动器时显示 PCL 图标"
                IsChecked="{Binding ShowLauncherLogoSetting}" />
            <CheckBox
                Foreground="#343D4A"
                Content="锁定启动器大小"
                IsChecked="{Binding LockWindowSizeSetting}" />
            <CheckBox
                Foreground="#343D4A"
                Content="在启动游戏时显示“你知道吗”"
                IsChecked="{Binding ShowLaunchingHintSetting}" />

            <StackPanel Spacing="10">
              <CheckBox
                  Foreground="#343D4A"
                  Content="高级材质"
                  IsChecked="{Binding EnableAdvancedMaterial}" />
              <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" RowDefinitions="Auto,10,Auto">
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="#343D4A"
                    FontSize="13"
                    Margin="0,0,20,0"
                    Text="模糊半径" />
                <Grid Grid.Column="1" ColumnDefinitions="*,42">
                  <Slider
                      VerticalAlignment="Center"
                      Minimum="0"
                      Maximum="40"
                      Value="{Binding BlurRadius}" />
                  <TextBlock
                      Grid.Column="1"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      Foreground="#677789"
                      FontSize="12"
                      Text="{Binding BlurRadiusLabel}" />
                </Grid>
                <TextBlock
                    Grid.Row="2"
                    VerticalAlignment="Center"
                    Foreground="#343D4A"
                    FontSize="13"
                    Margin="0,0,20,0"
                    Text="模糊方法" />
                <ComboBox
                    Grid.Row="2"
                    Grid.Column="1"
                    Width="120"
                    ItemsSource="{Binding BlurTypeOptions}"
                    SelectedIndex="{Binding SelectedBlurTypeIndex}" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="2"
                    Margin="20,0,10,0"
                    VerticalAlignment="Center"
                    Foreground="#343D4A"
                    FontSize="13"
                    Text="采样率" />
                <Grid Grid.Row="2" Grid.Column="3" ColumnDefinitions="*,52">
                  <Slider
                      VerticalAlignment="Center"
                      Minimum="0"
                      Maximum="100"
                      Value="{Binding BlurSamplingRate}" />
                  <TextBlock
                      Grid.Column="1"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      Foreground="#677789"
                      FontSize="12"
                      Text="{Binding BlurSamplingRateLabel}" />
                </Grid>
              </Grid>
            </StackPanel>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="字体" ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <Grid ColumnDefinitions="Auto,25,*" RowDefinitions="30,10,30">
            <TextBlock
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13.5"
                Text="全局" />
            <ComboBox
                Grid.Column="2"
                ItemsSource="{Binding FontOptions}"
                SelectedIndex="{Binding SelectedGlobalFontIndex}" />
            <TextBlock
                Grid.Row="2"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13.5"
                Text="MOTD" />
            <ComboBox
                Grid.Row="2"
                Grid.Column="2"
                ItemsSource="{Binding FontOptions}"
                SelectedIndex="{Binding SelectedMotdFontIndex}" />
          </Grid>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="背景内容" ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="8">
            <CheckBox
                Foreground="#343D4A"
                Content="游戏启动后暂停视频背景，游戏退出后重新播放"
                IsChecked="{Binding AutoPauseVideo}" />
            <CheckBox
                Foreground="#343D4A"
                Content="叠加彩色背景"
                IsChecked="{Binding BackgroundColorful}" />
            <Grid ColumnDefinitions="Auto,Auto,Auto">
              <controls:PclButton
                  Grid.Column="0"
                  Margin="0,0,20,0"
                  MinWidth="140"
                  Command="{Binding BackgroundOpenFolderCommand}"
                  Text="打开文件夹" />
              <controls:PclButton
                  Grid.Column="1"
                  Margin="0,0,20,0"
                  MinWidth="140"
                  Command="{Binding BackgroundRefreshCommand}"
                  Text="刷新背景内容" />
              <controls:PclButton
                  Grid.Column="2"
                  MinWidth="140"
                  Command="{Binding BackgroundClearCommand}"
                  ColorType="Red"
                  Text="清空背景内容" />
            </Grid>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="背景音乐" ContentMargin="25,42,25,20">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="10">
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto">
              <TextBlock
                  VerticalAlignment="Center"
                  Foreground="#343D4A"
                  FontSize="13.5"
                  Margin="0,0,20,0"
                  Text="音量" />
              <Grid Grid.Column="1" ColumnDefinitions="*,56">
                <Slider
                    VerticalAlignment="Center"
                    Minimum="0"
                    Maximum="1000"
                    Value="{Binding MusicVolume}" />
                <TextBlock
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Foreground="#677789"
                    FontSize="12"
                    Text="{Binding MusicVolumeLabel}" />
              </Grid>
            </Grid>
            <CheckBox
                Foreground="#343D4A"
                Content="随机播放"
                IsChecked="{Binding MusicRandomPlay}" />
            <CheckBox
                Foreground="#343D4A"
                Content="打开启动器自动开始播放"
                IsChecked="{Binding MusicAutoStart}" />
            <CheckBox
                Foreground="#343D4A"
                Content="游戏启动后自动开始播放，游戏退出后自动暂停播放"
                IsChecked="{Binding MusicStartOnGameLaunch}" />
            <CheckBox
                Foreground="#343D4A"
                Content="游戏启动后自动暂停播放，游戏退出后自动开始播放"
                IsChecked="{Binding MusicStopOnGameLaunch}" />
            <CheckBox
                Foreground="#343D4A"
                Content="接入系统媒体传输控制 (SMTC) 控件"
                IsChecked="{Binding MusicEnableSmtc}" />
            <Grid ColumnDefinitions="Auto,Auto,Auto">
              <controls:PclButton
                  Grid.Column="0"
                  Margin="0,0,20,0"
                  MinWidth="140"
                  Command="{Binding MusicOpenFolderCommand}"
                  Text="打开文件夹" />
              <controls:PclButton
                  Grid.Column="1"
                  Margin="0,0,20,0"
                  MinWidth="140"
                  Command="{Binding MusicRefreshCommand}"
                  Text="刷新背景音乐" />
              <controls:PclButton
                  Grid.Column="2"
                  MinWidth="140"
                  Command="{Binding MusicClearCommand}"
                  ColorType="Red"
                  Text="清空背景音乐" />
            </Grid>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="标题栏" ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="10">
            <Grid ColumnDefinitions="*,*,*,*,0.2*">
              <RadioButton
                  Grid.Column="0"
                  GroupName="LogoType"
                  Content="无"
                  IsChecked="{Binding IsLogoTypeNoneSelected}" />
              <RadioButton
                  Grid.Column="1"
                  GroupName="LogoType"
                  Content="默认"
                  IsChecked="{Binding IsLogoTypeDefaultSelected}" />
              <RadioButton
                  Grid.Column="2"
                  GroupName="LogoType"
                  Content="文本"
                  IsChecked="{Binding IsLogoTypeTextSelected}" />
              <RadioButton
                  Grid.Column="3"
                  GroupName="LogoType"
                  Content="图片"
                  IsChecked="{Binding IsLogoTypeImageSelected}" />
            </Grid>
            <CheckBox
                Foreground="#343D4A"
                Content="标题栏居左"
                IsChecked="{Binding LogoAlignLeft}"
                IsVisible="{Binding IsLogoLeftVisible}" />
            <Grid IsVisible="{Binding IsLogoTextVisible}" ColumnDefinitions="Auto,*">
              <TextBlock
                  VerticalAlignment="Center"
                  Foreground="#343D4A"
                  FontSize="13.5"
                  Margin="0,0,25,0"
                  Text="标题栏文本" />
              <TextBox
                  Grid.Column="1"
                  Height="28"
                  Padding="8,4"
                  Text="{Binding LogoTextValue}" />
            </Grid>
            <Grid IsVisible="{Binding IsLogoImageActionsVisible}" ColumnDefinitions="Auto,Auto">
              <controls:PclButton
                  Grid.Column="0"
                  Margin="0,0,20,0"
                  MinWidth="140"
                  Command="{Binding ChangeLogoImageCommand}"
                  Text="更改图片" />
              <controls:PclButton
                  Grid.Column="1"
                  MinWidth="140"
                  Command="{Binding DeleteLogoImageCommand}"
                  ColorType="Red"
                  Text="清空图片" />
            </Grid>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="主页" ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="10">
            <Grid ColumnDefinitions="*,*,*,*,0.2*">
              <RadioButton
                  Grid.Column="0"
                  GroupName="HomepageType"
                  Content="空白"
                  IsChecked="{Binding IsHomepageBlankSelected}" />
              <RadioButton
                  Grid.Column="1"
                  GroupName="HomepageType"
                  Content="预设"
                  IsChecked="{Binding IsHomepagePresetSelected}" />
              <RadioButton
                  Grid.Column="2"
                  GroupName="HomepageType"
                  Content="读取本地文件"
                  IsChecked="{Binding IsHomepageLocalSelected}" />
              <RadioButton
                  Grid.Column="3"
                  GroupName="HomepageType"
                  Content="联网更新"
                  IsChecked="{Binding IsHomepageNetSelected}" />
            </Grid>

            <Border
                Padding="12,10"
                Background="#EAF2FE"
                BorderBrush="#D5E6FD"
                BorderThickness="1"
                CornerRadius="4">
              <TextBlock
                  Foreground="#4068A8"
                  FontSize="12.5"
                  Text="内容见 ModSetup"
                  TextWrapping="Wrap" />
            </Border>
            <Border
                Padding="12,10"
                Background="#FFF8DD"
                BorderBrush="#F2D777"
                BorderThickness="1"
                CornerRadius="4">
              <TextBlock
                  Foreground="#6E5800"
                  FontSize="12.5"
                  Text="请谨慎使用陌生人提供的主页，恶意代码可能会造成损害！"
                  TextWrapping="Wrap" />
            </Border>

            <Grid IsVisible="{Binding IsHomepageLocalActionsVisible}" ColumnDefinitions="Auto,Auto,Auto">
              <controls:PclButton
                  Grid.Column="0"
                  Margin="0,0,20,0"
                  MinWidth="140"
                  Command="{Binding RefreshHomepageCommand}"
                  ColorType="Highlight"
                  Text="刷新主页" />
              <controls:PclButton
                  Grid.Column="1"
                  Margin="0,0,20,0"
                  MinWidth="140"
                  Command="{Binding GenerateHomepageTutorialFileCommand}"
                  Text="生成教学文件" />
              <controls:PclButton
                  Grid.Column="2"
                  MinWidth="140"
                  Command="{Binding ViewHomepageTutorialCommand}"
                  Text="查看教程" />
            </Grid>

            <Grid IsVisible="{Binding IsHomepageNetVisible}" ColumnDefinitions="Auto,*">
              <TextBlock
                  VerticalAlignment="Center"
                  Foreground="#343D4A"
                  FontSize="13.5"
                  Margin="0,0,25,0"
                  Text="下载地址" />
              <TextBox
                  Grid.Column="1"
                  Height="28"
                  Padding="8,4"
                  Text="{Binding HomepageUrl}" />
            </Grid>

            <Grid IsVisible="{Binding IsHomepagePresetVisible}" ColumnDefinitions="Auto,*">
              <TextBlock
                  VerticalAlignment="Center"
                  Foreground="#343D4A"
                  FontSize="13.5"
                  Margin="0,0,25,0"
                  Text="主页预设" />
              <ComboBox
                  Grid.Column="1"
                  ItemsSource="{Binding HomepagePresetOptions}"
                  SelectedIndex="{Binding SelectedHomepagePresetIndex}" />
            </Grid>

            <Grid ColumnDefinitions="Auto,Auto">
              <TextBlock
                  VerticalAlignment="Center"
                  Foreground="#343D4A"
                  FontSize="13.5"
                  Margin="0,10,0,0"
                  Text="获取更多主页" />
              <controls:PclButton
                  Grid.Column="1"
                  Margin="10,10,0,0"
                  MinWidth="140"
                  Command="{Binding OpenHomepageMarketCommand}"
                  Text="前往主页市场" />
            </Grid>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="功能隐藏" ContentMargin="25,38,20,15">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <TextBlock
                Foreground="#4B5968"
                FontSize="13"
                Text="你可以隐藏不需要的页面或关闭特定功能。在任意界面按 F12 可以暂时显示被隐藏的功能。"
                TextWrapping="Wrap" />
            <ItemsControl ItemsSource="{Binding UiFeatureToggleGroups}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <StackPanel Margin="0,0,0,12" Spacing="8">
                    <TextBlock
                        Foreground="#343D4A"
                        FontSize="13.5"
                        Text="{Binding Title}" />
                    <ItemsControl ItemsSource="{Binding Items}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <CheckBox
                              Margin="0,0,18,8"
                              Foreground="#343D4A"
                              Content="{Binding Title}"
                              IsChecked="{Binding IsChecked}" />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>
    </StackPanel>
  </ScrollViewer>
</UserControl>
