<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.ShellViews.Right.SetupUiShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,10,25,10" Spacing="15">
      <controls:PclCard Header="{Binding SetupText.Ui.BasicCardHeader}" ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="10">
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,10,Auto,10,Auto">
              <TextBlock
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource ColorBrush1}"
                  FontSize="13.5"
                  Margin="0,0,20,0"
                  Text="{Binding SetupText.Ui.LocaleLabel}" />
              <ComboBox
                  Grid.Column="1"
                  ItemsSource="{Binding LauncherLocaleOptions}"
                  SelectedIndex="{Binding SelectedLauncherLocaleIndex}" />

              <TextBlock
                  Grid.Row="2"
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource ColorBrush1}"
                  FontSize="13.5"
                  Margin="0,0,20,0"
                  Text="{Binding SetupText.Ui.LauncherOpacityLabel}" />
              <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,60">
                <Slider
                    VerticalAlignment="Center"
                    Minimum="0"
                    Maximum="600"
                    Value="{Binding LauncherOpacity}" />
                <TextBlock
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                    FontSize="12"
                    Text="{Binding LauncherOpacityLabel}" />
              </Grid>

              <TextBlock
                  Grid.Row="4"
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource ColorBrush1}"
                  FontSize="13.5"
                  Margin="0,0,20,0"
                  Text="{Binding SetupText.Ui.ThemeLabel}" />
              <StackPanel Grid.Row="4" Grid.Column="1" Spacing="8">
                <Grid ColumnDefinitions="Auto,*,92,Auto,92,Auto">
                  <ComboBox
                      Grid.Column="0"
                      ItemsSource="{Binding DarkModeOptions}"
                      SelectedIndex="{Binding SelectedDarkModeIndex}" />
                  <TextBlock
                      Grid.Column="2"
                      Margin="20,0,0,0"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      IsVisible="{Binding IsThemeColorSwitchSupported}"
                      Foreground="{DynamicResource ColorBrush1}"
                      FontSize="12.5"
                      Text="{Binding SetupText.Ui.LightPaletteLabel}" />
                  <ComboBox
                      Grid.Column="3"
                      IsVisible="{Binding IsThemeColorSwitchSupported}"
                      ItemsSource="{Binding ThemeColorOptions}"
                      SelectedIndex="{Binding SelectedLightColorIndex}" />
                  <TextBlock
                      Grid.Column="4"
                      Margin="20,0,0,0"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      IsVisible="{Binding IsThemeColorSwitchSupported}"
                      Foreground="{DynamicResource ColorBrush1}"
                      FontSize="12.5"
                      Text="{Binding SetupText.Ui.DarkPaletteLabel}" />
                  <ComboBox
                      Grid.Column="5"
                      IsVisible="{Binding IsThemeColorSwitchSupported}"
                      ItemsSource="{Binding ThemeColorOptions}"
                      SelectedIndex="{Binding SelectedDarkColorIndex}" />
                </Grid>

                <Grid
                    IsVisible="{Binding IsLightCustomThemeColorEditorVisible}"
                    ColumnDefinitions="92,*,28"
                    ColumnSpacing="10">
                  <TextBlock
                      VerticalAlignment="Center"
                      Foreground="{DynamicResource ColorBrush1}"
                      FontSize="12.5"
                      Text="{Binding SetupText.Ui.LightCustomLabel}" />
                  <TextBox
                      Grid.Column="1"
                      Watermark="{DynamicResource ThemeColorLightSampleText}"
                      Text="{Binding CustomLightThemeColorHex, UpdateSourceTrigger=PropertyChanged}" />
                  <Border
                      Grid.Column="2"
                      Width="20"
                      Height="20"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Background="{Binding CustomLightThemePreviewBrush}"
                      BorderBrush="{DynamicResource ColorBrush6}"
                      BorderThickness="1"
                      CornerRadius="10" />
                </Grid>

                <TextBlock
                    IsVisible="{Binding IsLightCustomThemeColorInvalid}"
                    Margin="102,0,0,0"
                    Foreground="{DynamicResource ColorBrushSemanticDangerForeground}"
                    FontSize="12"
                    Text="{Binding CustomThemeColorInputHint}" />

                <Grid
                    IsVisible="{Binding IsDarkCustomThemeColorEditorVisible}"
                    ColumnDefinitions="92,*,28"
                    ColumnSpacing="10">
                  <TextBlock
                      VerticalAlignment="Center"
                      Foreground="{DynamicResource ColorBrush1}"
                      FontSize="12.5"
                      Text="{Binding SetupText.Ui.DarkCustomLabel}" />
                  <TextBox
                      Grid.Column="1"
                      Watermark="{DynamicResource ThemeColorDarkSampleText}"
                      Text="{Binding CustomDarkThemeColorHex, UpdateSourceTrigger=PropertyChanged}" />
                  <Border
                      Grid.Column="2"
                      Width="20"
                      Height="20"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Background="{Binding CustomDarkThemePreviewBrush}"
                      BorderBrush="{DynamicResource ColorBrush6}"
                      BorderThickness="1"
                      CornerRadius="10" />
                </Grid>

                <TextBlock
                    IsVisible="{Binding IsDarkCustomThemeColorInvalid}"
                    Margin="102,0,0,0"
                    Foreground="{DynamicResource ColorBrushSemanticDangerForeground}"
                    FontSize="12"
                    Text="{Binding CustomThemeColorInputHint}" />

                <TextBlock
                    IsVisible="{Binding IsAnyCustomThemeColorEditorVisible}"
                    Margin="102,0,0,0"
                    Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                    FontSize="12"
                    Text="{Binding SetupText.Ui.ThemeRefreshHint}" />
              </StackPanel>
            </Grid>

            <Border
                Padding="18,16"
                IsVisible="{Binding IsThemeColorSwitchUnsupportedNoticeVisible}"
                Background="{DynamicResource ColorBrushSemanticWarningBackground}"
                BorderBrush="{DynamicResource ColorBrushSemanticWarningBorder}"
                BorderThickness="1"
                CornerRadius="5">
              <StackPanel Spacing="9">
                <TextBlock
                    Foreground="{DynamicResource ColorBrushSemanticWarningForeground}"
                    FontSize="13"
                    Text="{Binding SetupText.Ui.ThemeSwitchUnsupportedNotice}"
                    TextWrapping="Wrap" />
                <controls:PclButton
                    Width="140"
                    Height="35"
                    HorizontalAlignment="Center"
                    Command="{Binding OpenSnapshotBuildCommand}"
                    ColorType="Highlight"
                    Text="{Binding SetupText.Ui.ThemeSwitchUnsupportedAction}" />
              </StackPanel>
            </Border>

              <CheckBox
                Foreground="{DynamicResource ColorBrush1}"
                Content="{Binding SetupText.Ui.ShowLauncherLogoLabel}"
                IsChecked="{Binding ShowLauncherLogoSetting}" />
            <CheckBox
                Foreground="{DynamicResource ColorBrush1}"
                Content="{Binding SetupText.Ui.LockWindowSizeLabel}"
                IsChecked="{Binding LockWindowSizeSetting}" />
            <CheckBox
                Foreground="{DynamicResource ColorBrush1}"
                Content="{Binding SetupText.Ui.ShowLaunchingHintLabel}"
                IsChecked="{Binding ShowLaunchingHintSetting}" />
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="{Binding SetupText.Ui.FontCardHeader}" ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <Grid ColumnDefinitions="Auto,25,*" RowDefinitions="30,10,30">
            <TextBlock
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13.5"
                Text="{Binding SetupText.Ui.GlobalFontLabel}" />
            <ComboBox
                Grid.Column="2"
                ItemsSource="{Binding FontOptions}"
                SelectedIndex="{Binding SelectedGlobalFontIndex}" />
            <TextBlock
                Grid.Row="2"
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13.5"
                Text="{Binding SetupText.Ui.MotdFontLabel}" />
            <ComboBox
                Grid.Row="2"
                Grid.Column="2"
                ItemsSource="{Binding FontOptions}"
                SelectedIndex="{Binding SelectedMotdFontIndex}" />
          </Grid>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="{Binding BackgroundCardHeader}" ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="8">
            <Grid IsVisible="{Binding ShowBackgroundAdvancedSettings}" ColumnDefinitions="Auto,*">
              <TextBlock
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource ColorBrush1}"
                  FontSize="13.5"
                  Margin="0,0,20,0"
                  Text="{Binding SetupText.Ui.BackgroundAdaptLabel}" />
              <ComboBox
                  Grid.Column="1"
                  ItemsSource="{Binding BackgroundSuitOptions}"
                  SelectedIndex="{Binding SelectedBackgroundSuitIndex}" />
            </Grid>
            <Grid IsVisible="{Binding ShowBackgroundAdvancedSettings}" ColumnDefinitions="Auto,*">
              <TextBlock
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource ColorBrush1}"
                  FontSize="13.5"
                  Margin="0,0,20,0"
                  Text="{Binding SetupText.Ui.BackgroundOpacityLabel}" />
              <Grid Grid.Column="1" ColumnDefinitions="*,56">
                <Slider
                    VerticalAlignment="Center"
                    Minimum="0"
                    Maximum="1000"
                    Value="{Binding BackgroundOpacity}" />
                <TextBlock
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                    FontSize="12"
                    Text="{Binding BackgroundOpacityLabel}" />
              </Grid>
            </Grid>
            <Grid IsVisible="{Binding ShowBackgroundAdvancedSettings}" ColumnDefinitions="Auto,*">
              <TextBlock
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource ColorBrush1}"
                  FontSize="13.5"
                  Margin="0,0,20,0"
                  Text="{Binding SetupText.Ui.BackgroundBlurLabel}" />
              <Grid Grid.Column="1" ColumnDefinitions="*,56">
                <Slider
                    VerticalAlignment="Center"
                    Minimum="0"
                    Maximum="40"
                    Value="{Binding BackgroundBlur}" />
                <TextBlock
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                    FontSize="12"
                    Text="{Binding BackgroundBlurLabel}" />
              </Grid>
            </Grid>
            <CheckBox
                Foreground="{DynamicResource ColorBrush1}"
                Content="{Binding SetupText.Ui.BackgroundColorfulLabel}"
                IsChecked="{Binding BackgroundColorful}" />
            <Grid ColumnDefinitions="Auto,Auto,Auto">
              <controls:PclButton
                  Grid.Column="0"
                  Margin="0,0,20,0"
                  MinWidth="140"
                  Command="{Binding BackgroundOpenFolderCommand}"
                  Text="{Binding SetupText.Ui.BackgroundOpenFolderButton}" />
              <controls:PclButton
                  Grid.Column="1"
                  Margin="0,0,20,0"
                  MinWidth="140"
                  Command="{Binding BackgroundRefreshCommand}"
                  Text="{Binding SetupText.Ui.BackgroundRefreshButton}" />
              <controls:PclButton
                  Grid.Column="2"
                  MinWidth="140"
                  Command="{Binding BackgroundClearCommand}"
                  IsVisible="{Binding ShowBackgroundClearAction}"
                  ColorType="Red"
                  Text="{Binding SetupText.Ui.BackgroundClearButton}" />
            </Grid>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="{Binding SetupText.Ui.MusicCardHeader}" ContentMargin="25,42,25,20">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="10">
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto">
              <TextBlock
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource ColorBrush1}"
                  FontSize="13.5"
                  Margin="0,0,20,0"
                  Text="{Binding SetupText.Ui.MusicVolumeLabel}" />
              <Grid Grid.Column="1" ColumnDefinitions="*,56">
                <Slider
                    VerticalAlignment="Center"
                    Minimum="0"
                    Maximum="1000"
                    Value="{Binding MusicVolume}" />
                <TextBlock
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                    FontSize="12"
                    Text="{Binding MusicVolumeLabel}" />
              </Grid>
            </Grid>
            <CheckBox
                Foreground="{DynamicResource ColorBrush1}"
                Content="{Binding SetupText.Ui.MusicRandomLabel}"
                IsChecked="{Binding MusicRandomPlay}" />
            <CheckBox
                Foreground="{DynamicResource ColorBrush1}"
                Content="{Binding SetupText.Ui.MusicAutoStartLabel}"
                IsChecked="{Binding MusicAutoStart}" />
            <CheckBox
                Foreground="{DynamicResource ColorBrush1}"
                Content="{Binding SetupText.Ui.MusicStartOnLaunchLabel}"
                IsChecked="{Binding MusicStartOnGameLaunch}" />
            <CheckBox
                Foreground="{DynamicResource ColorBrush1}"
                Content="{Binding SetupText.Ui.MusicStopOnLaunchLabel}"
                IsChecked="{Binding MusicStopOnGameLaunch}" />
            <CheckBox
                Foreground="{DynamicResource ColorBrush1}"
                Content="{Binding SetupText.Ui.MusicEnableSmtcLabel}"
                IsChecked="{Binding MusicEnableSmtc}" />
            <Grid ColumnDefinitions="Auto,Auto,Auto">
              <controls:PclButton
                  Grid.Column="0"
                  Margin="0,0,20,0"
                  MinWidth="140"
                  Command="{Binding MusicOpenFolderCommand}"
                  Text="{Binding SetupText.Ui.MusicOpenFolderButton}" />
              <controls:PclButton
                  Grid.Column="1"
                  Margin="0,0,20,0"
                  MinWidth="140"
                  Command="{Binding MusicRefreshCommand}"
                  Text="{Binding SetupText.Ui.MusicRefreshButton}" />
              <controls:PclButton
                  Grid.Column="2"
                  MinWidth="140"
                  Command="{Binding MusicClearCommand}"
                  ColorType="Red"
                  Text="{Binding SetupText.Ui.MusicClearButton}" />
            </Grid>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="{Binding SetupText.Ui.TitleBarCardHeader}" ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="10">
            <Grid ColumnDefinitions="*,*,*,*,0.2*">
              <RadioButton
                  Grid.Column="0"
                  GroupName="LogoType"
                  Content="{Binding SetupText.Ui.LogoTypeNoneLabel}"
                  IsChecked="{Binding IsLogoTypeNoneSelected}" />
              <RadioButton
                  Grid.Column="1"
                  GroupName="LogoType"
                  Content="{Binding SetupText.Ui.LogoTypeDefaultLabel}"
                  IsChecked="{Binding IsLogoTypeDefaultSelected}" />
              <RadioButton
                  Grid.Column="2"
                  GroupName="LogoType"
                  Content="{Binding SetupText.Ui.LogoTypeTextLabel}"
                  IsChecked="{Binding IsLogoTypeTextSelected}" />
              <RadioButton
                  Grid.Column="3"
                  GroupName="LogoType"
                  Content="{Binding SetupText.Ui.LogoTypeImageLabel}"
                  IsChecked="{Binding IsLogoTypeImageSelected}" />
            </Grid>
            <CheckBox
                Foreground="{DynamicResource ColorBrush1}"
                Content="{Binding SetupText.Ui.LogoAlignLeftLabel}"
                IsChecked="{Binding LogoAlignLeft}"
                IsVisible="{Binding IsLogoLeftVisible}" />
            <Grid IsVisible="{Binding IsLogoTextVisible}" ColumnDefinitions="Auto,*">
              <TextBlock
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource ColorBrush1}"
                  FontSize="13.5"
                  Margin="0,0,25,0"
                  Text="{Binding SetupText.Ui.LogoTextLabel}" />
              <TextBox
                  Grid.Column="1"
                  Height="28"
                  Padding="8,4"
                  Text="{Binding LogoTextValue}" />
            </Grid>
            <Grid IsVisible="{Binding IsLogoImageActionsVisible}" ColumnDefinitions="Auto,Auto">
              <controls:PclButton
                  Grid.Column="0"
                  Margin="0,0,20,0"
                  MinWidth="140"
                  Command="{Binding ChangeLogoImageCommand}"
                  Text="{Binding SetupText.Ui.ChangeLogoImageButton}" />
              <controls:PclButton
                  Grid.Column="1"
                  MinWidth="140"
                  Command="{Binding DeleteLogoImageCommand}"
                  ColorType="Red"
                  Text="{Binding SetupText.Ui.ClearLogoImageButton}" />
            </Grid>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="{Binding SetupText.Ui.HomepageCardHeader}" ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="10">
            <Grid ColumnDefinitions="*,*,*,*,0.2*">
              <RadioButton
                  Grid.Column="0"
                  GroupName="HomepageType"
                  Content="{Binding SetupText.Ui.HomepageTypeBlankLabel}"
                  IsChecked="{Binding IsHomepageBlankSelected}" />
              <RadioButton
                  Grid.Column="1"
                  GroupName="HomepageType"
                  Content="{Binding SetupText.Ui.HomepageTypePresetLabel}"
                  IsChecked="{Binding IsHomepagePresetSelected}" />
              <RadioButton
                  Grid.Column="2"
                  GroupName="HomepageType"
                  Content="{Binding SetupText.Ui.HomepageTypeLocalLabel}"
                  IsChecked="{Binding IsHomepageLocalSelected}" />
              <RadioButton
                  Grid.Column="3"
                  GroupName="HomepageType"
                  Content="{Binding SetupText.Ui.HomepageTypeRemoteLabel}"
                  IsChecked="{Binding IsHomepageNetSelected}" />
            </Grid>

            <Border
                Padding="12,10"
                Background="{DynamicResource ColorBrush8}"
                BorderBrush="{DynamicResource ColorBrush6}"
                BorderThickness="1"
                CornerRadius="4">
              <TextBlock
                  Foreground="{DynamicResource ColorBrushEntrySecondarySelected}"
                  FontSize="12.5"
                  Text="{Binding SetupText.Ui.HomepagePresetNotice}"
                  TextWrapping="Wrap" />
            </Border>
            <Border
                Padding="12,10"
                Background="{DynamicResource ColorBrushSemanticWarningBackground}"
                BorderBrush="{DynamicResource ColorBrushSemanticWarningBorder}"
                BorderThickness="1"
                CornerRadius="4">
              <TextBlock
                  Foreground="{DynamicResource ColorBrushSemanticWarningForeground}"
                  FontSize="12.5"
                  Text="{Binding SetupText.Ui.HomepageSecurityWarning}"
                  TextWrapping="Wrap" />
            </Border>

            <Grid IsVisible="{Binding IsHomepageLocalActionsVisible}" ColumnDefinitions="Auto,Auto,Auto">
              <controls:PclButton
                  Grid.Column="0"
                  Margin="0,0,20,0"
                  MinWidth="140"
                  Command="{Binding RefreshHomepageCommand}"
                  ColorType="Highlight"
                  Text="{Binding SetupText.Ui.HomepageRefreshButton}" />
              <controls:PclButton
                  Grid.Column="1"
                  Margin="0,0,20,0"
                  MinWidth="140"
                  Command="{Binding GenerateHomepageTutorialFileCommand}"
                  Text="{Binding SetupText.Ui.HomepageGenerateTutorialButton}" />
              <controls:PclButton
                  Grid.Column="2"
                  MinWidth="140"
                  Command="{Binding ViewHomepageTutorialCommand}"
                  Text="{Binding SetupText.Ui.HomepageViewTutorialButton}" />
            </Grid>

            <Grid IsVisible="{Binding IsHomepageNetVisible}" ColumnDefinitions="Auto,*">
              <TextBlock
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource ColorBrush1}"
                  FontSize="13.5"
                  Margin="0,0,25,0"
                  Text="{Binding SetupText.Ui.HomepageUrlLabel}" />
              <TextBox
                  Grid.Column="1"
                  Height="28"
                  Padding="8,4"
                  Text="{Binding HomepageUrl}" />
            </Grid>

            <Grid IsVisible="{Binding IsHomepagePresetVisible}" ColumnDefinitions="Auto,*">
              <TextBlock
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource ColorBrush1}"
                  FontSize="13.5"
                  Margin="0,0,25,0"
                  Text="{Binding SetupText.Ui.HomepagePresetLabel}" />
              <ComboBox
                  Grid.Column="1"
                  ItemsSource="{Binding HomepagePresetOptions}"
                  SelectedIndex="{Binding SelectedHomepagePresetIndex}" />
            </Grid>

          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="{Binding UiFeatureHiddenCardHeader}" ContentMargin="25,38,20,15" IsVisible="{Binding ShowUiFeatureHiddenCard}">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <TextBlock
                Foreground="{DynamicResource ColorBrushEntrySecondarySelected}"
                FontSize="13"
                Text="{Binding SetupText.Ui.HiddenFeaturesHint}"
                TextWrapping="Wrap" />
            <ItemsControl ItemsSource="{Binding UiFeatureToggleGroups}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <StackPanel Margin="0,0,0,12" Spacing="8">
                    <TextBlock
                        Foreground="{DynamicResource ColorBrush1}"
                        FontSize="13.5"
                        Text="{Binding Title}" />
                    <ItemsControl ItemsSource="{Binding Items}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <CheckBox
                              Margin="0,0,18,8"
                              Foreground="{DynamicResource ColorBrush1}"
                              Content="{Binding Title}"
                              IsChecked="{Binding IsChecked}" />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>
    </StackPanel>
  </ScrollViewer>
</UserControl>
