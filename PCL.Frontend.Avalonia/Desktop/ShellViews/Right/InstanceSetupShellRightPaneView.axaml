<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.ShellViews.Right.InstanceSetupShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls"
    xmlns:sections="clr-namespace:PCL.Frontend.Avalonia.Desktop.ShellViews.Right.Sections"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,25,25,25" Spacing="15">
      <Border
          Padding="12,10"
          Background="{DynamicResource ColorBrush8}"
          BorderBrush="{DynamicResource ColorBrush6}"
          BorderThickness="1"
          CornerRadius="4">
        <TextBlock
            Foreground="{DynamicResource ColorBrush2}"
            FontSize="12.5"
            Text="{Binding InstanceSetupIntroText}"
            TextWrapping="Wrap" />
      </Border>

      <sections:InstanceSetupLaunchOptionsSection />
      <sections:InstanceSetupMemorySection />
      <sections:InstanceSetupServerSection />
      <sections:InstanceSetupAdvancedLaunchSection />

      <controls:PclButton
          Width="140"
          HorizontalAlignment="Center"
          Command="{Binding OpenGlobalLaunchSettingsCommand}"
          Text="{Binding InstanceSetupOpenGlobalSettingsText}" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
