<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.ShellViews.Right.InstanceOverviewShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sections="clr-namespace:PCL.Frontend.Avalonia.Desktop.ShellViews.Right.Sections"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,10,25,15" Spacing="15">
      <sections:InstanceOverviewHeroSection />
      <sections:InstanceOverviewInfoSection />
      <sections:InstanceOverviewPersonalizationSection />
      <sections:InstanceOverviewShortcutsSection />
      <sections:InstanceOverviewAdvancedActionsSection />
    </StackPanel>
  </ScrollViewer>
</UserControl>
