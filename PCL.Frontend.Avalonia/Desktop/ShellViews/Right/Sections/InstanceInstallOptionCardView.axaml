<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.ShellViews.Right.Sections.InstanceInstallOptionCardView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls">
  <controls:PclCard
      Margin="0,0,0,15"
      Header="{Binding Title}"
      ShowChevron="{Binding CanExpand}"
      IsChevronExpanded="{Binding IsExpanded}"
      HeaderCommand="{Binding ToggleCommand}"
      ContentMargin="{Binding CardContentMargin}">
    <controls:PclCard.HeaderOverlayContent>
      <Grid
          Height="30"
          Margin="132,5,15,0"
          VerticalAlignment="Top"
          ColumnDefinitions="Auto,*">
        <Border
            Width="18"
            Height="18"
            Margin="0,0,7,0"
            VerticalAlignment="Center"
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            CornerRadius="5"
            IsHitTestVisible="False"
            IsVisible="{Binding ShowIcon}">
          <Image Source="{Binding Icon}" Stretch="Uniform" Margin="3" />
        </Border>
        <TextBlock
            Grid.Column="1"
            Margin="0,0,12,0"
            IsHitTestVisible="False"
            VerticalAlignment="Center"
            Foreground="{Binding SelectionForegroundBrush}"
            FontSize="13"
            Text="{Binding SelectionText}"
            TextTrimming="CharacterEllipsis" />
      </Grid>
    </controls:PclCard.HeaderOverlayContent>
    <controls:PclCard.CardContent>
      <StackPanel IsVisible="{Binding CanExpand}" Spacing="8">
        <TextBlock
            IsVisible="{Binding IsLoading}"
            Margin="0,2,0,8"
            Foreground="#677789"
            FontSize="12"
            Text="{Binding LoadingText}" />

        <TextBlock
            IsVisible="{Binding ShowEmptyState}"
            Margin="0,2,0,8"
            Foreground="#677789"
            FontSize="12"
            Text="{Binding EmptyStateText}"
            TextWrapping="Wrap" />

        <ItemsControl ItemsSource="{Binding Choices}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <controls:PclListItem
                  HorizontalAlignment="Stretch"
                  Margin="0"
                  Command="{Binding SelectCommand}"
                  IconSource="{Binding Icon}"
                  Info="{Binding Summary}"
                  IsSelected="{Binding IsSelected}"
                  Title="{Binding Title}" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </controls:PclCard.CardContent>
  </controls:PclCard>
</UserControl>
