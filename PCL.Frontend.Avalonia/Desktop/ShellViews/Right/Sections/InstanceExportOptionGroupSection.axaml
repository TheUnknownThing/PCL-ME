<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.ShellViews.Right.Sections.InstanceExportOptionGroupSection"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel Margin="0,0,0,2">
    <CheckBox
        MinHeight="26"
        Foreground="#343D4A"
        IsChecked="{Binding Header.IsChecked}">
      <TextBlock TextWrapping="Wrap">
        <Run Text="{Binding Header.Title}" />
        <Run Foreground="#7D8897" Text="{Binding Header.InlineDescription}" />
      </TextBlock>
    </CheckBox>

    <ItemsControl ItemsSource="{Binding Children}" IsVisible="{Binding Header.IsChecked, FallbackValue=False}">
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <CheckBox
              MinHeight="26"
              Margin="30,0,0,0"
              Foreground="#343D4A"
              IsChecked="{Binding IsChecked}">
            <TextBlock TextWrapping="Wrap">
              <Run Text="{Binding Title}" />
              <Run Foreground="#7D8897" Text="{Binding InlineDescription}" />
            </TextBlock>
          </CheckBox>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </StackPanel>
</UserControl>
