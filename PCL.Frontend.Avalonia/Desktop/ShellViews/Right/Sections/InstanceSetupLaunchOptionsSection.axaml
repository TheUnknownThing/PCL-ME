<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.ShellViews.Right.Sections.InstanceSetupLaunchOptionsSection"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls">
  <controls:PclCard Header="启动选项" ContentMargin="20,40,20,18">
    <controls:PclCard.CardContent>
      <Grid ColumnDefinitions="Auto,*" RowDefinitions="28,9,28,9,Auto,9,28,9,28">
        <TextBlock
            Grid.Row="0"
            Margin="0,0,25,0"
            VerticalAlignment="Center"
            Foreground="#343D4A"
            FontSize="13"
            Text="版本隔离" />
        <ComboBox
            Grid.Row="0"
            Grid.Column="1"
            ItemsSource="{Binding InstanceIsolationOptions}"
            SelectedIndex="{Binding SelectedInstanceIsolationIndex}" />

        <TextBlock
            Grid.Row="2"
            Margin="0,0,25,0"
            VerticalAlignment="Center"
            Foreground="#343D4A"
            FontSize="13"
            Text="游戏窗口标题" />
        <TextBox
            Grid.Row="2"
            Grid.Column="1"
            Text="{Binding InstanceWindowTitleSetting}" />

        <CheckBox
            Grid.Row="4"
            Grid.ColumnSpan="2"
            Foreground="#343D4A"
            Content="默认窗口标题"
            IsChecked="{Binding UseDefaultInstanceWindowTitle}" />

        <TextBlock
            Grid.Row="6"
            Margin="0,0,25,0"
            VerticalAlignment="Center"
            Foreground="#343D4A"
            FontSize="13"
            Text="自定义信息" />
        <Grid Grid.Row="6" Grid.Column="1" ColumnDefinitions="*,Auto">
          <TextBox
              Grid.Column="0"
              Text="{Binding InstanceCustomInfoSetting}" />
        </Grid>

        <TextBlock
            Grid.Row="8"
            Margin="0,0,25,0"
            VerticalAlignment="Center"
            Foreground="#343D4A"
            FontSize="13"
            Text="游戏 Java" />
        <ComboBox
            Grid.Row="8"
            Grid.Column="1"
            ItemsSource="{Binding InstanceJavaOptions}"
            SelectedIndex="{Binding SelectedInstanceJavaIndex}" />
      </Grid>
    </controls:PclCard.CardContent>
  </controls:PclCard>
</UserControl>
