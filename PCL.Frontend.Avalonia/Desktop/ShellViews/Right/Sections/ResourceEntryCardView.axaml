<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.ShellViews.Right.Sections.ResourceEntryCardView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls">
  <Grid Margin="0,0,0,12" ColumnDefinitions="Auto,Auto,*,Auto">
    <CheckBox
        Margin="0,0,12,0"
        VerticalAlignment="Center"
        IsChecked="{Binding IsSelected, Mode=TwoWay}"
        IsVisible="{Binding ShowSelection}" />

    <Image
        Grid.Column="1"
        Width="28"
        Height="28"
        Margin="0,0,12,0"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Source="{Binding Icon}"
        Stretch="Uniform" />

    <StackPanel Grid.Column="2" Margin="0,0,12,0" Spacing="3" Opacity="{Binding ContentOpacity}">
      <TextBlock
          Foreground="{Binding TitleForeground}"
          FontSize="13.5"
          Text="{Binding Title}" />
      <TextBlock
          Foreground="#677789"
          FontSize="12.5"
          Text="{Binding Info}"
          TextWrapping="Wrap" />
      <Border
          Padding="8,4"
          Background="#F7FAFE"
          BorderBrush="#D5E6FD"
          BorderThickness="1"
          CornerRadius="4">
        <TextBlock
            Foreground="#4B78C2"
            FontSize="11.5"
            Text="{Binding Meta}" />
      </Border>
    </StackPanel>

    <controls:PclButton
        Grid.Column="3"
        Width="96"
        Height="35"
        VerticalAlignment="Center"
        Command="{Binding ActionCommand}"
        Text="查看" />
  </Grid>
</UserControl>
