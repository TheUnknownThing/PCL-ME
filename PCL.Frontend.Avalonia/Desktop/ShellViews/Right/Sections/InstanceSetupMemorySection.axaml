<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.ShellViews.Right.Sections.InstanceSetupMemorySection"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls">
  <controls:PclCard Header="游戏内存" ContentMargin="20,40,20,18">
    <controls:PclCard.CardContent>
      <StackPanel Spacing="12">
        <Border
            Padding="12,10"
            Background="#FFF8DD"
            BorderBrush="#F2D777"
            BorderThickness="1"
            CornerRadius="4"
            IsVisible="{Binding ShowInstance32BitJavaWarning}">
          <TextBlock
              Foreground="#6E5800"
              FontSize="12.5"
              Text="32 位 Java 只能分配最多 1 GB 的内存。强烈建议换用 64 位的 Java！"
              TextWrapping="Wrap" />
        </Border>

        <Border
            Padding="12,10"
            Background="#FFF8DD"
            BorderBrush="#F2D777"
            BorderThickness="1"
            CornerRadius="4"
            IsVisible="{Binding ShowRamAllocationWarning}">
          <TextBlock
              Foreground="#6E5800"
              FontSize="12.5"
              Text="你给游戏分配的内存过多，这可能引发游戏崩溃。建议优先考虑“自动分配”选项。"
              TextWrapping="Wrap" />
        </Border>

        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
          <RadioButton
              Grid.Row="0"
              Content="跟随全局设置"
              GroupName="instance-ram"
              IsChecked="{Binding UseGlobalInstanceRamAllocation}" />
          <RadioButton
              Grid.Row="1"
              Content="自动配置"
              GroupName="instance-ram"
              IsChecked="{Binding UseAutomaticInstanceRamAllocation}" />
          <RadioButton
              Grid.Row="2"
              Content="自定义"
              GroupName="instance-ram"
              IsChecked="{Binding UseCustomInstanceRamAllocation}" />
          <Grid Grid.Row="2" Grid.Column="1" Margin="18,0,0,0" ColumnDefinitions="*,72">
            <Slider
                VerticalAlignment="Center"
                Minimum="1"
                Maximum="32"
                IsEnabled="{Binding IsInstanceCustomRamAllocationEnabled}"
                Value="{Binding InstanceCustomRamAllocation}" />
            <TextBlock
                Grid.Column="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Foreground="#4B5968"
                FontSize="12.5"
                Text="{Binding InstanceCustomRamAllocationLabel}" />
          </Grid>
        </Grid>

        <Grid ColumnDefinitions="Auto,*" RowDefinitions="28">
          <TextBlock
              Margin="0,0,25,0"
              VerticalAlignment="Center"
              Foreground="#343D4A"
              FontSize="13"
              Text="启动游戏前进行内存优化" />
          <ComboBox
              Grid.Column="1"
              ItemsSource="{Binding InstanceMemoryOptimizeOptions}"
              SelectedIndex="{Binding SelectedInstanceMemoryOptimizeIndex}" />
        </Grid>

        <Border
            Padding="12,12"
            Background="#F7FAFE"
            BorderBrush="#D5E6FD"
            BorderThickness="1"
            CornerRadius="6">
          <StackPanel Spacing="8">
            <Grid Height="6">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding InstanceUsedRamBarWidth}" />
                <ColumnDefinition Width="{Binding InstanceAllocatedRamBarWidth}" />
                <ColumnDefinition Width="{Binding InstanceFreeRamBarWidth}" />
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0" Background="#58C86F" CornerRadius="3,0,0,3" />
              <Border Grid.Column="1" Background="#86B6FF" />
              <Border Grid.Column="2" Background="#D5DCE5" CornerRadius="0,3,3,0" />
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock
                  Foreground="#4B5968"
                  FontSize="12"
                  Text="已使用内存" />
              <TextBlock
                  Foreground="#2F8F45"
                  FontSize="16"
                  Text="{Binding InstanceUsedRamLabel}" />
              <TextBlock
                  Foreground="#4B5968"
                  FontSize="16"
                  Text="{Binding InstanceTotalRamLabel}" />
            </StackPanel>
            <TextBlock
                Foreground="#4C78C2"
                FontSize="16"
                Text="{Binding InstanceAllocatedRamLabel}" />
          </StackPanel>
        </Border>
      </StackPanel>
    </controls:PclCard.CardContent>
  </controls:PclCard>
</UserControl>
