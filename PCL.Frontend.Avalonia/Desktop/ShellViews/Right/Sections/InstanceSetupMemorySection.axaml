<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.ShellViews.Right.Sections.InstanceSetupMemorySection"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls">
  <controls:PclCard Header="{Binding InstanceSetupMemoryHeaderText}" ContentMargin="20,40,20,18">
    <controls:PclCard.CardContent>
      <StackPanel Spacing="12">
        <Border
            Padding="12,10"
            Background="{DynamicResource ColorBrushSemanticWarningBackground}"
            BorderBrush="{DynamicResource ColorBrushSemanticWarningBorder}"
            BorderThickness="1"
            CornerRadius="4"
            IsVisible="{Binding ShowInstance32BitJavaWarning}">
          <TextBlock
              Foreground="{DynamicResource ColorBrushSemanticWarningForeground}"
              FontSize="12.5"
              Text="{Binding InstanceSetupMemory32BitWarningText}"
              TextWrapping="Wrap" />
        </Border>

        <Border
            Padding="12,10"
            Background="{DynamicResource ColorBrushSemanticWarningBackground}"
            BorderBrush="{DynamicResource ColorBrushSemanticWarningBorder}"
            BorderThickness="1"
            CornerRadius="4"
            IsVisible="{Binding ShowInstanceRamAllocationWarning}">
          <TextBlock
              Foreground="{DynamicResource ColorBrushSemanticWarningForeground}"
              FontSize="12.5"
              Text="{Binding InstanceSetupMemoryAllocationWarningText}"
              TextWrapping="Wrap" />
        </Border>

        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
          <RadioButton
              Grid.Row="0"
              Content="{Binding InstanceSetupMemoryUseGlobalText}"
              GroupName="instance-ram"
              IsChecked="{Binding UseGlobalInstanceRamAllocation}" />
          <RadioButton
              Grid.Row="1"
              Content="{Binding InstanceSetupMemoryUseAutoText}"
              GroupName="instance-ram"
              IsChecked="{Binding UseAutomaticInstanceRamAllocation}" />
          <RadioButton
              Grid.Row="2"
              Content="{Binding InstanceSetupMemoryUseCustomText}"
              GroupName="instance-ram"
              IsChecked="{Binding UseCustomInstanceRamAllocation}" />
          <Grid Grid.Row="2" Grid.Column="1" Margin="18,0,0,0" ColumnDefinitions="*,72">
            <Slider
                VerticalAlignment="Center"
                Minimum="1"
                Maximum="32"
                IsEnabled="{Binding IsInstanceCustomRamAllocationEnabled}"
                Value="{Binding InstanceCustomRamAllocation}" />
            <TextBlock
                Grid.Column="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                FontSize="12.5"
                Text="{Binding InstanceCustomRamAllocationLabel}" />
          </Grid>
        </Grid>

        <Grid ColumnDefinitions="Auto,*" RowDefinitions="28">
          <TextBlock
              Margin="0,0,25,0"
              VerticalAlignment="Center"
              Foreground="{DynamicResource ColorBrush1}"
              FontSize="13"
              Text="{Binding InstanceSetupMemoryOptimizeLabelText}" />
          <ComboBox
              Grid.Column="1"
              ItemsSource="{Binding InstanceMemoryOptimizeOptions}"
              SelectedIndex="{Binding SelectedInstanceMemoryOptimizeIndex}" />
        </Grid>

        <controls:PclMemorySummary
            UsedBarWidth="{Binding InstanceUsedRamBarWidth}"
            AllocatedBarWidth="{Binding InstanceAllocatedRamBarWidth}"
            FreeBarWidth="{Binding InstanceFreeRamBarWidth}"
            UsedRamLabel="{Binding InstanceUsedRamLabel}"
            TotalRamLabel="{Binding InstanceTotalRamLabel}"
            AllocatedRamLabel="{Binding InstanceAllocatedRamLabel}" />
      </StackPanel>
    </controls:PclCard.CardContent>
  </controls:PclCard>
</UserControl>
