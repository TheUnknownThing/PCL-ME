<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.ShellViews.Right.Sections.InstanceSetupServerSection"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls">
  <controls:PclCard Header="{Binding InstanceSetupServerHeaderText}" ContentMargin="20,40,20,18">
    <controls:PclCard.CardContent>
      <StackPanel Spacing="12">
        <Border
            Padding="12,10"
            Background="{DynamicResource ColorBrushSemanticDangerBackground}"
            BorderBrush="{DynamicResource ColorBrushSemanticDangerBorder}"
            BorderThickness="1"
            CornerRadius="4"
            IsVisible="{Binding ShowInstanceServerLoginLockedWarning}">
          <TextBlock
              Foreground="{DynamicResource ColorBrushSemanticDangerForeground}"
              FontSize="12.5"
              Text="{Binding InstanceSetupServerLockedWarningText}"
              TextWrapping="Wrap" />
        </Border>
        <Grid ColumnDefinitions="Auto,*" RowDefinitions="28,Auto,9,28">
          <TextBlock
              Grid.Row="0"
              Margin="0,0,25,0"
              VerticalAlignment="Center"
              Foreground="{DynamicResource ColorBrush1}"
              FontSize="13"
              Text="{Binding InstanceSetupServerLoginRequirementLabelText}" />
          <ComboBox
              Grid.Row="0"
              Grid.Column="1"
              IsEnabled="{Binding IsInstanceServerLoginEditable}"
              ItemsSource="{Binding InstanceServerLoginRequireOptions}"
              SelectedIndex="{Binding SelectedInstanceServerLoginRequireIndex}" />

          <Grid
              Grid.Row="1"
              Grid.ColumnSpan="2"
              Margin="0,8,0,0"
              IsVisible="{Binding ShowInstanceServerAuthFields}"
              ColumnDefinitions="Auto,*"
              RowDefinitions="28,9,28,9,28">
            <TextBlock
                Margin="0,0,25,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13"
                Text="{Binding InstanceSetupServerAuthServerLabelText}" />
            <TextBox
                Grid.Column="1"
                IsEnabled="{Binding IsInstanceServerAuthEditable}"
                Text="{Binding InstanceServerAuthServer}" />

            <TextBlock
                Grid.Row="2"
                Margin="0,0,25,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13"
                Text="{Binding InstanceSetupServerAuthRegisterLabelText}" />
            <TextBox
                Grid.Row="2"
                Grid.Column="1"
                IsEnabled="{Binding IsInstanceServerAuthEditable}"
                Text="{Binding InstanceServerAuthRegister}" />

            <TextBlock
                Grid.Row="4"
                Margin="0,0,25,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13"
                Text="{Binding InstanceSetupServerAuthNameLabelText}" />
            <TextBox
                Grid.Row="4"
                Grid.Column="1"
                IsEnabled="{Binding IsInstanceServerAuthEditable}"
                Text="{Binding InstanceServerAuthName}" />
          </Grid>

          <TextBlock
              Grid.Row="3"
              Margin="0,0,25,0"
              VerticalAlignment="Center"
              Foreground="{DynamicResource ColorBrush1}"
              FontSize="13"
              Text="{Binding InstanceSetupServerAutoJoinLabelText}" />
          <TextBox
              Grid.Row="3"
              Grid.Column="1"
              Text="{Binding InstanceServerAutoJoin}" />
        </Grid>

        <Grid ColumnDefinitions="Auto,Auto,Auto" IsVisible="{Binding ShowInstanceServerProfileActions}">
          <controls:PclButton
              Grid.Column="0"
              MinWidth="150"
              Margin="0,0,20,0"
              ColorType="Highlight"
              Command="{Binding SetLittleSkinCommand}"
              IsEnabled="{Binding IsInstanceServerAuthEditable}"
              Text="{Binding InstanceSetupServerSetLittleSkinText}" />
          <controls:PclButton
              Grid.Column="1"
              MinWidth="150"
              Margin="0,0,20,0"
              Command="{Binding LockInstanceLoginCommand}"
              IsEnabled="{Binding CanLockInstanceLogin}"
              IsVisible="{Binding ShowInstanceServerLockAction}"
              Text="{Binding InstanceSetupServerLockLoginText}" />
          <controls:PclButton
              Grid.Column="2"
              MinWidth="150"
              Command="{Binding CreateInstanceProfileCommand}"
              IsEnabled="{Binding CanCreateInstanceProfile}"
              Text="{Binding InstanceSetupServerCreateProfileText}" />
        </Grid>
      </StackPanel>
    </controls:PclCard.CardContent>
  </controls:PclCard>
</UserControl>
