<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.ShellViews.Right.Sections.InstanceResourceEntriesSection"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls"
    xmlns:sections="clr-namespace:PCL.Frontend.Avalonia.Desktop.ShellViews.Right.Sections">
  <controls:PclCard Header=" " MinHeight="55" ContentMargin="20,48,18,22" IsVisible="{Binding ShowInstanceResourceContent}">
    <controls:PclCard.HeaderOverlayContent>
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel
            Margin="15,13,0,0"
            Orientation="Horizontal"
            HorizontalAlignment="Left"
            Height="28"
            IsVisible="{Binding ShowInstanceResourceFilterBar}"
            VerticalAlignment="Top">
          <controls:PclRadioButton
              Margin="2,0"
              Command="{Binding SetInstanceResourceAllFilterCommand}"
              IsChecked="{Binding IsInstanceResourceFilterAllSelected}"
              Text="{Binding InstanceResourceFilterAllText}" />
          <controls:PclRadioButton
              Margin="2,0"
              Command="{Binding SetInstanceResourceEnabledFilterCommand}"
              IsChecked="{Binding IsInstanceResourceFilterEnabledSelected}"
              IsVisible="{Binding ShowInstanceResourceEnabledFilter}"
              Text="{Binding InstanceResourceFilterEnabledText}" />
          <controls:PclRadioButton
              Margin="2,0"
              Command="{Binding SetInstanceResourceDisabledFilterCommand}"
              IsChecked="{Binding IsInstanceResourceFilterDisabledSelected}"
              IsVisible="{Binding ShowInstanceResourceDisabledFilter}"
              Text="{Binding InstanceResourceFilterDisabledText}" />
          <controls:PclRadioButton
              Margin="2,0"
              Command="{Binding SetInstanceResourceDuplicateFilterCommand}"
              IsChecked="{Binding IsInstanceResourceFilterDuplicateSelected}"
              IsVisible="{Binding ShowInstanceResourceDuplicateFilter}"
              Text="{Binding InstanceResourceFilterDuplicateText}" />
        </StackPanel>

        <StackPanel
            Grid.Column="1"
            Margin="0,13,15,0"
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            Height="28"
            VerticalAlignment="Top">
          <controls:PclIconTextButton
              Click="OnSortButtonClick"
              IconData="M673.158095 252.830476v634.026667h-71.923809V172.251429c0-10.142476 4.022857-19.846095 11.215238-26.989715a38.546286 38.546286 0 0 1 54.296381 0L926.47619 403.553524l-50.883047 50.566095-202.435048-201.289143zM350.841905 768.121905V134.095238h71.923809v719.823238l-0.902095 6.460953c-1.26781 8.045714-2.56 9.728-9.703619 18.992761l-8.045714 4.388572c-17.92 9.45981-20.577524 7.996952-43.154286-4.388572L97.52381 617.374476l50.883047-50.541714 202.435048 201.264762z"
              Text="{Binding InstanceResourceSortText}" />
        </StackPanel>
      </Grid>
    </controls:PclCard.HeaderOverlayContent>
    <controls:PclCard.CardContent>
      <ItemsControl
          ItemsSource="{Binding InstanceResourceEntries}"
          Padding="0">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <sections:ResourceEntryCardView />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </controls:PclCard.CardContent>
  </controls:PclCard>
</UserControl>
