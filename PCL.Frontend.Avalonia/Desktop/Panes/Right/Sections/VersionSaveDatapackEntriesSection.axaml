<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.Panes.Right.Sections.VersionSaveDatapackEntriesSection"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls">
  <controls:PclCard Header=" " MinHeight="55" ContentMargin="20,48,18,22" IsVisible="{Binding ShowVersionSaveDatapackContent}">
    <controls:PclCard.HeaderOverlayContent>
      <controls:PclIconTextButton
          Margin="0,13,15,0"
          HorizontalAlignment="Right"
          VerticalAlignment="Top"
          Click="OnSortButtonClick"
          UseFloatingSurface="True"
          IconData="M673.158095 252.830476v634.026667h-71.923809V172.251429c0-10.142476 4.022857-19.846095 11.215238-26.989715a38.546286 38.546286 0 0 1 54.296381 0L926.47619 403.553524l-50.883047 50.566095-202.435048-201.289143zM350.841905 768.121905V134.095238h71.923809v719.823238l-0.902095 6.460953c-1.26781 8.045714-2.56 9.728-9.703619 18.992761l-8.045714 4.388572c-17.92 9.45981-20.577524 7.996952-43.154286-4.388572L97.52381 617.374476l50.883047-50.541714 202.435048 201.264762z"
          Text="{Binding VersionSaveDatapackSortText}" />
    </controls:PclCard.HeaderOverlayContent>
    <controls:PclCard.CardContent>
      <Grid RowDefinitions="Auto">
        <ItemsControl
            Grid.Row="0"
            ItemsSource="{Binding VersionSaveDatapackEntries}"
            Padding="0">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <controls:PclListItem
                  Height="44"
                  Margin="0,0,0,8"
                  AccessoryCommand="{Binding ActionCommand}"
                  AccessoryIconData="{Binding ActionIconData}"
                  AccessoryToolTip="{Binding ActionToolTip}"
                  Command="{Binding PrimaryCommand}"
                  IconSource="{Binding Icon}"
                  Info="{Binding Info}"
                  IsSelected="{Binding IsSelected}"
                  Title="{Binding Title}"
                  TitleSuffix="{Binding Meta}" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </controls:PclCard.CardContent>
  </controls:PclCard>
</UserControl>
