<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.Panes.Right.Sections.InstanceInstallSelectionSummarySection"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls">
  <controls:PclCard Margin="0,15,0,0" ContentMargin="15,7,15,7">
    <controls:PclCard.CardContent>
      <Grid ColumnDefinitions="Auto,*" MinHeight="42">
        <Border
            Width="32"
            Height="32"
            Margin="0,0,12,0"
            VerticalAlignment="Center"
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            CornerRadius="6">
          <Image Source="{Binding InstanceInstallSelectionIcon}" Stretch="Uniform" Margin="4" />
        </Border>
        <Grid Grid.Column="1" RowDefinitions="Auto,2,Auto">
          <TextBlock
              Foreground="{DynamicResource ColorBrush1}"
              FontSize="13.5"
              Text="{Binding InstanceInstallSelectionTitle}"
              TextTrimming="CharacterEllipsis" />
          <TextBlock
              Grid.Row="2"
              Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
              FontSize="11.5"
              Text="{Binding InstanceInstallSelectionSummary}"
              TextTrimming="CharacterEllipsis" />
        </Grid>
      </Grid>
    </controls:PclCard.CardContent>
  </controls:PclCard>
</UserControl>
