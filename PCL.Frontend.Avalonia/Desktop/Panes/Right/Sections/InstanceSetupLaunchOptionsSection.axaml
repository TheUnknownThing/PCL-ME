<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.Panes.Right.Sections.InstanceSetupLaunchOptionsSection"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls">
  <controls:PclCard Header="{Binding InstanceSetupLaunchHeaderText}" ContentMargin="20,40,20,18">
    <controls:PclCard.CardContent>
      <Grid ColumnDefinitions="Auto,*" RowDefinitions="28,9,28,9,Auto,9,28,9,28">
        <TextBlock
            Grid.Row="0"
            Margin="0,0,25,0"
            VerticalAlignment="Center"
            Foreground="{DynamicResource ColorBrush1}"
            FontSize="13"
            Text="{Binding InstanceSetupIsolationLabelText}" />
        <ComboBox
            Grid.Row="0"
            Grid.Column="1"
            ItemsSource="{Binding InstanceIsolationOptions}"
            SelectedIndex="{Binding SelectedInstanceIsolationIndex}" />

        <TextBlock
            Grid.Row="2"
            Margin="0,0,25,0"
            VerticalAlignment="Center"
            Foreground="{DynamicResource ColorBrush1}"
            FontSize="13"
            Text="{Binding InstanceSetupWindowTitleLabelText}" />
        <TextBox
            Grid.Row="2"
            Grid.Column="1"
            Text="{Binding InstanceWindowTitleSetting}" />

        <CheckBox
            Grid.Row="4"
            Grid.ColumnSpan="2"
            Foreground="{DynamicResource ColorBrush1}"
            Content="{Binding InstanceSetupDefaultWindowTitleText}"
            IsChecked="{Binding UseDefaultInstanceWindowTitle}" />

        <TextBlock
            Grid.Row="6"
            Margin="0,0,25,0"
            VerticalAlignment="Center"
            Foreground="{DynamicResource ColorBrush1}"
            FontSize="13"
            Text="{Binding InstanceSetupCustomInfoLabelText}" />
        <Grid Grid.Row="6" Grid.Column="1" ColumnDefinitions="*,Auto">
          <TextBox
              Grid.Column="0"
              Text="{Binding InstanceCustomInfoSetting}" />
        </Grid>

        <TextBlock
            Grid.Row="8"
            Margin="0,0,25,0"
            VerticalAlignment="Center"
            Foreground="{DynamicResource ColorBrush1}"
            FontSize="13"
            Text="{Binding InstanceSetupJavaLabelText}" />
        <ComboBox
            Grid.Row="8"
            Grid.Column="1"
            ItemsSource="{Binding InstanceJavaOptions}"
            SelectedIndex="{Binding SelectedInstanceJavaIndex}" />
      </Grid>
    </controls:PclCard.CardContent>
  </controls:PclCard>
</UserControl>
