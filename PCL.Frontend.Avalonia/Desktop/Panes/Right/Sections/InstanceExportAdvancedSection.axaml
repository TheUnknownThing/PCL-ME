<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.Panes.Right.Sections.InstanceExportAdvancedSection"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:PCL.Frontend.Avalonia.ViewModels"
    x:DataType="vm:LauncherViewModel"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls">
  <controls:PclCard Header="{Binding InstanceExportAdvancedHeaderText}" ContentMargin="20,12,20,15">
    <controls:PclCard.CardContent>
      <StackPanel Spacing="12">
        <Border
            Padding="12,10"
            Background="{DynamicResource ColorBrushSemanticWarningBackground}"
            BorderBrush="{DynamicResource ColorBrushSemanticWarningBorder}"
            BorderThickness="1"
            CornerRadius="4"
            IsVisible="{Binding ShowInstanceExportIncludeWarning}">
          <TextBlock
              Foreground="{DynamicResource ColorBrushSemanticWarningForeground}"
              FontSize="12.5"
              Text="{Binding InstanceExportIncludeWarningText}"
              TextWrapping="Wrap" />
        </Border>

        <CheckBox
            Foreground="{DynamicResource ColorBrush1}"
            Content="{Binding InstanceExportIncludeResourcesText}"
            IsChecked="{Binding InstanceExportIncludeResources}" />
        <CheckBox
            Foreground="{DynamicResource ColorBrush1}"
            Content="{Binding InstanceExportModrinthModeText}"
            IsChecked="{Binding InstanceExportModrinthMode}" />

        <Border
            Padding="12,10"
            Background="{DynamicResource ColorBrushSemanticSuccessBackground}"
            BorderBrush="{DynamicResource ColorBrushSemanticSuccessBorder}"
            BorderThickness="1"
            CornerRadius="4">
          <TextBlock
              Foreground="{DynamicResource ColorBrushSemanticSuccessForeground}"
              FontSize="12.5"
              Text="{Binding InstanceExportConfigHintText}"
              TextWrapping="Wrap" />
        </Border>

        <Grid ColumnDefinitions="Auto,Auto,Auto">
          <controls:PclButton
              Grid.Column="0"
              MinWidth="140"
              Margin="0,0,20,0"
              Command="{Binding ImportInstanceExportConfigCommand}"
              ColorType="Highlight"
              Text="{Binding InstanceExportImportConfigText}" />
          <controls:PclButton
              Grid.Column="1"
              MinWidth="140"
              Margin="0,0,20,0"
              Command="{Binding SaveInstanceExportConfigCommand}"
              Text="{Binding InstanceExportSaveConfigText}" />
          <controls:PclButton
              Grid.Column="2"
              MinWidth="140"
              Command="{Binding OpenInstanceExportGuideCommand}"
              Text="{Binding InstanceExportGuideText}" />
        </Grid>
      </StackPanel>
    </controls:PclCard.CardContent>
  </controls:PclCard>
</UserControl>
