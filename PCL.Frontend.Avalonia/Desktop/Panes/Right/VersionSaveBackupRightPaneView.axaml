<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.Panes.Right.VersionSaveBackupRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:PCL.Frontend.Avalonia.ViewModels"
    x:DataType="vm:LauncherViewModel"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls"
    x:Name="Root"
    DataContext="{ReflectionBinding Launcher}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,10,25,10" Spacing="0">
      <controls:PclCard Margin="0,15,0,0" ContentMargin="0,0,0,0">
        <controls:PclCard.CardContent>
          <StackPanel Margin="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <controls:PclIconTextButton
                Command="{Binding CleanVersionSaveBackupCommand}"
                IconData="M701 564v195c0 11-9 20-20 20H343c-11 0-20-9-20-20V564c0-8.3-6.7-15-15-15s-15 6.7-15 15v205c0 22.1 17.9 40 40 40h358c22.1 0 40-17.9 40-40V564c0-8.3-6.7-15-15-15s-15 6.7-15 15z M393 792v-80c0-8.3 6.7-15 15-15s15 6.7 15 15v80c0 8.3-6.7 15-15 15s-15-6.7-15-15zM497 791V671c0-8.3 6.7-15 15-15s15 6.7 15 15v120c0 8.3-6.7 15-15 15s-15-6.7-15-15zM601 791V631c0-8.3 6.7-15 15-15s15 6.7 15 15v160c0 8.3-6.7 15-15 15s-15-6.7-15-15zM514.1 195c-32.9 0.5-59.1 28-59.1 60.9v211h30V255.7c0-16.3 12.8-30.2 29.1-30.7 16.9-0.5 30.9 13.2 30.9 30v212h30V255c0-33.4-27.4-60.5-60.9-60z M731 467.5c5.5 0 10 4.5 10 10v48c0 5.5-4.5 10-10 10H293c-5.5 0-10-4.5-10-10v-48c0-5.5 4.5-10 10-10h438m0-30H293c-22.1 0-40 17.9-40 40v48c0 22.1 17.9 40 40 40h438c22.1 0 40-17.9 40-40v-48c0-22.1-17.9-40-40-40z"
                Text="{Binding VersionSaveBackupCleanText}" />
            <controls:PclIconTextButton
                Margin="8,0,0,0"
                Command="{Binding CreateVersionSaveBackupCommand}"
                IconData="M512.277 954.412c-118.89 0-230.659-46.078-314.73-129.73S67.12 629.666 67.12 511.222s46.327-229.744 130.398-313.427 195.82-129.73 314.73-129.73 230.659 46.078 314.72 129.73S957.397 392.81 957.397 511.183 911.078 740.96 826.97 824.642s-195.8 129.77-314.692 129.77z m0-822.784c-101.972 0-197.809 39.494-269.865 111.222s-111.7 166.997-111.7 268.373 39.653 196.695 111.67 268.335S410.246 890.78 512.248 890.78s197.809-39.484 269.865-111.222 111.7-166.998 111.67-268.374c-0.03-101.375-39.654-196.665-111.67-268.303S614.22 131.628 512.277 131.628z m222.585 347.8H544.073V288.64c-0.76-17.561-15.613-31.18-33.173-30.419-16.495 0.714-29.704 13.924-30.419 30.419v190.787H289.703c-17.56 0.761-31.179 15.614-30.419 33.174 0.715 16.494 13.924 29.703 30.42 30.418H480.48v190.788c0.761 17.56 15.614 31.179 33.174 30.419 16.494-0.715 29.703-13.925 30.418-30.42V543.02h190.788c17.56 0.762 32.413-12.857 33.173-30.418 0.762-17.561-12.858-32.414-30.419-33.174a31.683 31.683 0 0 0-2.753 0z"
                Text="{Binding VersionSaveBackupCreateText}" />
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Margin="0,15,0,0" Header="{Binding VersionSaveBackupListHeaderText}" ContentMargin="20,40,18,20" IsVisible="{Binding HasVersionSaveBackupEntries}">
        <controls:PclCard.CardContent>
          <ItemsControl ItemsSource="{Binding VersionSaveBackupEntries}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,0,0,12" ColumnDefinitions="*,Auto">
                    <StackPanel Margin="0,0,18,0" Spacing="3">
                      <TextBlock
                        Foreground="{DynamicResource ColorBrush1}"
                        FontSize="13.5"
                        Text="{Binding Title}" />
                      <TextBlock
                        Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                        FontSize="12.5"
                        Text="{Binding Info}"
                        TextWrapping="Wrap" />
                  </StackPanel>
                  <controls:PclButton
                      Grid.Column="1"
                      Width="96"
                      Height="35"
                      VerticalAlignment="Center"
                      Command="{Binding Command}"
                      Text="{Binding DataContext.VersionSaveBackupOpenText, ElementName=Root}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Margin="0,15,0,0" IsVisible="{Binding HasNoVersionSaveBackupEntries}" ContentMargin="20,17,20,17">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="10">
            <TextBlock
                HorizontalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="19"
                Text="{Binding VersionSaveBackupEmptyTitle}" />
            <Border Height="2" Background="{DynamicResource ColorBrush6}" />
            <TextBlock
                Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                FontSize="12.5"
                Text="{Binding VersionSaveBackupEmptyDescription}"
                TextAlignment="Center"
                TextWrapping="Wrap" />
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>
    </StackPanel>
  </ScrollViewer>
</UserControl>
