<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.Panes.Right.SetupLaunchRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:PCL.Frontend.Avalonia.ViewModels"
    x:DataType="vm:LauncherViewModel"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls"
    DataContext="{ReflectionBinding Launcher}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,25,25,10" Spacing="15">
      <controls:PclCard Header="{Binding SetupText.Launch.OptionsCardHeader}" ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="28,9,28,9,28,9,28,9,28,9,28,9,28">
            <TextBlock
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="{Binding SetupText.Launch.DefaultIsolationLabel}" />
            <ComboBox
                Grid.Column="1"
                Height="28"
                ItemsSource="{Binding LaunchIsolationOptions}"
                SelectedIndex="{Binding SelectedLaunchIsolationIndex}" />

            <TextBlock
                Grid.Row="2"
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="{Binding SetupText.Launch.GameWindowTitleLabel}" />
            <TextBox
                Grid.Row="2"
                Grid.Column="1"
                Height="28"
                Padding="8,4"
                Text="{Binding LaunchWindowTitleSetting}" />

            <TextBlock
                Grid.Row="4"
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="{Binding SetupText.Launch.CustomInfoLabel}" />
            <TextBox
                Grid.Row="4"
                Grid.Column="1"
                Height="28"
                Padding="8,4"
                Text="{Binding LaunchCustomInfoSetting}" />

            <TextBlock
                Grid.Row="6"
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="{Binding SetupText.Launch.LauncherVisibilityLabel}" />
            <ComboBox
                Grid.Row="6"
                Grid.Column="1"
                Height="28"
                ItemsSource="{Binding LaunchVisibilityOptions}"
                SelectedIndex="{Binding SelectedLaunchVisibilityIndex}" />

            <TextBlock
                Grid.Row="8"
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="{Binding SetupText.Launch.ProcessPriorityLabel}" />
            <ComboBox
                Grid.Row="8"
                Grid.Column="1"
                Height="28"
                ItemsSource="{Binding LaunchPriorityOptions}"
                SelectedIndex="{Binding SelectedLaunchPriorityIndex}" />

            <TextBlock
                Grid.Row="10"
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="{Binding SetupText.Launch.WindowSizeLabel}" />
            <Grid Grid.Row="10" Grid.Column="1" ColumnDefinitions="220,10,70,10,70">
              <ComboBox
                  Grid.Column="0"
                  Height="28"
                  ItemsSource="{Binding LaunchWindowTypeOptions}"
                  SelectedIndex="{Binding SelectedLaunchWindowTypeIndex}" />
              <TextBox
                  Grid.Column="2"
                  Height="28"
                  Padding="8,4"
                  HorizontalContentAlignment="Center"
                  IsVisible="{Binding IsCustomLaunchWindowSizeVisible}"
                  Text="{Binding LaunchWindowWidth}" />
              <TextBlock
                  Grid.Column="3"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                  FontSize="15"
                  IsVisible="{Binding IsCustomLaunchWindowSizeVisible}"
                  Text="×" />
              <TextBox
                  Grid.Column="4"
                  Height="28"
                  Padding="8,4"
                  HorizontalContentAlignment="Center"
                  IsVisible="{Binding IsCustomLaunchWindowSizeVisible}"
                  Text="{Binding LaunchWindowHeight}" />
            </Grid>

            <TextBlock
                Grid.Row="12"
                VerticalAlignment="Center"
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="{Binding SetupText.Launch.PreferredIpStackLabel}" />
            <ComboBox
                Grid.Row="12"
                Grid.Column="1"
                Height="28"
                ItemsSource="{Binding LaunchPreferredIpStackOptions}"
                SelectedIndex="{Binding SelectedLaunchPreferredIpStackIndex}" />
          </Grid>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="{Binding SetupText.Launch.MemoryCardHeader}" ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <Border
                Padding="12,10"
                Background="{DynamicResource ColorBrushSemanticWarningBackground}"
                BorderBrush="{DynamicResource ColorBrushSemanticWarningBorder}"
                BorderThickness="1"
                CornerRadius="4"
                IsVisible="{Binding ShowLaunch32BitJavaWarning}">
              <TextBlock
                  Foreground="{DynamicResource ColorBrushSemanticWarningForeground}"
                  FontSize="12.5"
                  Text="{Binding SetupText.Launch.Memory32BitWarning}"
                  TextWrapping="Wrap" />
            </Border>

            <Border
                Padding="12,10"
                Background="{DynamicResource ColorBrushSemanticWarningBackground}"
                BorderBrush="{DynamicResource ColorBrushSemanticWarningBorder}"
                BorderThickness="1"
                CornerRadius="4"
                IsVisible="{Binding ShowRamAllocationWarning}">
              <TextBlock
                  Foreground="{DynamicResource ColorBrushSemanticWarningForeground}"
                  FontSize="12.5"
                  Text="{Binding SetupText.Launch.MemoryOverallocationWarning}"
                  TextWrapping="Wrap" />
            </Border>

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,9,Auto">
              <RadioButton
                  Content="{Binding SetupText.Launch.AutomaticAllocationLabel}"
                  IsChecked="{Binding UseAutomaticRamAllocation}" />
              <TextBlock
                  Grid.Column="1"
                  Margin="12,0,0,0"
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                  FontSize="12.5"
                  Text="{Binding SetupText.Launch.AutomaticAllocationDescription}"
                  TextWrapping="Wrap" />

              <RadioButton
                  Grid.Row="2"
                  Content="{Binding SetupText.Launch.CustomAllocationLabel}"
                  IsChecked="{Binding UseCustomRamAllocation}" />
              <Grid Grid.Row="2" Grid.Column="1" Margin="12,0,0,0" ColumnDefinitions="*,62">
                <Slider
                    VerticalAlignment="Center"
                    IsEnabled="{Binding IsCustomRamAllocationEnabled}"
                    Minimum="1"
                    Maximum="16"
                    Value="{Binding CustomRamAllocation}" />
                <TextBlock
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                    FontSize="12"
                    Text="{Binding CustomRamAllocationLabel}" />
              </Grid>
            </Grid>

            <controls:PclMemorySummary
                UsedBarWidth="{Binding UsedRamBarWidth}"
                AllocatedBarWidth="{Binding AllocatedRamBarWidth}"
                FreeBarWidth="{Binding FreeRamBarWidth}"
                UsageHeaderText="{Binding MemorySummaryUsageHeaderText}"
                UsedRamLabel="{Binding UsedRamLabel}"
                TotalRamLabel="{Binding TotalRamLabel}"
                AllocatedRamLabel="{Binding AllocatedRamLabel}"
                AllocationPrefixText="{Binding MemorySummaryAllocationPrefixText}" />
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard
          Header="{Binding SetupText.Launch.AdvancedCardHeader}"
          ShowChevron="True"
          IsChevronExpanded="{Binding IsLaunchAdvancedOptionsExpanded}"
          HeaderCommand="{Binding ToggleLaunchAdvancedOptionsCommand}"
          ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="Auto,*">
              <TextBlock
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource ColorBrush1}"
                  FontSize="13.5"
                  Margin="0,0,25,0"
                  Text="{Binding SetupText.Launch.RendererLabel}" />
              <ComboBox
                  Grid.Column="1"
                  Height="28"
                  ItemsSource="{Binding LaunchRendererOptions}"
                  SelectedIndex="{Binding SelectedLaunchRendererIndex}" />
            </Grid>

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,9,Auto,9,Auto,9,Auto,9,Auto,9,Auto,9,Auto">
              <TextBlock
                  VerticalAlignment="Top"
                  Foreground="{DynamicResource ColorBrush1}"
                  FontSize="13.5"
                  Margin="0,4,25,0"
                  Text="{Binding SetupText.Launch.BeforeCommandLabel}" />
              <StackPanel Grid.Column="1" Spacing="8">
                <TextBox
                    MinHeight="72"
                    Padding="8,6"
                    AcceptsReturn="True"
                    Text="{Binding LaunchBeforeCommand}"
                    TextWrapping="Wrap"
                    VerticalContentAlignment="Top" />
                <CheckBox
                    Foreground="{DynamicResource ColorBrush1}"
                    Content="{Binding SetupText.Launch.WaitForBeforeCommandLabel}"
                    IsChecked="{Binding WaitForLaunchBeforeCommand}" />
              </StackPanel>

              <TextBlock
                  Grid.Row="2"
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource ColorBrush1}"
                  FontSize="13.5"
                  Margin="0,0,25,0"
                  Text="{Binding SetupText.Launch.WrapperCommandLabel}" />
              <TextBox
                  Grid.Row="2"
                  Grid.Column="1"
                  Height="28"
                  Padding="8,4"
                  Text="{Binding LaunchWrapperCommand}" />

              <TextBlock
                  Grid.Row="4"
                  VerticalAlignment="Top"
                  Foreground="{DynamicResource ColorBrush1}"
                  FontSize="13.5"
                  Margin="0,4,25,0"
                  Text="{Binding SetupText.Launch.JvmArgumentsLabel}" />
              <TextBox
                  Grid.Row="4"
                  Grid.Column="1"
                  MinHeight="92"
                  Padding="8,6"
                  AcceptsReturn="True"
                  Text="{Binding LaunchJvmArguments}"
                  TextWrapping="Wrap"
                  VerticalContentAlignment="Top" />

              <TextBlock
                  Grid.Row="6"
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource ColorBrush1}"
                  FontSize="13.5"
                  Margin="0,0,25,0"
                  Text="{Binding SetupText.Launch.GameArgumentsLabel}" />
              <TextBox
                  Grid.Row="6"
                  Grid.Column="1"
                  Height="28"
                  Padding="8,4"
                  Text="{Binding LaunchGameArguments}" />

              <TextBlock
                  Grid.Row="8"
                  VerticalAlignment="Top"
                  Foreground="{DynamicResource ColorBrush1}"
                  FontSize="13.5"
                  Margin="0,4,25,0"
                  Text="{Binding SetupText.Launch.EnvironmentVariablesLabel}" />
              <StackPanel Grid.Row="8" Grid.Column="1" Spacing="6">
                <TextBox
                    MinHeight="92"
                    Padding="8,6"
                    AcceptsReturn="True"
                    Text="{Binding LaunchEnvironmentVariables}"
                    TextWrapping="Wrap"
                    VerticalContentAlignment="Top" />
                <TextBlock
                    Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                    FontSize="12"
                    Text="{Binding SetupText.Launch.EnvironmentVariablesHint}"
                    TextWrapping="Wrap" />
              </StackPanel>

              <TextBlock
                  Grid.Row="10"
                  VerticalAlignment="Top"
                  Foreground="{DynamicResource ColorBrush1}"
                  FontSize="13.5"
                  Margin="0,4,25,0"
                  Text="{Binding SetupText.Launch.LinuxDisplayBackendLabel}" />
              <StackPanel Grid.Row="10" Grid.Column="1" Spacing="6">
                <CheckBox
                    Foreground="{DynamicResource ColorBrush1}"
                    Content="{Binding SetupText.Launch.ForceX11Label}"
                    IsChecked="{Binding ForceX11OnWaylandForLaunch}" />
                <TextBlock
                    Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                    FontSize="12"
                    Text="{Binding SetupText.Launch.ForceX11Hint}"
                    TextWrapping="Wrap" />
              </StackPanel>
            </Grid>

            <StackPanel Spacing="8">
              <CheckBox
                  Foreground="{DynamicResource ColorBrush1}"
                  Content="{Binding SetupText.Launch.DisableJavaLaunchWrapperLabel}"
                  IsChecked="{Binding DisableJavaLaunchWrapper}" />
              <CheckBox
                  Foreground="{DynamicResource ColorBrush1}"
                  Content="{Binding SetupText.Launch.DisableRetroWrapperLabel}"
                  IsChecked="{Binding DisableRetroWrapper}" />
              <CheckBox
                  Foreground="{DynamicResource ColorBrush1}"
                  Content="{Binding SetupText.Launch.RequireDedicatedGpuLabel}"
                  IsChecked="{Binding RequireDedicatedGpu}" />
              <CheckBox
                  Foreground="{DynamicResource ColorBrush1}"
                  Content="{Binding SetupText.Launch.UseJavaExecutableLabel}"
                  IsChecked="{Binding UseJavaExecutable}" />
            </StackPanel>

            <Border
                Padding="12,10"
                Background="{DynamicResource ColorBrush8}"
                BorderBrush="{DynamicResource ColorBrush6}"
                BorderThickness="1"
                CornerRadius="4">
              <TextBlock
                  Foreground="{DynamicResource ColorBrush2}"
                  FontSize="12.5"
                  Text="{Binding SetupText.Launch.InstanceSettingsHint}"
                  TextWrapping="Wrap" />
            </Border>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclIconTextButton
          HorizontalAlignment="Center"
          Command="{Binding VersionSetupCommand}"
          ColorType="Highlight"
          IconData="M73 584L920 584 608 896C579 925 579 972 608 1001 637 1030 683 1030 712 1001L1149 565C1164 550 1170 531 1170 511 1170 492 1164 472 1149 457L712 21C683-7 637-7 608 21 579 50 579 97 608 126L920 438 73 438C33 438 0 471 0 511 0 551 33 584 73 584Z"
          IconPlacement="Right"
          IconScale="0.75"
          IsVisible="{Binding ShowLaunchVersionSetupButton}"
          Text="{Binding SetupText.Launch.InstanceSettingsButton}" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
