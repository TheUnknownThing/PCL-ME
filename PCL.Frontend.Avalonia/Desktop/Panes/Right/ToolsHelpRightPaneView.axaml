<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.Panes.Right.ToolsHelpRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls"
    DataContext="{Binding Launcher}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,25,25,10" Spacing="15">
      <controls:PclSearchBox
          Text="{Binding HelpSearchQuery, Mode=TwoWay}"
          Watermark="{Binding ToolsHelpSearchWatermark}" />

      <ItemsControl ItemsSource="{Binding HelpTopicGroups}" IsVisible="{Binding ShowHelpTopicLibrary}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <controls:PclCard
                Margin="0,0,0,15"
                Header="{Binding Title}"
                ContentMargin="20,40,18,18"
                HeaderCommand="{Binding ToggleCommand}"
                IsChevronExpanded="{Binding IsExpanded}"
                ShowChevron="True">
              <controls:PclCard.CardContent>
                <ItemsControl ItemsSource="{Binding Items}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <controls:PclListItem
                          Margin="0,0,0,8"
                          Command="{Binding Command}"
                          IconSource="{Binding Icon}"
                          Info="{Binding Summary}"
                          Title="{Binding Title}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </controls:PclCard.CardContent>
            </controls:PclCard>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <controls:PclCard Margin="0,0,0,15" Header="{Binding HelpSearchResultsHeader}" IsVisible="{Binding IsHelpSearchActive}" ContentMargin="20,40,18,18">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="10">
            <ItemsControl ItemsSource="{Binding HelpSearchResults}" IsVisible="{Binding HasHelpSearchResults}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <controls:PclListItem
                      Margin="0,0,0,8"
                      Command="{Binding Command}"
                      IconSource="{Binding Icon}"
                      Info="{Binding Summary}"
                      Title="{Binding Title}" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock
                Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                FontSize="13"
                IsVisible="{Binding HasNoHelpSearchResults}"
                Text="{Binding ToolsHelpNoResultsText}"
                TextWrapping="Wrap" />
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>
    </StackPanel>
  </ScrollViewer>
</UserControl>
