<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.Panes.Right.ToolsTestRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:PCL.Frontend.Avalonia.ViewModels"
    x:DataType="vm:LauncherViewModel"
    xmlns:controls="clr-namespace:PCL.Frontend.Avalonia.Desktop.Controls"
    DataContext="{ReflectionBinding Launcher}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,10,25,10" Spacing="15">
      <controls:PclCard Header="{Binding ToolsTestToolboxCardHeader}" ContentMargin="25,40,21,5">
        <controls:PclCard.CardContent>
          <ItemsControl ItemsSource="{Binding ToolboxActions}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel ItemHeight="50" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <controls:PclButton
                    Height="35"
                    Margin="0,0,15,15"
                    MinWidth="{Binding MinWidth}"
                    Command="{Binding Command}"
                    ColorType="{Binding ColorType}"
                    Text="{Binding Title}"
                    ToolTip.Tip="{Binding ToolTip}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="{Binding ToolsTestCustomDownloadCardHeader}" ContentMargin="25,40,25,20">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <TextBlock
                Foreground="{DynamicResource ColorBrush1}"
                FontSize="13"
                Text="{Binding ToolsTestCustomDownloadDescription}"
                TextWrapping="Wrap" />
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="28,10,28,10,28,10,28">
              <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush1}" FontSize="13.5" Margin="0,0,25,0" Text="{Binding ToolsTestCustomDownloadAddressLabel}" />
              <TextBox Grid.Column="1" Height="28" Padding="8,4" Text="{Binding ToolDownloadUrl}" />

              <TextBlock Grid.Row="2" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush1}" FontSize="13.5" Margin="0,0,25,0" Text="{Binding ToolsTestCustomDownloadUserAgentLabel}" />
              <TextBox Grid.Row="2" Grid.Column="1" Height="28" Padding="8,4" Text="{Binding ToolDownloadUserAgent}" />

              <TextBlock Grid.Row="4" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush1}" FontSize="13.5" Margin="0,0,25,0" Text="{Binding ToolsTestCustomDownloadSaveToLabel}" />
              <Grid Grid.Row="4" Grid.Column="1" ColumnDefinitions="*,Auto">
                <TextBox Height="28" Padding="8,4" Text="{Binding ToolDownloadFolder}" />
                <controls:PclButton
                    Grid.Column="1"
                    Height="35"
                    Width="70"
                    Margin="10,0,0,0"
                    Command="{Binding SelectDownloadFolderCommand}"
                    Text="{Binding ToolsTestCustomDownloadSelectButtonText}" />
              </Grid>

              <TextBlock Grid.Row="6" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush1}" FontSize="13.5" Margin="0,0,25,0" Text="{Binding ToolsTestCustomDownloadFileNameLabel}" />
              <TextBox Grid.Row="6" Grid.Column="1" Height="28" Padding="8,4" Text="{Binding ToolDownloadName}" />
            </Grid>

            <Grid ColumnDefinitions="*,*" Margin="0,5,0,0">
              <controls:PclButton
                  Grid.Column="0"
                  Height="35"
                  Width="140"
                  HorizontalAlignment="Right"
                  Margin="0,0,15,0"
                  Command="{Binding StartCustomDownloadCommand}"
                  ColorType="Highlight"
                  Text="{Binding ToolsTestCustomDownloadStartButtonText}" />
              <controls:PclButton
                  Grid.Column="1"
                  Height="35"
                  Width="140"
                  HorizontalAlignment="Left"
                  Command="{Binding OpenCustomDownloadFolderCommand}"
                  Text="{Binding ToolsTestCustomDownloadOpenFolderButtonText}" />
            </Grid>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="{Binding ToolsTestOfficialSkinCardHeader}" ContentMargin="25,40,25,15">
        <controls:PclCard.CardContent>
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="28,14,35">
            <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush1}" FontSize="13.5" Margin="0,0,25,0" Text="{Binding ToolsTestOfficialSkinPlayerNameLabel}" />
            <TextBox Grid.Column="1" Height="28" Padding="8,4" Text="{Binding OfficialSkinPlayerName}" />
            <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="Auto,*">
              <controls:PclButton
                  Height="35"
                  Width="140"
                  Command="{Binding SaveOfficialSkinCommand}"
                  Text="{Binding ToolsTestOfficialSkinSaveButtonText}" />
            </Grid>
          </Grid>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="{Binding ToolsTestServerQueryCardHeader}" ContentMargin="15,40,15,15">
        <controls:PclCard.CardContent>
          <controls:MinecraftServerQuery />
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="{Binding ToolsTestAchievementCardHeader}" ShowChevron="True" IsChevronExpanded="False" ContentMargin="25,30,25,15">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="28,10,28,10,28,10,28">
              <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush1}" FontSize="13.5" Margin="0,0,25,0" Text="{Binding ToolsTestAchievementBlockIdLabel}" />
              <TextBox Grid.Column="1" Height="28" Padding="8,4" Text="{Binding AchievementBlockId}" />
              <TextBlock Grid.Row="2" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush1}" FontSize="13.5" Margin="0,0,25,0" Text="{Binding ToolsTestAchievementTitleLabel}" />
              <TextBox Grid.Row="2" Grid.Column="1" Height="28" Padding="8,4" Text="{Binding AchievementTitle}" />
              <TextBlock Grid.Row="4" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush1}" FontSize="13.5" Margin="0,0,25,0" Text="{Binding ToolsTestAchievementFirstLineLabel}" />
              <TextBox Grid.Row="4" Grid.Column="1" Height="28" Padding="8,4" Text="{Binding AchievementFirstLine}" />
              <TextBlock Grid.Row="6" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush1}" FontSize="13.5" Margin="0,0,25,0" Text="{Binding ToolsTestAchievementSecondLineLabel}" />
              <TextBox Grid.Row="6" Grid.Column="1" Height="28" Padding="8,4" Text="{Binding AchievementSecondLine}" />
            </Grid>

            <Grid ColumnDefinitions="*,*">
              <controls:PclButton
                  Grid.Column="0"
                  Height="35"
                  Width="140"
                  HorizontalAlignment="Right"
                  Margin="0,0,15,0"
                  Command="{Binding PreviewAchievementCommand}"
                  ColorType="Highlight"
                  Text="{Binding ToolsTestAchievementPreviewButtonText}" />
              <controls:PclButton
                  Grid.Column="1"
                  Height="35"
                  Width="140"
                  HorizontalAlignment="Left"
                  Command="{Binding SaveAchievementCommand}"
                  Text="{Binding ToolsTestAchievementSaveButtonText}" />
            </Grid>

            <Border
                Width="360"
                Height="80"
                Padding="8"
                Background="{DynamicResource ColorBrushAchievementPreviewCardBackground}"
                BorderBrush="{DynamicResource ColorBrushAchievementPreviewCardBorder}"
                BorderThickness="1"
                CornerRadius="5"
                HorizontalAlignment="Center"
                IsVisible="{Binding ShowAchievementPreview}">
              <Image
                  Source="{Binding AchievementPreviewImage}"
                  Stretch="Uniform"
                  RenderOptions.BitmapInterpolationMode="None" />
            </Border>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="{Binding ToolsTestHeadCardHeader}" ShowChevron="True" IsChevronExpanded="False" ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="Auto,*">
              <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush1}" FontSize="13.5" Margin="0,0,20,0" Text="{Binding ToolsTestHeadSizeLabel}" />
              <ComboBox
                  Grid.Column="1"
                  Width="120"
                  ItemsSource="{Binding HeadSizeOptions}"
                  SelectedIndex="{Binding SelectedHeadSizeIndex}" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto,Auto,*">
              <controls:PclButton
                  Grid.Column="1"
                  Height="35"
                  Width="140"
                  Margin="0,0,10,0"
                  Command="{Binding SelectHeadSkinCommand}"
                  Text="{Binding ToolsTestHeadSelectButtonText}" />
              <controls:PclButton
                  Grid.Column="2"
                  Height="35"
                  Width="140"
                  Command="{Binding SaveHeadCommand}"
                  Text="{Binding ToolsTestHeadSaveButtonText}" />
            </Grid>

            <Border
                Width="{Binding HeadPreviewSize}"
                Height="{Binding HeadPreviewSize}"
                Padding="8"
                Background="{DynamicResource ColorBrush8}"
                BorderBrush="{DynamicResource ColorBrush6}"
                BorderThickness="1"
                CornerRadius="5"
                HorizontalAlignment="Center"
                IsVisible="{Binding HasHeadPreviewImage}">
              <Image
                  Source="{Binding HeadPreviewImage}"
                  Stretch="Uniform"
                  RenderOptions.BitmapInterpolationMode="None" />
            </Border>
            <TextBlock
                HorizontalAlignment="Center"
                Foreground="{DynamicResource ColorBrushEntrySecondaryIdle}"
                FontSize="12.5"
                Text="{Binding SelectedHeadSkinPath}" />
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>
    </StackPanel>
  </ScrollViewer>
</UserControl>
