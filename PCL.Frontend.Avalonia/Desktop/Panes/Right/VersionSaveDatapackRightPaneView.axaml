<UserControl
    x:Class="PCL.Frontend.Avalonia.Desktop.Panes.Right.VersionSaveDatapackRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sections="clr-namespace:PCL.Frontend.Avalonia.Desktop.Panes.Right.Sections"
    DataContext="{Binding Launcher}">
  <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto" IsVisible="{Binding ShowVersionSaveDatapackContent}">
      <StackPanel Margin="25,10,25,10" Spacing="15">
        <sections:VersionSaveDatapackHeaderSection />
        <sections:VersionSaveDatapackEntriesSection />
      </StackPanel>
    </ScrollViewer>
    <sections:VersionSaveDatapackEmptyStateSection HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40" IsVisible="{Binding ShowVersionSaveDatapackEmptyState}" />
  </Grid>
</UserControl>
