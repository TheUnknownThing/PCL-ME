               Text="Use the instance export page when you want to share a playable pack with other people. The export flow helps you choose which files should be packaged and which local-only files should stay out of the archive." />
  </StackPanel>
</local:MyCard>

<local:MyCard Title="Choose the instance and export target" Margin="0,0,0,15">
