<local:MyCard Title="Create useful help entries" Margin="0,0,0,15">
  <StackPanel Margin="25,40,23,15">
    <TextBlock Margin="0,0,0,4" LineHeight="17" TextWrapping="Wrap"
               Text="Each article should solve a concrete user problem, keep the title specific, and avoid burying key steps inside vague or decorative language." />
  </StackPanel>
</local:MyCard>

<local:MyCard Title="Choose the right category" Margin="0,0,0,15">
  <StackPanel Margin="25,40,23,15">
    <TextBlock Margin="0,0,0,4" LineHeight="17" TextWrapping="Wrap"
               Text="Place each article in the group where users are most likely to search for it. Good categories reduce search friction and make the library easier to maintain later." />
  </StackPanel>
</local:MyCard>

<local:MyCard Title="Content, images, and review" Margin="0,0,0,15">
  <StackPanel Margin="25,40,23,15">
    <TextBlock Margin="0,0,0,4" LineHeight="17" TextWrapping="Wrap"
               Text="Prefer short, actionable paragraphs, screenshots that directly support the step being described, and links only when the external reference is genuinely more authoritative than the local article." />
  </StackPanel>
</local:MyCard>
