  <StackPanel Margin="25,40,23,15">
    <TextBlock Margin="0,0,0,4" LineHeight="17" TextWrapping="Wrap"
               Text="A token can insert data such as the current launcher path, selected instance, or similar runtime-specific content into a line of text without editing the article for every user." />
  </StackPanel>
</local:MyCard>

