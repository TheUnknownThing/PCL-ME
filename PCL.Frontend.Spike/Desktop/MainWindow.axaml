<Window
    x:Class="PCL.Frontend.Spike.Desktop.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PCL Frontend Spike"
    Width="1158"
    Height="648"
    MinWidth="980"
    MinHeight="620"
    Background="Transparent"
    SystemDecorations="None">
  <Grid Margin="2">
    <Border CornerRadius="12"
            Background="#FBFBFB"
            BorderBrush="#9FC0F9"
            BorderThickness="1">
      <Grid RowDefinitions="48,*">
        <Border Grid.Row="0"
                Background="#1370F3"
                CornerRadius="12,12,0,0"
                PointerPressed="TitleBar_OnPointerPressed">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <Grid Grid.Column="0" Margin="22,0,0,0" ColumnDefinitions="Auto,Auto,Auto">
              <TextBlock Grid.Column="0"
                         VerticalAlignment="Center"
                         Foreground="White"
                         FontSize="18"
                         FontWeight="Light"
                         Text="Point Cloud Library" />
              <Border Grid.Column="1"
                      Margin="10,0,0,0"
                      VerticalAlignment="Center"
                      Padding="5,1"
                      Background="#FFFFFF"
                      CornerRadius="5">
                <TextBlock Foreground="#1370F3"
                           FontSize="11"
                           FontWeight="Bold"
                           Text="CE" />
              </Border>
            </Grid>

            <ItemsControl Grid.Column="1"
                          HorizontalAlignment="Left"
                          Margin="165,0,0,0"
                          VerticalAlignment="Center"
                          ItemsSource="{Binding TopLevelEntries}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="12,0,0,0"
                          Padding="16,0"
                          Height="34"
                          Background="{Binding BackgroundBrush}"
                          CornerRadius="17">
                    <Button Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding Command}">
                      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{Binding ForegroundBrush}"
                                   FontSize="17"
                                   Text="◉"
                                   IsVisible="{Binding IsSelected}" />
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{Binding ForegroundBrush}"
                                   FontSize="17"
                                   Text="{Binding Title}" />
                      </StackPanel>
                    </Button>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Grid.Column="2"
                        Margin="0,0,16,0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Spacing="12">
              <TextBlock VerticalAlignment="Center"
                         Foreground="White"
                         FontSize="20"
                         Text="－"
                         Cursor="Hand"
                         PointerPressed="MinimizeGlyph_OnPointerPressed" />
              <TextBlock VerticalAlignment="Center"
                         Foreground="White"
                         FontSize="20"
                         Text="×"
                         Cursor="Hand"
                         PointerPressed="CloseGlyph_OnPointerPressed" />
            </StackPanel>
          </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="460,*">
          <Border Grid.Column="0"
                  Background="#FBFBFB"
                  BorderBrush="#D5E6FD"
                  BorderThickness="0,0,1,0">
            <Grid RowDefinitions="*,Auto">
              <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="14">
                <Border Width="74" Height="74" Background="#F4E7B8" CornerRadius="8">
                  <Grid RowDefinitions="18,18,18,20" ColumnDefinitions="18,18,18,20">
                    <Border Grid.Row="0" Grid.ColumnSpan="4" Background="#F8E6B6" />
                    <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Background="#FFE9C5" />
                    <Border Grid.Row="1" Grid.Column="1" Background="#65D8FF" />
                    <Border Grid.Row="1" Grid.Column="2" Background="#74C4FF" />
                    <Border Grid.Row="2" Grid.Column="1" Background="#665032" />
                    <Border Grid.Row="2" Grid.Column="2" Background="#665032" />
                    <Border Grid.Row="2" Grid.Column="0" Background="#FFDCB4" />
                    <Border Grid.Row="2" Grid.Column="3" Background="#FFDCB4" />
                    <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" Background="#FFE6C9" />
                    <Border Grid.Row="2" Grid.Column="1" Width="6" Height="10" Background="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Border Grid.Row="2" Grid.Column="2" Width="6" Height="10" Background="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Border Grid.Row="2" Grid.Column="1" Width="3" Height="5" Background="#755F82" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Border Grid.Row="2" Grid.Column="2" Width="3" Height="5" Background="#7A8C54" HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Grid>
                </Border>
                <TextBlock Foreground="#343D4A"
                           FontSize="28"
                           FontWeight="Light"
                           Text="{Binding LaunchUserName}" />
                <TextBlock Foreground="#B0B0B0"
                           FontSize="18"
                           Text="{Binding LaunchAuthLabel}" />
              </StackPanel>

              <StackPanel Grid.Row="1" Margin="28,0,28,28" Spacing="16">
                <Border Height="81"
                        BorderBrush="#1370F3"
                        BorderThickness="2"
                        CornerRadius="6"
                        Background="#FFFFFF">
                  <Button Background="Transparent"
                          BorderThickness="0"
                          Command="{Binding LaunchCommand}">
                    <StackPanel Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                      <TextBlock HorizontalAlignment="Center"
                                 Foreground="#1370F3"
                                 FontSize="21"
                                 FontWeight="Regular"
                                 Text="{Binding LaunchButtonTitle}" />
                      <TextBlock HorizontalAlignment="Center"
                                 Foreground="#8C8C8C"
                                 FontSize="13"
                                 Text="{Binding LaunchVersionSubtitle}" />
                    </StackPanel>
                  </Button>
                </Border>

                <Grid ColumnDefinitions="*,16,*">
                  <Border Grid.Column="0"
                          Height="52"
                          BorderBrush="#404040"
                          BorderThickness="1"
                          CornerRadius="5"
                          Background="#FFFFFF">
                    <Button Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding VersionSelectCommand}">
                      <TextBlock HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Foreground="#404040"
                                 FontSize="18"
                                 Text="版本选择" />
                    </Button>
                  </Border>
                  <Border Grid.Column="2"
                          Height="52"
                          BorderBrush="#404040"
                          BorderThickness="1"
                          CornerRadius="5"
                          Background="#FFFFFF">
                    <Button Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding VersionSetupCommand}">
                      <TextBlock HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Foreground="#404040"
                                 FontSize="18"
                                 Text="版本设置" />
                    </Button>
                  </Border>
                </Grid>
              </StackPanel>
            </Grid>
          </Border>

          <Border Grid.Column="1" Background="#EAF2FE">
            <Grid>
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="32,18,32,18" Spacing="14">
                  <Border Height="49"
                          Background="#BFD6FB"
                          BorderBrush="#4890F5"
                          BorderThickness="1.5"
                          CornerRadius="8">
                    <Grid Margin="18,0" ColumnDefinitions="Auto,*">
                      <TextBlock VerticalAlignment="Center"
                                 Foreground="#404040"
                                 FontSize="18"
                                 Text="▣" />
                      <TextBlock Grid.Column="1"
                                 Margin="10,0,0,0"
                                 VerticalAlignment="Center"
                                 Foreground="#404040"
                                 FontSize="17"
                                 FontWeight="SemiBold"
                                 Text="{Binding LaunchWelcomeBanner}" />
                    </Grid>
                  </Border>

                  <Border Height="61"
                          Background="#FFFFFF"
                          CornerRadius="10">
                    <Grid Margin="22,0" ColumnDefinitions="*,Auto">
                      <TextBlock VerticalAlignment="Center"
                                 Foreground="#343D4A"
                                 FontSize="17"
                                 FontWeight="SemiBold"
                                 Text="{Binding LaunchMigrationHeadline}" />
                      <TextBlock Grid.Column="1"
                                 VerticalAlignment="Center"
                                 Foreground="#4A5A6A"
                                 FontSize="26"
                                 Text="⌄" />
                    </Grid>
                  </Border>

                  <Border Background="#FFFFFF"
                          CornerRadius="10">
                    <StackPanel Margin="22,18,22,22" Spacing="14">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="#343D4A"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Text="{Binding LaunchNewsTitle}" />
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Foreground="#4A5A6A"
                                   FontSize="26"
                                   Text="⌃" />
                      </Grid>

                      <Border BorderBrush="#1370F3"
                              BorderThickness="5"
                              CornerRadius="16">
                        <Grid>
                          <Image Source="{Binding LaunchNewsImagePath}"
                                 Height="200"
                                 Stretch="Fill" />
                          <Border HorizontalAlignment="Center"
                                  VerticalAlignment="Bottom"
                                  Margin="0,0,0,-18"
                                  Padding="42,10"
                                  Background="#1370F3"
                                  CornerRadius="14">
                            <TextBlock Foreground="White"
                                       FontSize="30"
                                       Text="25w20a" />
                          </Border>
                        </Grid>
                      </Border>

                      <TextBlock Margin="0,22,0,0"
                                 Foreground="#1370F3"
                                 FontSize="26"
                                 FontWeight="Bold"
                                 Text="新特性" />
                      <ItemsControl ItemsSource="{Binding SurfaceSections}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <StackPanel Spacing="6">
                              <ItemsControl ItemsSource="{Binding Lines}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*">
                                      <TextBlock Foreground="#1370F3"
                                                 FontSize="16"
                                                 Text="•" />
                                      <TextBlock Grid.Column="1"
                                                 Margin="10,0,0,0"
                                                 Foreground="#343D4A"
                                                 FontSize="15"
                                                 TextWrapping="Wrap"
                                                 Text="{Binding Text}" />
                                    </Grid>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Border>
                </StackPanel>
              </ScrollViewer>

              <Border HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Margin="0,0,12,20"
                      Width="62"
                      Height="62"
                      Background="#1370F3"
                      CornerRadius="31">
                <Button Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding TogglePromptOverlayCommand}">
                  <TextBlock HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Foreground="White"
                             FontSize="32"
                             Text="▶" />
                </Button>
              </Border>

              <Border IsVisible="{Binding IsPromptOverlayVisible}"
                      Width="480"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top"
                      Margin="0,84,0,0"
                      Background="#F7F9FC"
                      BorderBrush="#404040"
                      BorderThickness="1"
                      CornerRadius="8">
                <StackPanel Margin="18" Spacing="12">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="3">
                      <TextBlock Foreground="#1370F3"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 Text="{Binding PromptInboxTitle}" />
                      <TextBlock Foreground="#343D4A"
                                 FontSize="18"
                                 FontWeight="Bold"
                                 Text="Consent, environment, and first-run prompts." />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Width="26"
                            Height="26"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding DismissPromptOverlayCommand}">
                      <TextBlock HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Foreground="#404040"
                                 FontSize="18"
                                 Text="×" />
                    </Button>
                  </Grid>

                  <ItemsControl ItemsSource="{Binding PromptLanes}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Margin="0,0,10,0"
                                Padding="14,9"
                                Background="{Binding BackgroundBrush}"
                                CornerRadius="17">
                          <Button Background="Transparent"
                                  BorderThickness="0"
                                  Command="{Binding Command}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                              <TextBlock Foreground="{Binding ForegroundBrush}"
                                         FontSize="14"
                                         FontWeight="SemiBold"
                                         Text="{Binding Title}" />
                              <TextBlock Foreground="{Binding ForegroundBrush}"
                                         FontSize="14"
                                         Text="{Binding Count}" />
                            </StackPanel>
                          </Button>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ActivePrompts}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,10"
                                  Padding="14"
                                  Background="#FFFFFF"
                                  BorderBrush="#D5E6FD"
                                  BorderThickness="1"
                                  CornerRadius="6">
                            <StackPanel Spacing="8">
                              <TextBlock Foreground="#1370F3"
                                         FontSize="12"
                                         FontWeight="SemiBold"
                                         Text="{Binding Source}" />
                              <TextBlock Foreground="#343D4A"
                                         FontSize="16"
                                         FontWeight="Bold"
                                         Text="{Binding Title}" />
                              <TextBlock Foreground="#404040"
                                         FontSize="13.5"
                                         TextWrapping="Wrap"
                                         Text="{Binding Message}" />
                              <ItemsControl ItemsSource="{Binding Options}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <Button Margin="0,0,0,8"
                                            Padding="10"
                                            Background="#F4F8FF"
                                            BorderBrush="#D5E6FD"
                                            BorderThickness="1"
                                            Command="{Binding Command}"
                                            HorizontalContentAlignment="Left">
                                      <StackPanel Spacing="3">
                                        <TextBlock Foreground="#343D4A"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Label}" />
                                        <TextBlock Foreground="#737373"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Detail}" />
                                      </StackPanel>
                                    </Button>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </StackPanel>
              </Border>
            </Grid>
          </Border>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>
