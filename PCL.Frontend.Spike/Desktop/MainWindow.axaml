<Window
    x:Class="PCL.Frontend.Spike.Desktop.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PCL Frontend Spike"
    Width="1220"
    Height="780"
    MinWidth="980"
    MinHeight="620"
    Background="Transparent"
    SystemDecorations="None">
  <Grid Margin="10">
    <Border CornerRadius="12"
            Background="#FBFBFB"
            BorderBrush="#C9D8EA"
            BorderThickness="1">
      <Grid RowDefinitions="48,*">
        <Border Grid.Row="0"
                Background="#1370F3"
                CornerRadius="12,12,0,0"
                PointerPressed="TitleBar_OnPointerPressed">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <Grid Grid.Column="0" Margin="18,0,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0"
                      Width="28"
                      Height="28"
                      CornerRadius="8"
                      Background="#FFFFFF"
                      VerticalAlignment="Center">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#1370F3"
                           FontSize="14"
                           FontWeight="Bold"
                           Text="PCL" />
              </Border>
              <TextBlock Grid.Column="1"
                         Margin="10,0,0,0"
                         VerticalAlignment="Center"
                         Foreground="White"
                         FontSize="18"
                         FontWeight="Bold"
                         Text="Plain Craft Launcher" />
              <Border Grid.Column="2"
                      Margin="10,0,0,0"
                      VerticalAlignment="Center"
                      Padding="6,2"
                      Background="#FFFFFF"
                      CornerRadius="5">
                <TextBlock Foreground="#1370F3"
                           FontSize="11"
                           FontWeight="Bold"
                           Text="CE" />
              </Border>
            </Grid>

            <ItemsControl Grid.Column="1"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          ItemsSource="{Binding TopLevelEntries}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="5,0"
                          Padding="12,0"
                          Height="27"
                          Background="{Binding BackgroundBrush}"
                          CornerRadius="13.5">
                    <Button Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding Command}">
                      <TextBlock VerticalAlignment="Center"
                                 Foreground="{Binding ForegroundBrush}"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 Text="{Binding Title}" />
                    </Button>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Grid.Column="2"
                        Margin="0,0,12,0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Spacing="8">
              <Border Padding="8,3"
                      VerticalAlignment="Center"
                      Background="#33FFFFFF"
                      CornerRadius="999">
                <TextBlock Foreground="#F4F8FF"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Text="{Binding EnvironmentLabel}" />
              </Border>
              <Border Width="28"
                      Height="28"
                      Background="#33FFFFFF"
                      CornerRadius="1000">
                <Button Background="Transparent"
                        BorderThickness="0"
                        Click="MinimizeButton_OnClick">
                  <TextBlock HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Foreground="White"
                             FontSize="14"
                             Text="—" />
                </Button>
              </Border>
              <Border Width="28"
                      Height="28"
                      Background="#D84444"
                      CornerRadius="1000">
                <Button Background="Transparent"
                        BorderThickness="0"
                        Click="CloseButton_OnClick">
                  <TextBlock HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Foreground="White"
                             FontSize="16"
                             Text="×" />
                </Button>
              </Border>
            </StackPanel>
          </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="300,*">
          <Border Grid.Column="0"
                  Background="#D2FBFBFB"
                  BorderBrush="#E5EEF8"
                  BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto,Auto,20">
              <StackPanel Margin="20,20,20,0" Spacing="10">
                <TextBlock Foreground="#8F4D23"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Text="{Binding ScenarioLabel}" />
                <TextBlock Foreground="#343D4A"
                           FontSize="19"
                           FontWeight="Bold"
                           Text="{Binding Title}" />
                <TextBlock Foreground="#737373"
                           FontSize="13.5"
                           TextWrapping="Wrap"
                           Text="{Binding Description}" />
              </StackPanel>

              <ScrollViewer Grid.Row="1"
                            Margin="0,16,0,0"
                            VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,0,20,0" Spacing="10">
                  <Border Padding="14"
                          Background="#01EAF2FE"
                          CornerRadius="7">
                    <TextBlock Foreground="#404040"
                               FontSize="12.5"
                               TextWrapping="Wrap"
                               Text="{Binding SurfaceMeta}" />
                  </Border>

                  <ItemsControl ItemsSource="{Binding SidebarEntries}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Height="42"
                                Background="{Binding BackgroundBrush}"
                                CornerRadius="3">
                          <Button Padding="0"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Command="{Binding Command}"
                                  HorizontalContentAlignment="Stretch">
                            <Grid ColumnDefinitions="4,Auto,*" Margin="0,0,8,0">
                              <Border Background="{Binding AccentBrush}" />
                              <TextBlock Grid.Column="1"
                                         Margin="12,0,0,0"
                                         VerticalAlignment="Center"
                                         Foreground="{Binding ForegroundBrush}"
                                         FontSize="13"
                                         FontWeight="SemiBold"
                                         Text="{Binding Title}" />
                              <TextBlock Grid.Column="2"
                                         Margin="8,0,0,0"
                                         VerticalAlignment="Center"
                                         Foreground="#8C8C8C"
                                         FontSize="12"
                                         TextTrimming="CharacterEllipsis"
                                         Text="{Binding Summary}" />
                            </Grid>
                          </Button>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <Border Padding="14"
                          Background="#01EAF2FE"
                          CornerRadius="7">
                    <StackPanel Spacing="6">
                      <TextBlock Foreground="#1370F3"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 Text="启动器状态" />
                      <TextBlock Foreground="#404040"
                                 FontSize="12.5"
                                 TextWrapping="Wrap"
                                 Text="{Binding Status}" />
                      <TextBlock Foreground="#737373"
                                 FontSize="12"
                                 TextWrapping="Wrap"
                                 Text="{Binding BreadcrumbTrail}" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </ScrollViewer>

              <Grid Grid.Row="2" Margin="20,10,20,0" ColumnDefinitions="*,Auto,Auto,10">
                <Border Grid.Column="0"
                        Height="35"
                        CornerRadius="5"
                        BorderBrush="#A6A6A6"
                        BorderThickness="1">
                  <Button Background="Transparent"
                          BorderThickness="0"
                          Command="{Binding BackCommand}"
                          IsEnabled="{Binding CanGoBack}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#404040"
                               FontSize="13"
                               Text="返回" />
                  </Button>
                </Border>
                <Border Grid.Column="1"
                        Margin="10,0,0,0"
                        Height="35"
                        MinWidth="128"
                        CornerRadius="5"
                        Background="#1370F3">
                  <Grid>
                    <TextBlock HorizontalAlignment="Center"
                               Margin="18,0,18,12"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Text="{Binding Title}" />
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Bottom"
                               Margin="18,0,18,7"
                               Foreground="#CFE0FD"
                               FontSize="11"
                               Text="{Binding PromptInboxTitle}" />
                  </Grid>
                </Border>
                <Border Grid.Column="2"
                        Margin="10,0,0,0"
                        Height="35"
                        Padding="12,0"
                        CornerRadius="5"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1"
                        Background="#FFFFFF">
                  <TextBlock VerticalAlignment="Center"
                             Foreground="#737373"
                             FontSize="12"
                             Text="{Binding InputLabel}" />
                </Border>
              </Grid>
            </Grid>
          </Border>

          <Grid Grid.Column="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="25,25,25,10" Spacing="15">
                <Border Padding="20,14,20,15"
                        Background="#FFFFFF"
                        BorderBrush="#D5E6FD"
                        BorderThickness="1"
                        CornerRadius="7">
                  <StackPanel Spacing="8">
                    <TextBlock Foreground="#1370F3"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Text="{Binding Eyebrow}" />
                    <TextBlock Foreground="#343D4A"
                               FontSize="24"
                               FontWeight="Bold"
                               Text="{Binding Title}" />
                    <TextBlock Foreground="#404040"
                               FontSize="13.5"
                               TextWrapping="Wrap"
                               Text="{Binding Description}" />
                  </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding SurfaceFacts}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,12,0"
                              MinWidth="150"
                              Padding="14,10"
                              Background="#01EAF2FE"
                              BorderBrush="#D5E6FD"
                              BorderThickness="1"
                              CornerRadius="5">
                        <StackPanel Spacing="4">
                          <TextBlock Foreground="#1370F3"
                                     FontSize="12"
                                     FontWeight="SemiBold"
                                     Text="{Binding Label}" />
                          <TextBlock Foreground="#343D4A"
                                     FontSize="15"
                                     FontWeight="Bold"
                                     Text="{Binding Value}" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding SurfaceSections}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="#FFFFFF"
                              BorderBrush="#D5E6FD"
                              BorderThickness="1"
                              CornerRadius="7">
                        <StackPanel>
                          <Border Height="3"
                                  Background="#4890F5"
                                  CornerRadius="7,7,0,0" />
                          <StackPanel Margin="20,16,20,16" Spacing="8">
                            <TextBlock Foreground="#1370F3"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Text="{Binding Eyebrow}" />
                            <TextBlock Foreground="#343D4A"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Text="{Binding Title}" />
                            <ItemsControl ItemsSource="{Binding Lines}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <Grid ColumnDefinitions="Auto,*" Margin="0,2,0,2">
                                    <TextBlock Foreground="#1370F3"
                                               FontSize="14"
                                               Text="•" />
                                    <TextBlock Grid.Column="1"
                                               Margin="10,0,0,0"
                                               Foreground="#404040"
                                               FontSize="13.5"
                                               TextWrapping="Wrap"
                                               Text="{Binding Text}" />
                                  </Grid>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Background="#FFFFFF"
                        BorderBrush="#D5E6FD"
                        BorderThickness="1"
                        CornerRadius="7">
                  <StackPanel Margin="20,16,20,18" Spacing="8">
                    <TextBlock Foreground="#1370F3"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="启动日志" />
                    <TextBlock Foreground="#343D4A"
                               FontSize="20"
                               FontWeight="Bold"
                               Text="Shell events" />
                    <ItemsControl ItemsSource="{Binding ActivityEntries}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,8"
                                  Padding="12"
                                  Background="#01EAF2FE"
                                  CornerRadius="5">
                            <Grid ColumnDefinitions="70,*">
                              <TextBlock Foreground="#8C8C8C"
                                         FontSize="12"
                                         VerticalAlignment="Top"
                                         Text="{Binding Time}" />
                              <StackPanel Grid.Column="1" Spacing="3">
                                <TextBlock Foreground="#343D4A"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Text="{Binding Title}" />
                                <TextBlock Foreground="#404040"
                                           FontSize="12.5"
                                           TextWrapping="Wrap"
                                           Text="{Binding Body}" />
                              </StackPanel>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>

            <Border IsVisible="{Binding HasActivePrompts}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,72,0,0"
                    MaxWidth="520"
                    Background="#E5FFFFFF"
                    BorderBrush="#343D4A"
                    BorderThickness="1"
                    CornerRadius="7">
              <StackPanel Margin="18" Spacing="10">
                <TextBlock Foreground="#1370F3"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Text="{Binding PromptInboxTitle}" />
                <TextBlock Foreground="#343D4A"
                           FontSize="18"
                           FontWeight="Bold"
                           Text="{Binding PromptInboxSummary}" />
                <ItemsControl ItemsSource="{Binding PromptLanes}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,8,8"
                              Padding="10,6"
                              Background="{Binding BackgroundBrush}"
                              CornerRadius="13.5">
                        <Button Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding Command}">
                          <TextBlock Foreground="{Binding ForegroundBrush}"
                                     FontSize="12.5"
                                     FontWeight="SemiBold"
                                     Text="{Binding Title}" />
                        </Button>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding ActivePrompts}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,10"
                              Padding="14"
                              Background="#FBFBFB"
                              BorderBrush="#D5E6FD"
                              BorderThickness="1"
                              CornerRadius="5">
                        <StackPanel Spacing="8">
                          <TextBlock Foreground="#1370F3"
                                     FontSize="12"
                                     FontWeight="SemiBold"
                                     Text="{Binding Source}" />
                          <TextBlock Foreground="#343D4A"
                                     FontSize="18"
                                     FontWeight="Bold"
                                     Text="{Binding Title}" />
                          <TextBlock Foreground="#404040"
                                     FontSize="13.5"
                                     TextWrapping="Wrap"
                                     Text="{Binding Message}" />
                          <ItemsControl ItemsSource="{Binding Options}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="10"
                                        Background="#01EAF2FE"
                                        CornerRadius="5">
                                  <Button Padding="0"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Command="{Binding Command}"
                                          HorizontalContentAlignment="Stretch">
                                    <StackPanel Spacing="3">
                                      <TextBlock Foreground="#343D4A"
                                                 FontSize="13"
                                                 FontWeight="SemiBold"
                                                 Text="{Binding Label}" />
                                      <TextBlock Foreground="#737373"
                                                 FontSize="12"
                                                 TextWrapping="Wrap"
                                                 Text="{Binding Detail}" />
                                    </StackPanel>
                                  </Button>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <ItemsControl HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Margin="0,0,15,15"
                          ItemsSource="{Binding UtilityEntries}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <StackPanel Margin="8,0,0,0" Spacing="4">
                    <Border Width="40"
                            Height="40"
                            Background="#1370F3"
                            CornerRadius="1000">
                      <Button Background="Transparent"
                              BorderThickness="0"
                              Command="{Binding Command}">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="White"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Text="{Binding Meta}" />
                      </Button>
                    </Border>
                    <TextBlock HorizontalAlignment="Center"
                               Foreground="#404040"
                               FontSize="11"
                               Text="{Binding Title}" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Grid>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>
