<Window
    x:Class="PCL.Frontend.Spike.Desktop.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    xmlns:motion="clr-namespace:PCL.Frontend.Spike.Desktop.Animation"
    Title="Plain Craft Launcher Community Edition"
    Icon="/Assets/icon.ico"
    Width="1158"
    Height="648"
    MinWidth="980"
    MinHeight="620"
    Background="Transparent"
    SystemDecorations="None"
    TransparencyLevelHint="Transparent"
    WindowStartupLocation="CenterScreen">
  <Window.Styles>
    <Style Selector="Button.chrome">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="MinWidth" Value="28" />
      <Setter Property="MinHeight" Value="28" />
    </Style>

    <Style Selector="Button.flat">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
    </Style>
  </Window.Styles>

  <Grid x:Name="GridRoot">
    <Grid x:Name="GridResize" Margin="10" RowDefinitions="14,*,14" ColumnDefinitions="14,*,14">
      <Border x:Name="TopLeft" Grid.Row="0" Grid.Column="0">
        <Border.Background>
          <RadialGradientBrush Center="100%,100%" GradientOrigin="100%,100%" RadiusX="100%" RadiusY="100%">
            <GradientStop Color="#21000000" Offset="0.43" />
            <GradientStop Color="#11000000" Offset="0.6" />
            <GradientStop Color="#00000000" Offset="1" />
          </RadialGradientBrush>
        </Border.Background>
      </Border>
      <Border x:Name="TopRight" Grid.Row="0" Grid.Column="2">
        <Border.Background>
          <RadialGradientBrush Center="0%,100%" GradientOrigin="0%,100%" RadiusX="100%" RadiusY="100%">
            <GradientStop Color="#21000000" Offset="0.43" />
            <GradientStop Color="#11000000" Offset="0.6" />
            <GradientStop Color="#00000000" Offset="1" />
          </RadialGradientBrush>
        </Border.Background>
      </Border>
      <Border x:Name="BottomLeft" Grid.Row="2" Grid.Column="0">
        <Border.Background>
          <RadialGradientBrush Center="100%,0%" GradientOrigin="100%,0%" RadiusX="100%" RadiusY="100%">
            <GradientStop Color="#21000000" Offset="0.43" />
            <GradientStop Color="#11000000" Offset="0.6" />
            <GradientStop Color="#00000000" Offset="1" />
          </RadialGradientBrush>
        </Border.Background>
      </Border>
      <Border x:Name="BottomRight" Grid.Row="2" Grid.Column="2">
        <Border.Background>
          <RadialGradientBrush Center="0%,0%" GradientOrigin="0%,0%" RadiusX="100%" RadiusY="100%">
            <GradientStop Color="#21000000" Offset="0.43" />
            <GradientStop Color="#11000000" Offset="0.6" />
            <GradientStop Color="#00000000" Offset="1" />
          </RadialGradientBrush>
        </Border.Background>
      </Border>
      <Border x:Name="Top" Grid.Row="0" Grid.Column="1" Height="8" VerticalAlignment="Top">
        <Border.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Color="#00000000" Offset="0" />
            <GradientStop Color="#11000000" Offset="0.7" />
            <GradientStop Color="#21000000" Offset="1.0" />
          </LinearGradientBrush>
        </Border.Background>
      </Border>
      <Border x:Name="Right" Grid.Row="1" Grid.Column="2" Width="8" HorizontalAlignment="Right">
        <Border.Background>
          <LinearGradientBrush StartPoint="100%,0%" EndPoint="0%,0%">
            <GradientStop Color="#00000000" Offset="0" />
            <GradientStop Color="#11000000" Offset="0.7" />
            <GradientStop Color="#21000000" Offset="1.0" />
          </LinearGradientBrush>
        </Border.Background>
      </Border>
      <Border x:Name="Bottom" Grid.Row="2" Grid.Column="1" Height="8" VerticalAlignment="Bottom">
        <Border.Background>
          <LinearGradientBrush StartPoint="0%,100%" EndPoint="0%,0%">
            <GradientStop Color="#00000000" Offset="0" />
            <GradientStop Color="#11000000" Offset="0.7" />
            <GradientStop Color="#21000000" Offset="1.0" />
          </LinearGradientBrush>
        </Border.Background>
      </Border>
      <Border x:Name="Left" Grid.Row="1" Grid.Column="0" Width="8" HorizontalAlignment="Left">
        <Border.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
            <GradientStop Color="#00000000" Offset="0" />
            <GradientStop Color="#11000000" Offset="0.7" />
            <GradientStop Color="#21000000" Offset="1.0" />
          </LinearGradientBrush>
        </Border.Background>
      </Border>
    </Grid>

    <Border x:Name="MainBorder" Margin="18" CornerRadius="15,15,8,8">
      <Border.Background>
        <LinearGradientBrush StartPoint="90%,0%" EndPoint="10%,100%">
          <GradientStop Color="{DynamicResource ColorObjectBg0}" Offset="-0.1" />
          <GradientStop Color="{DynamicResource ColorObject7}" Offset="0.4" />
          <GradientStop Color="{DynamicResource ColorObject6}" Offset="1.1" />
        </LinearGradientBrush>
      </Border.Background>
      <Border.Transitions>
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.2" />
        </Transitions>
      </Border.Transitions>

      <Border x:Name="MainClipBorder" ClipToBounds="True" CornerRadius="6">
        <Grid RowDefinitions="Auto,*">
          <StackPanel
              Margin="19,0,0,0"
              Orientation="Horizontal"
              VerticalAlignment="Center"
              ZIndex="3">
            <Path
                Width="48"
                Height="16"
                Data="M26,29 v-25 h5 a7,7 180 0 1 0,14 h-5 M61,6.5 a10,11.5 180 1 0 0,18 M68,2.5 v24.5 h12 M98,2"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                IsHitTestVisible="False"
                Stretch="Fill"
                Stroke="White"
                StrokeThickness="1.9"
                UseLayoutRounding="False" />

            <Border
                Width="32"
                Height="20"
                Margin="0,0,0,0"
                Background="White"
                CornerRadius="5"
                IsHitTestVisible="False"
                VerticalAlignment="Center">
              <TextBlock
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource ColorBrush2}"
                  Text="CE" />
            </Border>
          </StackPanel>

          <StackPanel
              Grid.Row="0"
              HorizontalAlignment="Right"
              Margin="0,0,12,0"
              Orientation="Horizontal"
              VerticalAlignment="Center"
              ZIndex="3"
              Spacing="2">
            <controls:PclIconButton
                x:Name="MinimizeButton"
                Width="28"
                Height="28"
                IconBrush="#F4FAFF"
                HoverBackgroundBrush="#32FFFFFF"
                Click="MinimizeButton_OnClick" />
            <controls:PclIconButton
                x:Name="MaximizeButton"
                Width="28"
                Height="28"
                IconBrush="#F4FAFF"
                HoverBackgroundBrush="#32FFFFFF"
                Click="MaximizeButton_OnClick" />
            <controls:PclIconButton
                x:Name="CloseButton"
                Width="28"
                Height="28"
                IconBrush="#F4FAFF"
                HoverBackgroundBrush="#32FFFFFF"
                Click="CloseButton_OnClick" />
          </StackPanel>

          <Border
              x:Name="NavBackgroundBorder"
              Grid.Row="0"
              Height="48"
              PointerPressed="TitleBar_OnPointerPressed"
              DoubleTapped="TitleBar_OnDoubleTapped"
              ZIndex="2">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                <GradientStop Color="{DynamicResource ColorObject2}" Offset="0" />
                <GradientStop Color="{DynamicResource ColorObject3}" Offset="0.5" />
                <GradientStop Color="{DynamicResource ColorObject2}" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>

            <Grid ColumnDefinitions="Auto,*,Auto">
              <Grid Grid.Column="1">
                <ItemsControl
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    motion:Motion.AnimateOnVisible="True"
                    motion:Motion.OffsetY="8"
                    IsVisible="{Binding ShowTopLevelNavigation}"
                    ItemsSource="{Binding TopLevelEntries}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <controls:PclTabButton
                          Margin="5,0"
                          Command="{Binding Command}"
                          IconData="{Binding IconPath}"
                          IconScale="{Binding IconScale}"
                          IsSelected="{Binding IsSelected}"
                          Text="{Binding Title}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid
                    Margin="15,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    motion:Motion.AnimateOnVisible="True"
                    motion:Motion.OffsetX="-12"
                    ColumnDefinitions="Auto,*"
                    IsVisible="{Binding ShowInnerNavigation}">
                  <controls:PclIconButton
                      x:Name="BackButton"
                      Width="27"
                      Height="27"
                      VerticalAlignment="Center"
                      Command="{Binding BackCommand}"
                      IconBrush="#F4FAFF"
                      HoverBackgroundBrush="#32FFFFFF"
                      ToolTip.Tip="返回" />
                  <TextBlock
                      Grid.Column="1"
                      Margin="12,0,0,0"
                      VerticalAlignment="Center"
                      Foreground="White"
                      FontSize="15"
                      Text="{Binding TitleBarLabel}" />
                </Grid>
              </Grid>
            </Grid>
          </Border>

          <Grid Grid.Row="1">
            <Grid
                x:Name="LaunchRouteGrid"
                IsVisible="{Binding IsLaunchRoute}"
                ColumnDefinitions="Auto,*">
              <Border
                  x:Name="LaunchLeftHost"
                  Grid.Column="0"
                  Width="300"
                  ClipToBounds="True"
                  Background="{DynamicResource ColorBrushBackgroundTransparentSidebar}">
                <Grid x:Name="LaunchLeftContentHost">
                  <controls:PclLaunchLeftPanel HorizontalAlignment="Center" VerticalAlignment="Stretch" />
                </Grid>
              </Border>

              <Border x:Name="LaunchRightHost" Grid.Column="1" ClipToBounds="True" Background="#08FFFFFF">
                <Grid x:Name="LaunchRightContentHost">
                  <controls:PclLaunchRightPanel />
                </Grid>
              </Border>
            </Grid>

            <Grid
                x:Name="StandardRouteGrid"
                IsVisible="{Binding IsStandardShellRoute}"
                ColumnDefinitions="236,*">
              <Border
                  x:Name="StandardLeftHost"
                  Grid.Column="0"
                  ClipToBounds="True"
                  Background="{DynamicResource ColorBrushBackgroundTransparentSidebar}">
                <Grid x:Name="StandardLeftContentHost">
                  <ContentControl
                      HorizontalContentAlignment="Stretch"
                      VerticalContentAlignment="Stretch"
                      Content="{Binding CurrentStandardLeftPane}" />
                </Grid>
              </Border>

              <Border x:Name="StandardRightHost" Grid.Column="1" ClipToBounds="True" Background="#08FFFFFF">
                <Grid x:Name="StandardRightContentHost">
                  <ContentControl
                      HorizontalContentAlignment="Stretch"
                      VerticalContentAlignment="Stretch"
                      Content="{Binding CurrentStandardRightPane}" />
                </Grid>
              </Border>
            </Grid>

            <StackPanel
                Margin="0,0,12,20"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                motion:Motion.AnimateOnVisible="True"
                motion:Motion.StaggerChildren="True"
                motion:Motion.OffsetY="10"
                Spacing="10">
              <ItemsControl ItemsSource="{Binding UtilityEntries}" IsVisible="{Binding HasUtilityEntries}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <controls:PclExtraButton
                        Margin="0,0,0,10"
                        Command="{Binding Command}"
                        IconData="{Binding IconPath}"
                        ToolTip.Tip="{Binding Title}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <controls:PclExtraButton
                  x:Name="PromptQueueButton"
                  Command="{Binding TogglePromptOverlayCommand}"
                  ToolTip.Tip="提示队列" />
            </StackPanel>

            <Border
                IsVisible="{Binding IsPromptOverlayVisible}"
                motion:Motion.AnimateOnVisible="True"
                motion:Motion.OffsetY="8"
                Background="#500E2038" />

            <Border
                IsVisible="{Binding IsPromptOverlayVisible}"
                Width="520"
                MaxHeight="540"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#00000000"
                BorderBrush="#00000000"
                BorderThickness="0"
                CornerRadius="14">
              <StackPanel
                  Margin="20"
                  motion:Motion.AnimateOnVisible="True"
                  motion:Motion.StaggerChildren="True"
                  motion:Motion.OffsetY="18"
                  Spacing="14">
                <controls:PclCard ContentMargin="20,20,20,20">
                  <controls:PclCard.CardContent>
                    <StackPanel Spacing="14">
                      <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="4">
                          <TextBlock
                              Foreground="#1370F3"
                              FontSize="12"
                              FontWeight="Bold"
                              Text="{Binding PromptInboxTitle}" />
                          <TextBlock
                              Foreground="#343D4A"
                              FontSize="18"
                              FontWeight="SemiBold"
                              Text="{Binding PromptInboxSummary}" />
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            Classes="chrome"
                            Command="{Binding DismissPromptOverlayCommand}">
                          <TextBlock
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Foreground="#404040"
                              FontSize="18"
                              Text="✕" />
                        </Button>
                      </Grid>

                      <ItemsControl ItemsSource="{Binding PromptLanes}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <controls:PclPromptLaneChip
                                Margin="0,0,10,0"
                                BackgroundBrush="{Binding BackgroundBrush}"
                                ChipBorderBrush="{Binding BorderBrush}"
                                Command="{Binding Command}"
                                Count="{Binding Count}"
                                ForegroundBrush="{Binding ForegroundBrush}"
                                Title="{Binding Title}" />
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>

                      <ScrollViewer MaxHeight="410" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="10">
                          <ItemsControl ItemsSource="{Binding ActivePrompts}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <controls:PclPromptCard
                                    AccentBrush="{Binding AccentBrush}"
                                    BadgeBackgroundBrush="{Binding BackgroundBrush}"
                                    Message="{Binding Message}"
                                    Severity="{Binding Severity}"
                                    Source="{Binding Source}"
                                    Title="{Binding Title}">
                                  <controls:PclPromptCard.OptionsContent>
                                    <ItemsControl ItemsSource="{Binding Options}">
                                      <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                          <controls:PclPromptOption
                                              Margin="0,0,0,8"
                                              Command="{Binding Command}"
                                              Detail="{Binding Detail}"
                                              Label="{Binding Label}" />
                                        </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                  </controls:PclPromptCard.OptionsContent>
                                </controls:PclPromptCard>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>

                          <TextBlock
                              HorizontalAlignment="Center"
                              Foreground="#7D8897"
                              FontSize="12"
                              Text="{Binding PromptEmptyState}"
                              IsVisible="{Binding HasNoActivePrompts}" />
                        </StackPanel>
                      </ScrollViewer>
                    </StackPanel>
                  </controls:PclCard.CardContent>
                </controls:PclCard>
              </StackPanel>
            </Border>
          </Grid>
        </Grid>
      </Border>
    </Border>
  </Grid>
</Window>
