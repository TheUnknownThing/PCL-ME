<Window
    x:Class="PCL.Frontend.Spike.Desktop.Dialogs.PclChoiceDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    Width="560"
    Height="420"
    MinWidth="560"
    MinHeight="420"
    MaxWidth="560"
    MaxHeight="420"
    CanResize="False"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    Title="选择">
  <Grid Background="#EAF4FE">
    <controls:PclCard Margin="20" ContentMargin="20">
      <controls:PclCard.CardContent>
        <Grid RowDefinitions="Auto,Auto,*,Auto">
          <StackPanel Spacing="6">
            <TextBlock
                x:Name="TitleTextBlock"
                Foreground="#343D4A"
                FontSize="18"
                FontWeight="SemiBold" />
            <TextBlock
                x:Name="MessageTextBlock"
                Foreground="#4C5664"
                FontSize="13"
                TextWrapping="Wrap" />
          </StackPanel>

          <Border
              Grid.Row="1"
              Margin="0,14,0,14"
              Padding="10,8"
              Background="#F7FBFF"
              BorderBrush="#D9E7F5"
              BorderThickness="1"
              CornerRadius="8">
            <TextBlock
                x:Name="SelectionSummaryTextBlock"
                Foreground="#617284"
                FontSize="12.5"
                TextWrapping="Wrap" />
          </Border>

          <Border
              Grid.Row="2"
              Background="#FFFFFF"
              BorderBrush="#D9E7F5"
              BorderThickness="1"
              CornerRadius="8">
            <ListBox
                x:Name="ChoiceListBox"
                Background="Transparent"
                BorderThickness="0">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Margin="10,8" Spacing="4">
                    <TextBlock
                        Foreground="#343D4A"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="{Binding Title}" />
                    <TextBlock
                        Foreground="#697A8C"
                        FontSize="12.5"
                        Text="{Binding Summary}"
                        TextWrapping="Wrap" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Border>

          <Grid
              Grid.Row="3"
              Margin="0,16,0,0"
              ColumnDefinitions="*,Auto,Auto">
            <controls:PclOutlineButton
                Grid.Column="1"
                Margin="0,0,12,0"
                Width="108"
                Text="取消"
                Command="{Binding CancelCommand}" />
            <controls:PclButton
                Grid.Column="2"
                Width="128"
                Text="{Binding ConfirmText}"
                ContentPadding="14,7"
                ColorType="Highlight"
                Command="{Binding ConfirmCommand}" />
          </Grid>
        </Grid>
      </controls:PclCard.CardContent>
    </controls:PclCard>
  </Grid>
</Window>
