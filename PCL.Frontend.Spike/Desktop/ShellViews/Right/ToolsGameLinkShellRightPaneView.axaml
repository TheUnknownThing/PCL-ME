<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.ToolsGameLinkShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    DataContext="{Binding Shell}">
  <UserControl.Styles>
    <Style Selector="Button.link-action">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>
    <Style Selector="Button.meta-link">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
  </UserControl.Styles>
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="10">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Border
          Grid.Row="0"
          Margin="10,10,10,0"
          Padding="14,10"
          Background="#EAF2FE"
          BorderBrush="#D5E6FD"
          BorderThickness="1"
          CornerRadius="5">
        <TextBlock
            Foreground="#4068A8"
            FontSize="12.5"
            Text="{Binding GameLinkAnnouncement}"
            TextWrapping="Wrap" />
      </Border>

      <StackPanel Grid.Row="1" Margin="0,10,0,0" Spacing="0">
        <controls:PclCard Margin="10,10,10,0" Header="PCL CE 联机大厅说明与条款" ContentMargin="20,40,18,18">
          <controls:PclCard.CardContent>
            <StackPanel Spacing="10">
              <TextBlock
                  Foreground="#4B5968"
                  FontSize="13"
                  Text="此处列出了 PCL CE 大厅使用的相关服务文档及介绍。"
                  TextWrapping="Wrap" />
              <ItemsControl ItemsSource="{Binding GameLinkPolicyEntries}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <controls:PclListItem
                        Margin="0,0,0,8"
                        Command="{Binding Command}"
                        Info="{Binding Info}"
                        Title="{Binding Title}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock
                  Foreground="#4B5968"
                  FontSize="13"
                  Text="使用大厅功能即代表你同意下列条款：&#x0a;&#x0a;我承诺严格遵守中国大陆相关法律法规，不会将大厅功能用于违法违规用途。&#x0a;我承诺使用大厅功能带来的一切风险自行承担。&#x0a;我已知晓并同意 PCL CE 收集经处理的本机识别码、Natayark ID 与其他信息并在必要时提供给执法部门。&#x0a;为保护未成年人个人信息，使用联机大厅前，我确认我已满十四周岁。&#x0a;&#x0a;另外，你还需要同意 PCL CE 大厅相关隐私政策及《Natayark OpenID 服务条款》。"
                  TextWrapping="Wrap" />
              <controls:PclButton
                  Width="160"
                  Height="35"
                  HorizontalAlignment="Center"
                  Command="{Binding AcceptGameLinkTermsCommand}"
                  ColorType="Highlight"
                  Text="我已阅读并同意" />
            </StackPanel>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <StackPanel Margin="10,4,10,0" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="12">
          <Border
              Padding="12,8"
              Background="#F8FBFF"
              BorderBrush="#D5E6FD"
              BorderThickness="1"
              CornerRadius="5">
            <Button
                Classes="meta-link"
                Command="{Binding TestLobbyNatCommand}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Foreground="#677789" FontSize="12.5" Text="NAT 类型" />
                <TextBlock Foreground="#343D4A" FontSize="12.5" Text="{Binding GameLinkNatStatus}" />
              </StackPanel>
            </Button>
          </Border>

          <Border
              Padding="12,8"
              Background="#F8FBFF"
              BorderBrush="#D5E6FD"
              BorderThickness="1"
              CornerRadius="5">
            <Button
                Classes="meta-link"
                Command="{Binding LoginNatayarkAccountCommand}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Foreground="#677789" FontSize="12.5" Text="Natayark 账户" />
                <TextBlock Foreground="#343D4A" FontSize="12.5" Text="{Binding GameLinkAccountStatus}" />
              </StackPanel>
            </Button>
          </Border>
        </StackPanel>

        <Grid Margin="10,10,10,0" ColumnDefinitions="1.35*,18,1*" RowDefinitions="Auto">
          <StackPanel Grid.Column="0" Spacing="10">
            <controls:PclCard Header="加入大厅" ContentMargin="20,40,18,18">
              <controls:PclCard.CardContent>
                <StackPanel Spacing="10">
                  <TextBlock
                      Foreground="#4B5968"
                      FontSize="13"
                      Text="1、在下方输入朋友发送给你的大厅编号，单击【加入】。2、启动游戏，选择【多人游戏】，在局域网游戏中加入大厅。"
                      TextWrapping="Wrap" />
                  <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                    <TextBox
                        Height="28"
                        Padding="8,4"
                        Text="{Binding GameLinkLobbyId}"
                        Watermark="编号应该长得像这样：U/NNNN-AAAA-SSSS-EEEE" />
                    <controls:PclButton
                        Grid.Column="1"
                        Width="70"
                        Margin="10,0,0,0"
                        Command="{Binding ClearLobbyIdCommand}"
                        Text="清除" />
                    <controls:PclButton
                        Grid.Column="2"
                        Width="70"
                        Margin="10,0,0,0"
                        Command="{Binding PasteLobbyIdCommand}"
                        Text="粘贴" />
                    <controls:PclButton
                        Grid.Column="3"
                        Width="70"
                        Margin="10,0,0,0"
                        Command="{Binding JoinLobbyCommand}"
                        ColorType="Highlight"
                        Text="加入" />
                  </Grid>
                </StackPanel>
              </controls:PclCard.CardContent>
            </controls:PclCard>

            <controls:PclCard Header="创建大厅" ShowChevron="True" IsChevronExpanded="True" ContentMargin="20,40,18,18">
              <controls:PclCard.CardContent>
                <StackPanel Spacing="10">
                  <TextBlock
                      Foreground="#4B5968"
                      FontSize="13"
                      Text="1、进入世界后，在游戏菜单中选择【对局域网开放】。2、在下方选择此游戏实例，单击【创建】。3、成功创建大厅后，复制大厅编号并发送给你的朋友。"
                      TextWrapping="Wrap" />
                  <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                    <ComboBox
                        Height="28"
                        ItemsSource="{Binding GameLinkWorldOptions}"
                        SelectedIndex="{Binding SelectedGameLinkWorldIndex}" />
                    <controls:PclButton
                        Grid.Column="1"
                        Width="90"
                        Margin="10,0,0,0"
                        Command="{Binding InputLobbyPortCommand}"
                        Text="手动输入" />
                    <controls:PclButton
                        Grid.Column="2"
                        Width="70"
                        Margin="10,0,0,0"
                        Command="{Binding RefreshLobbyWorldsCommand}"
                        Text="刷新" />
                    <controls:PclButton
                        Grid.Column="3"
                        Width="70"
                        Margin="10,0,0,0"
                        Command="{Binding CreateLobbyCommand}"
                        ColorType="Highlight"
                        Text="创建" />
                  </Grid>
                </StackPanel>
              </controls:PclCard.CardContent>
            </controls:PclCard>
          </StackPanel>

          <StackPanel Grid.Column="2" Spacing="10">
            <controls:PclCard Header="大厅信息" ContentMargin="18,36,18,14">
              <controls:PclCard.CardContent>
                <WrapPanel>
                  <StackPanel Margin="0,0,10,0" Orientation="Horizontal">
                    <TextBlock Foreground="#7D8897" FontSize="12.5" Text="大厅延迟" />
                    <TextBlock Margin="7,0,12,0" Foreground="#343D4A" FontSize="12.5" Text="{Binding GameLinkSessionPing}" />
                  </StackPanel>
                  <TextBlock Margin="0,0,12,0" Foreground="#A0A9B5" FontSize="12" Text="|" />
                  <StackPanel Margin="0,0,10,0" Orientation="Horizontal">
                    <TextBlock Foreground="#7D8897" FontSize="12.5" Text="大厅编号" />
                    <TextBlock Margin="7,0,12,0" Foreground="#343D4A" FontSize="12.5" Text="{Binding GameLinkSessionId}" />
                  </StackPanel>
                  <TextBlock Margin="0,0,12,0" Foreground="#A0A9B5" FontSize="12" Text="|" />
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="#7D8897" FontSize="12.5" Text="连接方式" />
                    <TextBlock Margin="7,0,0,0" Foreground="#343D4A" FontSize="12.5" Text="{Binding GameLinkConnectionType}" />
                  </StackPanel>
                </WrapPanel>
              </controls:PclCard.CardContent>
            </controls:PclCard>

            <controls:PclCard Header="用户信息" ContentMargin="18,36,18,14">
              <controls:PclCard.CardContent>
                <WrapPanel>
                  <StackPanel Margin="0,0,10,0" Orientation="Horizontal">
                    <TextBlock Foreground="#7D8897" FontSize="12.5" Text="用户名" />
                    <TextBlock Margin="7,0,12,0" Foreground="#343D4A" FontSize="12.5" Text="{Binding GameLinkConnectedUserName}" />
                  </StackPanel>
                  <TextBlock Margin="0,0,12,0" Foreground="#A0A9B5" FontSize="12" Text="|" />
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="#7D8897" FontSize="12.5" Text="用户类型" />
                    <TextBlock Margin="7,0,0,0" Foreground="#343D4A" FontSize="12.5" Text="{Binding GameLinkConnectedUserType}" />
                  </StackPanel>
                </WrapPanel>
              </controls:PclCard.CardContent>
            </controls:PclCard>

            <controls:PclCard Header="大厅操作" ContentMargin="10,35,10,10">
              <controls:PclCard.CardContent>
                <StackPanel>
                  <Button Classes="link-action" Command="{Binding CopyLobbyVirtualIpCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Path Width="14" Height="14" Fill="#5F8DE8" Stretch="Uniform" Data="M394.666667 106.666667h448a74.666667 74.666667 0 0 1 74.666666 74.666666v448a74.666667 74.666667 0 0 1-74.666666 74.666667H394.666667a74.666667 74.666667 0 0 1-74.666667-74.666667V181.333333a74.666667 74.666667 0 0 1 74.666667-74.666666z m0 64a10.666667 10.666667 0 0 0-10.666667 10.666666v448a10.666667 10.666667 0 0 0 10.666667 10.666667h448a10.666667 10.666667 0 0 0 10.666666-10.666667V181.333333a10.666667 10.666667 0 0 0-10.666666-10.666666H394.666667z m245.333333 597.333333a32 32 0 0 1 64 0v74.666667a74.666667 74.666667 0 0 1-74.666667 74.666666H181.333333a74.666667 74.666667 0 0 1-74.666666-74.666666V394.666667a74.666667 74.666667 0 0 1 74.666666-74.666667h74.666667a32 32 0 0 1 0 64h-74.666667a10.666667 10.666667 0 0 0-10.666666 10.666667v448a10.666667 10.666667 0 0 0 10.666666 10.666666h448a10.666667 10.666667 0 0 0 10.666667-10.666666v-74.666667z" />
                      <TextBlock Foreground="#4B5968" FontSize="13" Text="复制虚拟 IP" />
                    </StackPanel>
                  </Button>
                  <Button Classes="link-action" Command="{Binding CopyActiveLobbyIdCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Path Width="14" Height="14" Fill="#5F8DE8" Stretch="Uniform" Data="M394.666667 106.666667h448a74.666667 74.666667 0 0 1 74.666666 74.666666v448a74.666667 74.666667 0 0 1-74.666666 74.666667H394.666667a74.666667 74.666667 0 0 1-74.666667-74.666667V181.333333a74.666667 74.666667 0 0 1 74.666667-74.666666z m0 64a10.666667 10.666667 0 0 0-10.666667 10.666666v448a10.666667 10.666667 0 0 0 10.666667 10.666667h448a10.666667 10.666667 0 0 0 10.666666-10.666667V181.333333a10.666667 10.666667 0 0 0-10.666666-10.666666H394.666667z m245.333333 597.333333a32 32 0 0 1 64 0v74.666667a74.666667 74.666667 0 0 1-74.666667 74.666666H181.333333a74.666667 74.666667 0 0 1-74.666666-74.666666V394.666667a74.666667 74.666667 0 0 1 74.666666-74.666667h74.666667a32 32 0 0 1 0 64h-74.666667a10.666667 10.666667 0 0 0-10.666666 10.666667v448a10.666667 10.666667 0 0 0 10.666666 10.666666h448a10.666667 10.666667 0 0 0 10.666667-10.666666v-74.666667z" />
                      <TextBlock Foreground="#4B5968" FontSize="13" Text="复制大厅编号" />
                    </StackPanel>
                  </Button>
                  <Button Classes="link-action" Command="{Binding ExitLobbyCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Path Width="14" Height="14" Fill="#5F8DE8" Stretch="Uniform" Data="M718.9248 239.328c24.1984 17.2096 45.7152 36.704 64.5376 58.4896s34.9568 45.312 48.4032 70.592c13.4464 25.28 23.6608 52.032 30.6496 80.2688 6.9952 28.2368 10.4896 56.8704 10.4896 85.9136 0 50.016-9.5424 96.9408-28.64 140.7744-19.0848 43.8336-44.9088 82.016-77.4464 114.5536s-70.7264 58.3552-114.5536 77.4464C608.5376 886.4576 561.6192 896 511.5968 896c-49.472 0-96.1344-9.5424-139.9616-28.64-43.8336-19.0848-82.1504-44.9088-114.9568-77.4464s-58.6176-70.7264-77.4464-114.5536-28.2368-90.7584-28.2368-140.7744c0-28.4992 3.36-56.4736 10.0864-83.8976 6.72-27.4304 16.2624-53.5104 28.64-78.2464 12.3712-24.7424 27.6928-47.872 45.984-69.376 18.2848-21.5168 38.72-40.8768 61.3056-58.0928 11.84-8.6016 24.608-11.8272 38.3232-9.6768 13.7152 2.1504 24.8704 8.8768 33.472 20.1664 8.608 11.296 11.84 23.936 9.6896 37.92-2.1568 13.984-8.8768 25.28-20.1728 33.8816C324.4352 352 298.4896 382.3872 280.4736 418.4192c-18.016 36.032-27.0336 74.7584-27.0336 116.1664 0 35.5008 6.7264 68.9728 20.1728 100.4352 13.4464 31.4624 31.8656 58.8928 55.2576 82.2848 23.3984 23.392 50.8224 41.952 82.2848 55.6608 31.4624 13.7216 64.9344 20.576 100.4288 20.576 35.5008 0 68.9792-6.8544 100.4352-20.576 31.4624-13.7152 58.8928-32.2688 82.2848-55.6608 23.3984-23.392 41.952-50.8224 55.6608-82.2848 13.7216-31.4624 20.576-64.9344 20.576-100.4352 0-41.952-9.6832-81.6128-29.0432-118.9888s-46.5216-68.1664-81.472-92.3712c-11.84-8.064-18.9632-19.0912-21.3824-33.0688-2.4192-13.9904 0.4032-26.8928 8.4672-38.7264 8.0704-11.296 19.0912-18.1504 33.0752-20.5696C694.1824 228.4352 707.0912 231.264 718.9248 239.328L718.9248 239.328zM511.5968 537.0048c-13.984 0-25.9456-4.9728-35.8912-14.9184-9.952-9.952-14.9248-21.92-14.9248-35.904L460.7808 179.6288c0-13.984 4.9728-26.08 14.9248-36.3008S497.6128 128 511.5968 128c14.528 0 26.7648 5.1072 36.704 15.328 9.9584 10.2208 14.9312 22.3168 14.9312 36.3008l0 306.5536c0 13.984-4.9728 25.952-14.9312 35.904C538.3552 532.032 526.1184 537.0048 511.5968 537.0048L511.5968 537.0048zM511.5968 537.0048" />
                      <TextBlock Foreground="#4B5968" FontSize="13" Text="退出大厅" />
                    </StackPanel>
                  </Button>
                </StackPanel>
              </controls:PclCard.CardContent>
            </controls:PclCard>

            <controls:PclCard Header="{Binding GameLinkPlayerListTitle}" ContentMargin="12,35,12,10">
              <controls:PclCard.CardContent>
                <ItemsControl ItemsSource="{Binding GameLinkPlayerEntries}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <controls:PclListItem
                          Margin="0,0,0,8"
                          Command="{Binding Command}"
                          Info="{Binding Info}"
                          Title="{Binding Title}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </controls:PclCard.CardContent>
            </controls:PclCard>
          </StackPanel>
        </Grid>
      </StackPanel>

      <StackPanel Grid.Row="2" Margin="10,12,10,8" Spacing="0">
        <WrapPanel HorizontalAlignment="Center">
          <Button
              Classes="meta-link"
              Margin="0,0,8,8"
              Command="{Binding OpenLobbyReportCommand}">
            <TextBlock Foreground="#7D8897" FontSize="12" Text="违法违规举报" />
          </Button>
          <TextBlock Margin="0,0,8,8" Foreground="#A0A9B5" FontSize="12" Text="|" />
          <Button
              Classes="meta-link"
              Margin="0,0,8,8"
              Command="{Binding OpenNatayarkPolicyCommand}">
            <TextBlock Foreground="#7D8897" FontSize="12" Text="Natayark Network 用户协议与隐私政策" />
          </Button>
          <TextBlock Margin="0,0,8,8" Foreground="#A0A9B5" FontSize="12" Text="|" />
          <Button
              Classes="meta-link"
              Margin="0,0,8,8"
              Command="{Binding OpenLobbyPrivacyPolicyCommand}">
            <TextBlock Foreground="#7D8897" FontSize="12" Text="大厅隐私协议" />
          </Button>
          <TextBlock Margin="0,0,8,8" Foreground="#A0A9B5" FontSize="12" Text="|" />
          <Button
              Classes="meta-link"
              Margin="0,0,8,8"
              Command="{Binding DisableGameLinkFeatureCommand}">
            <TextBlock Foreground="#7D8897" FontSize="12" Text="停用联机功能" />
          </Button>
          <TextBlock Margin="0,0,8,8" Foreground="#A0A9B5" FontSize="12" Text="|" />
          <Button
              Classes="meta-link"
              Margin="0,0,0,8"
              Command="{Binding OpenGameLinkFaqCommand}">
            <TextBlock Foreground="#7D8897" FontSize="12" Text="常见问题解答" />
          </Button>
        </WrapPanel>

        <WrapPanel HorizontalAlignment="Center">
          <TextBlock Margin="0,0,8,8" Foreground="#7D8897" FontSize="12" Text="友情链接：" />
          <Button
              Classes="meta-link"
              Margin="0,0,8,8"
              Command="{Binding OpenEasyTierWebsiteCommand}">
            <TextBlock Foreground="#7D8897" FontSize="12" Text="EasyTier 工具官网" />
          </Button>
          <TextBlock Margin="0,0,8,8" Foreground="#A0A9B5" FontSize="12" Text="|" />
          <Button
              Classes="meta-link"
              Margin="0,0,0,8"
              Command="{Binding OpenPysioWebsiteCommand}">
            <TextBlock Foreground="#7D8897" FontSize="12" Text="Pysio's Home" />
          </Button>
        </WrapPanel>
      </StackPanel>
    </Grid>
  </ScrollViewer>
</UserControl>
