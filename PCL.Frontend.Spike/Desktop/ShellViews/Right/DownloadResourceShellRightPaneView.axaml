<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.DownloadResourceShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,10,25,25" Spacing="15">
      <Border
          Height="40"
          Padding="12,0"
          Background="#F8FBFF"
          BorderBrush="#D5E6FD"
          BorderThickness="1"
          CornerRadius="5">
        <TextBox
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            FontSize="13.5"
            Text="{Binding DownloadResourceSearchQuery}"
            VerticalContentAlignment="Center"
            Watermark="搜索资源" />
      </Border>

      <controls:PclCard ContentMargin="16,16,16,16">
        <controls:PclCard.CardContent>
          <Grid ColumnDefinitions="Auto,*,Auto,1.3*,Auto,*,Auto" RowDefinitions="30,8,30">
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                Margin="4,0,8,0"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13"
                Text="来源" />
            <ComboBox
                Grid.Row="0"
                Grid.Column="1"
                SelectedIndex="{Binding SelectedDownloadResourceSourceIndex}"
                ItemsSource="{Binding DownloadResourceSourceOptions}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock
                Grid.Row="0"
                Grid.Column="2"
                Margin="12,0,8,0"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13"
                Text="标签" />
            <ComboBox
                Grid.Row="0"
                Grid.Column="3"
                SelectedIndex="{Binding SelectedDownloadResourceTagIndex}"
                ItemsSource="{Binding DownloadResourceTagOptions}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock
                Grid.Row="0"
                Grid.Column="4"
                Margin="12,0,8,0"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13"
                Text="排序方式" />
            <ComboBox
                Grid.Row="0"
                Grid.Column="5"
                SelectedIndex="{Binding SelectedDownloadResourceSortIndex}"
                ItemsSource="{Binding DownloadResourceSortOptions}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <StackPanel
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="6"
                Margin="12,0,0,0"
                HorizontalAlignment="Right"
                Spacing="8">
              <controls:PclButton
                  Width="86"
                  Height="30"
                  Command="{Binding ResetDownloadResourceFiltersCommand}"
                  Text="重置条件" />
              <controls:PclButton
                  Width="86"
                  Height="30"
                  Command="{Binding InstallDownloadResourceModPackCommand}"
                  IsVisible="{Binding ShowDownloadResourceInstallModPackAction}"
                  Text="安装整合包" />
            </StackPanel>

            <TextBlock
                Grid.Row="2"
                Grid.Column="0"
                Margin="4,0,8,0"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13"
                Text="版本" />
            <ComboBox
                Grid.Row="2"
                Grid.Column="1"
                SelectedIndex="{Binding SelectedDownloadResourceVersionIndex}"
                ItemsSource="{Binding DownloadResourceVersionOptions}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock
                Grid.Row="2"
                Grid.Column="2"
                Margin="12,0,8,0"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13"
                Text="加载器" />
            <ComboBox
                Grid.Row="2"
                Grid.Column="3"
                SelectedIndex="{Binding SelectedDownloadResourceLoaderIndex}"
                ItemsSource="{Binding DownloadResourceLoaderOptions}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <Border
          Padding="12,10"
          Background="#FFF8DD"
          BorderBrush="#F2D777"
          BorderThickness="1"
          CornerRadius="4"
          IsVisible="{Binding ShowDownloadResourceHint}">
        <TextBlock
            Foreground="#6E5800"
            FontSize="12.5"
            Text="{Binding DownloadResourceHintText}"
            TextWrapping="Wrap" />
      </Border>

      <controls:PclCard Header="{Binding DownloadResourceSurfaceTitle}" ContentMargin="14,38,14,14">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <ItemsControl ItemsSource="{Binding DownloadResourceEntries}" IsVisible="{Binding HasDownloadResourceEntries}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,0,0,12" ColumnDefinitions="Auto,*,Auto">
                    <Border
                        Width="42"
                        Height="42"
                        Margin="0,0,12,0"
                        Background="#F7FAFE"
                        BorderBrush="#D5E6FD"
                        BorderThickness="1"
                        CornerRadius="6">
                      <Image
                          Width="28"
                          Height="28"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Source="{Binding Icon}"
                          Stretch="Uniform" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0" Spacing="3">
                      <TextBlock
                          Foreground="#343D4A"
                          FontSize="13.5"
                          FontWeight="SemiBold"
                          Text="{Binding Title}" />
                      <TextBlock
                          Foreground="#677789"
                          FontSize="12.5"
                          Text="{Binding Info}"
                          TextWrapping="Wrap" />
                      <Border
                          Padding="8,4"
                          Background="#F7FAFE"
                          BorderBrush="#D5E6FD"
                          BorderThickness="1"
                          CornerRadius="4">
                        <TextBlock
                            Foreground="#4B78C2"
                            FontSize="11.5"
                            Text="{Binding Meta}" />
                      </Border>
                    </StackPanel>

                    <controls:PclButton
                        Grid.Column="2"
                        Width="96"
                        Height="35"
                        VerticalAlignment="Center"
                        Command="{Binding Command}"
                        Text="{Binding ActionText}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel IsVisible="{Binding HasNoDownloadResourceEntries}" Spacing="6">
              <TextBlock
                  Foreground="#677789"
                  FontSize="13"
                  Text="{Binding DownloadResourceEmptyStateText}"
                  TextWrapping="Wrap" />
              <TextBlock
                  Foreground="#96A2B1"
                  FontSize="12"
                  Text="{Binding DownloadResourceLoadingText}"
                  TextWrapping="Wrap" />
            </StackPanel>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard ContentMargin="10,10,10,10">
        <controls:PclCard.CardContent>
          <Grid ColumnDefinitions="Auto,Auto,*,Auto">
            <controls:PclButton
                Grid.Column="0"
                Width="72"
                Command="{Binding FirstDownloadResourcePageCommand}"
                Text="首页" />
            <controls:PclButton
                Grid.Column="1"
                Width="72"
                Margin="8,0,0,0"
                Command="{Binding PreviousDownloadResourcePageCommand}"
                Text="上一页" />
            <TextBlock
                Grid.Column="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="#4B5968"
                FontSize="13.5"
                FontWeight="SemiBold"
                Text="{Binding DownloadResourcePageLabel}" />
            <controls:PclButton
                Grid.Column="3"
                Width="72"
                HorizontalAlignment="Right"
                Command="{Binding NextDownloadResourcePageCommand}"
                Text="下一页" />
          </Grid>
        </controls:PclCard.CardContent>
      </controls:PclCard>
    </StackPanel>
  </ScrollViewer>
</UserControl>
