<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.DownloadResourceShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,10,25,25" Spacing="15">
      <Border
          Height="40"
          Padding="12,0,10,0"
          Background="#F8FBFF"
          BorderBrush="#D5E6FD"
          BorderThickness="1"
          CornerRadius="5">
        <Grid ColumnDefinitions="*,Auto">
          <TextBox
              Background="Transparent"
              BorderBrush="Transparent"
              BorderThickness="0"
              FontSize="13.5"
              Text="{Binding DownloadResourceSearchQuery}"
              VerticalContentAlignment="Center"
              Watermark="{Binding DownloadResourceSearchWatermark}" />
          <Path
              Grid.Column="1"
              Width="14"
              Height="14"
              Margin="10,0,0,0"
              VerticalAlignment="Center"
              Fill="#7B8EA5"
              Stretch="Uniform"
              Data="M15.5,14H14.71L14.43,13.73A6.471,6.471 0 0,0 16,9.5A6.5,6.5 0 1,0 9.5,16A6.471,6.471 0 0,0 13.73,14.43L14,14.71V15.5L19,20.49L20.49,19L15.5,14M9.5,14A4.5,4.5 0 1,1 14,9.5A4.5,4.5 0 0,1 9.5,14Z" />
        </Grid>
      </Border>

      <controls:PclCard ContentMargin="16,14,16,14">
        <controls:PclCard.CardContent>
          <Grid ColumnDefinitions="Auto,*,Auto,1.3*,Auto,*,Auto" RowDefinitions="28,8,28">
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                Margin="5,0,7,0"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13"
                Text="来源" />
            <ComboBox
                Grid.Row="0"
                Grid.Column="1"
                SelectedIndex="{Binding SelectedDownloadResourceSourceIndex}"
                ItemsSource="{Binding DownloadResourceSourceOptions}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock
                Grid.Row="0"
                Grid.Column="2"
                Margin="12,0,7,0"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13"
                Text="标签" />
            <ComboBox
                Grid.Row="0"
                Grid.Column="3"
                SelectedIndex="{Binding SelectedDownloadResourceTagIndex}"
                ItemsSource="{Binding DownloadResourceTagOptions}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock
                Grid.Row="0"
                Grid.Column="4"
                Margin="12,0,7,0"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13"
                Text="排序方式" />
            <ComboBox
                Grid.Row="0"
                Grid.Column="5"
                SelectedIndex="{Binding SelectedDownloadResourceSortIndex}"
                ItemsSource="{Binding DownloadResourceSortOptions}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <StackPanel
                Grid.Row="0"
                Grid.Column="6"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="4">
              <controls:PclIconButton
                  Command="{Binding ResetDownloadResourceFiltersCommand}"
                  HoverBackgroundBrush="#2A0B5BCB"
                  IconBrush="#63758B"
                  IconData="F1 M 3 2 A 1 1 0 0 0 2 3 V 8 A 1.0001 1.0001 0 0 0 3 9 H 8 A 1 1 0 0 0 9 8 A 1 1 0 0 0 8 7 H 4 V 3 A 1 1 0 0 0 3 2 Z m 8.99609 0 C 9.22233 2.01043 6.55872 3.09358 4.56445 5.02148 a 1.0001 1.0001 0 0 0 -0.011719 0.011719 L 2.29297 7.29297 a 1 1 0 0 0 0 1.41406 a 1 1 0 0 0 1.41406 0 L 5.95508 6.45898 C 7.57782 4.89024 9.74308 4.0095 12 4 c 3.60637 0 6.23273 2.14173 7.39062 4.9375 c 1.1579 2.79577 0.815357 6.16902 -1.73438 8.71875 c -2.54973 2.54973 -5.92298 2.89227 -8.71875 1.73438 C 6.14173 18.2327 4 15.6064 4 12 A 1 1 0 0 0 3 11 A 1 1 0 0 0 2 12 c 0 4.41234 2.70513 7.80169 6.17383 9.23828 c 3.4687 1.43659 7.77682 0.951691 10.8965 -2.16797 c 3.11966 -3.11966 3.60456 -7.42779 2.16797 -10.8965 C 19.8017 4.70513 16.4123 2 12 2 a 1.0001 1.0001 0 0 0 -0.0039 0 z" />
              <controls:PclIconButton
                  Command="{Binding InstallDownloadResourceModPackCommand}"
                  HoverBackgroundBrush="#2A0B5BCB"
                  IconBrush="#63758B"
                  IconData="F1 m 7 9 a 1 1 0 0 0 -0.707031 0.292969 a 1 1 0 0 0 0 1.41406 l 5 5 a 1.0001 1.0001 0 0 0 1.41406 0 l 5 -5 a 1 1 0 0 0 0 -1.41406 a 1 1 0 0 0 -1.41406 0 L 12 13.5859 L 7.70703 9.29297 A 1 1 0 0 0 7 9 Z m -4 5 a 1 1 0 0 0 -1 1 v 4 c 0 1.64501 1.35499 3 3 3 h 14 c 1.64501 0 3 -1.35499 3 -3 v -4 a 1 1 0 0 0 -1 -1 a 1 1 0 0 0 -1 1 v 4 c 0 0.564129 -0.435871 1 -1 1 H 5 C 4.43587 20 4 19.5641 4 19 V 15 A 1 1 0 0 0 3 14 Z M 12 2 a 1 1 0 0 0 -1 1 v 12 a 1 1 0 0 0 1 1 a 1 1 0 0 0 1 -1 V 3 A 1 1 0 0 0 12 2 Z"
                  IsVisible="{Binding ShowDownloadResourceInstallModPackAction}" />
            </StackPanel>

            <TextBlock
                Grid.Row="2"
                Grid.Column="0"
                Margin="5,0,7,0"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13"
                Text="版本" />
            <ComboBox
                Grid.Row="2"
                Grid.Column="1"
                SelectedIndex="{Binding SelectedDownloadResourceVersionIndex}"
                ItemsSource="{Binding DownloadResourceVersionOptions}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock
                Grid.Row="2"
                Grid.Column="2"
                Margin="12,0,7,0"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13"
                Text="加载器" />
            <ComboBox
                Grid.Row="2"
                Grid.Column="3"
                SelectedIndex="{Binding SelectedDownloadResourceLoaderIndex}"
                ItemsSource="{Binding DownloadResourceLoaderOptions}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <Border
          Padding="12,10"
          Background="#FFF8DD"
          BorderBrush="#F2D777"
          BorderThickness="1"
          CornerRadius="4"
          IsVisible="{Binding ShowDownloadResourceHint}">
        <TextBlock
            Foreground="#6E5800"
            FontSize="12.5"
            Text="{Binding DownloadResourceHintText}"
            TextWrapping="Wrap" />
      </Border>

      <StackPanel IsVisible="{Binding ShowDownloadResourceContent}" Spacing="15">
        <controls:PclCard ContentMargin="12,12,12,12">
          <controls:PclCard.CardContent>
            <StackPanel Spacing="0">
              <ItemsControl ItemsSource="{Binding DownloadResourceEntries}" IsVisible="{Binding HasDownloadResourceEntries}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button
                        Classes="nochrome"
                        Margin="0,0,0,2"
                        Padding="0"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Command="{Binding Command}">
                      <Border
                          Padding="10,7"
                          Background="#12FFFFFF"
                          BorderBrush="#1F000000"
                          BorderThickness="1"
                          CornerRadius="4">
                        <Grid ColumnDefinitions="50,10,*,18" MinHeight="64">
                          <Border
                              Grid.Column="0"
                              Width="50"
                              Height="50"
                              VerticalAlignment="Center"
                              Background="#F7FAFE"
                              BorderBrush="#D5E6FD"
                              BorderThickness="1"
                              CornerRadius="6">
                            <Image
                                Width="38"
                                Height="38"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsVisible="{Binding HasIcon}"
                                Source="{Binding Icon}"
                                Stretch="Uniform" />
                          </Border>

                          <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4">
                            <TextBlock
                                Foreground="#343D4A"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Text="{Binding Title}"
                                TextTrimming="CharacterEllipsis" />

                            <Grid ColumnDefinitions="Auto,*">
                              <ItemsControl Grid.Column="0" IsVisible="{Binding HasVisibleTags}" ItemsSource="{Binding VisibleTags}">
                                <ItemsControl.ItemsPanel>
                                  <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                  </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <Border
                                        Margin="0,0,4,0"
                                        Padding="4,1"
                                        Background="#13000000"
                                        CornerRadius="3">
                                      <TextBlock
                                          Foreground="#858585"
                                          FontSize="11"
                                          Text="{Binding}" />
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                              <TextBlock
                                  Grid.Column="1"
                                  Margin="2,0,0,0"
                                  VerticalAlignment="Center"
                                  Foreground="#6D7B89"
                                  FontSize="12"
                                  IsVisible="{Binding HasInfo}"
                                  Text="{Binding Info}"
                                  TextTrimming="CharacterEllipsis" />
                            </Grid>

                            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*,Auto">
                              <TextBlock
                                  Grid.Column="0"
                                  Foreground="#7D8A98"
                                  FontSize="11.5"
                                  Text="{Binding VersionLabel}"
                                  TextTrimming="CharacterEllipsis" />
                              <TextBlock
                                  Grid.Column="2"
                                  Margin="6,0,0,0"
                                  Foreground="#7D8A98"
                                  FontSize="11.5"
                                  Text="{Binding DownloadCountLabel}"
                                  TextTrimming="CharacterEllipsis" />
                              <TextBlock
                                  Grid.Column="4"
                                  Margin="6,0,0,0"
                                  Foreground="#7D8A98"
                                  FontSize="11.5"
                                  Text="{Binding UpdatedLabel}"
                                  TextTrimming="CharacterEllipsis" />
                              <TextBlock
                                  Grid.Column="6"
                                  Margin="6,0,0,0"
                                  Foreground="#7D8A98"
                                  FontSize="11.5"
                                  Text="{Binding Source}"
                                  TextTrimming="CharacterEllipsis" />
                            </Grid>
                          </StackPanel>

                          <Path
                              Grid.Column="3"
                              Width="10"
                              Height="10"
                              VerticalAlignment="Center"
                              Fill="#97A6B5"
                              Stretch="Uniform"
                              Data="M6.4,0L4.98,1.4L8.58,5L4.98,8.6L6.4,10L11.4,5L6.4,0Z" />
                        </Grid>
                      </Border>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <StackPanel IsVisible="{Binding HasNoDownloadResourceEntries}" Spacing="6">
                <TextBlock
                    Foreground="#677789"
                    FontSize="13"
                    Text="{Binding DownloadResourceEmptyStateText}"
                    TextWrapping="Wrap" />
                <TextBlock
                    Foreground="#96A2B1"
                    FontSize="12"
                    Text="{Binding DownloadResourceLoadingText}"
                    TextWrapping="Wrap" />
              </StackPanel>
            </StackPanel>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <controls:PclCard ContentMargin="10,10,10,10" IsVisible="{Binding ShowDownloadResourcePagination}">
          <controls:PclCard.CardContent>
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
              <controls:PclButton
                  Grid.Column="0"
                  Width="72"
                  Command="{Binding FirstDownloadResourcePageCommand}"
                  Text="首页" />
              <controls:PclButton
                  Grid.Column="1"
                  Width="72"
                  Margin="8,0,0,0"
                  Command="{Binding PreviousDownloadResourcePageCommand}"
                  Text="上一页" />
              <TextBlock
                  Grid.Column="2"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Foreground="#4B5968"
                  FontSize="13.5"
                  FontWeight="SemiBold"
                  Text="{Binding DownloadResourcePageLabel}" />
              <controls:PclButton
                  Grid.Column="3"
                  Width="72"
                  HorizontalAlignment="Right"
                  Command="{Binding NextDownloadResourcePageCommand}"
                  Text="下一页" />
            </Grid>
          </controls:PclCard.CardContent>
        </controls:PclCard>
      </StackPanel>

      <controls:PclCard
          Margin="40,50"
          ContentMargin="20,20,20,17"
          HorizontalAlignment="Center"
          IsVisible="{Binding ShowDownloadResourceLoadingCard}"
          VerticalAlignment="Center">
        <controls:PclCard.CardContent>
          <StackPanel HorizontalAlignment="Center" Spacing="10">
            <ProgressBar Width="180" Height="4" IsIndeterminate="True" />
            <TextBlock
                HorizontalAlignment="Center"
                Foreground="#4B5968"
                FontSize="13"
                Text="{Binding DownloadResourceLoadingText}" />
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>
    </StackPanel>
  </ScrollViewer>
</UserControl>
