<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.Sections.InstanceInstallMinecraftSection"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls">
  <controls:PclCard Header="Minecraft" ContentMargin="20,40,18,15">
    <controls:PclCard.CardContent>
      <Grid ColumnDefinitions="Auto,*,Auto">
        <Border
            Width="18"
            Height="18"
            Margin="0,0,7,0"
            VerticalAlignment="Center">
          <Image Source="{Binding InstanceInstallMinecraftIcon}" Stretch="Uniform" />
        </Border>
        <TextBlock
            Grid.Column="1"
            VerticalAlignment="Center"
            Foreground="#343D4A"
            FontSize="13.5"
            Text="{Binding InstanceInstallMinecraftVersion}"
            TextTrimming="CharacterEllipsis" />
        <controls:PclButton
            Grid.Column="2"
            Width="72"
            Margin="10,0,0,0"
            Command="{Binding EditInstanceInstallMinecraftCommand}"
            Text="修改" />
      </Grid>
    </controls:PclCard.CardContent>
  </controls:PclCard>
</UserControl>
