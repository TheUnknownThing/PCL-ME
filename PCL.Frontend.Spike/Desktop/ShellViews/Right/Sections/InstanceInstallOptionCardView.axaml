<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.Sections.InstanceInstallOptionCardView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls">
  <controls:PclCard Header="{Binding Title}" ShowChevron="True" IsChevronExpanded="True" ContentMargin="20,40,18,15">
    <controls:PclCard.CardContent>
      <StackPanel Spacing="10">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Border
              Width="18"
              Height="18"
              Margin="0,0,7,0"
              VerticalAlignment="Center">
            <Image Source="{Binding Icon}" Stretch="Uniform" />
          </Border>
          <TextBlock
              Grid.Column="1"
              VerticalAlignment="Center"
              Foreground="#343D4A"
              FontSize="13.5"
              Text="{Binding Selection}"
              TextTrimming="CharacterEllipsis" />
          <controls:PclButton
              Grid.Column="2"
              Width="72"
              Margin="10,0,0,0"
              IsEnabled="{Binding CanClear}"
              Command="{Binding ClearCommand}"
              Text="清除" />
        </Grid>

        <TextBlock
            Foreground="#677789"
            FontSize="12"
            Text="{Binding DetailText}"
            TextWrapping="Wrap" />

        <Grid ColumnDefinitions="Auto,Auto">
          <controls:PclButton
              Grid.Column="0"
              Width="88"
              IsEnabled="{Binding CanSelect}"
              Command="{Binding SelectCommand}"
              Text="{Binding SelectText}" />
          <controls:PclButton
              Grid.Column="1"
              Width="88"
              Margin="10,0,0,0"
              IsEnabled="{Binding CanClear}"
              Command="{Binding ClearCommand}"
              Text="清除选择" />
        </Grid>
      </StackPanel>
    </controls:PclCard.CardContent>
  </controls:PclCard>
</UserControl>
