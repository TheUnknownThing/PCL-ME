<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.Sections.InstanceInstallSelectionSummarySection"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls">
  <controls:PclCard ContentMargin="15,8,15,8">
    <controls:PclCard.CardContent>
      <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,4,Auto">
        <Border
            Width="34"
            Height="34"
            VerticalAlignment="Center"
            Background="#EAF2FE"
            BorderBrush="#D5E6FD"
            BorderThickness="1"
            CornerRadius="17">
          <TextBlock
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Foreground="#4B78C2"
              FontSize="14"
              FontWeight="SemiBold"
              Text="例" />
        </Border>
        <TextBlock
            Grid.Column="1"
            Margin="12,0,0,0"
            VerticalAlignment="Center"
            Foreground="#343D4A"
            FontSize="14"
            FontWeight="SemiBold"
            Text="{Binding InstanceInstallSelectionTitle}" />
        <TextBlock
            Grid.Row="2"
            Grid.Column="1"
            Margin="12,0,0,0"
            Foreground="#7D8897"
            FontSize="12"
            Text="{Binding InstanceInstallSelectionSummary}"
            TextWrapping="Wrap" />
      </Grid>
    </controls:PclCard.CardContent>
  </controls:PclCard>
</UserControl>
