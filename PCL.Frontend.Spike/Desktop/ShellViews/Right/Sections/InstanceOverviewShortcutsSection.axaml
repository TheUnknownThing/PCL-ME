<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.Sections.InstanceOverviewShortcutsSection"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls">
  <controls:PclCard Header="快捷方式" ContentMargin="20,40,20,18">
    <controls:PclCard.CardContent>
      <Grid ColumnDefinitions="Auto,Auto,Auto">
        <controls:PclButton
            Grid.Column="0"
            MinWidth="140"
            Margin="0,0,20,0"
            Command="{Binding OpenInstanceFolderCommand}"
            Text="实例文件夹" />
        <controls:PclButton
            Grid.Column="1"
            MinWidth="140"
            Margin="0,0,20,0"
            Command="{Binding OpenInstanceSavesFolderCommand}"
            Text="存档文件夹" />
        <controls:PclButton
            Grid.Column="2"
            MinWidth="140"
            Command="{Binding OpenInstanceModsFolderCommand}"
            Text="Mod 文件夹" />
      </Grid>
    </controls:PclCard.CardContent>
  </controls:PclCard>
</UserControl>
