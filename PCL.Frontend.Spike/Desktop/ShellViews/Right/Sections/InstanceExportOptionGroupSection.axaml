<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.Sections.InstanceExportOptionGroupSection"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel Margin="0,0,0,10" Spacing="8">
    <StackPanel Spacing="2">
      <CheckBox
          Foreground="#343D4A"
          Content="{Binding Header.Title}"
          IsChecked="{Binding Header.IsChecked}" />
      <TextBlock
          Margin="24,0,0,0"
          Foreground="#7D8897"
          FontSize="12"
          IsVisible="{Binding Header.HasDescription}"
          Text="{Binding Header.Description}"
          TextWrapping="Wrap" />
    </StackPanel>

    <ItemsControl ItemsSource="{Binding Children}" IsVisible="{Binding Header.IsChecked}">
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <StackPanel Margin="28,0,0,4" Spacing="2">
            <CheckBox
                Foreground="#343D4A"
                Content="{Binding Title}"
                IsChecked="{Binding IsChecked}" />
            <TextBlock
                Margin="24,0,0,0"
                Foreground="#7D8897"
                FontSize="12"
                IsVisible="{Binding HasDescription}"
                Text="{Binding Description}"
                TextWrapping="Wrap" />
          </StackPanel>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </StackPanel>
</UserControl>
