<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.Sections.InstanceExportOptionsSection"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    xmlns:sections="clr-namespace:PCL.Frontend.Spike.Desktop.ShellViews.Right.Sections">
  <controls:PclCard Header="导出内容" ContentMargin="18,40,18,18">
    <controls:PclCard.CardContent>
      <StackPanel Spacing="14">
        <controls:PclButton
            Width="90"
            HorizontalAlignment="Right"
            Command="{Binding ResetInstanceExportOptionsCommand}"
            Text="重置" />

        <ItemsControl ItemsSource="{Binding InstanceExportOptionGroups}" IsVisible="{Binding HasInstanceExportOptionGroups}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <sections:InstanceExportOptionGroupSection />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </controls:PclCard.CardContent>
  </controls:PclCard>
</UserControl>
