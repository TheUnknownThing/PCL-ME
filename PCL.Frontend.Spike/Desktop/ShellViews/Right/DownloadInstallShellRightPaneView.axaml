<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.DownloadInstallShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,10,25,25" Spacing="12">
      <StackPanel IsVisible="{Binding ShowDownloadInstallMinecraftCatalog}" Spacing="12">
        <controls:PclCard IsVisible="{Binding ShowDownloadInstallMinecraftCatalogLoading}" ContentMargin="18,16,18,16">
          <controls:PclCard.CardContent>
            <TextBlock
                Foreground="#677789"
                FontSize="13"
                Text="{Binding DownloadInstallMinecraftCatalogStatus}"
                TextWrapping="Wrap" />
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <controls:PclCard IsVisible="{Binding ShowDownloadInstallMinecraftCatalogEmptyState}" ContentMargin="18,16,18,16">
          <controls:PclCard.CardContent>
            <TextBlock
                Foreground="#677789"
                FontSize="13"
                Text="{Binding DownloadInstallMinecraftCatalogStatus}"
                TextWrapping="Wrap" />
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <ItemsControl ItemsSource="{Binding DownloadInstallMinecraftSections}" IsVisible="{Binding ShowDownloadInstallMinecraftCatalogContent}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <controls:PclCard
                  Header="{Binding Title}"
                  ShowChevron="{Binding CanCollapse}"
                  IsChevronExpanded="{Binding IsExpanded}"
                  HeaderCommand="{Binding ToggleCommand}"
                  ContentMargin="18,40,18,8">
                <controls:PclCard.CardContent>
                  <ItemsControl ItemsSource="{Binding Choices}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Margin="0,0,0,10" Background="#F7F9FC" BorderBrush="#E1E7EF" BorderThickness="1" CornerRadius="6">
                          <Button
                              Classes="nochrome"
                              Command="{Binding SelectCommand}"
                              HorizontalContentAlignment="Stretch"
                              Padding="0"
                              Background="Transparent"
                              BorderBrush="Transparent"
                              BorderThickness="0">
                            <Grid Margin="12,10" ColumnDefinitions="Auto,*">
                              <Border
                                  Width="34"
                                  Height="34"
                                  Margin="0,0,12,0"
                                  Background="#EAF2FE"
                                  BorderBrush="#D5E6FD"
                                  BorderThickness="1"
                                  CornerRadius="8">
                                <Image Source="{Binding Icon}" Stretch="Uniform" Margin="6" />
                              </Border>
                              <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Foreground="#343D4A" FontSize="13.5" FontWeight="SemiBold" Text="{Binding Title}" />
                                <TextBlock Foreground="#7D8897" FontSize="11.5" Text="{Binding Summary}" TextWrapping="Wrap" />
                              </StackPanel>
                            </Grid>
                          </Button>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </controls:PclCard.CardContent>
              </controls:PclCard>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>

      <StackPanel IsVisible="{Binding ShowDownloadInstallSelectionStage}" Spacing="12">
        <controls:PclCard ContentMargin="13,13,16,13">
          <controls:PclCard.CardContent>
            <Grid ColumnDefinitions="Auto,Auto,*">
              <Button
                  Width="26"
                  Height="26"
                  Padding="0"
                  Background="#F0F6FF"
                  BorderBrush="#D5E6FD"
                  BorderThickness="1"
                  Command="{Binding DownloadInstallBackCommand}"
                  CornerRadius="13">
                <Path
                    Width="10"
                    Height="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Fill="#4B78C2"
                    Stretch="Uniform"
                    Data="M1097 584 250 584 562 896C591 925 591 972 562 1001 533 1030 487 1030 458 1001L21 565C6 550-0 531 0 511L0 511 0 511C-0 492 6 472 21 457L458 21C487-7 533-7 562 21 591 50 591 97 562 126L250 438 1097 438C1137 438 1170 471 1170 511 1170 551 1137 584 1097 584L1097 584Z" />
              </Button>
              <Border
                  Grid.Column="1"
                  Width="32"
                  Height="32"
                  Margin="12,0,14,0"
                  VerticalAlignment="Center"
                  Background="#EAF2FE"
                  BorderBrush="#D5E6FD"
                  BorderThickness="1"
                  CornerRadius="6">
                <Image Source="{Binding DownloadInstallMinecraftIcon}" Stretch="Uniform" Margin="5" />
              </Border>
              <TextBox
                  Grid.Column="2"
                  Height="30"
                  Padding="8,4"
                  VerticalAlignment="Center"
                  Background="Transparent"
                  BorderBrush="Transparent"
                  BorderThickness="0"
                  FontSize="15"
                  Text="{Binding DownloadInstallName}" />
            </Grid>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <Border
            IsVisible="{Binding ShowDownloadInstallNameValidation}"
            Padding="12,10"
            Background="#FFF1EA"
            BorderBrush="#F1C8B6"
            BorderThickness="1"
            CornerRadius="4">
          <TextBlock
              Foreground="#A94F2B"
              FontSize="12.5"
              Text="{Binding DownloadInstallNameValidationMessage}"
              TextWrapping="Wrap" />
        </Border>

        <ItemsControl ItemsSource="{Binding DownloadInstallHints}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border
                  Padding="12,10"
                  Background="{Binding BackgroundBrush}"
                  BorderBrush="{Binding BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="4">
                <TextBlock
                    Foreground="{Binding ForegroundBrush}"
                    FontSize="12.5"
                    Text="{Binding Text}"
                    TextWrapping="Wrap" />
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <ItemsControl ItemsSource="{Binding DownloadInstallOptionCards}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <controls:PclCard ContentMargin="15,12,15,12">
                <controls:PclCard.CardContent>
                  <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock
                          VerticalAlignment="Center"
                          Foreground="#343D4A"
                          FontSize="13"
                          FontWeight="Bold"
                          Text="{Binding Title}" />
                      <Button
                          Grid.Column="1"
                          Width="26"
                          Height="26"
                          Padding="0"
                          Background="#F0F6FF"
                          BorderBrush="#D5E6FD"
                          BorderThickness="1"
                          CornerRadius="13"
                          Command="{Binding ToggleCommand}"
                          IsEnabled="{Binding CanExpand}">
                        <Path
                            Width="10"
                            Height="6"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Fill="#4B78C2"
                            Stretch="Uniform"
                            Data="M2,4 l-2,2 10,10 10,-10 -2,-2 -8,8 -8,-8 z">
                          <Path.RenderTransform>
                            <RotateTransform Angle="{Binding ChevronAngle}" />
                          </Path.RenderTransform>
                        </Path>
                      </Button>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*,Auto">
                      <Border
                          Width="22"
                          Height="22"
                          Margin="0,0,10,0"
                          VerticalAlignment="Center"
                          Background="#EAF2FE"
                          BorderBrush="#D5E6FD"
                          BorderThickness="1"
                          CornerRadius="5"
                          IsVisible="{Binding ShowIcon}">
                        <Image Source="{Binding Icon}" Stretch="Uniform" Margin="3" />
                      </Border>
                      <TextBlock
                          Grid.Column="1"
                          VerticalAlignment="Center"
                          Foreground="{Binding SelectionForegroundBrush}"
                          FontSize="13.5"
                          Text="{Binding SelectionText}"
                          TextTrimming="CharacterEllipsis" />
                      <controls:PclButton
                          Grid.Column="2"
                          Width="72"
                          Margin="12,0,0,0"
                          Command="{Binding ClearCommand}"
                          IsVisible="{Binding CanClear}"
                          Text="清除" />
                    </Grid>

                    <StackPanel IsVisible="{Binding IsExpanded}" Spacing="8">
                      <Border
                          IsVisible="{Binding IsLoading}"
                          Padding="12,10"
                          Background="#F7F9FC"
                          BorderBrush="#E1E7EF"
                          BorderThickness="1"
                          CornerRadius="6">
                        <TextBlock
                            Foreground="#677789"
                            FontSize="12"
                            Text="{Binding LoadingText}" />
                      </Border>

                      <Border
                          IsVisible="{Binding ShowEmptyState}"
                          Padding="12,10"
                          Background="#F7F9FC"
                          BorderBrush="#E1E7EF"
                          BorderThickness="1"
                          CornerRadius="6">
                        <TextBlock
                            Foreground="#677789"
                            FontSize="12"
                            Text="{Binding EmptyStateText}"
                            TextWrapping="Wrap" />
                      </Border>

                      <ItemsControl ItemsSource="{Binding Choices}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Background="{Binding BackgroundBrush}" BorderBrush="{Binding BorderBrush}" BorderThickness="1" CornerRadius="6">
                              <Button
                                  Classes="nochrome"
                                  Command="{Binding SelectCommand}"
                                  HorizontalContentAlignment="Stretch"
                                  Padding="0"
                                  Background="Transparent"
                                  BorderBrush="Transparent"
                                  BorderThickness="0">
                                <Grid Margin="12,10" ColumnDefinitions="*,Auto">
                                  <StackPanel Spacing="2">
                                    <TextBlock Foreground="{Binding ForegroundBrush}" FontSize="13" FontWeight="SemiBold" Text="{Binding Title}" />
                                    <TextBlock Foreground="{Binding SummaryBrush}" FontSize="11.5" Text="{Binding Summary}" TextWrapping="Wrap" />
                                  </StackPanel>
                                  <Border
                                      Grid.Column="1"
                                      Padding="8,3"
                                      Margin="12,0,0,0"
                                      Background="#DDEBFE"
                                      BorderBrush="#BFD9FF"
                                      BorderThickness="1"
                                      CornerRadius="999"
                                      IsVisible="{Binding IsSelected}">
                                    <TextBlock Foreground="#1370F3" FontSize="11" FontWeight="SemiBold" Text="已选择" />
                                  </Border>
                                </Grid>
                              </Button>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </StackPanel>
                </controls:PclCard.CardContent>
              </controls:PclCard>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid ColumnDefinitions="*,Auto">
          <TextBlock
              VerticalAlignment="Center"
              Foreground="#6B7C8E"
              FontSize="12.5"
              Text="继续沿用原版下载页的双阶段安装流程，在当前壳层直接写入安装清单并补全依赖文件。"
              TextWrapping="Wrap" />
          <controls:PclButton
              Grid.Column="1"
              Width="120"
              Margin="16,0,0,0"
              Command="{Binding StartDownloadInstallCommand}"
              IsEnabled="{Binding CanStartDownloadInstall}"
              Text="开始安装" />
        </Grid>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
