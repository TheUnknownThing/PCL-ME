<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.DownloadInstallShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,10,25,25" Spacing="12">
      <controls:PclCard ContentMargin="13,13,16,13">
        <controls:PclCard.CardContent>
          <Grid ColumnDefinitions="Auto,Auto,*">
            <Button
                Width="26"
                Height="26"
                Padding="0"
                Background="#F0F6FF"
                BorderBrush="#D5E6FD"
                BorderThickness="1"
                Command="{Binding BackCommand}"
                CornerRadius="13">
              <Path
                  Width="10"
                  Height="10"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Fill="#4B78C2"
                  Stretch="Uniform"
                  Data="M1097 584 250 584 562 896C591 925 591 972 562 1001 533 1030 487 1030 458 1001L21 565C6 550-0 531 0 511L0 511 0 511C-0 492 6 472 21 457L458 21C487-7 533-7 562 21 591 50 591 97 562 126L250 438 1097 438C1137 438 1170 471 1170 511 1170 551 1137 584 1097 584L1097 584Z" />
            </Button>
            <Border
                Grid.Column="1"
                Width="32"
                Height="32"
                Margin="12,0,14,0"
                VerticalAlignment="Center"
                Background="#EAF2FE"
                BorderBrush="#D5E6FD"
                BorderThickness="1"
                CornerRadius="6">
              <TextBlock
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Foreground="#4B78C2"
                  FontSize="14"
                  FontWeight="SemiBold"
                  Text="包" />
            </Border>
            <TextBox
                Grid.Column="2"
                Height="30"
                Padding="8,4"
                VerticalAlignment="Center"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                FontSize="15"
                Text="{Binding DownloadInstallName}" />
          </Grid>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <ItemsControl ItemsSource="{Binding DownloadInstallHints}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border
                Margin="0,10,0,0"
                Padding="12,10"
                Background="{Binding BackgroundBrush}"
                BorderBrush="{Binding BorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
              <TextBlock
                  Foreground="{Binding ForegroundBrush}"
                  FontSize="12.5"
                  Text="{Binding Text}"
                  TextWrapping="Wrap" />
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <controls:PclCard Header="Minecraft" ContentMargin="20,40,18,15">
        <controls:PclCard.CardContent>
          <Grid ColumnDefinitions="Auto,*,Auto">
            <Border
                Width="18"
                Height="18"
                Margin="0,0,7,0"
                VerticalAlignment="Center">
              <Image Source="{Binding DownloadInstallMinecraftIcon}" Stretch="Uniform" />
            </Border>
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13.5"
                Text="{Binding DownloadInstallMinecraftVersion}"
                TextTrimming="CharacterEllipsis" />
            <controls:PclButton
                Grid.Column="2"
                Width="72"
                Margin="10,0,0,0"
                Command="{Binding EditDownloadInstallMinecraftCommand}"
                Text="修改" />
          </Grid>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <ItemsControl ItemsSource="{Binding DownloadInstallOptions}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <controls:PclCard Header="{Binding Title}" ShowChevron="True" IsChevronExpanded="True" ContentMargin="20,40,18,15">
              <controls:PclCard.CardContent>
                <StackPanel Spacing="10">
                  <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border
                        Width="18"
                        Height="18"
                        Margin="0,0,7,0"
                        VerticalAlignment="Center">
                      <Image Source="{Binding Icon}" Stretch="Uniform" />
                    </Border>
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Foreground="#343D4A"
                        FontSize="13.5"
                        Text="{Binding Selection}"
                        TextTrimming="CharacterEllipsis" />
                    <controls:PclButton
                        Grid.Column="2"
                        Width="72"
                        Margin="10,0,0,0"
                        IsEnabled="{Binding CanClear}"
                        Command="{Binding ClearCommand}"
                        Text="清除" />
                  </Grid>

                  <TextBlock
                      Foreground="#677789"
                      FontSize="12"
                      Text="{Binding DetailText}"
                      TextWrapping="Wrap" />

                  <Grid ColumnDefinitions="Auto,Auto">
                    <controls:PclButton
                        Grid.Column="0"
                        Width="88"
                        IsEnabled="{Binding CanSelect}"
                        Command="{Binding SelectCommand}"
                        Text="{Binding SelectText}" />
                    <controls:PclButton
                        Grid.Column="1"
                        Width="88"
                        Margin="10,0,0,0"
                        IsEnabled="{Binding CanClear}"
                        Command="{Binding ClearCommand}"
                        Text="清除选择" />
                  </Grid>
                </StackPanel>
              </controls:PclCard.CardContent>
            </controls:PclCard>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Grid ColumnDefinitions="*,Auto">
        <TextBlock
            VerticalAlignment="Center"
            Foreground="#6B7C8E"
            FontSize="12.5"
            Text="继续沿用原版自动安装页的命名卡与组件卡结构，并在当前壳层直接写入真实安装清单。"
            TextWrapping="Wrap" />
        <controls:PclButton
            Grid.Column="1"
            Width="120"
            Margin="16,0,0,0"
            Command="{Binding StartDownloadInstallCommand}"
            Text="开始安装" />
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
