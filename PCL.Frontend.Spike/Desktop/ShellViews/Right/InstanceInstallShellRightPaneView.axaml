<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.InstanceInstallShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,10,25,25" Spacing="12">
      <ItemsControl ItemsSource="{Binding InstanceInstallHints}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border
                Margin="0,0,0,0"
                Padding="12,10"
                Background="{Binding BackgroundBrush}"
                BorderBrush="{Binding BorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
              <TextBlock
                  Foreground="{Binding ForegroundBrush}"
                  FontSize="12.5"
                  Text="{Binding Text}"
                  TextWrapping="Wrap" />
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <controls:PclCard ContentMargin="15,8,15,8">
        <controls:PclCard.CardContent>
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,4,Auto">
            <Border
                Width="34"
                Height="34"
                VerticalAlignment="Center"
                Background="#EAF2FE"
                BorderBrush="#D5E6FD"
                BorderThickness="1"
                CornerRadius="17">
              <TextBlock
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Foreground="#4B78C2"
                  FontSize="14"
                  FontWeight="SemiBold"
                  Text="例" />
            </Border>
            <TextBlock
                Grid.Column="1"
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="14"
                FontWeight="SemiBold"
                Text="{Binding InstanceInstallSelectionTitle}" />
            <TextBlock
                Grid.Row="2"
                Grid.Column="1"
                Margin="12,0,0,0"
                Foreground="#7D8897"
                FontSize="12"
                Text="{Binding InstanceInstallSelectionSummary}"
                TextWrapping="Wrap" />
          </Grid>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="Minecraft" ContentMargin="20,40,18,15">
        <controls:PclCard.CardContent>
          <Grid ColumnDefinitions="Auto,*,Auto">
            <Border
                Width="18"
                Height="18"
                Margin="0,0,7,0"
                VerticalAlignment="Center">
              <Image Source="{Binding InstanceInstallMinecraftIcon}" Stretch="Uniform" />
            </Border>
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13.5"
                Text="{Binding InstanceInstallMinecraftVersion}"
                TextTrimming="CharacterEllipsis" />
            <controls:PclButton
                Grid.Column="2"
                Width="72"
                Margin="10,0,0,0"
                Command="{Binding EditInstanceInstallMinecraftCommand}"
                Text="修改" />
          </Grid>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <ItemsControl ItemsSource="{Binding InstanceInstallOptions}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <controls:PclCard Header="{Binding Title}" ShowChevron="True" IsChevronExpanded="True" ContentMargin="20,40,18,15">
              <controls:PclCard.CardContent>
                <StackPanel Spacing="10">
                  <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border
                        Width="18"
                        Height="18"
                        Margin="0,0,7,0"
                        VerticalAlignment="Center">
                      <Image Source="{Binding Icon}" Stretch="Uniform" />
                    </Border>
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Foreground="#343D4A"
                        FontSize="13.5"
                        Text="{Binding Selection}"
                        TextTrimming="CharacterEllipsis" />
                    <controls:PclButton
                        Grid.Column="2"
                        Width="72"
                        Margin="10,0,0,0"
                        Command="{Binding ClearCommand}"
                        Text="清除" />
                  </Grid>

                  <TextBlock
                      Foreground="#677789"
                      FontSize="12"
                      Text="{Binding DetailText}"
                      TextWrapping="Wrap" />

                  <Grid ColumnDefinitions="Auto,Auto">
                    <controls:PclButton
                        Grid.Column="0"
                        Width="88"
                        IsEnabled="{Binding CanSelect}"
                        Command="{Binding SelectCommand}"
                        Text="{Binding SelectText}" />
                    <controls:PclButton
                        Grid.Column="1"
                        Width="88"
                        Margin="10,0,0,0"
                        IsEnabled="{Binding CanClear}"
                        Command="{Binding ClearCommand}"
                        Text="清除选择" />
                  </Grid>
                </StackPanel>
              </controls:PclCard.CardContent>
            </controls:PclCard>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Grid ColumnDefinitions="*,Auto">
        <TextBlock
            VerticalAlignment="Center"
            Foreground="#6B7C8E"
            FontSize="12.5"
            Text="继续沿用原版实例安装页的操作位置，并在当前壳层直接写入实例安装清单与补全结果。"
            TextWrapping="Wrap" />
        <controls:PclButton
            Grid.Column="1"
            Width="120"
            Margin="16,0,0,0"
            Command="{Binding ApplyInstanceInstallCommand}"
            Text="{Binding InstanceInstallApplyButtonText}" />
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
