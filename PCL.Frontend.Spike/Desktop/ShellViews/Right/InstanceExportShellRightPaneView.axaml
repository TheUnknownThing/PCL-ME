<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.InstanceExportShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    xmlns:sections="clr-namespace:PCL.Frontend.Spike.Desktop.ShellViews.Right.Sections"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,10,25,25" Spacing="15">
      <sections:InstanceExportHeaderSection />
      <sections:InstanceExportOptionsSection />
      <sections:InstanceExportAdvancedSection />

      <controls:PclButton
          Width="160"
          Height="38"
          HorizontalAlignment="Center"
          Command="{Binding StartInstanceExportCommand}"
          ColorType="Highlight"
          Text="开始导出" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
