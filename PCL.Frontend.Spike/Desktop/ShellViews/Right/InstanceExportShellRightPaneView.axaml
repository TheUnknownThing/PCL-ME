<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.InstanceExportShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,10,25,25" Spacing="15">
      <Border
          Padding="12,10"
          Background="#FFF8DD"
          BorderBrush="#F2D777"
          BorderThickness="1"
          CornerRadius="4"
          IsVisible="{Binding ShowInstanceExportOptiFineWarning}">
        <TextBlock
            Foreground="#6E5800"
            FontSize="12.5"
            Text="受 Modrinth 整合包规范限制，导出的整合包中不会包含 OptiFine。"
            TextWrapping="Wrap" />
      </Border>

      <controls:PclCard ContentMargin="20,18,20,18">
        <controls:PclCard.CardContent>
          <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="28">
            <TextBlock
                Grid.Column="0"
                Margin="0,0,20,0"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13"
                Text="整合包名称" />
            <TextBox
                Grid.Column="1"
                Margin="0,0,12,0"
                Text="{Binding InstanceExportName}" />
            <TextBlock
                Grid.Column="2"
                Margin="18,0,20,0"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13"
                Text="整合包版本" />
            <TextBox
                Grid.Column="3"
                Text="{Binding InstanceExportVersion}" />
          </Grid>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="导出内容" ContentMargin="18,40,18,18">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="14">
            <controls:PclButton
                Width="90"
                HorizontalAlignment="Right"
                Command="{Binding ResetInstanceExportOptionsCommand}"
                Text="重置" />

            <ItemsControl ItemsSource="{Binding InstanceExportOptionGroups}" IsVisible="{Binding HasInstanceExportOptionGroups}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <StackPanel Margin="0,0,0,10" Spacing="8">
                    <StackPanel Spacing="2">
                      <CheckBox
                          Foreground="#343D4A"
                          Content="{Binding Header.Title}"
                          IsChecked="{Binding Header.IsChecked}" />
                      <TextBlock
                          Margin="24,0,0,0"
                          Foreground="#7D8897"
                          FontSize="12"
                          IsVisible="{Binding Header.HasDescription}"
                          Text="{Binding Header.Description}"
                          TextWrapping="Wrap" />
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Children}" IsVisible="{Binding Header.IsChecked}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <StackPanel Margin="28,0,0,4" Spacing="2">
                            <CheckBox
                                Foreground="#343D4A"
                                Content="{Binding Title}"
                                IsChecked="{Binding IsChecked}" />
                            <TextBlock
                                Margin="24,0,0,0"
                                Foreground="#7D8897"
                                FontSize="12"
                                IsVisible="{Binding HasDescription}"
                                Text="{Binding Description}"
                                TextWrapping="Wrap" />
                          </StackPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="高级选项" ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <Border
                Padding="12,10"
                Background="#FFF8DD"
                BorderBrush="#F2D777"
                BorderThickness="1"
                CornerRadius="4"
                IsVisible="{Binding ShowInstanceExportIncludeWarning}">
              <TextBlock
                  Foreground="#6E5800"
                  FontSize="12.5"
                  Text="建议仅在无法稳定连接 CurseForge 或 Modrinth 时才打包资源文件。请不要公开发布含资源文件的整合包，这会违反部分 Mod 的使用协议！"
                  TextWrapping="Wrap" />
            </Border>

            <CheckBox
                Foreground="#343D4A"
                Content="打包资源文件，以避免在导入时下载"
                IsChecked="{Binding InstanceExportIncludeResources}" />
            <CheckBox
                Foreground="#343D4A"
                Content="Modrinth 上传模式"
                IsChecked="{Binding InstanceExportModrinthMode}" />

            <Border
                Padding="12,10"
                Background="#EAF7F4"
                BorderBrush="#C8E6DF"
                BorderThickness="1"
                CornerRadius="4">
              <TextBlock
                  Foreground="#24534E"
                  FontSize="12.5"
                  Text="配置文件中含有更多高级选项，例如精准控制导出的文件、设置整合包存放位置等。要修改这些选项，请先点击“保存配置”，在编辑配置文件后再导入。"
                  TextWrapping="Wrap" />
            </Border>

            <Grid ColumnDefinitions="Auto,Auto,Auto">
              <controls:PclButton
                  Grid.Column="0"
                  MinWidth="140"
                  Margin="0,0,20,0"
                  Command="{Binding ImportInstanceExportConfigCommand}"
                  ColorType="Highlight"
                  Text="读取配置" />
              <controls:PclButton
                  Grid.Column="1"
                  MinWidth="140"
                  Margin="0,0,20,0"
                  Command="{Binding SaveInstanceExportConfigCommand}"
                  Text="保存配置" />
              <controls:PclButton
                  Grid.Column="2"
                  MinWidth="140"
                  Command="{Binding OpenInstanceExportGuideCommand}"
                  Text="整合包制作指南" />
            </Grid>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclButton
          Width="160"
          Height="38"
          HorizontalAlignment="Center"
          Command="{Binding StartInstanceExportCommand}"
          ColorType="Highlight"
          Text="开始导出" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
