<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.GenericStandardShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
      <StackPanel Margin="25,25,25,10" Spacing="15">
        <controls:PclCard Header="实例选择" IsVisible="{Binding ShowInstanceSelectSurface}" ContentMargin="20,18,20,18">
          <controls:PclCard.CardContent>
            <StackPanel Spacing="14">
              <Grid ColumnDefinitions="*,Auto">
                <Border
                    Height="40"
                    Padding="12,0"
                    Background="#F8FBFF"
                    BorderBrush="#D5E6FD"
                    BorderThickness="1"
                    CornerRadius="5">
                  <TextBox
                      Background="Transparent"
                      BorderBrush="Transparent"
                      BorderThickness="0"
                      FontSize="13.5"
                      Text="{Binding InstanceSelectionSearchQuery}"
                      Watermark="搜索实例名称、版本或加载器" />
                </Border>
                <controls:PclButton
                    Grid.Column="1"
                    Width="72"
                    Height="40"
                    Margin="10,0,0,0"
                    Command="{Binding RefreshInstanceSelectionCommand}"
                    Text="刷新" />
              </Grid>

              <Border
                  Padding="12,10"
                  Background="#F7FAFE"
                  BorderBrush="#D5E6FD"
                  BorderThickness="1"
                  CornerRadius="4">
                <StackPanel Spacing="5">
                  <TextBlock
                      Foreground="#344352"
                      FontSize="13"
                      FontWeight="SemiBold"
                      Text="{Binding InstanceSelectionResultSummary}" />
                  <TextBlock
                      Foreground="#6B7C8F"
                      FontSize="11.5"
                      Text="{Binding InstanceSelectionLauncherDirectory}"
                      TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <ItemsControl ItemsSource="{Binding InstanceSelectionEntries}" IsVisible="{Binding HasInstanceSelectionEntries}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <controls:PclCard Header="{Binding Title}" ContentMargin="18,18,18,16">
                      <controls:PclCard.CardContent>
                        <StackPanel Spacing="12">
                          <TextBlock
                              Foreground="#45586A"
                              FontSize="13"
                              Text="{Binding Subtitle}"
                              TextWrapping="Wrap" />
                          <ItemsControl ItemsSource="{Binding Tags}" IsVisible="{Binding HasTags}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <WrapPanel />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border
                                    Margin="0,0,8,8"
                                    Padding="10,4"
                                    Background="#EDF5FF"
                                    BorderBrush="#C8DEFB"
                                    BorderThickness="1"
                                    CornerRadius="999">
                                  <TextBlock
                                      Foreground="#215EA9"
                                      FontSize="11.5"
                                      FontWeight="SemiBold"
                                      Text="{Binding}" />
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                          <TextBlock
                              Foreground="#7A8794"
                              FontSize="11.5"
                              Text="{Binding Detail}"
                              TextWrapping="Wrap" />
                          <WrapPanel>
                            <controls:PclButton
                                Width="132"
                                Height="35"
                                Margin="0,0,10,0"
                                ColorType="Highlight"
                                Command="{Binding SelectCommand}"
                                Text="{Binding SelectText}" />
                            <controls:PclButton
                                Width="96"
                                Height="35"
                                Margin="0,0,10,0"
                                Command="{Binding OpenCommand}"
                                Text="打开详情" />
                            <controls:PclButton
                                Width="108"
                                Height="35"
                                Command="{Binding OpenFolderCommand}"
                                Text="打开目录" />
                          </WrapPanel>
                        </StackPanel>
                      </controls:PclCard.CardContent>
                    </controls:PclCard>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <controls:PclCard Header="没有可显示的实例" IsVisible="{Binding HasNoInstanceSelectionEntries}" ContentMargin="20,18,20,18">
                <controls:PclCard.CardContent>
                  <StackPanel Spacing="10">
                    <TextBlock
                        Foreground="#4B5968"
                        FontSize="13"
                        Text="当前启动目录下没有匹配到实例。你可以先下载实例，或检查启动目录是否指向正确的 `.minecraft`。"
                        TextWrapping="Wrap" />
                    <controls:PclButton
                        Width="110"
                        Height="35"
                        Command="{Binding ClearInstanceSelectionSearchCommand}"
                        Text="清空筛选" />
                  </StackPanel>
                </controls:PclCard.CardContent>
              </controls:PclCard>
            </StackPanel>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <controls:PclCard Header="任务管理" IsVisible="{Binding ShowTaskManagerSurface}" ContentMargin="20,18,20,18">
          <controls:PclCard.CardContent>
            <StackPanel Spacing="14">
              <WrapPanel>
                <controls:PclButton
                    Width="92"
                    Height="35"
                    Margin="0,0,10,0"
                    ColorType="Highlight"
                    Command="{Binding RefreshTaskManagerCommand}"
                    Text="刷新" />
                <controls:PclButton
                    Width="120"
                    Height="35"
                    Command="{Binding ClearFinishedTasksCommand}"
                    Text="清理已结束" />
              </WrapPanel>

              <Grid ColumnDefinitions="*,*,*,*">
                <Border
                    Padding="12,10"
                    Background="#F7FAFE"
                    BorderBrush="#D5E6FD"
                    BorderThickness="1"
                    CornerRadius="4">
                  <StackPanel Spacing="4">
                    <TextBlock Foreground="#7D8897" FontSize="11.5" Text="等待中" />
                    <TextBlock Foreground="#2B4260" FontSize="18" FontWeight="Bold" Text="{Binding TaskManagerWaitingCount}" />
                  </StackPanel>
                </Border>
                <Border
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Padding="12,10"
                    Background="#EEF9F2"
                    BorderBrush="#C7E8D1"
                    BorderThickness="1"
                    CornerRadius="4">
                  <StackPanel Spacing="4">
                    <TextBlock Foreground="#6E8A73" FontSize="11.5" Text="运行中" />
                    <TextBlock Foreground="#1B6B3A" FontSize="18" FontWeight="Bold" Text="{Binding TaskManagerRunningCount}" />
                  </StackPanel>
                </Border>
                <Border
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    Padding="12,10"
                    Background="#FFF8E6"
                    BorderBrush="#F2DCA1"
                    BorderThickness="1"
                    CornerRadius="4">
                  <StackPanel Spacing="4">
                    <TextBlock Foreground="#8D7641" FontSize="11.5" Text="已结束" />
                    <TextBlock Foreground="#8A5A00" FontSize="18" FontWeight="Bold" Text="{Binding TaskManagerFinishedCount}" />
                  </StackPanel>
                </Border>
                <Border
                    Grid.Column="3"
                    Margin="10,0,0,0"
                    Padding="12,10"
                    Background="#FFF0EF"
                    BorderBrush="#F2CBC7"
                    BorderThickness="1"
                    CornerRadius="4">
                  <StackPanel Spacing="4">
                    <TextBlock Foreground="#8D6C69" FontSize="11.5" Text="失败" />
                    <TextBlock Foreground="#B23A2B" FontSize="18" FontWeight="Bold" Text="{Binding TaskManagerFailedCount}" />
                  </StackPanel>
                </Border>
              </Grid>

              <Border
                  Padding="12,10"
                  Background="#F7FAFE"
                  BorderBrush="#D5E6FD"
                  BorderThickness="1"
                  CornerRadius="4">
                <TextBlock
                    Foreground="#45586A"
                    FontSize="12.5"
                    Text="{Binding TaskManagerSummary}"
                    TextWrapping="Wrap" />
              </Border>

              <ItemsControl ItemsSource="{Binding TaskManagerEntries}" IsVisible="{Binding HasTaskManagerEntries}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <controls:PclCard Header="{Binding Title}" ContentMargin="18,18,18,16">
                      <controls:PclCard.CardContent>
                        <StackPanel Spacing="12">
                          <Grid ColumnDefinitions="Auto,*">
                            <Border
                                Padding="10,4"
                                Background="#EDF5FF"
                                BorderBrush="#C8DEFB"
                                BorderThickness="1"
                                CornerRadius="999">
                              <TextBlock
                                  Foreground="#215EA9"
                                  FontSize="11.5"
                                  FontWeight="SemiBold"
                                  Text="{Binding State}" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="4">
                              <TextBlock
                                  Foreground="#45586A"
                                  FontSize="13"
                                  Text="{Binding Summary}"
                                  TextWrapping="Wrap" />
                              <TextBlock
                                  Foreground="#7A8794"
                                  FontSize="11.5"
                                  Text="{Binding ProgressText}" />
                              <TextBlock
                                  Foreground="#7A8794"
                                  FontSize="11.5"
                                  IsVisible="{Binding HasChildren}"
                                  Text="{Binding ChildrenText}" />
                            </StackPanel>
                          </Grid>
                          <WrapPanel>
                            <controls:PclButton
                                Width="84"
                                Height="35"
                                Margin="0,0,10,0"
                                Command="{Binding PauseCommand}"
                                IsEnabled="{Binding CanPause}"
                                Text="暂停" />
                            <controls:PclButton
                                Width="84"
                                Height="35"
                                Command="{Binding CancelCommand}"
                                ColorType="Red"
                                IsEnabled="{Binding CanCancel}"
                                Text="取消" />
                          </WrapPanel>
                        </StackPanel>
                      </controls:PclCard.CardContent>
                    </controls:PclCard>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <controls:PclCard Header="当前没有活动任务" IsVisible="{Binding HasNoTaskManagerEntries}" ContentMargin="20,18,20,18">
                <controls:PclCard.CardContent>
                  <TextBlock
                      Foreground="#4B5968"
                      FontSize="13"
                      Text="TaskCenter 中还没有需要展示的任务。下载、安装或其他后台流程开始后，这里会自动出现实时状态。"
                      TextWrapping="Wrap" />
                </controls:PclCard.CardContent>
              </controls:PclCard>
            </StackPanel>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <controls:PclCard Header="实时日志" IsVisible="{Binding ShowGameLogSurface}" ContentMargin="20,18,20,18">
          <controls:PclCard.CardContent>
            <StackPanel Spacing="14">
              <WrapPanel>
                <controls:PclButton
                    Width="92"
                    Height="35"
                    Margin="0,0,10,0"
                    ColorType="Highlight"
                    Command="{Binding RefreshGameLogCommand}"
                    Text="刷新" />
                <controls:PclButton
                    Width="92"
                    Height="35"
                    Margin="0,0,10,0"
                    Command="{Binding ExportLogCommand}"
                    Text="导出日志" />
                <controls:PclButton
                    Width="120"
                    Height="35"
                    Margin="0,0,10,0"
                    Command="{Binding OpenLogDirectoryCommand}"
                    Text="打开日志目录" />
                <controls:PclButton
                    Width="108"
                    Height="35"
                    Command="{Binding ClearGameLogCommand}"
                    ColorType="Red"
                    Text="清空缓存" />
              </WrapPanel>

              <Grid ColumnDefinitions="*,*">
                <Border
                    Padding="12,10"
                    Background="#F7FAFE"
                    BorderBrush="#D5E6FD"
                    BorderThickness="1"
                    CornerRadius="4">
                  <StackPanel Spacing="4">
                    <TextBlock Foreground="#7D8897" FontSize="11.5" Text="实时输出行数" />
                    <TextBlock Foreground="#2B4260" FontSize="18" FontWeight="Bold" Text="{Binding GameLogLiveLineCount}" />
                  </StackPanel>
                </Border>
                <Border
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Padding="12,10"
                    Background="#F7FAFE"
                    BorderBrush="#D5E6FD"
                    BorderThickness="1"
                    CornerRadius="4">
                  <StackPanel Spacing="4">
                    <TextBlock Foreground="#7D8897" FontSize="11.5" Text="最近日志文件" />
                    <TextBlock Foreground="#2B4260" FontSize="18" FontWeight="Bold" Text="{Binding GameLogRecentFileCount}" />
                    <TextBlock Foreground="#7A8794" FontSize="11" Text="{Binding GameLogLatestUpdateLabel}" />
                  </StackPanel>
                </Border>
              </Grid>

              <controls:PclCard Header="当前会话输出" IsVisible="{Binding ShowGameLogLiveOutput}" ContentMargin="16,16,16,16">
                <controls:PclCard.CardContent>
                  <Border
                      Background="#0C1117"
                      BorderBrush="#1E2A36"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="1">
                    <TextBox
                        MinHeight="320"
                        AcceptsReturn="True"
                        Background="#0C1117"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        FontFamily="Consolas"
                        FontSize="12.5"
                        Foreground="#D7E3F1"
                        IsReadOnly="True"
                        Text="{Binding LaunchLogText}"
                        TextWrapping="Wrap" />
                  </Border>
                </controls:PclCard.CardContent>
              </controls:PclCard>

              <controls:PclCard Header="最近生成的日志文件" IsVisible="{Binding HasGameLogFiles}" ContentMargin="18,18,18,16">
                <controls:PclCard.CardContent>
                  <ItemsControl ItemsSource="{Binding GameLogFileEntries}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <controls:PclListItem
                            Margin="0,0,0,8"
                            Command="{Binding Command}"
                            Info="{Binding Info}"
                            Title="{Binding Title}" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </controls:PclCard.CardContent>
              </controls:PclCard>

              <controls:PclCard Header="还没有可展示的日志" IsVisible="{Binding ShowGameLogEmptyState}" ContentMargin="20,18,20,18">
                <controls:PclCard.CardContent>
                  <TextBlock
                      Foreground="#4B5968"
                      FontSize="13"
                      Text="启动一次游戏、触发崩溃恢复，或者刷新日志目录后，这里就会出现实时输出和最近的日志文件。"
                      TextWrapping="Wrap" />
                </controls:PclCard.CardContent>
              </controls:PclCard>
            </StackPanel>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <controls:PclCard Header="{Binding CommunityProjectTitle}" IsVisible="{Binding ShowCompDetailSurface}" ContentMargin="20,18,20,18">
          <controls:PclCard.CardContent>
            <StackPanel Spacing="14">
              <Grid ColumnDefinitions="*,*,*,*">
                <Border
                    Padding="12,10"
                    Background="#F7FAFE"
                    BorderBrush="#D5E6FD"
                    BorderThickness="1"
                    CornerRadius="4">
                  <StackPanel Spacing="4">
                    <TextBlock Foreground="#7D8897" FontSize="11.5" Text="来源" />
                    <TextBlock Foreground="#2B4260" FontSize="16" FontWeight="Bold" Text="{Binding CommunityProjectSource}" />
                  </StackPanel>
                </Border>
                <Border
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Padding="12,10"
                    Background="#EEF9F2"
                    BorderBrush="#C7E8D1"
                    BorderThickness="1"
                    CornerRadius="4">
                  <StackPanel Spacing="4">
                    <TextBlock Foreground="#6E8A73" FontSize="11.5" Text="状态" />
                    <TextBlock Foreground="#1B6B3A" FontSize="16" FontWeight="Bold" Text="{Binding CommunityProjectStatus}" />
                  </StackPanel>
                </Border>
                <Border
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    Padding="12,10"
                    Background="#FFF8E6"
                    BorderBrush="#F2DCA1"
                    BorderThickness="1"
                    CornerRadius="4">
                  <StackPanel Spacing="4">
                    <TextBlock Foreground="#8D7641" FontSize="11.5" Text="下载量" />
                    <TextBlock Foreground="#8A5A00" FontSize="16" FontWeight="Bold" Text="{Binding CommunityProjectDownloadCountLabel}" />
                  </StackPanel>
                </Border>
                <Border
                    Grid.Column="3"
                    Margin="10,0,0,0"
                    Padding="12,10"
                    Background="#FDF2FB"
                    BorderBrush="#F1CDE7"
                    BorderThickness="1"
                    CornerRadius="4">
                  <StackPanel Spacing="4">
                    <TextBlock Foreground="#8D6A82" FontSize="11.5" Text="关注 / 点赞" />
                    <TextBlock Foreground="#9B2B73" FontSize="16" FontWeight="Bold" Text="{Binding CommunityProjectFollowCountLabel}" />
                  </StackPanel>
                </Border>
              </Grid>

              <Border
                  Padding="12,10"
                  Background="#F7FAFE"
                  BorderBrush="#D5E6FD"
                  BorderThickness="1"
                  CornerRadius="4">
                <StackPanel Spacing="6">
                  <TextBlock
                      Foreground="#344352"
                      FontSize="13"
                      FontWeight="SemiBold"
                      Text="{Binding CommunityProjectSummary}"
                      TextWrapping="Wrap" />
                  <TextBlock
                      Foreground="#6B7C8F"
                      FontSize="11.5"
                      Text="{Binding CommunityProjectCompatibilitySummary}"
                      TextWrapping="Wrap" />
                  <TextBlock
                      Foreground="#6B7C8F"
                      FontSize="11.5"
                      Text="{Binding CommunityProjectCategorySummary}"
                      TextWrapping="Wrap" />
                  <TextBlock
                      Foreground="#7A8794"
                      FontSize="11.5"
                      Text="{Binding CommunityProjectUpdatedLabel}"
                      TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border
                  Padding="12,10"
                  Background="#FFF8DD"
                  BorderBrush="#F2D777"
                  BorderThickness="1"
                  CornerRadius="4"
                  IsVisible="{Binding ShowCommunityProjectWarning}">
                <TextBlock
                    Foreground="#6E5800"
                    FontSize="12.5"
                    Text="{Binding CommunityProjectWarningText}"
                    TextWrapping="Wrap" />
              </Border>

              <controls:PclCard Header="项目简介" IsVisible="{Binding HasCommunityProjectDescription}" ContentMargin="18,18,18,16">
                <controls:PclCard.CardContent>
                  <TextBlock
                      Foreground="#4B5968"
                      FontSize="13"
                      Text="{Binding CommunityProjectDescription}"
                      TextWrapping="Wrap" />
                </controls:PclCard.CardContent>
              </controls:PclCard>

              <ItemsControl ItemsSource="{Binding CommunityProjectSections}" IsVisible="{Binding HasCommunityProjectSections}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <controls:PclCard Header="{Binding Title}" ContentMargin="18,18,18,16">
                      <controls:PclCard.CardContent>
                        <ItemsControl ItemsSource="{Binding Items}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <controls:PclActionSummaryRow
                                  ActionText="{Binding ActionText}"
                                  Command="{Binding Command}"
                                  Info="{Binding Info}"
                                  Meta="{Binding Meta}"
                                  ShowMeta="{Binding HasMeta}"
                                  Title="{Binding Title}" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </controls:PclCard.CardContent>
                    </controls:PclCard>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <controls:PclCard Header="还没有更多详情" IsVisible="{Binding HasNoCommunityProjectSections}" ContentMargin="20,18,20,18">
                <controls:PclCard.CardContent>
                  <TextBlock
                      Foreground="#4B5968"
                      FontSize="13"
                      Text="该工程暂时没有返回可展示的版本或外部链接信息。"
                      TextWrapping="Wrap" />
                </controls:PclCard.CardContent>
              </controls:PclCard>
            </StackPanel>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <controls:PclCard Header="主页市场" IsVisible="{Binding ShowHomePageMarketSurface}" ContentMargin="20,18,20,18">
          <controls:PclCard.CardContent>
            <StackPanel Spacing="14">
              <Border
                  Padding="12,10"
                  Background="#F7FAFE"
                  BorderBrush="#D5E6FD"
                  BorderThickness="1"
                  CornerRadius="4">
                <TextBlock
                    Foreground="#45586A"
                    FontSize="12.5"
                    Text="{Binding HomePageMarketSummary}"
                    TextWrapping="Wrap" />
              </Border>

              <Border
                  Padding="12,10"
                  Background="#FFF8DD"
                  BorderBrush="#F2D777"
                  BorderThickness="1"
                  CornerRadius="4"
                  IsVisible="{Binding ShowHomePageMarketWarning}">
                <TextBlock
                    Foreground="#6E5800"
                    FontSize="12.5"
                    Text="{Binding HomePageMarketWarningText}"
                    TextWrapping="Wrap" />
              </Border>

              <ItemsControl ItemsSource="{Binding HomePageMarketSections}" IsVisible="{Binding HasHomePageMarketSections}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <controls:PclCard Header="{Binding Title}" ContentMargin="18,18,18,16">
                      <controls:PclCard.CardContent>
                        <ItemsControl ItemsSource="{Binding Items}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <controls:PclActionSummaryRow
                                  ActionText="{Binding ActionText}"
                                  Command="{Binding Command}"
                                  Info="{Binding Info}"
                                  Meta="{Binding Meta}"
                                  ShowMeta="{Binding HasMeta}"
                                  Title="{Binding Title}" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </controls:PclCard.CardContent>
                    </controls:PclCard>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <controls:PclCard Header="市场还没有可展示内容" IsVisible="{Binding HasNoHomePageMarketSections}" ContentMargin="20,18,20,18">
                <controls:PclCard.CardContent>
                  <TextBlock
                      Foreground="#4B5968"
                      FontSize="13"
                      Text="当前还没有成功聚合到主页市场条目，请稍后再试。"
                      TextWrapping="Wrap" />
                </controls:PclCard.CardContent>
              </controls:PclCard>
            </StackPanel>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <controls:PclCard Header="{Binding HelpDetailTitle}" IsVisible="{Binding ShowHelpDetailSurface}" ContentMargin="20,18,20,18">
          <controls:PclCard.CardContent>
            <StackPanel Spacing="14">
              <Border
                  Padding="12,10"
                  Background="#F7FAFE"
                  BorderBrush="#D5E6FD"
                  BorderThickness="1"
                  CornerRadius="4">
                <StackPanel Spacing="5">
                  <TextBlock
                      Foreground="#344352"
                      FontSize="13"
                      FontWeight="SemiBold"
                      Text="{Binding HelpDetailSummary}"
                      TextWrapping="Wrap" />
                  <TextBlock
                      Foreground="#6B7C8F"
                      FontSize="11.5"
                      Text="{Binding HelpDetailSource}"
                      TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <ItemsControl ItemsSource="{Binding HelpDetailSections}" IsVisible="{Binding HasHelpDetailSections}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <controls:PclCard Header="{Binding Title}" ContentMargin="18,18,18,16">
                      <controls:PclCard.CardContent>
                        <StackPanel Spacing="12">
                          <ItemsControl ItemsSource="{Binding Lines}" IsVisible="{Binding HasLines}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Grid Margin="0,0,0,8" ColumnDefinitions="Auto,*">
                                  <TextBlock
                                      VerticalAlignment="Top"
                                      Foreground="#1370F3"
                                      FontSize="16"
                                      Text="•" />
                                  <TextBlock
                                      Grid.Column="1"
                                      Margin="10,0,0,0"
                                      Foreground="#45586A"
                                      FontSize="13.5"
                                      Text="{Binding}"
                                      TextWrapping="Wrap" />
                                </Grid>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>

                          <ItemsControl ItemsSource="{Binding Actions}" IsVisible="{Binding HasActions}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <controls:PclListItem
                                    Margin="0,0,0,8"
                                    Command="{Binding Command}"
                                    Info="{Binding Info}"
                                    Title="{Binding Title}" />
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </controls:PclCard.CardContent>
                    </controls:PclCard>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <controls:PclCard Header="暂无详情内容" IsVisible="{Binding HasNoHelpDetailSections}" ContentMargin="20,18,20,18">
                <controls:PclCard.CardContent>
                  <TextBlock
                      Foreground="#4B5968"
                      FontSize="13"
                      Text="当前帮助条目没有可显示的详情内容。"
                      TextWrapping="Wrap" />
                </controls:PclCard.CardContent>
              </controls:PclCard>
            </StackPanel>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <controls:PclCard Header="{Binding Title}" IsVisible="{Binding ShowGenericCompatibilitySurface}" ContentMargin="20,12,20,15">
          <controls:PclCard.CardContent>
            <StackPanel Spacing="10">
              <TextBlock
                  Foreground="#1370F3"
                  FontSize="12"
                  FontWeight="Bold"
                  Text="{Binding Eyebrow}" />
              <TextBlock
                  Foreground="#4B5968"
                  FontSize="13"
                  Text="{Binding Description}"
                  TextWrapping="Wrap" />
              <Border
                  Padding="12,10"
                  Background="#F7FAFE"
                  BorderBrush="#D5E6FD"
                  BorderThickness="1"
                  CornerRadius="4">
                <StackPanel Spacing="6">
                  <TextBlock
                      Foreground="#404040"
                      FontSize="11.5"
                      Text="{Binding BreadcrumbTrail}"
                      TextWrapping="Wrap" />
                  <TextBlock
                      Foreground="#7D8897"
                      FontSize="11"
                      Text="{Binding SurfaceMeta}"
                      TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </StackPanel>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <controls:PclCard Header="页面概览" IsVisible="{Binding ShowGenericCompatibilitySurface}" ContentMargin="20,12,20,15">
          <controls:PclCard.CardContent>
            <ItemsControl ItemsSource="{Binding SurfaceFacts}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,0,0,12" ColumnDefinitions="140,*">
                    <TextBlock
                        Margin="0,2,12,0"
                        Foreground="#7D8897"
                        FontSize="11.5"
                        Text="{Binding Label}"
                        TextWrapping="Wrap" />
                    <Border
                        Grid.Column="1"
                        Padding="12,9"
                        Background="{Binding BackgroundBrush}"
                        BorderBrush="{Binding BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                      <TextBlock
                          Foreground="{Binding ForegroundBrush}"
                          FontSize="13.5"
                          FontWeight="SemiBold"
                          Text="{Binding Value}"
                          TextWrapping="Wrap" />
                    </Border>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <ItemsControl ItemsSource="{Binding SurfaceSections}" IsVisible="{Binding ShowGenericCompatibilitySurface}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <controls:PclCard Header="{Binding Title}" ContentMargin="20,16,20,18">
                <controls:PclCard.CardContent>
                  <StackPanel Spacing="10">
                    <TextBlock
                        Foreground="{Binding AccentBrush}"
                        FontSize="12"
                        FontWeight="Bold"
                        Text="{Binding Eyebrow}" />
                    <ItemsControl ItemsSource="{Binding Lines}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid Margin="0,0,0,8" ColumnDefinitions="Auto,*">
                            <TextBlock
                                VerticalAlignment="Top"
                                Foreground="{Binding AccentBrush}"
                                FontSize="16"
                                Text="•" />
                            <TextBlock
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                Foreground="{Binding ForegroundBrush}"
                                FontSize="13.5"
                                Text="{Binding Text}"
                                TextWrapping="Wrap" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </controls:PclCard.CardContent>
              </controls:PclCard>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <controls:PclCard Header="活动记录" IsVisible="{Binding HasActivityEntries}" ContentMargin="18,38,18,18">
          <controls:PclCard.CardContent>
            <ItemsControl ItemsSource="{Binding ActivityEntries}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border
                      Margin="0,0,0,10"
                      Padding="12,10"
                      Background="#F7FAFE"
                      BorderBrush="#D5E6FD"
                      BorderThickness="1"
                      CornerRadius="4">
                    <Grid ColumnDefinitions="Auto,*">
                      <TextBlock
                          Foreground="#7D8897"
                          FontSize="11.5"
                          Text="{Binding Time}" />
                      <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="3">
                        <TextBlock
                            Foreground="#343D4A"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Text="{Binding Title}" />
                        <TextBlock
                            Foreground="#677789"
                            FontSize="12"
                            Text="{Binding Body}"
                            TextWrapping="Wrap" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </controls:PclCard.CardContent>
        </controls:PclCard>
      </StackPanel>
    </Grid>
  </ScrollViewer>
</UserControl>
