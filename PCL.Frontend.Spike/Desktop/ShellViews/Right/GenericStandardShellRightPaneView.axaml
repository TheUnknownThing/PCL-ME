<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.GenericStandardShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
      <StackPanel Margin="25,25,25,10" Spacing="15">
        <controls:PclCard Header="实例选择" IsVisible="{Binding ShowInstanceSelectSurface}" ContentMargin="20,18,20,18">
          <controls:PclCard.CardContent>
            <StackPanel Spacing="14">
              <Grid ColumnDefinitions="*,Auto">
                <Border
                    Height="40"
                    Padding="12,0"
                    Background="#F8FBFF"
                    BorderBrush="#D5E6FD"
                    BorderThickness="1"
                    CornerRadius="5">
                  <TextBox
                      Background="Transparent"
                      BorderBrush="Transparent"
                      BorderThickness="0"
                      FontSize="13.5"
                      Text="{Binding InstanceSelectionSearchQuery}"
                      Watermark="搜索实例名称、版本或加载器" />
                </Border>
                <controls:PclButton
                    Grid.Column="1"
                    Width="72"
                    Height="40"
                    Margin="10,0,0,0"
                    Command="{Binding RefreshInstanceSelectionCommand}"
                    Text="刷新" />
              </Grid>

              <Border
                  Padding="12,10"
                  Background="#F7FAFE"
                  BorderBrush="#D5E6FD"
                  BorderThickness="1"
                  CornerRadius="4">
                <StackPanel Spacing="5">
                  <TextBlock
                      Foreground="#344352"
                      FontSize="13"
                      FontWeight="SemiBold"
                      Text="{Binding InstanceSelectionResultSummary}" />
                  <TextBlock
                      Foreground="#6B7C8F"
                      FontSize="11.5"
                      Text="{Binding InstanceSelectionLauncherDirectory}"
                      TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <ItemsControl ItemsSource="{Binding InstanceSelectionEntries}" IsVisible="{Binding HasInstanceSelectionEntries}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <controls:PclCard Header="{Binding Title}" ContentMargin="18,18,18,16">
                      <controls:PclCard.CardContent>
                        <StackPanel Spacing="12">
                          <TextBlock
                              Foreground="#45586A"
                              FontSize="13"
                              Text="{Binding Subtitle}"
                              TextWrapping="Wrap" />
                          <ItemsControl ItemsSource="{Binding Tags}" IsVisible="{Binding HasTags}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <WrapPanel />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border
                                    Margin="0,0,8,8"
                                    Padding="10,4"
                                    Background="#EDF5FF"
                                    BorderBrush="#C8DEFB"
                                    BorderThickness="1"
                                    CornerRadius="999">
                                  <TextBlock
                                      Foreground="#215EA9"
                                      FontSize="11.5"
                                      FontWeight="SemiBold"
                                      Text="{Binding}" />
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                          <TextBlock
                              Foreground="#7A8794"
                              FontSize="11.5"
                              Text="{Binding Detail}"
                              TextWrapping="Wrap" />
                          <WrapPanel>
                            <controls:PclButton
                                Width="132"
                                Height="35"
                                Margin="0,0,10,0"
                                ColorType="Highlight"
                                Command="{Binding SelectCommand}"
                                Text="{Binding SelectText}" />
                            <controls:PclButton
                                Width="96"
                                Height="35"
                                Margin="0,0,10,0"
                                Command="{Binding OpenCommand}"
                                Text="打开详情" />
                            <controls:PclButton
                                Width="108"
                                Height="35"
                                Command="{Binding OpenFolderCommand}"
                                Text="打开目录" />
                          </WrapPanel>
                        </StackPanel>
                      </controls:PclCard.CardContent>
                    </controls:PclCard>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <controls:PclCard Header="没有可显示的实例" IsVisible="{Binding HasNoInstanceSelectionEntries}" ContentMargin="20,18,20,18">
                <controls:PclCard.CardContent>
                  <StackPanel Spacing="10">
                    <TextBlock
                        Foreground="#4B5968"
                        FontSize="13"
                        Text="当前启动目录下没有匹配到实例。你可以先下载实例，或检查启动目录是否指向正确的 `.minecraft`。"
                        TextWrapping="Wrap" />
                    <controls:PclButton
                        Width="110"
                        Height="35"
                        Command="{Binding ClearInstanceSelectionSearchCommand}"
                        Text="清空筛选" />
                  </StackPanel>
                </controls:PclCard.CardContent>
              </controls:PclCard>
            </StackPanel>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <controls:PclCard Header="任务管理" IsVisible="{Binding ShowTaskManagerSurface}" ContentMargin="20,18,20,18">
          <controls:PclCard.CardContent>
            <StackPanel Spacing="14">
              <WrapPanel>
                <controls:PclButton
                    Width="92"
                    Height="35"
                    Margin="0,0,10,0"
                    ColorType="Highlight"
                    Command="{Binding RefreshTaskManagerCommand}"
                    Text="刷新" />
                <controls:PclButton
                    Width="120"
                    Height="35"
                    Command="{Binding ClearFinishedTasksCommand}"
                    Text="清理已结束" />
              </WrapPanel>

              <Grid ColumnDefinitions="*,*,*,*">
                <Border
                    Padding="12,10"
                    Background="#F7FAFE"
                    BorderBrush="#D5E6FD"
                    BorderThickness="1"
                    CornerRadius="4">
                  <StackPanel Spacing="4">
                    <TextBlock Foreground="#7D8897" FontSize="11.5" Text="等待中" />
                    <TextBlock Foreground="#2B4260" FontSize="18" FontWeight="Bold" Text="{Binding TaskManagerWaitingCount}" />
                  </StackPanel>
                </Border>
                <Border
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Padding="12,10"
                    Background="#EEF9F2"
                    BorderBrush="#C7E8D1"
                    BorderThickness="1"
                    CornerRadius="4">
                  <StackPanel Spacing="4">
                    <TextBlock Foreground="#6E8A73" FontSize="11.5" Text="运行中" />
                    <TextBlock Foreground="#1B6B3A" FontSize="18" FontWeight="Bold" Text="{Binding TaskManagerRunningCount}" />
                  </StackPanel>
                </Border>
                <Border
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    Padding="12,10"
                    Background="#FFF8E6"
                    BorderBrush="#F2DCA1"
                    BorderThickness="1"
                    CornerRadius="4">
                  <StackPanel Spacing="4">
                    <TextBlock Foreground="#8D7641" FontSize="11.5" Text="已结束" />
                    <TextBlock Foreground="#8A5A00" FontSize="18" FontWeight="Bold" Text="{Binding TaskManagerFinishedCount}" />
                  </StackPanel>
                </Border>
                <Border
                    Grid.Column="3"
                    Margin="10,0,0,0"
                    Padding="12,10"
                    Background="#FFF0EF"
                    BorderBrush="#F2CBC7"
                    BorderThickness="1"
                    CornerRadius="4">
                  <StackPanel Spacing="4">
                    <TextBlock Foreground="#8D6C69" FontSize="11.5" Text="失败" />
                    <TextBlock Foreground="#B23A2B" FontSize="18" FontWeight="Bold" Text="{Binding TaskManagerFailedCount}" />
                  </StackPanel>
                </Border>
              </Grid>

              <Border
                  Padding="12,10"
                  Background="#F7FAFE"
                  BorderBrush="#D5E6FD"
                  BorderThickness="1"
                  CornerRadius="4">
                <TextBlock
                    Foreground="#45586A"
                    FontSize="12.5"
                    Text="{Binding TaskManagerSummary}"
                    TextWrapping="Wrap" />
              </Border>

              <ItemsControl ItemsSource="{Binding TaskManagerEntries}" IsVisible="{Binding HasTaskManagerEntries}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <controls:PclCard Header="{Binding Title}" ContentMargin="18,18,18,16">
                      <controls:PclCard.CardContent>
                        <StackPanel Spacing="12">
                          <Grid ColumnDefinitions="Auto,*">
                            <Border
                                Padding="10,4"
                                Background="#EDF5FF"
                                BorderBrush="#C8DEFB"
                                BorderThickness="1"
                                CornerRadius="999">
                              <TextBlock
                                  Foreground="#215EA9"
                                  FontSize="11.5"
                                  FontWeight="SemiBold"
                                  Text="{Binding State}" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="4">
                              <TextBlock
                                  Foreground="#45586A"
                                  FontSize="13"
                                  Text="{Binding Summary}"
                                  TextWrapping="Wrap" />
                              <TextBlock
                                  Foreground="#7A8794"
                                  FontSize="11.5"
                                  Text="{Binding ProgressText}" />
                              <TextBlock
                                  Foreground="#7A8794"
                                  FontSize="11.5"
                                  IsVisible="{Binding HasChildren}"
                                  Text="{Binding ChildrenText}" />
                            </StackPanel>
                          </Grid>
                          <WrapPanel>
                            <controls:PclButton
                                Width="84"
                                Height="35"
                                Margin="0,0,10,0"
                                Command="{Binding PauseCommand}"
                                IsEnabled="{Binding CanPause}"
                                Text="暂停" />
                            <controls:PclButton
                                Width="84"
                                Height="35"
                                Command="{Binding CancelCommand}"
                                ColorType="Red"
                                IsEnabled="{Binding CanCancel}"
                                Text="取消" />
                          </WrapPanel>
                        </StackPanel>
                      </controls:PclCard.CardContent>
                    </controls:PclCard>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <controls:PclCard Header="当前没有活动任务" IsVisible="{Binding HasNoTaskManagerEntries}" ContentMargin="20,18,20,18">
                <controls:PclCard.CardContent>
                  <TextBlock
                      Foreground="#4B5968"
                      FontSize="13"
                      Text="TaskCenter 中还没有需要展示的任务。下载、安装或其他后台流程开始后，这里会自动出现实时状态。"
                      TextWrapping="Wrap" />
                </controls:PclCard.CardContent>
              </controls:PclCard>
            </StackPanel>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <controls:PclCard Header="实时日志" IsVisible="{Binding ShowGameLogSurface}" ContentMargin="20,18,20,18">
          <controls:PclCard.CardContent>
            <StackPanel Spacing="14">
              <WrapPanel>
                <controls:PclButton
                    Width="92"
                    Height="35"
                    Margin="0,0,10,0"
                    ColorType="Highlight"
                    Command="{Binding RefreshGameLogCommand}"
                    Text="刷新" />
                <controls:PclButton
                    Width="92"
                    Height="35"
                    Margin="0,0,10,0"
                    Command="{Binding ExportLogCommand}"
                    Text="导出日志" />
                <controls:PclButton
                    Width="120"
                    Height="35"
                    Margin="0,0,10,0"
                    Command="{Binding OpenLogDirectoryCommand}"
                    Text="打开日志目录" />
                <controls:PclButton
                    Width="108"
                    Height="35"
                    Command="{Binding ClearGameLogCommand}"
                    ColorType="Red"
                    Text="清空缓存" />
              </WrapPanel>

              <Grid ColumnDefinitions="*,*">
                <Border
                    Padding="12,10"
                    Background="#F7FAFE"
                    BorderBrush="#D5E6FD"
                    BorderThickness="1"
                    CornerRadius="4">
                  <StackPanel Spacing="4">
                    <TextBlock Foreground="#7D8897" FontSize="11.5" Text="实时输出行数" />
                    <TextBlock Foreground="#2B4260" FontSize="18" FontWeight="Bold" Text="{Binding GameLogLiveLineCount}" />
                  </StackPanel>
                </Border>
                <Border
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Padding="12,10"
                    Background="#F7FAFE"
                    BorderBrush="#D5E6FD"
                    BorderThickness="1"
                    CornerRadius="4">
                  <StackPanel Spacing="4">
                    <TextBlock Foreground="#7D8897" FontSize="11.5" Text="最近日志文件" />
                    <TextBlock Foreground="#2B4260" FontSize="18" FontWeight="Bold" Text="{Binding GameLogRecentFileCount}" />
                    <TextBlock Foreground="#7A8794" FontSize="11" Text="{Binding GameLogLatestUpdateLabel}" />
                  </StackPanel>
                </Border>
              </Grid>

              <controls:PclCard Header="当前会话输出" IsVisible="{Binding ShowGameLogLiveOutput}" ContentMargin="16,16,16,16">
                <controls:PclCard.CardContent>
                  <Border
                      Background="#0C1117"
                      BorderBrush="#1E2A36"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="1">
                    <TextBox
                        MinHeight="320"
                        AcceptsReturn="True"
                        Background="#0C1117"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        FontFamily="Consolas"
                        FontSize="12.5"
                        Foreground="#D7E3F1"
                        IsReadOnly="True"
                        Text="{Binding LaunchLogText}"
                        TextWrapping="Wrap" />
                  </Border>
                </controls:PclCard.CardContent>
              </controls:PclCard>

              <controls:PclCard Header="最近生成的日志文件" IsVisible="{Binding HasGameLogFiles}" ContentMargin="18,18,18,16">
                <controls:PclCard.CardContent>
                  <ItemsControl ItemsSource="{Binding GameLogFileEntries}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <controls:PclListItem
                            Margin="0,0,0,8"
                            Command="{Binding Command}"
                            Info="{Binding Info}"
                            Title="{Binding Title}" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </controls:PclCard.CardContent>
              </controls:PclCard>

              <controls:PclCard Header="还没有可展示的日志" IsVisible="{Binding ShowGameLogEmptyState}" ContentMargin="20,18,20,18">
                <controls:PclCard.CardContent>
                  <TextBlock
                      Foreground="#4B5968"
                      FontSize="13"
                      Text="启动一次游戏、触发崩溃恢复，或者刷新日志目录后，这里就会出现实时输出和最近的日志文件。"
                      TextWrapping="Wrap" />
                </controls:PclCard.CardContent>
              </controls:PclCard>
            </StackPanel>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <StackPanel IsVisible="{Binding ShowCompDetailSurface}" Spacing="0">
          <controls:PclCard Margin="0,0,0,25" ContentMargin="22,20,20,20">
            <controls:PclCard.CardContent>
              <StackPanel Spacing="8">
                <Border
                    Height="64"
                    Background="{DynamicResource ColorBrushSemiTransparent}"
                    CornerRadius="4">
                  <Grid ColumnDefinitions="7,50,8,Auto,*,24" RowDefinitions="*,20,18,16,*">
                    <Border
                        Grid.Column="1"
                        Grid.Row="1"
                        Grid.RowSpan="3"
                        Width="50"
                        Height="50"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="#F7FAFE"
                        BorderBrush="#D5E6FD"
                        BorderThickness="1"
                        CornerRadius="6">
                      <TextBlock
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Foreground="#4B78C2"
                          FontSize="16"
                          FontWeight="Bold"
                          Text="{Binding CommunityProjectSourceBadgeText}" />
                    </Border>

                    <TextBlock
                        Grid.Column="3"
                        Grid.ColumnSpan="2"
                        Grid.Row="1"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource ColorBrush1}"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="{Binding CommunityProjectTitle}"
                        TextTrimming="CharacterEllipsis" />

                    <StackPanel
                        Grid.Column="3"
                        Grid.Row="2"
                        Margin="-1,0,1,0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        IsVisible="{Binding HasCommunityProjectCategoryTags}">
                      <ItemsControl ItemsSource="{Binding CommunityProjectCategoryTags}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border
                                Margin="0,0,3,0"
                                Padding="3,1"
                                Background="#11000000"
                                CornerRadius="3">
                              <TextBlock
                                  Foreground="#868686"
                                  FontSize="11"
                                  Text="{Binding}" />
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>

                    <TextBlock
                        Grid.Column="4"
                        Grid.Row="2"
                        Margin="0,0,3,0.5"
                        VerticalAlignment="Center"
                        Foreground="#7D8897"
                        FontSize="12"
                        Text="{Binding CommunityProjectIntroDescription}"
                        TextTrimming="CharacterEllipsis" />

                    <Grid
                        Grid.Column="3"
                        Grid.ColumnSpan="2"
                        Grid.Row="3"
                        VerticalAlignment="Center"
                        ColumnDefinitions="Auto,Auto,0.25*,Auto,Auto,0.25*,Auto,Auto,0.25*,Auto,Auto,0.25*">
                      <Path
                          Grid.Column="0"
                          Height="11"
                          Fill="#8C99A6"
                          Stretch="Uniform"
                          Data="M940.4 463.7L773.3 174.2c-17.3-30-49.2-48.4-83.8-48.4H340.2c-34.6 0-66.5 18.5-83.8 48.4L89.2 463.7c-17.3 30-17.3 66.9 0 96.8L256.4 850c17.3 30 49.2 48.4 83.8 48.4h349.2c34.6 0 66.5-18.5 83.8-48.4l167.2-289.5c17.3-29.9 17.3-66.8 0-96.8z m-94.6 96.8L725.9 768.1c-17.3 30-49.2 48.4-83.8 48.4H387.5c-34.6 0-66.5-18.5-83.8-48.4L183.9 560.5c-17.3-30-17.3-66.9 0-96.8l119.8-207.5c17.3-30 49.2-48.4 83.8-48.4h254.6c34.6 0 66.5 18.5 83.8 48.4l119.8 207.5c17.3 30 17.3 66.9 0.1 96.8z M522.3 321.2c-2.5-0.1-5-0.2-7.5-0.2-119.9 0-214 110.3-186.3 235 15.8 70.9 71.5 126.6 142.4 142.4 17.5 3.9 34.7 5.4 51.4 4.7 102.1-3.9 183.6-87.9 183.6-191 0.1-103-81.5-187-183.6-190.9z m68.6 269.1c-18.5 18-43 28.9-68.6 30.7l-6 0.3c-30.2 0.4-58.6-11.4-79.7-33-19.5-20.1-30.7-47-30.9-75-0.3-29.6 11.1-57.4 32-78.3 20.6-20.6 48-32 77.2-32 2.5 0 5 0.1 7.5 0.3 26.7 1.8 51.5 13.2 70.5 32.5 19.6 20 30.8 46.9 31.2 74.9 0.2 30.2-11.5 58.6-33.2 79.6z" />
                      <TextBlock
                          Grid.Column="1"
                          Margin="4,0,2,0"
                          VerticalAlignment="Center"
                          Foreground="#8C99A6"
                          FontSize="12"
                          Text="{Binding CommunityProjectCompatibilitySummary}"
                          TextTrimming="CharacterEllipsis" />

                      <Path
                          Grid.Column="3"
                          Height="10.5"
                          Fill="#8C99A6"
                          Stretch="Uniform"
                          Data="M955 610h-59c-15 0-29 13-29 29v196c0 15-13 29-29 29h-649c-15 0-29-13-29-29v-196c0-15-13-29-29-29h-59c-15 0-29 13-29 29V905c0 43 35 78 78 78h787c43 0 78-35 78-78V640c0-15-13-29-29-29zM492 740c11 11 29 11 41 0l265-265c11-11 11-29 0-41l-41-41c-11-11-29-11-41 0l-110 110c-11 11-33 3-33-13V68C571 53 555 39 541 39h-59c-15 0-29 13-29 29v417c0 17-21 25-33 13l-110-110c-11-11-29-11-41 0L226 433c-11 11-11 29 0 41L492 740z" />
                      <TextBlock
                          Grid.Column="4"
                          Margin="5,0,2,0"
                          VerticalAlignment="Center"
                          Foreground="#8C99A6"
                          FontSize="12"
                          Text="{Binding CommunityProjectDownloadCountLabel}"
                          TextTrimming="CharacterEllipsis" />

                      <Path
                          Grid.Column="6"
                          Height="11.5"
                          Margin="0,0,1,0"
                          Fill="#8C99A6"
                          Stretch="Uniform"
                          Data="M810 403l-39 39c-10 10-28 10-39 0l-162-162v412c0 15-12 28-28 28h-56c-15 0-28-12-28-28v-412l-162 162c-10 10-28 10-39 0l-39-39c-10-10-10-28 0-39l278-278c10-10 28-10 39 0l278 278c10 10 10 28 0 39zM568 946h-112v-112h112v112z" />
                      <TextBlock
                          Grid.Column="7"
                          Margin="5,0,2,0"
                          VerticalAlignment="Center"
                          Foreground="#8C99A6"
                          FontSize="12"
                          Text="{Binding CommunityProjectUpdatedLabel}"
                          TextTrimming="CharacterEllipsis" />

                      <Path
                          Grid.Column="9"
                          Height="11.5"
                          Fill="#8C99A6"
                          Stretch="Uniform"
                          Data="M511 143c-203 0-369 165-369 369 0 203 165 369 369 369s369-165 369-369c0-203-165-369-369-369z m0 673c-29 0-68-59-89-159l178 0c-20 100-59 159-89 159z m-98-224c-2-24-3-51-3-79 0-29 1-57 4-83l197 0c2 25 4 53 4 83 0 28-1 54-3 79l-198-0z m98-383c29 0 67 58 88 156l-177-0c20-98 59-155 88-155z m164 221l128 0c7 26 11 54 11 82 0 27-3 54-10 80l-129-0c2-26 3-52 3-79 0-28-1-56-4-83z m101-64l-110-0c-7-37-16-72-28-102-4-11-9-22-15-33 66 25 121 74 155 135z m-376-135c-5 10-10 21-15 33-12 30-21 64-28 102l-110-0c34-60 89-109 154-134z m-181 199l128 0c-2 27-3 54-3 83 0 27 1 53 3 79l-127-0v6c-8-27-12-55-12-85-0-29 3-57 11-83z m24 227l112 0c7 38 16 74 29 105 4 11 9 22 15 33-67-26-122-76-156-139zM621 795c5-10 10-21 15-33 12-30 22-66 29-105l111 0c-34 62-89 111-156 137z" />
                      <TextBlock
                          Grid.Column="10"
                          Margin="5,0,2,0"
                          VerticalAlignment="Center"
                          Foreground="#8C99A6"
                          FontSize="12"
                          Text="{Binding CommunityProjectSource}"
                          TextTrimming="CharacterEllipsis" />
                    </Grid>
                  </Grid>
                </Border>

                <ItemsControl ItemsSource="{Binding CommunityProjectActionButtons}" IsVisible="{Binding HasCommunityProjectActionButtons}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <controls:PclOutlineButton
                          Margin="0,0,8,0"
                          Command="{Binding Command}"
                          Text="{Binding Text}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </controls:PclCard.CardContent>
          </controls:PclCard>

          <controls:PclCard
              Margin="0,0,0,8"
              ContentMargin="20,20,20,17"
              HorizontalAlignment="Center"
              IsVisible="{Binding ShowCommunityProjectLoadingCard}"
              VerticalAlignment="Center">
            <controls:PclCard.CardContent>
              <StackPanel HorizontalAlignment="Center" Spacing="10">
                <ProgressBar Width="180" Height="4" IsIndeterminate="True" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="#4B5968"
                    FontSize="13"
                    Text="{Binding CommunityProjectLoadingText}" />
              </StackPanel>
            </controls:PclCard.CardContent>
          </controls:PclCard>

          <StackPanel IsVisible="{Binding ShowCommunityProjectContent}" Spacing="0">
            <Border
                Margin="0,0,0,15"
                Padding="12,10"
                Background="#FFF8DD"
                BorderBrush="#F2D777"
                BorderThickness="1"
                CornerRadius="4"
                IsVisible="{Binding ShowCommunityProjectWarning}">
              <TextBlock
                  Foreground="#6E5800"
                  FontSize="12.5"
                  Text="{Binding CommunityProjectWarningText}"
                  TextWrapping="Wrap" />
            </Border>

            <controls:PclCard Margin="0,0,0,15" IsVisible="{Binding ShowCommunityProjectFilterCard}" ContentMargin="0,0,0,0">
              <controls:PclCard.CardContent>
                <StackPanel>
                  <Grid Margin="10,10,10,5" ColumnDefinitions="Auto,*" IsVisible="{Binding ShowCommunityProjectVersionFilters}">
                    <TextBlock
                        Margin="2,0,8,0"
                        VerticalAlignment="Center"
                        Foreground="#343D4A"
                        FontSize="13"
                        Text="实例筛选：" />
                    <ItemsControl Grid.Column="1" ItemsSource="{Binding CommunityProjectVersionFilterButtons}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <controls:PclButton
                              Margin="0,0,8,8"
                              MinWidth="72"
                              Command="{Binding Command}"
                              ColorType="{Binding ColorType}"
                              ContentPadding="10,4"
                              Text="{Binding Text}" />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Grid>

                  <Grid Margin="10,5,10,10" ColumnDefinitions="Auto,*" IsVisible="{Binding ShowCommunityProjectLoaderFilters}">
                    <TextBlock
                        Margin="2,0,8,0"
                        VerticalAlignment="Center"
                        Foreground="#343D4A"
                        FontSize="13"
                        Text="模组加载器筛选：" />
                    <ItemsControl Grid.Column="1" ItemsSource="{Binding CommunityProjectLoaderFilterButtons}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <controls:PclButton
                              Margin="0,0,8,8"
                              MinWidth="72"
                              Command="{Binding Command}"
                              ColorType="{Binding ColorType}"
                              ContentPadding="10,4"
                              Text="{Binding Text}" />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Grid>
                </StackPanel>
              </controls:PclCard.CardContent>
            </controls:PclCard>

            <ItemsControl ItemsSource="{Binding CommunityProjectReleaseGroups}" IsVisible="{Binding HasCommunityProjectReleaseGroups}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <controls:PclCard Margin="0,0,0,15" Header="{Binding Title}" ShowChevron="True" IsChevronExpanded="{Binding IsExpanded}" ContentMargin="18,38,18,12">
                    <controls:PclCard.CardContent>
                      <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <controls:PclListItem
                                Margin="0,0,0,8"
                                Command="{Binding Command}"
                                Info="{Binding CombinedInfo}"
                                Title="{Binding Title}" />
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </controls:PclCard.CardContent>
                  </controls:PclCard>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <controls:PclCard Margin="0,0,0,15" Header="还没有可展示的版本" IsVisible="{Binding HasNoCommunityProjectReleaseGroups}" ContentMargin="20,18,20,18">
              <controls:PclCard.CardContent>
                <TextBlock
                    Foreground="#4B5968"
                    FontSize="13"
                    Text="该工程暂时没有返回可展示的版本文件信息。"
                    TextWrapping="Wrap" />
              </controls:PclCard.CardContent>
            </controls:PclCard>

            <ItemsControl ItemsSource="{Binding CommunityProjectSections}" IsVisible="{Binding HasCommunityProjectSections}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <controls:PclCard Margin="0,0,0,15" Header="{Binding Title}" ContentMargin="18,18,18,12">
                    <controls:PclCard.CardContent>
                      <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <controls:PclListItem
                                Margin="0,0,0,8"
                                Command="{Binding Command}"
                                Info="{Binding CombinedInfo}"
                                Title="{Binding Title}" />
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </controls:PclCard.CardContent>
                  </controls:PclCard>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </StackPanel>

        <controls:PclCard Header="主页市场" IsVisible="{Binding ShowHomePageMarketSurface}" ContentMargin="20,18,20,18">
          <controls:PclCard.CardContent>
            <StackPanel Spacing="14">
              <Border
                  Padding="12,10"
                  Background="#F7FAFE"
                  BorderBrush="#D5E6FD"
                  BorderThickness="1"
                  CornerRadius="4">
                <TextBlock
                    Foreground="#45586A"
                    FontSize="12.5"
                    Text="{Binding HomePageMarketSummary}"
                    TextWrapping="Wrap" />
              </Border>

              <Border
                  Padding="12,10"
                  Background="#FFF8DD"
                  BorderBrush="#F2D777"
                  BorderThickness="1"
                  CornerRadius="4"
                  IsVisible="{Binding ShowHomePageMarketWarning}">
                <TextBlock
                    Foreground="#6E5800"
                    FontSize="12.5"
                    Text="{Binding HomePageMarketWarningText}"
                    TextWrapping="Wrap" />
              </Border>

              <ItemsControl ItemsSource="{Binding HomePageMarketSections}" IsVisible="{Binding HasHomePageMarketSections}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <controls:PclCard Header="{Binding Title}" ContentMargin="18,18,18,16">
                      <controls:PclCard.CardContent>
                        <ItemsControl ItemsSource="{Binding Items}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <controls:PclActionSummaryRow
                                  ActionText="{Binding ActionText}"
                                  Command="{Binding Command}"
                                  Info="{Binding Info}"
                                  Meta="{Binding Meta}"
                                  ShowMeta="{Binding HasMeta}"
                                  Title="{Binding Title}" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </controls:PclCard.CardContent>
                    </controls:PclCard>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <controls:PclCard Header="市场还没有可展示内容" IsVisible="{Binding HasNoHomePageMarketSections}" ContentMargin="20,18,20,18">
                <controls:PclCard.CardContent>
                  <TextBlock
                      Foreground="#4B5968"
                      FontSize="13"
                      Text="当前还没有成功聚合到主页市场条目，请稍后再试。"
                      TextWrapping="Wrap" />
                </controls:PclCard.CardContent>
              </controls:PclCard>
            </StackPanel>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <controls:PclCard Header="{Binding HelpDetailTitle}" IsVisible="{Binding ShowHelpDetailSurface}" ContentMargin="20,18,20,18">
          <controls:PclCard.CardContent>
            <StackPanel Spacing="14">
              <Border
                  Padding="12,10"
                  Background="#F7FAFE"
                  BorderBrush="#D5E6FD"
                  BorderThickness="1"
                  CornerRadius="4">
                <StackPanel Spacing="5">
                  <TextBlock
                      Foreground="#344352"
                      FontSize="13"
                      FontWeight="SemiBold"
                      Text="{Binding HelpDetailSummary}"
                      TextWrapping="Wrap" />
                  <TextBlock
                      Foreground="#6B7C8F"
                      FontSize="11.5"
                      Text="{Binding HelpDetailSource}"
                      TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <ItemsControl ItemsSource="{Binding HelpDetailSections}" IsVisible="{Binding HasHelpDetailSections}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <controls:PclCard Header="{Binding Title}" ContentMargin="18,18,18,16">
                      <controls:PclCard.CardContent>
                        <StackPanel Spacing="12">
                          <ItemsControl ItemsSource="{Binding Lines}" IsVisible="{Binding HasLines}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Grid Margin="0,0,0,8" ColumnDefinitions="Auto,*">
                                  <TextBlock
                                      VerticalAlignment="Top"
                                      Foreground="#1370F3"
                                      FontSize="16"
                                      Text="•" />
                                  <TextBlock
                                      Grid.Column="1"
                                      Margin="10,0,0,0"
                                      Foreground="#45586A"
                                      FontSize="13.5"
                                      Text="{Binding}"
                                      TextWrapping="Wrap" />
                                </Grid>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>

                          <ItemsControl ItemsSource="{Binding Actions}" IsVisible="{Binding HasActions}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <controls:PclListItem
                                    Margin="0,0,0,8"
                                    Command="{Binding Command}"
                                    Info="{Binding Info}"
                                    Title="{Binding Title}" />
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </controls:PclCard.CardContent>
                    </controls:PclCard>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <controls:PclCard Header="暂无详情内容" IsVisible="{Binding HasNoHelpDetailSections}" ContentMargin="20,18,20,18">
                <controls:PclCard.CardContent>
                  <TextBlock
                      Foreground="#4B5968"
                      FontSize="13"
                      Text="当前帮助条目没有可显示的详情内容。"
                      TextWrapping="Wrap" />
                </controls:PclCard.CardContent>
              </controls:PclCard>
            </StackPanel>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <controls:PclCard Header="{Binding Title}" IsVisible="{Binding ShowGenericCompatibilitySurface}" ContentMargin="20,12,20,15">
          <controls:PclCard.CardContent>
            <StackPanel Spacing="10">
              <TextBlock
                  Foreground="#1370F3"
                  FontSize="12"
                  FontWeight="Bold"
                  Text="{Binding Eyebrow}" />
              <TextBlock
                  Foreground="#4B5968"
                  FontSize="13"
                  Text="{Binding Description}"
                  TextWrapping="Wrap" />
              <Border
                  Padding="12,10"
                  Background="#F7FAFE"
                  BorderBrush="#D5E6FD"
                  BorderThickness="1"
                  CornerRadius="4">
                <StackPanel Spacing="6">
                  <TextBlock
                      Foreground="#404040"
                      FontSize="11.5"
                      Text="{Binding BreadcrumbTrail}"
                      TextWrapping="Wrap" />
                  <TextBlock
                      Foreground="#7D8897"
                      FontSize="11"
                      Text="{Binding SurfaceMeta}"
                      TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </StackPanel>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <controls:PclCard Header="页面概览" IsVisible="{Binding ShowGenericCompatibilitySurface}" ContentMargin="20,12,20,15">
          <controls:PclCard.CardContent>
            <ItemsControl ItemsSource="{Binding SurfaceFacts}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,0,0,12" ColumnDefinitions="140,*">
                    <TextBlock
                        Margin="0,2,12,0"
                        Foreground="#7D8897"
                        FontSize="11.5"
                        Text="{Binding Label}"
                        TextWrapping="Wrap" />
                    <Border
                        Grid.Column="1"
                        Padding="12,9"
                        Background="{Binding BackgroundBrush}"
                        BorderBrush="{Binding BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                      <TextBlock
                          Foreground="{Binding ForegroundBrush}"
                          FontSize="13.5"
                          FontWeight="SemiBold"
                          Text="{Binding Value}"
                          TextWrapping="Wrap" />
                    </Border>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <ItemsControl ItemsSource="{Binding SurfaceSections}" IsVisible="{Binding ShowGenericCompatibilitySurface}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <controls:PclCard Header="{Binding Title}" ContentMargin="20,16,20,18">
                <controls:PclCard.CardContent>
                  <StackPanel Spacing="10">
                    <TextBlock
                        Foreground="{Binding AccentBrush}"
                        FontSize="12"
                        FontWeight="Bold"
                        Text="{Binding Eyebrow}" />
                    <ItemsControl ItemsSource="{Binding Lines}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid Margin="0,0,0,8" ColumnDefinitions="Auto,*">
                            <TextBlock
                                VerticalAlignment="Top"
                                Foreground="{Binding AccentBrush}"
                                FontSize="16"
                                Text="•" />
                            <TextBlock
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                Foreground="{Binding ForegroundBrush}"
                                FontSize="13.5"
                                Text="{Binding Text}"
                                TextWrapping="Wrap" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </controls:PclCard.CardContent>
              </controls:PclCard>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <controls:PclCard Header="活动记录" IsVisible="{Binding HasActivityEntries}" ContentMargin="18,38,18,18">
          <controls:PclCard.CardContent>
            <ItemsControl ItemsSource="{Binding ActivityEntries}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border
                      Margin="0,0,0,10"
                      Padding="12,10"
                      Background="#F7FAFE"
                      BorderBrush="#D5E6FD"
                      BorderThickness="1"
                      CornerRadius="4">
                    <Grid ColumnDefinitions="Auto,*">
                      <TextBlock
                          Foreground="#7D8897"
                          FontSize="11.5"
                          Text="{Binding Time}" />
                      <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="3">
                        <TextBlock
                            Foreground="#343D4A"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Text="{Binding Title}" />
                        <TextBlock
                            Foreground="#677789"
                            FontSize="12"
                            Text="{Binding Body}"
                            TextWrapping="Wrap" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </controls:PclCard.CardContent>
        </controls:PclCard>
      </StackPanel>
    </Grid>
  </ScrollViewer>
</UserControl>
