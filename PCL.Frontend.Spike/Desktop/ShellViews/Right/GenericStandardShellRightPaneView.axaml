<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.GenericStandardShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
      <StackPanel Margin="25,25,25,10" Spacing="15">
        <controls:PclCard Header="{Binding Title}" ContentMargin="20,12,20,15">
          <controls:PclCard.CardContent>
            <StackPanel Spacing="10">
              <TextBlock
                  Foreground="#1370F3"
                  FontSize="12"
                  FontWeight="Bold"
                  Text="{Binding Eyebrow}" />
              <TextBlock
                  Foreground="#4B5968"
                  FontSize="13"
                  Text="{Binding Description}"
                  TextWrapping="Wrap" />
              <Border
                  Padding="12,10"
                  Background="#F7FAFE"
                  BorderBrush="#D5E6FD"
                  BorderThickness="1"
                  CornerRadius="4">
                <StackPanel Spacing="6">
                  <TextBlock
                      Foreground="#404040"
                      FontSize="11.5"
                      Text="{Binding BreadcrumbTrail}"
                      TextWrapping="Wrap" />
                  <TextBlock
                      Foreground="#7D8897"
                      FontSize="11"
                      Text="{Binding SurfaceMeta}"
                      TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </StackPanel>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <controls:PclCard Header="页面概览" IsVisible="{Binding HasSurfaceFacts}" ContentMargin="20,12,20,15">
          <controls:PclCard.CardContent>
            <ItemsControl ItemsSource="{Binding SurfaceFacts}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,0,0,12" ColumnDefinitions="140,*">
                    <TextBlock
                        Margin="0,2,12,0"
                        Foreground="#7D8897"
                        FontSize="11.5"
                        Text="{Binding Label}"
                        TextWrapping="Wrap" />
                    <Border
                        Grid.Column="1"
                        Padding="12,9"
                        Background="{Binding BackgroundBrush}"
                        BorderBrush="{Binding BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                      <TextBlock
                          Foreground="{Binding ForegroundBrush}"
                          FontSize="13.5"
                          FontWeight="SemiBold"
                          Text="{Binding Value}"
                          TextWrapping="Wrap" />
                    </Border>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </controls:PclCard.CardContent>
        </controls:PclCard>

        <ItemsControl ItemsSource="{Binding SurfaceSections}" IsVisible="{Binding HasSurfaceSections}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <controls:PclCard Header="{Binding Title}" ContentMargin="20,16,20,18">
                <controls:PclCard.CardContent>
                  <StackPanel Spacing="10">
                    <TextBlock
                        Foreground="{Binding AccentBrush}"
                        FontSize="12"
                        FontWeight="Bold"
                        Text="{Binding Eyebrow}" />
                    <ItemsControl ItemsSource="{Binding Lines}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid Margin="0,0,0,8" ColumnDefinitions="Auto,*">
                            <TextBlock
                                VerticalAlignment="Top"
                                Foreground="{Binding AccentBrush}"
                                FontSize="16"
                                Text="•" />
                            <TextBlock
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                Foreground="{Binding ForegroundBrush}"
                                FontSize="13.5"
                                Text="{Binding Text}"
                                TextWrapping="Wrap" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </controls:PclCard.CardContent>
              </controls:PclCard>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <controls:PclCard Header="活动记录" IsVisible="{Binding HasActivityEntries}" ContentMargin="18,38,18,18">
          <controls:PclCard.CardContent>
            <ItemsControl ItemsSource="{Binding ActivityEntries}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border
                      Margin="0,0,0,10"
                      Padding="12,10"
                      Background="#F7FAFE"
                      BorderBrush="#D5E6FD"
                      BorderThickness="1"
                      CornerRadius="4">
                    <Grid ColumnDefinitions="Auto,*">
                      <TextBlock
                          Foreground="#7D8897"
                          FontSize="11.5"
                          Text="{Binding Time}" />
                      <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="3">
                        <TextBlock
                            Foreground="#343D4A"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Text="{Binding Title}" />
                        <TextBlock
                            Foreground="#677789"
                            FontSize="12"
                            Text="{Binding Body}"
                            TextWrapping="Wrap" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </controls:PclCard.CardContent>
        </controls:PclCard>
      </StackPanel>
    </Grid>
  </ScrollViewer>
</UserControl>
