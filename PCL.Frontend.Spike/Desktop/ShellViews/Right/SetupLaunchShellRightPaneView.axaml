<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.SetupLaunchShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,25,25,10" Spacing="15">
      <controls:PclCard Header="启动选项" ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="28,9,28,9,28,9,28,9,28,9,28,9,28,9,28">
            <TextBlock
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="默认版本隔离" />
            <ComboBox
                Grid.Column="1"
                Height="28"
                ItemsSource="{Binding LaunchIsolationOptions}"
                SelectedIndex="{Binding SelectedLaunchIsolationIndex}" />

            <TextBlock
                Grid.Row="2"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="游戏窗口标题" />
            <TextBox
                Grid.Row="2"
                Grid.Column="1"
                Height="28"
                Padding="8,4"
                Text="{Binding LaunchWindowTitleSetting}" />

            <TextBlock
                Grid.Row="4"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="自定义信息" />
            <TextBox
                Grid.Row="4"
                Grid.Column="1"
                Height="28"
                Padding="8,4"
                Text="{Binding LaunchCustomInfoSetting}" />

            <TextBlock
                Grid.Row="6"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="启动器可见性" />
            <ComboBox
                Grid.Row="6"
                Grid.Column="1"
                Height="28"
                ItemsSource="{Binding LaunchVisibilityOptions}"
                SelectedIndex="{Binding SelectedLaunchVisibilityIndex}" />

            <TextBlock
                Grid.Row="8"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="进程优先级" />
            <ComboBox
                Grid.Row="8"
                Grid.Column="1"
                Height="28"
                ItemsSource="{Binding LaunchPriorityOptions}"
                SelectedIndex="{Binding SelectedLaunchPriorityIndex}" />

            <TextBlock
                Grid.Row="10"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="窗口大小" />
            <Grid Grid.Row="10" Grid.Column="1" ColumnDefinitions="220,10,70,10,70">
              <ComboBox
                  Grid.Column="0"
                  Height="28"
                  ItemsSource="{Binding LaunchWindowTypeOptions}"
                  SelectedIndex="{Binding SelectedLaunchWindowTypeIndex}" />
              <TextBox
                  Grid.Column="2"
                  Height="28"
                  Padding="8,4"
                  HorizontalContentAlignment="Center"
                  IsVisible="{Binding IsCustomLaunchWindowSizeVisible}"
                  Text="{Binding LaunchWindowWidth}" />
              <TextBlock
                  Grid.Column="3"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Foreground="#677789"
                  FontSize="15"
                  IsVisible="{Binding IsCustomLaunchWindowSizeVisible}"
                  Text="×" />
              <TextBox
                  Grid.Column="4"
                  Height="28"
                  Padding="8,4"
                  HorizontalContentAlignment="Center"
                  IsVisible="{Binding IsCustomLaunchWindowSizeVisible}"
                  Text="{Binding LaunchWindowHeight}" />
            </Grid>

            <TextBlock
                Grid.Row="12"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="正版验证方式" />
            <ComboBox
                Grid.Row="12"
                Grid.Column="1"
                Height="28"
                IsEnabled="False"
                ItemsSource="{Binding LaunchMicrosoftAuthOptions}"
                SelectedIndex="{Binding SelectedLaunchMicrosoftAuthIndex}" />

            <TextBlock
                Grid.Row="14"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13.5"
                Margin="0,0,25,0"
                Text="IP 协议偏好" />
            <ComboBox
                Grid.Row="14"
                Grid.Column="1"
                Height="28"
                ItemsSource="{Binding LaunchPreferredIpStackOptions}"
                SelectedIndex="{Binding SelectedLaunchPreferredIpStackIndex}" />
          </Grid>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="游戏内存" ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <Border
                Padding="12,10"
                Background="#FFF8DD"
                BorderBrush="#F2D777"
                BorderThickness="1"
                CornerRadius="4">
              <TextBlock
                  Foreground="#6E5800"
                  FontSize="12.5"
                  Text="32 位 Java 只能分配最多 1 GB 的内存。强烈建议换用 64 位的 Java！"
                  TextWrapping="Wrap" />
            </Border>

            <Border
                Padding="12,10"
                Background="#FFF8DD"
                BorderBrush="#F2D777"
                BorderThickness="1"
                CornerRadius="4"
                IsVisible="{Binding ShowRamAllocationWarning}">
              <TextBlock
                  Foreground="#6E5800"
                  FontSize="12.5"
                  Text="你给游戏分配的内存过多，这可能引发游戏崩溃。建议优先考虑自动分配。"
                  TextWrapping="Wrap" />
            </Border>

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,9,Auto,9,Auto">
              <RadioButton
                  Content="自动配置"
                  IsChecked="{Binding UseAutomaticRamAllocation}" />
              <TextBlock
                  Grid.Column="1"
                  Margin="12,0,0,0"
                  VerticalAlignment="Center"
                  Foreground="#677789"
                  FontSize="12.5"
                  Text="根据安装的 Mod 量与电脑剩余内存，动态调整为游戏分配的内存。"
                  TextWrapping="Wrap" />

              <RadioButton
                  Grid.Row="2"
                  Content="自定义"
                  IsChecked="{Binding UseCustomRamAllocation}" />
              <Grid Grid.Row="2" Grid.Column="1" Margin="12,0,0,0" ColumnDefinitions="*,62">
                <Slider
                    IsEnabled="{Binding IsCustomRamAllocationEnabled}"
                    Minimum="1"
                    Maximum="16"
                    Value="{Binding CustomRamAllocation}" />
                <TextBlock
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Foreground="#677789"
                    FontSize="12"
                    Text="{Binding CustomRamAllocationLabel}" />
              </Grid>

              <CheckBox
                  Grid.Row="4"
                  Grid.ColumnSpan="2"
                  Foreground="#343D4A"
                  Content="启动游戏前进行内存优化"
                  IsChecked="{Binding OptimizeMemoryBeforeLaunch}" />
            </Grid>

            <Grid ColumnDefinitions="4.7*,2.5*,0.7*" RowDefinitions="Auto,4,Auto">
              <TextBlock
                  Grid.ColumnSpan="3"
                  Margin="2,0,0,5"
                  Foreground="#7D8897"
                  FontSize="11"
                  Text="已使用内存 / 已安装内存" />
              <Border Grid.Row="1" Grid.Column="0" Background="#66A3DC" CornerRadius="2,0,0,2" />
              <Border Grid.Row="1" Grid.Column="1" Background="#B5D5F8" />
              <Border Grid.Row="1" Grid.Column="2" Background="#E0E9F5" CornerRadius="0,2,2,0" />
              <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Margin="2,4,0,0" Orientation="Horizontal">
                <TextBlock Foreground="#4083C4" FontSize="16" Text="{Binding UsedRamLabel}" />
                <TextBlock Foreground="#4083C4" FontSize="16" Text=" / " />
                <TextBlock Foreground="#4083C4" FontSize="16" Text="{Binding TotalRamLabel}" />
                <TextBlock Margin="18,0,0,0" Foreground="#4083C4" FontSize="16" Text="游戏分配" />
                <TextBlock Margin="8,0,0,0" Foreground="#4083C4" FontSize="16" Text="{Binding AllocatedRamLabel}" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard
          Header="高级启动选项"
          ShowChevron="True"
          IsChevronExpanded="{Binding IsLaunchAdvancedOptionsExpanded}"
          HeaderCommand="{Binding ToggleLaunchAdvancedOptionsCommand}"
          ContentMargin="20,12,20,15">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="Auto,*">
              <TextBlock
                  VerticalAlignment="Center"
                  Foreground="#343D4A"
                  FontSize="13.5"
                  Margin="0,0,25,0"
                  Text="渲染器" />
              <ComboBox
                  Grid.Column="1"
                  Height="28"
                  ItemsSource="{Binding LaunchRendererOptions}"
                  SelectedIndex="{Binding SelectedLaunchRendererIndex}" />
            </Grid>

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,9,Auto,9,Auto">
              <TextBlock
                  VerticalAlignment="Top"
                  Foreground="#343D4A"
                  FontSize="13.5"
                  Margin="0,4,25,0"
                  Text="JVM 参数头部" />
              <TextBox
                  Grid.Column="1"
                  MinHeight="92"
                  Padding="8,6"
                  AcceptsReturn="True"
                  Text="{Binding LaunchJvmArguments}"
                  TextWrapping="Wrap"
                  VerticalContentAlignment="Top" />

              <TextBlock
                  Grid.Row="2"
                  VerticalAlignment="Center"
                  Foreground="#343D4A"
                  FontSize="13.5"
                  Margin="0,0,25,0"
                  Text="游戏参数尾部" />
              <TextBox
                  Grid.Row="2"
                  Grid.Column="1"
                  Height="28"
                  Padding="8,4"
                  Text="{Binding LaunchGameArguments}" />

              <TextBlock
                  Grid.Row="4"
                  VerticalAlignment="Top"
                  Foreground="#343D4A"
                  FontSize="13.5"
                  Margin="0,4,25,0"
                  Text="启动前执行命令" />
              <StackPanel Grid.Row="4" Grid.Column="1" Spacing="8">
                <TextBox
                    MinHeight="72"
                    Padding="8,6"
                    AcceptsReturn="True"
                    Text="{Binding LaunchBeforeCommand}"
                    TextWrapping="Wrap"
                    VerticalContentAlignment="Top" />
                <CheckBox
                    Foreground="#343D4A"
                    Content="等待命令执行完成后再继续启动"
                    IsChecked="{Binding WaitForLaunchBeforeCommand}" />
              </StackPanel>
            </Grid>

            <StackPanel Spacing="8">
              <CheckBox
                  Foreground="#343D4A"
                  Content="禁用 Java Launch Wrapper"
                  IsChecked="{Binding DisableJavaLaunchWrapper}" />
              <CheckBox
                  Foreground="#343D4A"
                  Content="禁用 RetroWrapper"
                  IsChecked="{Binding DisableRetroWrapper}" />
              <CheckBox
                  Foreground="#343D4A"
                  Content="要求 Java 使用高性能显卡"
                  IsChecked="{Binding RequireDedicatedGpu}" />
              <CheckBox
                  Foreground="#343D4A"
                  Content="使用 java.exe 而不是 javaw.exe"
                  IsChecked="{Binding UseJavaExecutable}" />
            </StackPanel>

            <Border
                Padding="12,10"
                Background="#EAF2FE"
                BorderBrush="#D5E6FD"
                BorderThickness="1"
                CornerRadius="4">
              <TextBlock
                  Foreground="#4068A8"
                  FontSize="12.5"
                  Text="你还可以在实例独立设置中找到更多高级启动选项。"
                  TextWrapping="Wrap" />
            </Border>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <Button
          Padding="0"
          HorizontalAlignment="Center"
          Background="Transparent"
          BorderBrush="Transparent"
          BorderThickness="0"
          Command="{Binding VersionSetupCommand}">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock
              Foreground="#1370F3"
              FontSize="13.5"
              Text="实例独立设置" />
          <Path
              Width="10"
              Height="10"
              VerticalAlignment="Center"
              Fill="#1370F3"
              Stretch="Uniform"
              Data="M73 584L920 584 608 896C579 925 579 972 608 1001 637 1030 683 1030 712 1001L1149 565C1164 550 1170 531 1170 511 1170 492 1164 472 1149 457L712 21C683-7 637-7 608 21 579 50 579 97 608 126L920 438 73 438C33 438 0 471 0 511 0 551 33 584 73 584Z" />
        </StackPanel>
      </Button>
    </StackPanel>
  </ScrollViewer>
</UserControl>
