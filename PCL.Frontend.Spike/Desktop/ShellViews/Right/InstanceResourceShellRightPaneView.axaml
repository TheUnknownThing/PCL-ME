<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.InstanceResourceShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,10,25,10" Spacing="15">
      <Border
          Height="40"
          Padding="12,0"
          Background="#F8FBFF"
          BorderBrush="#D5E6FD"
          BorderThickness="1"
          CornerRadius="5">
        <TextBox
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            FontSize="13.5"
            Text="{Binding InstanceResourceSearchQuery}"
            VerticalContentAlignment="Center"
            Watermark="{Binding InstanceResourceSearchWatermark}" />
      </Border>

      <controls:PclCard ContentMargin="15,8,0,15">
        <controls:PclCard.CardContent>
          <WrapPanel>
            <controls:PclButton
                MinWidth="110"
                Margin="0,7,15,0"
                Command="{Binding OpenInstanceResourceFolderCommand}"
                ColorType="Highlight"
                Text="打开文件夹" />
            <controls:PclButton
                MinWidth="110"
                Margin="0,7,15,0"
                Command="{Binding InstallInstanceResourceFromFileCommand}"
                Text="从文件安装" />
            <controls:PclButton
                MinWidth="110"
                Margin="0,7,15,0"
                Command="{Binding DownloadInstanceResourceCommand}"
                Text="{Binding InstanceResourceDownloadButtonText}" />
            <controls:PclButton
                MinWidth="110"
                Margin="0,7,15,0"
                Command="{Binding SelectAllInstanceResourcesCommand}"
                Text="全选" />
            <controls:PclButton
                MinWidth="110"
                Margin="0,7,15,0"
                Command="{Binding ExportInstanceResourceInfoCommand}"
                Text="导出信息" />
            <controls:PclButton
                MinWidth="110"
                Margin="0,7,15,0"
                Command="{Binding CheckInstanceModsCommand}"
                IsVisible="{Binding ShowInstanceResourceCheckButton}"
                Text="检查 Mod" />
          </WrapPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header=" " MinHeight="55" ContentMargin="20,48,18,22" IsVisible="{Binding HasInstanceResourceEntries}">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <WrapPanel HorizontalAlignment="Left">
              <controls:PclButton MinWidth="72" Margin="0,0,8,8" ColorType="Highlight" Text="全部" />
              <controls:PclButton MinWidth="72" Margin="0,0,8,8" Text="已启用" />
              <controls:PclButton MinWidth="72" Margin="0,0,8,8" Text="已禁用" />
              <controls:PclButton MinWidth="72" Margin="0,0,8,8" Text="可更新" />
              <controls:PclButton MinWidth="72" Margin="0,0,8,8" Text="错误" />
              <controls:PclButton MinWidth="72" Margin="0,0,8,8" IsVisible="{Binding ShowInstanceResourceCheckButton}" Text="重复" />
            </WrapPanel>

            <controls:PclButton
                Width="110"
                HorizontalAlignment="Right"
                Text="排序：文件名" />

            <ItemsControl ItemsSource="{Binding InstanceResourceEntries}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,0,0,12" ColumnDefinitions="Auto,*,Auto">
                    <Border
                        Width="42"
                        Height="42"
                        Margin="0,0,12,0"
                        Background="#F7FAFE"
                        BorderBrush="#D5E6FD"
                        BorderThickness="1"
                        CornerRadius="6">
                      <Image
                          Width="28"
                          Height="28"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Source="{Binding Icon}"
                          Stretch="Uniform" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0" Spacing="3">
                      <TextBlock
                          Foreground="#343D4A"
                          FontSize="13.5"
                          FontWeight="SemiBold"
                          Text="{Binding Title}" />
                      <TextBlock
                          Foreground="#677789"
                          FontSize="12.5"
                          Text="{Binding Info}"
                          TextWrapping="Wrap" />
                      <Border
                          Padding="8,4"
                          Background="#F7FAFE"
                          BorderBrush="#D5E6FD"
                          BorderThickness="1"
                          CornerRadius="4">
                        <TextBlock
                            Foreground="#4B78C2"
                            FontSize="11.5"
                            Text="{Binding Meta}" />
                      </Border>
                    </StackPanel>

                    <controls:PclButton
                        Grid.Column="2"
                        Width="96"
                        Height="35"
                        VerticalAlignment="Center"
                        Command="{Binding ActionCommand}"
                        Text="查看" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard IsVisible="{Binding HasNoInstanceResourceEntries}" ContentMargin="20,17,20,17">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="10">
            <TextBlock
                HorizontalAlignment="Center"
                Foreground="#4B5968"
                FontSize="19"
                Text="{Binding InstanceResourceEmptyTitle}" />
            <Border Height="2" Background="#D5E6FD" />
            <TextBlock
                Foreground="#677789"
                FontSize="12.5"
                Text="{Binding InstanceResourceEmptyDescription}"
                TextAlignment="Center"
                TextWrapping="Wrap" />
            <WrapPanel HorizontalAlignment="Center" IsVisible="{Binding HasNoInstanceResourceEntries}">
              <controls:PclButton
                  MinWidth="130"
                  Margin="5,0"
                  Command="{Binding InstallInstanceResourceFromFileCommand}"
                  ColorType="Highlight"
                  IsVisible="{Binding ShowInstanceResourceEmptyInstallActions}"
                  Text="从文件安装资源" />
              <controls:PclButton
                  MinWidth="130"
                  Margin="5,0"
                  Command="{Binding DownloadInstanceResourceCommand}"
                  Text="{Binding InstanceResourceDownloadButtonText}" />
              <controls:PclButton
                  MinWidth="130"
                  Margin="5,0"
                  Command="{Binding OpenInstanceResourceFolderCommand}"
                  IsVisible="{Binding ShowInstanceResourceEmptyInstallActions}"
                  Text="打开文件夹" />
              <controls:PclButton
                  MinWidth="130"
                  Margin="5,0"
                  Command="{Binding VersionSelectCommand}"
                  IsVisible="{Binding ShowInstanceResourceInstanceSelectAction}"
                  Text="实例选择" />
            </WrapPanel>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>
    </StackPanel>
  </ScrollViewer>
</UserControl>
