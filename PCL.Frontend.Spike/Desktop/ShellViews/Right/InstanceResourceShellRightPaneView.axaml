<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.InstanceResourceShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sections="clr-namespace:PCL.Frontend.Spike.Desktop.ShellViews.Right.Sections"
    DataContext="{Binding Shell}">
  <Grid Margin="25,10,25,10" RowDefinitions="Auto,15,*,15,Auto">
    <sections:InstanceResourceHeaderSection Grid.Row="0" />
    <sections:InstanceResourceEntriesSection Grid.Row="2" />
    <sections:InstanceResourceEmptyStateSection Grid.Row="4" />
  </Grid>
</UserControl>
