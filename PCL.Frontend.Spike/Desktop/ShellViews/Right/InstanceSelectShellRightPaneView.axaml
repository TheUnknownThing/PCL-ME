<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.InstanceSelectShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    DataContext="{Binding Shell}">
  <UserControl.Styles>
    <Style Selector="Button.instance-entry">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Border.instance-entry-back">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="Button.instance-entry:pointerover Border.instance-entry-back">
      <Setter Property="Background" Value="#F3F8FF" />
    </Style>
    <Style Selector="Border.instance-entry-back.selected">
      <Setter Property="Background" Value="#E8F2FF" />
    </Style>
  </UserControl.Styles>

  <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="25,15,25,10" Spacing="0">
        <StackPanel Margin="0,0,0,12" IsVisible="{Binding HasInstanceSelectionSearchBox}">
          <Border
              Height="40"
              Padding="12,0"
              Background="#F8FBFF"
              BorderBrush="#D5E6FD"
              BorderThickness="1"
              CornerRadius="5">
            <Grid ColumnDefinitions="Auto,*">
              <Path
                  Width="14"
                  Height="14"
                  Margin="0,0,10,0"
                  VerticalAlignment="Center"
                  Data="M440.533333 106.666667a333.866667 333.866667 0 1 1 0 667.733333 333.866667 333.866667 0 0 1 0-667.733333z m0 85.333333a248.533333 248.533333 0 1 0 0 497.066667 248.533333 248.533333 0 0 0 0-497.066667z m271.445334 459.093333 241.493333 241.493334-60.330667 60.330666-241.493333-241.493333z"
                  Fill="#7D8EA3"
                  Stretch="Uniform" />
              <TextBox
                  Grid.Column="1"
                  Background="Transparent"
                  BorderBrush="Transparent"
                  BorderThickness="0"
                  FontSize="13.5"
                  Text="{Binding InstanceSelectionSearchQuery}"
                  Watermark="搜索游戏实例" />
            </Grid>
          </Border>
        </StackPanel>

        <ItemsControl ItemsSource="{Binding InstanceSelectionGroups}" IsVisible="{Binding HasInstanceSelectionEntries}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <controls:PclCard
                  Margin="4,4,4,18"
                  Header="{Binding HeaderText}"
                  HeaderCommand="{Binding ToggleExpandCommand}"
                  ShowChevron="True"
                  IsChevronExpanded="{Binding IsExpanded}"
                  ContentMargin="20,40,18,2">
                <controls:PclCard.CardContent>
                  <ItemsControl ItemsSource="{Binding Entries}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Button
                            Classes="instance-entry"
                            Command="{Binding SelectCommand}">
                          <Border
                              Classes="instance-entry-back"
                              Classes.selected="{Binding IsSelected}"
                              Margin="0,0,0,4"
                              Padding="8,7">
                            <Grid ColumnDefinitions="Auto,*">
                              <Image
                                  Width="24"
                                  Height="24"
                                  Margin="0,2,0,0"
                                  VerticalAlignment="Top"
                                  Source="{Binding Icon}"
                                  Stretch="UniformToFill" />

                              <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="2">
                                <TextBlock
                                    Foreground="#3D4653"
                                    FontSize="13.5"
                                    Text="{Binding Title}"
                                    TextTrimming="CharacterEllipsis" />

                                <WrapPanel IsVisible="{Binding HasMetadataContent}">
                                  <ItemsControl ItemsSource="{Binding Tags}" IsVisible="{Binding HasTags}">
                                    <ItemsControl.ItemsPanel>
                                      <ItemsPanelTemplate>
                                        <WrapPanel />
                                      </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                        <Border
                                            Margin="0,0,6,2"
                                            Padding="4,1"
                                            Background="#EEF1F5"
                                            CornerRadius="3">
                                          <TextBlock
                                              Foreground="#9AA5B4"
                                              FontSize="10.4"
                                              Text="{Binding}" />
                                        </Border>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                  <TextBlock
                                      Margin="0,0,0,2"
                                      Foreground="#8D98A7"
                                      FontSize="11.2"
                                      Text="{Binding Subtitle}"
                                      TextTrimming="CharacterEllipsis"
                                      IsVisible="{Binding HasSubtitle}" />
                                </WrapPanel>
                              </StackPanel>
                            </Grid>
                          </Border>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </controls:PclCard.CardContent>
              </controls:PclCard>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border
            Width="580"
            MaxWidth="640"
            Padding="26,18,26,18"
            Margin="0,28,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#F9FBFF"
            BorderBrush="#C9D7F0"
            BorderThickness="1"
            CornerRadius="7"
            IsVisible="{Binding HasNoInstanceSelectionEntries}">
          <StackPanel Spacing="12">
            <TextBlock
                HorizontalAlignment="Center"
                Foreground="#3892FF"
                FontSize="19"
                Text="{Binding InstanceSelectionEmptyTitle}" />
            <Border Height="2" Background="#4A92F2" />
            <TextBlock
                Margin="2,10,2,0"
                Foreground="#697687"
                FontSize="12.5"
                Text="{Binding InstanceSelectionEmptyDescription}"
                TextAlignment="Left"
                TextWrapping="Wrap" />
            <StackPanel
                Margin="0,4,0,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="10">
              <controls:PclButton
                  Width="126"
                  Height="35"
                  ColorType="Highlight"
                  Command="{Binding OpenInstanceSelectionDownloadCommand}"
                  IsVisible="{Binding ShowInstanceSelectionEmptyDownloadAction}"
                  Text="下载游戏" />
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
