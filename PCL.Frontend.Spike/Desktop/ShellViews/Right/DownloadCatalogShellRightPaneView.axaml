<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.DownloadCatalogShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,10,25,25" Spacing="15">
      <controls:PclCard Header="{Binding DownloadCatalogIntroTitle}" IsVisible="{Binding HasDownloadCatalogIntro}" ContentMargin="25,40,15,20">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <TextBlock
                Foreground="#4B5968"
                FontSize="13"
                Text="{Binding DownloadCatalogIntroBody}"
                TextWrapping="Wrap" />
            <ItemsControl ItemsSource="{Binding DownloadCatalogIntroActions}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <controls:PclButton
                      Margin="0,0,20,0"
                      MinWidth="140"
                      Command="{Binding Command}"
                      ColorType="{Binding ColorType}"
                      ContentPadding="13,0"
                      Text="{Binding Text}" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <ItemsControl ItemsSource="{Binding DownloadCatalogSections}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <controls:PclCard Header="{Binding Title}" ContentMargin="20,40,18,20">
              <controls:PclCard.CardContent>
                <ItemsControl ItemsSource="{Binding Items}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="0,0,0,12" ColumnDefinitions="*,Auto">
                        <StackPanel Margin="0,0,18,0" Spacing="3">
                          <TextBlock
                              Foreground="#343D4A"
                              FontSize="13.5"
                              FontWeight="SemiBold"
                              Text="{Binding Title}" />
                          <TextBlock
                              Foreground="#677789"
                              FontSize="12.5"
                              Text="{Binding Info}"
                              TextWrapping="Wrap" />
                          <Border
                              Padding="8,4"
                              Background="#F7FAFE"
                              BorderBrush="#D5E6FD"
                              BorderThickness="1"
                              CornerRadius="4"
                              IsVisible="{Binding HasMeta}">
                            <TextBlock
                                Foreground="#4B78C2"
                                FontSize="11.5"
                                Text="{Binding Meta}" />
                          </Border>
                        </StackPanel>
                        <controls:PclButton
                            Grid.Column="1"
                            Width="100"
                            Height="35"
                            VerticalAlignment="Center"
                            Command="{Binding Command}"
                            Text="{Binding ActionText}" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </controls:PclCard.CardContent>
            </controls:PclCard>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>
