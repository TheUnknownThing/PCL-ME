<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.VersionSaveDatapackShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,10,25,10" Spacing="15">
      <Border
          Height="40"
          Padding="12,0"
          Background="#F8FBFF"
          BorderBrush="#D5E6FD"
          BorderThickness="1"
          CornerRadius="5">
        <TextBox
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            FontSize="13.5"
            Text="{Binding VersionSaveDatapackSearchQuery}"
            VerticalContentAlignment="Center"
            Watermark="搜索数据包 名称 / 描述 / 标签" />
      </Border>

      <controls:PclCard ContentMargin="15,8,0,15">
        <controls:PclCard.CardContent>
          <WrapPanel>
            <controls:PclButton
                MinWidth="110"
                Margin="0,7,15,0"
                Command="{Binding OpenVersionSaveDatapackFolderCommand}"
                ColorType="Highlight"
                Text="打开文件夹" />
            <controls:PclButton
                MinWidth="110"
                Margin="0,7,15,0"
                Command="{Binding InstallVersionSaveDatapackFromFileCommand}"
                Text="从文件安装" />
            <controls:PclButton
                MinWidth="110"
                Margin="0,7,15,0"
                Command="{Binding DownloadVersionSaveDatapackCommand}"
                Text="下载新资源" />
            <controls:PclButton
                MinWidth="110"
                Margin="0,7,15,0"
                Command="{Binding ExportVersionSaveDatapackInfoCommand}"
                Text="导出信息" />
          </WrapPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header=" " MinHeight="55" ContentMargin="20,48,18,22" IsVisible="{Binding HasVersionSaveDatapackEntries}">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <controls:PclButton
                Width="110"
                HorizontalAlignment="Right"
                Text="排序：资源名称" />

            <ItemsControl ItemsSource="{Binding VersionSaveDatapackEntries}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,0,0,12" ColumnDefinitions="Auto,*,Auto">
                    <Border
                        Width="42"
                        Height="42"
                        Margin="0,0,12,0"
                        Background="#F7FAFE"
                        BorderBrush="#D5E6FD"
                        BorderThickness="1"
                        CornerRadius="6">
                      <Image
                          Width="28"
                          Height="28"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Source="{Binding Icon}"
                          Stretch="Uniform" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0" Spacing="3">
                      <TextBlock
                          Foreground="#343D4A"
                          FontSize="13.5"
                          FontWeight="SemiBold"
                          Text="{Binding Title}" />
                      <TextBlock
                          Foreground="#677789"
                          FontSize="12.5"
                          Text="{Binding Info}"
                          TextWrapping="Wrap" />
                      <Border
                          Padding="8,4"
                          Background="#F7FAFE"
                          BorderBrush="#D5E6FD"
                          BorderThickness="1"
                          CornerRadius="4">
                        <TextBlock
                            Foreground="#4B78C2"
                            FontSize="11.5"
                            Text="{Binding Meta}" />
                      </Border>
                    </StackPanel>

                    <controls:PclButton
                        Grid.Column="2"
                        Width="96"
                        Height="35"
                        VerticalAlignment="Center"
                        Command="{Binding ActionCommand}"
                        Text="查看" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard IsVisible="{Binding HasNoVersionSaveDatapackEntries}" ContentMargin="20,17,20,17">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="10">
            <TextBlock
                HorizontalAlignment="Center"
                Foreground="#4B5968"
                FontSize="19"
                Text="尚未安装数据包" />
            <Border Height="2" Background="#D5E6FD" />
            <TextBlock
                Foreground="#677789"
                FontSize="12.5"
                Text="你可以从已经下载好的文件安装数据包。数据包需要放置在存档的 datapacks 文件夹中才能生效。"
                TextAlignment="Center"
                TextWrapping="Wrap" />
            <WrapPanel HorizontalAlignment="Center">
              <controls:PclButton
                  MinWidth="130"
                  Margin="5,0"
                  Command="{Binding InstallVersionSaveDatapackFromFileCommand}"
                  ColorType="Highlight"
                  Text="从文件安装" />
              <controls:PclButton
                  MinWidth="130"
                  Margin="5,0"
                  Command="{Binding DownloadVersionSaveDatapackCommand}"
                  Text="下载新数据包" />
              <controls:PclButton
                  MinWidth="130"
                  Margin="5,0"
                  Command="{Binding OpenVersionSaveDatapackFolderCommand}"
                  Text="打开文件夹" />
            </WrapPanel>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>
    </StackPanel>
  </ScrollViewer>
</UserControl>
