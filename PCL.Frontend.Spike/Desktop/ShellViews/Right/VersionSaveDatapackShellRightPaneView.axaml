<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.VersionSaveDatapackShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sections="clr-namespace:PCL.Frontend.Spike.Desktop.ShellViews.Right.Sections"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,10,25,10" Spacing="15">
      <sections:VersionSaveDatapackHeaderSection />
      <sections:VersionSaveDatapackEntriesSection />
      <sections:VersionSaveDatapackEmptyStateSection />
    </StackPanel>
  </ScrollViewer>
</UserControl>
