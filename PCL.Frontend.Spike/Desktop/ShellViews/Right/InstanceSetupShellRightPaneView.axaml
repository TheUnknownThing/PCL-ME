<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Right.InstanceSetupShellRightPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    DataContext="{Binding Shell}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="25,25,25,25" Spacing="15">
      <Border
          Padding="12,10"
          Background="#EAF2FE"
          BorderBrush="#D5E6FD"
          BorderThickness="1"
          CornerRadius="4">
        <TextBlock
            Foreground="#4068A8"
            FontSize="12.5"
            Text="这些设置只对该游戏实例生效，不影响其他实例。"
            TextWrapping="Wrap" />
      </Border>

      <controls:PclCard Header="启动选项" ContentMargin="20,40,20,18">
        <controls:PclCard.CardContent>
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="28,9,28,9,Auto,9,28,9,28">
            <TextBlock
                Grid.Row="0"
                Margin="0,0,25,0"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13"
                Text="版本隔离" />
            <ComboBox
                Grid.Row="0"
                Grid.Column="1"
                ItemsSource="{Binding InstanceIsolationOptions}"
                SelectedIndex="{Binding SelectedInstanceIsolationIndex}" />

            <TextBlock
                Grid.Row="2"
                Margin="0,0,25,0"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13"
                Text="游戏窗口标题" />
            <TextBox
                Grid.Row="2"
                Grid.Column="1"
                Text="{Binding InstanceWindowTitleSetting}" />

            <CheckBox
                Grid.Row="4"
                Grid.ColumnSpan="2"
                Foreground="#343D4A"
                Content="默认窗口标题"
                IsChecked="{Binding UseDefaultInstanceWindowTitle}" />

            <TextBlock
                Grid.Row="6"
                Margin="0,0,25,0"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13"
                Text="自定义信息" />
            <Grid Grid.Row="6" Grid.Column="1" ColumnDefinitions="*,Auto">
              <TextBox
                  Grid.Column="0"
                  Text="{Binding InstanceCustomInfoSetting}" />
            </Grid>

            <TextBlock
                Grid.Row="8"
                Margin="0,0,25,0"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13"
                Text="游戏 Java" />
            <ComboBox
                Grid.Row="8"
                Grid.Column="1"
                ItemsSource="{Binding InstanceJavaOptions}"
                SelectedIndex="{Binding SelectedInstanceJavaIndex}" />
          </Grid>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="游戏内存" ContentMargin="20,40,20,18">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <Border
                Padding="12,10"
                Background="#FFF8DD"
                BorderBrush="#F2D777"
                BorderThickness="1"
                CornerRadius="4"
                IsVisible="{Binding ShowInstance32BitJavaWarning}">
              <TextBlock
                  Foreground="#6E5800"
                  FontSize="12.5"
                  Text="32 位 Java 只能分配最多 1 GB 的内存。强烈建议换用 64 位的 Java！"
                  TextWrapping="Wrap" />
            </Border>

            <Border
                Padding="12,10"
                Background="#FFF8DD"
                BorderBrush="#F2D777"
                BorderThickness="1"
                CornerRadius="4"
                IsVisible="{Binding ShowRamAllocationWarning}">
              <TextBlock
                  Foreground="#6E5800"
                  FontSize="12.5"
                  Text="你给游戏分配的内存过多，这可能引发游戏崩溃。建议优先考虑“自动分配”选项。"
                  TextWrapping="Wrap" />
            </Border>

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
              <RadioButton
                  Grid.Row="0"
                  Content="跟随全局设置"
                  GroupName="instance-ram"
                  IsChecked="{Binding UseGlobalInstanceRamAllocation}" />
              <RadioButton
                  Grid.Row="1"
                  Content="自动配置"
                  GroupName="instance-ram"
                  IsChecked="{Binding UseAutomaticInstanceRamAllocation}" />
              <RadioButton
                  Grid.Row="2"
                  Content="自定义"
                  GroupName="instance-ram"
                  IsChecked="{Binding UseCustomInstanceRamAllocation}" />
              <StackPanel Grid.Row="2" Grid.Column="1" Margin="18,0,0,0" Spacing="6">
                <Slider
                    Minimum="1"
                    Maximum="32"
                    IsEnabled="{Binding IsInstanceCustomRamAllocationEnabled}"
                    Value="{Binding InstanceCustomRamAllocation}" />
                <TextBlock
                    Foreground="#4B5968"
                    FontSize="12.5"
                    Text="{Binding InstanceCustomRamAllocationLabel}" />
              </StackPanel>
            </Grid>

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="28">
              <TextBlock
                  Margin="0,0,25,0"
                  VerticalAlignment="Center"
                  Foreground="#343D4A"
                  FontSize="13"
                  Text="启动游戏前进行内存优化" />
              <ComboBox
                  Grid.Column="1"
                  ItemsSource="{Binding InstanceMemoryOptimizeOptions}"
                  SelectedIndex="{Binding SelectedInstanceMemoryOptimizeIndex}" />
            </Grid>

            <Border
                Padding="12,12"
                Background="#F7FAFE"
                BorderBrush="#D5E6FD"
                BorderThickness="1"
                CornerRadius="6">
              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="4.7*,2.5*,0.7*" Height="6">
                  <Border Grid.Column="0" Background="#58C86F" CornerRadius="3,0,0,3" />
                  <Border Grid.Column="1" Background="#86B6FF" />
                  <Border Grid.Column="2" Background="#D5DCE5" CornerRadius="0,3,3,0" />
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock
                      Foreground="#4B5968"
                      FontSize="12"
                      Text="已使用内存" />
                  <TextBlock
                      Foreground="#2F8F45"
                      FontSize="16"
                      Text="{Binding InstanceUsedRamLabel}" />
                  <TextBlock
                      Foreground="#4B5968"
                      FontSize="16"
                      Text="{Binding InstanceTotalRamLabel}" />
                </StackPanel>
                <TextBlock
                    Foreground="#4C78C2"
                    FontSize="16"
                    Text="{Binding InstanceAllocatedRamLabel}" />
              </StackPanel>
            </Border>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="服务器" ContentMargin="20,40,20,18">
        <controls:PclCard.CardContent>
          <StackPanel Spacing="12">
            <Border
                Padding="12,10"
                Background="#FFF1EA"
                BorderBrush="#F1C8B6"
                BorderThickness="1"
                CornerRadius="4"
                IsVisible="{Binding ShowInstanceServerLoginLockedWarning}">
              <TextBlock
                  Foreground="#A94F2B"
                  FontSize="12.5"
                  Text="当前实例的验证方式已锁定，无法再次更改。请使用要求的验证方式启动游戏。"
                  TextWrapping="Wrap" />
            </Border>
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="28,28,28,28,9,28">
              <TextBlock
                  Grid.Row="0"
                  Margin="0,0,25,0"
                  VerticalAlignment="Center"
                  Foreground="#343D4A"
                  FontSize="13"
                  Text="限制验证方式" />
              <ComboBox
                  Grid.Row="0"
                  Grid.Column="1"
                  ItemsSource="{Binding InstanceServerLoginRequireOptions}"
                  SelectedIndex="{Binding SelectedInstanceServerLoginRequireIndex}" />

              <TextBlock
                  Grid.Row="1"
                  Margin="0,8,25,0"
                  VerticalAlignment="Center"
                  Foreground="#343D4A"
                  FontSize="13"
                  IsVisible="{Binding ShowInstanceServerAuthFields}"
                  Text="目标验证服务器" />
              <TextBox
                  Grid.Row="1"
                  Grid.Column="1"
                  Margin="0,8,0,0"
                  IsVisible="{Binding ShowInstanceServerAuthFields}"
                  Text="{Binding InstanceServerAuthServer}" />

              <TextBlock
                  Grid.Row="2"
                  Margin="0,8,25,0"
                  VerticalAlignment="Center"
                  Foreground="#343D4A"
                  FontSize="13"
                  IsVisible="{Binding ShowInstanceServerAuthFields}"
                  Text="注册链接" />
              <TextBox
                  Grid.Row="2"
                  Grid.Column="1"
                  Margin="0,8,0,0"
                  IsVisible="{Binding ShowInstanceServerAuthFields}"
                  Text="{Binding InstanceServerAuthRegister}" />

              <TextBlock
                  Grid.Row="3"
                  Margin="0,8,25,0"
                  VerticalAlignment="Center"
                  Foreground="#343D4A"
                  FontSize="13"
                  IsVisible="{Binding ShowInstanceServerAuthFields}"
                  Text="服务器名称" />
              <TextBox
                  Grid.Row="3"
                  Grid.Column="1"
                  Margin="0,8,0,0"
                  IsVisible="{Binding ShowInstanceServerAuthFields}"
                  Text="{Binding InstanceServerAuthName}" />

              <TextBlock
                  Grid.Row="5"
                  Margin="0,0,25,0"
                  VerticalAlignment="Center"
                  Foreground="#343D4A"
                  FontSize="13"
                  Text="自动进入服务器" />
              <TextBox
                  Grid.Row="5"
                  Grid.Column="1"
                  Text="{Binding InstanceServerAutoJoin}" />
            </Grid>

            <Grid ColumnDefinitions="Auto,Auto,Auto">
              <controls:PclButton
                  Grid.Column="0"
                  MinWidth="150"
                  Margin="0,0,20,0"
                  ColorType="Highlight"
                  Command="{Binding SetLittleSkinCommand}"
                  Text="设置为 LittleSkin" />
              <controls:PclButton
                  Grid.Column="1"
                  MinWidth="150"
                  Margin="0,0,20,0"
                  Command="{Binding LockInstanceLoginCommand}"
                  IsEnabled="{Binding CanLockInstanceLogin}"
                  Text="锁定验证方式" />
              <controls:PclButton
                  Grid.Column="2"
                  MinWidth="150"
                  Command="{Binding CreateInstanceProfileCommand}"
                  Text="新建档案" />
            </Grid>
          </StackPanel>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclCard Header="高级启动选项" ContentMargin="20,40,20,18">
        <controls:PclCard.CardContent>
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="28,9,100,9,28,9,28,9,64,Auto">
            <TextBlock
                Grid.Row="0"
                Margin="0,0,25,0"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13"
                Text="渲染器" />
            <ComboBox
                Grid.Row="0"
                Grid.Column="1"
                ItemsSource="{Binding InstanceRendererOptions}"
                SelectedIndex="{Binding SelectedInstanceRendererIndex}" />

            <TextBlock
                Grid.Row="2"
                Margin="0,0,25,0"
                VerticalAlignment="Top"
                Foreground="#343D4A"
                FontSize="13"
                Text="JVM 参数头部" />
            <TextBox
                Grid.Row="2"
                Grid.Column="1"
                AcceptsReturn="True"
                Text="{Binding InstanceLaunchJvmArguments}"
                TextWrapping="Wrap"
                VerticalContentAlignment="Top" />

            <TextBlock
                Grid.Row="4"
                Margin="0,0,25,0"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13"
                Text="游戏参数尾部" />
            <TextBox
                Grid.Row="4"
                Grid.Column="1"
                Text="{Binding InstanceLaunchGameArguments}" />

            <TextBlock
                Grid.Row="6"
                Margin="0,0,25,0"
                VerticalAlignment="Center"
                Foreground="#343D4A"
                FontSize="13"
                Text="Classpath 头部附加" />
            <TextBox
                Grid.Row="6"
                Grid.Column="1"
                Text="{Binding InstanceClasspathHead}" />

            <TextBlock
                Grid.Row="8"
                Margin="0,0,25,3"
                VerticalAlignment="Top"
                Foreground="#343D4A"
                FontSize="13"
                Text="启动前执行命令" />
            <TextBox
                Grid.Row="8"
                Grid.Column="1"
                AcceptsReturn="True"
                Text="{Binding InstanceLaunchBeforeCommand}"
                TextWrapping="Wrap"
                VerticalContentAlignment="Top" />

            <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Margin="0,8,0,0" Spacing="4">
              <CheckBox
                  Foreground="#343D4A"
                  Content="等待命令执行完成后再继续启动"
                  IsChecked="{Binding WaitForInstanceLaunchBeforeCommand}" />
              <CheckBox
                  Foreground="#343D4A"
                  Content="忽略 Java 兼容性警告"
                  IsChecked="{Binding IgnoreInstanceJavaCompatibilityWarning}" />
              <CheckBox
                  Foreground="#343D4A"
                  Content="关闭文件校验"
                  IsChecked="{Binding DisableInstanceFileValidation}" />
              <CheckBox
                  Foreground="#343D4A"
                  Content="跟随启动器网络代理设置"
                  IsChecked="{Binding FollowInstanceLauncherProxy}" />
              <CheckBox
                  Foreground="#343D4A"
                  Content="禁用 Java Launch Wrapper"
                  IsChecked="{Binding DisableInstanceJavaLaunchWrapper}" />
              <CheckBox
                  Foreground="#343D4A"
                  Content="禁用 RetroWrapper"
                  IsChecked="{Binding DisableInstanceRetroWrapper}" />
              <CheckBox
                  Foreground="#343D4A"
                  Content="使用调试级别 log4j 配置文件"
                  IsChecked="{Binding UseInstanceDebugLog4jConfig}" />
            </StackPanel>
          </Grid>
        </controls:PclCard.CardContent>
      </controls:PclCard>

      <controls:PclButton
          Width="140"
          HorizontalAlignment="Center"
          Command="{Binding OpenGlobalLaunchSettingsCommand}"
          Text="全局设置" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
