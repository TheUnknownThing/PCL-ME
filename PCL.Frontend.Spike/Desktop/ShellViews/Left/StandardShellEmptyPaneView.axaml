<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.ShellViews.Left.StandardShellEmptyPaneView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    DataContext="{Binding Shell}">
  <Grid Margin="18,20,18,18">
    <controls:PclCard Header="导航面板" ContentMargin="18,14,18,18">
      <controls:PclCard.CardContent>
        <StackPanel Spacing="10">
          <TextBlock
              Foreground="#343D4A"
              FontSize="18"
              FontWeight="SemiBold"
              Text="当前页面没有额外左侧内容" />
          <TextBlock
              Foreground="#677789"
              FontSize="12.5"
              Text="右侧内容仍然可用；这个占位 pane 仅用于标准 shell 的空左栏回退路径。"
              TextWrapping="Wrap" />
          <TextBlock
              Foreground="#7D8897"
              FontSize="11"
              Text="{Binding SurfaceMeta}"
              TextWrapping="Wrap" />
        </StackPanel>
      </controls:PclCard.CardContent>
    </controls:PclCard>
  </Grid>
</UserControl>
