<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.Controls.PclPromptLaneChip"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:motion="clr-namespace:PCL.Frontend.Spike.Desktop.Animation"
    x:Name="Root"
    motion:Motion.AnimateOnVisible="True"
    motion:Motion.OffsetY="8">
  <Border
      x:Name="ChipBorder"
      Padding="14,9"
      Background="{Binding BackgroundBrush, ElementName=Root}"
      BorderBrush="{Binding ChipBorderBrush, ElementName=Root}"
      BorderThickness="1"
      CornerRadius="18"
      RenderTransformOrigin="0.5,0.5"
      RenderTransform="scale(1)">
    <Border.Transitions>
      <Transitions>
        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" />
        <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
      </Transitions>
    </Border.Transitions>
    <Button
        x:Name="ButtonHost"
        Classes="nochrome"
        Background="Transparent"
        BorderBrush="Transparent"
        BorderThickness="0"
        Command="{Binding Command, ElementName=Root}"
        Padding="0">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <TextBlock
            x:Name="TitleBlock"
            Foreground="{Binding ForegroundBrush, ElementName=Root}"
            FontSize="14"
            FontWeight="SemiBold"
            Text="{Binding Title, ElementName=Root}" />
        <TextBlock
            x:Name="CountBlock"
            Foreground="{Binding ForegroundBrush, ElementName=Root}"
            FontSize="14"
            Text="{Binding Count, ElementName=Root}" />
      </StackPanel>
    </Button>
  </Border>
</UserControl>
