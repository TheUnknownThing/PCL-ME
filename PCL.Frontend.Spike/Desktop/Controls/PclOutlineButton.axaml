<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.Controls.PclOutlineButton"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root">
  <Border
      x:Name="PanFore"
      Height="35"
      CornerRadius="3"
      BorderThickness="1"
      RenderTransformOrigin="0.5,0.5"
      RenderTransform="scale(1)"
      Background="{DynamicResource ColorBrushHalfWhite}"
      BorderBrush="{DynamicResource ColorBrush1}">
    <Border.Transitions>
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.12" />
        <BrushTransition Property="BorderBrush" Duration="0:0:0.12" />
        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" />
        <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
      </Transitions>
    </Border.Transitions>
    <Button
        x:Name="ButtonHost"
        Classes="nochrome"
        Background="Transparent"
        BorderBrush="Transparent"
        BorderThickness="0"
        Command="{Binding Command, ElementName=Root}"
        Padding="0">
      <TextBlock
          x:Name="LabText"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          FontSize="13"
          Foreground="{DynamicResource ColorBrush1}" />
    </Button>
  </Border>
</UserControl>
