<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.Controls.PclLaunchRightPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel
        Margin="25,25,25,10"
        Spacing="15">
      <Border x:Name="LaunchCommunityHintHost" IsVisible="False" Background="Transparent">
        <controls:PclCard
            x:Name="LaunchCommunityHintCard"
            Header="社区版提示"
            ContentMargin="20,12,20,15">
          <controls:PclCard.CardContent>
            <Grid>
              <controls:PclIconButton
                  x:Name="DismissLaunchCommunityHintButton"
                  Margin="0,-28,-8,0"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top" />
              <StackPanel Spacing="2">
                <TextBlock
                    FontSize="13.5"
                    TextWrapping="Wrap"
                    Text="{Binding LaunchCommunityHintPrimaryText}" />
                <TextBlock
                    FontSize="13.5"
                    TextWrapping="Wrap"
                    Text="{Binding LaunchCommunityHintSecondaryText}" />
              </StackPanel>
            </Grid>
          </controls:PclCard.CardContent>
        </controls:PclCard>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
