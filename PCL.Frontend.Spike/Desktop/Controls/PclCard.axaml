<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.Controls.PclCard"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root">
  <Border
      x:Name="CardShadow"
      Background="#00000000"
      BoxShadow="0 2 10 0 #12000000"
      CornerRadius="5">
    <Border
        x:Name="CardBorder"
        Background="{DynamicResource ColorBrushTransparentBackground}"
        BorderBrush="#30D5E6FD"
        BorderThickness="1"
        CornerRadius="5">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Button
            x:Name="HeaderButton"
            Margin="0"
            Padding="0"
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            Command="{Binding HeaderCommand, ElementName=Root}"
            HorizontalContentAlignment="Stretch"
            IsVisible="{Binding HasHeader, ElementName=Root}">
          <Grid Margin="15,12,15,0" ColumnDefinitions="*,Auto">
            <TextBlock
                x:Name="HeaderTextBlock"
                VerticalAlignment="Top"
                FontSize="13"
                FontWeight="Bold"
                Foreground="{DynamicResource ColorBrush1}" />
            <Path
                x:Name="ChevronPath"
                Grid.Column="1"
                Width="10"
                Height="6"
                Margin="0,5,0,0"
                VerticalAlignment="Top"
                Data="M2,4 l-2,2 10,10 10,-10 -2,-2 -8,8 -8,-8 z"
                Fill="{DynamicResource ColorBrush1}"
                Stretch="Uniform"
                IsVisible="{Binding ShowChevron, ElementName=Root}" />
          </Grid>
        </Button>

        <ContentPresenter
            Grid.Row="1"
            Margin="{Binding ContentMargin, ElementName=Root}"
            IsVisible="{Binding IsContentVisible, ElementName=Root}"
            Content="{Binding CardContent, ElementName=Root}" />
      </Grid>
    </Border>
  </Border>
</UserControl>
