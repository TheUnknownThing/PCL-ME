<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.Controls.PclCard"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root">
  <Grid ClipToBounds="False">
    <Border
        x:Name="CardShadow"
        Margin="-1,-1,-1,-2"
        Background="{DynamicResource ColorBrush1}"
        CornerRadius="6"
        Effect="blur(3)"
        Opacity="0.1">
      <Border.Transitions>
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.24" />
          <DoubleTransition Property="Opacity" Duration="0:0:0.24" />
        </Transitions>
      </Border.Transitions>
    </Border>

    <Border
        x:Name="CardBorder"
        Background="{DynamicResource ColorBrushMyCard}"
        BorderBrush="#00FFFFFF"
        BorderThickness="1"
        CornerRadius="6">
      <Border.Transitions>
        <Transitions>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.24" />
          <BrushTransition Property="Background" Duration="0:0:0.24" />
        </Transitions>
      </Border.Transitions>
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Button
            x:Name="HeaderButton"
            Classes="nochrome"
            Margin="0"
            Padding="0"
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            Command="{Binding HeaderCommand, ElementName=Root}"
            HorizontalContentAlignment="Stretch"
            IsVisible="{Binding HasHeader, ElementName=Root}">
          <Grid Margin="15,12,15,0" ColumnDefinitions="*,Auto">
            <TextBlock
                x:Name="HeaderTextBlock"
                VerticalAlignment="Top"
                FontSize="13"
                FontWeight="Bold"
                Foreground="{DynamicResource ColorBrush1}" />
            <Path
                x:Name="ChevronPath"
                Grid.Column="1"
                Width="10"
                Height="6"
                Margin="0,5,0,0"
                VerticalAlignment="Top"
                Data="M2,4 l-2,2 10,10 10,-10 -2,-2 -8,8 -8,-8 z"
                Fill="{DynamicResource ColorBrush1}"
                Stretch="Uniform"
                IsVisible="{Binding ShowChevron, ElementName=Root}" />
          </Grid>
        </Button>

        <ContentPresenter
            Grid.Row="1"
            Margin="{Binding ContentMargin, ElementName=Root}"
            IsVisible="{Binding IsContentVisible, ElementName=Root}"
            Content="{Binding CardContent, ElementName=Root}" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
