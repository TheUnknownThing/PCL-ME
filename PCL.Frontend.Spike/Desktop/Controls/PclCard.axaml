<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.Controls.PclCard"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root">
  <Grid ClipToBounds="False">
    <Border
        x:Name="CardBorder"
        Background="{DynamicResource ColorBrushMyCard}"
        BorderBrush="#00FFFFFF"
        BorderThickness="1"
        BoxShadow="0 6 18 0 #14343D4A"
        CornerRadius="6">
      <Border.Transitions>
        <Transitions>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.24" />
          <BrushTransition Property="Background" Duration="0:0:0.24" />
        </Transitions>
      </Border.Transitions>
      <Grid x:Name="LayoutRoot">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Button
            x:Name="HeaderButton"
            Classes="nochrome"
            Grid.Row="0"
            Margin="0"
            Padding="0"
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            IsVisible="{Binding HasHeader, ElementName=Root}" />

        <TextBlock
            x:Name="HeaderTextBlock"
            Grid.Row="0"
            Margin="15,12,0,0"
            VerticalAlignment="Top"
            IsHitTestVisible="False"
            FontSize="13"
            Foreground="{DynamicResource ColorBrush1}" />

        <Path
            x:Name="ChevronPath"
            Grid.Row="0"
            Width="10"
            Height="6"
            Margin="0,17,16,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            IsHitTestVisible="False"
            Data="M2,4 l-2,2 10,10 10,-10 -2,-2 -8,8 -8,-8 z"
            Fill="{DynamicResource ColorBrush1}"
            RenderTransformOrigin="0.5,0.5"
            Stretch="Uniform"
            IsVisible="{Binding ShowChevron, ElementName=Root}" />

        <ContentPresenter
            x:Name="HeaderOverlayContentPresenter"
            Grid.Row="0"
            Content="{Binding HeaderOverlayContent, ElementName=Root}"
            IsVisible="{Binding HasHeaderOverlayContent, ElementName=Root}" />

        <ContentPresenter
            x:Name="CardContentPresenter"
            Grid.Row="1"
            Margin="{Binding EffectiveContentMargin, ElementName=Root}"
            IsVisible="{Binding IsContentVisible, ElementName=Root}"
            Content="{Binding CardContent, ElementName=Root}" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
