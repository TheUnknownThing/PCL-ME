<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.Controls.PclActionSummaryRow"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls">
  <Grid Margin="0,0,0,12" ColumnDefinitions="*,Auto">
    <StackPanel Margin="0,0,18,0" Spacing="3">
      <TextBlock
          Foreground="#343D4A"
          FontSize="13.5"
          FontWeight="SemiBold"
          Text="{Binding Title, ElementName=Root}" />
      <TextBlock
          Foreground="#677789"
          FontSize="12.5"
          Text="{Binding Info, ElementName=Root}"
          TextWrapping="Wrap" />
      <Border
          Padding="8,4"
          Background="#F7FAFE"
          BorderBrush="#D5E6FD"
          BorderThickness="1"
          CornerRadius="4"
          IsVisible="{Binding ShowMeta, ElementName=Root}">
        <TextBlock
            Foreground="#4B78C2"
            FontSize="11.5"
            Text="{Binding Meta, ElementName=Root}" />
      </Border>
    </StackPanel>

    <controls:PclButton
        Grid.Column="1"
        Width="100"
        Height="35"
        VerticalAlignment="Center"
        Command="{Binding Command, ElementName=Root}"
        Text="{Binding ActionText, ElementName=Root}" />
  </Grid>
</UserControl>
