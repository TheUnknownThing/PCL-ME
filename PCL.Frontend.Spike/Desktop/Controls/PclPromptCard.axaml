<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.Controls.PclPromptCard"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PCL.Frontend.Spike.Desktop.Controls"
    x:Name="Root">
  <controls:PclCard ContentMargin="14,14,14,14">
    <controls:PclCard.CardContent>
      <StackPanel Spacing="10">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock
              Foreground="{Binding AccentBrush, ElementName=Root}"
              FontSize="11"
              FontWeight="Bold"
              Text="{Binding Source, ElementName=Root}" />
          <Border
              Grid.Column="1"
              Padding="8,3"
              Background="{Binding BadgeBackgroundBrush, ElementName=Root}"
              CornerRadius="10">
            <TextBlock
                Foreground="{Binding AccentBrush, ElementName=Root}"
                FontSize="11"
                FontWeight="Bold"
                Text="{Binding Severity, ElementName=Root}" />
          </Border>
        </Grid>
        <TextBlock
            Foreground="#343D4A"
            FontSize="16"
            FontWeight="SemiBold"
            Text="{Binding Title, ElementName=Root}" />
        <TextBlock
            Foreground="#4B5968"
            FontSize="13"
            TextWrapping="Wrap"
            Text="{Binding Message, ElementName=Root}" />
        <ContentPresenter Content="{Binding OptionsContent, ElementName=Root}" />
      </StackPanel>
    </controls:PclCard.CardContent>
  </controls:PclCard>
</UserControl>
