<UserControl
    x:Class="PCL.Frontend.Spike.Desktop.Controls.PclTabButton"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root">
  <Border
      x:Name="PanBack"
      MinHeight="27"
      MaxHeight="27"
      Height="27"
      Padding="0"
      CornerRadius="13.5"
      RenderTransformOrigin="0.5,0.5"
      RenderTransform="scale(1)"
      Background="{DynamicResource ColorBrushSemiTransparent}">
    <Border.Transitions>
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.12" />
        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" />
        <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
      </Transitions>
    </Border.Transitions>
    <Button
        x:Name="ButtonHost"
        Background="Transparent"
        BorderBrush="Transparent"
        BorderThickness="0"
        Command="{Binding Command, ElementName=Root}"
        Padding="0">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <Border
            x:Name="ShapeLogo"
            Width="10"
            Height="10"
            Margin="15,0,0,0"
            VerticalAlignment="Center"
            Background="White"
            CornerRadius="5" />
        <TextBlock
            x:Name="LabText"
            Margin="8,0,12,0"
            VerticalAlignment="Center"
            FontSize="14"
            Foreground="White" />
      </StackPanel>
    </Button>
  </Border>
</UserControl>
